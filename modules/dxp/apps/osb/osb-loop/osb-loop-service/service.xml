<?xml version="1.0"?>
<!DOCTYPE service-builder PUBLIC "-//Liferay//DTD Service Builder 7.0.0//EN" "http://www.liferay.com/dtd/liferay-service-builder_7_0_0.dtd">

<service-builder auto-namespace-tables="false" package-path="com.liferay.osb.loop">
	<author>Ethan Bustad</author>
	<namespace>OSB</namespace>
	<entity local-service="true" name="LoopAuditEntry" remote-service="false">

		<!-- PK fields -->

		<column name="loopAuditEntryId" primary="true" type="long" />

		<!-- Audit fields -->

		<column name="companyId" type="long" />
		<column name="userId" type="long" />
		<column name="userName" type="String" />
		<column name="createDate" type="Date" />
		<column name="modifiedDate" type="Date" />

		<!-- Other fields -->

		<column name="classNameId" type="long" />
		<column name="classPK" type="long" />
		<column name="name" type="String" />
	</entity>
	<entity local-service="true" name="LoopDivision" remote-service="false">

		<!-- PK fields -->

		<column name="loopDivisionId" primary="true" type="long" />

		<!-- Audit fields -->

		<column name="companyId" type="long" />
		<column name="userId" type="long" />
		<column name="userName" type="String" />
		<column name="createDate" type="Date" />
		<column name="modifiedDate" type="Date" />

		<!-- Other fields -->

		<column name="organizationId" type="long" />
		<column name="parentLoopDivisionId" type="long" />
		<column name="type" type="int" />
		<column name="subtype" type="int" />
		<column name="extraData" type="String" />
		<column name="imagePayload" type="String" />

		<!-- Finder methods -->

		<finder name="OrganizationId" return-type="LoopDivision" unique="true">
			<finder-column name="organizationId" />
		</finder>
		<finder name="CI_T" return-type="Collection">
			<finder-column name="companyId" />
			<finder-column name="type" />
		</finder>

		<!-- References -->

		<reference entity="Organization" package-path="com.liferay.portal" />
	</entity>
	<entity local-service="true" name="LoopDivisionRel" remote-service="false">

		<!-- PK fields -->

		<column name="loopDivisionRelId" primary="true" type="long" />

		<!-- Other fields -->

		<column name="childLoopDivisionId" type="long" />
		<column name="loopPersonId" type="long" />
		<column name="parentLoopDivisionId" type="long" />

		<!-- Finder methods -->

		<finder name="CLDI_LPI" return-type="LoopDivisionRel">
			<finder-column name="childLoopDivisionId" />
			<finder-column name="loopPersonId" />
		</finder>
		<finder name="LPI_PLDI" return-type="LoopDivisionRel">
			<finder-column name="loopPersonId" />
			<finder-column name="parentLoopDivisionId" />
		</finder>
		<finder name="CLDI_LPI_PLDI" return-type="LoopDivisionRel" unique="true">
			<finder-column name="childLoopDivisionId" />
			<finder-column name="loopPersonId" />
			<finder-column name="parentLoopDivisionId" />
		</finder>
	</entity>
	<entity local-service="true" name="LoopExternalReferenceRel" remote-service="false">

		<!-- PK fields -->

		<column name="loopExternalReferenceRelId" primary="true" type="long" />

		<!-- Other fields -->

		<column name="classNameId" type="long" />
		<column name="classPK" type="long" />
		<column name="externalReferenceName" type="String" />
		<column name="externalReferencePK" type="String" />

		<!-- Finder methods -->

		<finder name="ERP_ESN" return-type="LoopExternalReferenceRel" unique="true">
			<finder-column name="externalReferenceName" />
			<finder-column name="externalReferencePK" />
		</finder>
	</entity>
	<entity local-service="true" name="LoopJobTitle" remote-service="false">

		<!-- PK fields -->

		<column name="loopJobTitleId" primary="true" type="long" />

		<!-- Audit fields -->

		<column name="companyId" type="long" />
		<column name="userId" type="long" />
		<column name="userName" type="String" />
		<column name="createDate" type="Date" />
		<column name="modifiedDate" type="Date" />

		<!-- Other fields -->

		<column name="name" type="String" />
		<column name="description" type="String" />
		<column name="status" type="int" />

		<!-- Order -->

		<order by="asc">
			<order-column name="name" />
		</order>

		<!-- Finder methods -->

		<finder name="Name" return-type="LoopJobTitle" unique="true">
			<finder-column name="name" />
		</finder>
	</entity>
	<entity local-service="true" name="LoopParticipantAssignment" remote-service="false">

