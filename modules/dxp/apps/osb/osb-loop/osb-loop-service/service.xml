		<!-- Finder methods -->

		<finder name="PersonUserId" return-type="LoopPerson" unique="true">
			<finder-column name="personUserId" />
		</finder>

		<!-- References -->

		<reference entity="PortletPreferences" package-path="com.liferay.portal" />
	</entity>
	<entity local-service="true" name="LoopPersonRel" remote-service="false">

		<!-- PK fields -->

