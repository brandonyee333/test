		<column name="classNameId" type="long" />
		<column name="classPK" type="long" />
		<column name="following" type="boolean" />
		<column name="followingType" type="int" />

		<!-- Finder methods -->

		<finder name="CPI_CSI_F" return-type="LoopStreamEntry">
			<finder-column name="loopPersonId" />
			<finder-column name="loopStreamId" />
			<finder-column name="following" />
		</finder>
		<finder name="CPI_CNI_CP" return-type="LoopStreamEntry">
			<finder-column name="loopPersonId" />
			<finder-column name="classNameId" />
			<finder-column name="classPK" />
		</finder>
		<finder name="CPI_CSI_CNI_CP" return-type="LoopStreamEntry" unique="true">
			<finder-column name="loopPersonId" />
			<finder-column name="loopStreamId" />
			<finder-column name="classNameId" />
			<finder-column name="classPK" />
		</finder>
	</entity>
	<entity local-service="true" name="LoopTopic" remote-service="false">

