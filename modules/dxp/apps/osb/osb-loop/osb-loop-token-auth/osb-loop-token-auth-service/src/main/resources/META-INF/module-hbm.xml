<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN" "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping auto-import="false" default-lazy="false">
	<import class="com.liferay.osb.loop.token.auth.model.TokenAuthEntry" />
	<class name="com.liferay.osb.loop.token.auth.model.impl.TokenAuthEntryImpl" table="TokenAuthEntry">
		<id name="tokenAuthEntryId" type="long">
			<generator class="assigned" />
		</id>
		<property name="companyId" type="com.liferay.portal.dao.orm.hibernate.LongType" />
		<property name="userId" type="com.liferay.portal.dao.orm.hibernate.LongType" />
		<property name="userName" type="com.liferay.portal.dao.orm.hibernate.StringType" />
		<property name="createDate" type="org.hibernate.type.TimestampType" />
		<property name="device" type="com.liferay.portal.dao.orm.hibernate.StringType" />
		<property name="token" type="com.liferay.portal.dao.orm.hibernate.StringType" />
		<property name="loginDate" type="org.hibernate.type.TimestampType" />
		<property name="loginIP" type="com.liferay.portal.dao.orm.hibernate.StringType" />
	</class>
</hibernate-mapping>