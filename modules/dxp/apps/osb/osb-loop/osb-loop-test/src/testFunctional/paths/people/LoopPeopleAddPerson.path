<html>
<head>
<title>LoopPeopleAddPerson</title>
</head>
<body>
<table cellpadding="1" cellspacing="1" border="1">
<thead>
<tr><td rowspan="1" colspan="3">LoopPeopleAddPerson</td></tr>
</thead>
<tbody>
<tr>
	<td>SUCCESS_MESSAGE</td>
	<td>//div[contains(@class,'alert-container')]</td>
	<td></td>
</tr>
<tr>
	<td>ERROR_MESSAGE</td>
	<td>//div[contains(@class,'error-message')]</td>
	<td></td>
</tr>
<tr>
	<td>EMAIL_ADDRESS_FIELD</td>
	<td>//input[contains(@name,'emailAddress')]</td>
	<td></td>
</tr>
<tr>
	<td>FIRST_NAME_FIELD</td>
	<td>//input[contains(@name,'firstName')]</td>
	<td></td>
</tr>
<tr>
	<td>LAST_NAME_FIELD</td>
	<td>//input[contains(@name,'lastName')]</td>
	<td></td>
</tr>
<tr>
	<td>PREFERRED_NAME_FIELD</td>
	<td>//input[contains(@name,'preferredName')]</td>
	<td></td>
</tr>
<tr>
	<td>EMPLOYMENT_TYPE_SELECT</td>
	<td>//label[contains(.,'Employment Type')]/following-sibling::select</td>
	<td></td>
</tr>
<tr>
	<td>JOB_TITLE_SELECT</td>
	<td>//label[contains(.,'Job Title')]/following-sibling::select</td>
	<td></td>
</tr>
<tr>
	<td>HIRE_DATE_FIELD</td>
	<td>//label[contains(.,'Hire Date')]/following-sibling::div//input</td>
	<td></td>
</tr>
<tr>
	<td>CREATE_BUTTON</td>
	<td>//button[contains(.,'Create')]</td>
	<td></td>
</tr>
<tr>
	<td>CANCEL_BUTTON</td>
	<td>//button[contains(.,'Cancel')]</td>
	<td></td>
</tr>
</tbody>
</table>
</body>
</html>