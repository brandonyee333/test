<html>
<head>
<title>LoopTopicsUpdateTopic</title>
</head>
<body>
<table cellpadding="1" cellspacing="1" border="1">
<thead>
<tr><td rowspan="1" colspan="3">LoopTopicsUpdateTopic</td></tr>
</thead>
<tbody>
<tr>
	<td>SUCCESS_MESSAGE</td>
	<td>//div[contains(@class,'alert-container')]</td>
	<td></td>
</tr>
<tr>
	<td>NAME_FIELD</td>
	<td>//input[contains(@name,'name')]</td>
	<td></td>
</tr>
<tr>
	<td>DESCRIPTION_FIELD</td>
	<td>//label[contains(.,'Description')]//following-sibling::div//textarea</td>
	<td></td>
</tr>
<tr>
	<td>SUBMIT_BUTTON</td>
	<td>//button[contains(.,'Submit')]</td>
	<td></td>
</tr>
<tr>
	<td>CANCEL_BUTTON</td>
	<td>//button[contains(.,'Cancel')]</td>
	<td></td>
</tr>
</tbody>
</table>
</body>
</html>