			<var name="groupType" value="Department" />
		</execute>

		<execute macro="LoopFeedEntry#viewAuthorAndContent">
			<var name="feedEntryAuthorName" value="${userName}" />
			<var name="feedEntryContent" value="${feedEntryText1}" />
		</execute>

		<execute macro="LoopFeedEntry#viewNone">
			<var name="feedEntryContent" value="${feedEntryText2}" />
		</execute>

		<execute macro="LoopGroups#gotoGroupProfile">
