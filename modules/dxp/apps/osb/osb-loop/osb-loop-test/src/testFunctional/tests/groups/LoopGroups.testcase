		<var name="userEmailAddress4" value="loopuser04@liferay.com" />
		<var name="userFirstName2" value="Loop02" />
		<var name="userFirstName3" value="Loop03" />
		<var name="userFirstName4" value="Loop04" />
		<var name="userLastName2" value="User02" />
		<var name="userLastName3" value="User03" />
		<var name="userLastName4" value="User04" />
		<var name="userName2" value="Loop02 User02" />
		<var name="userName3" value="Loop03 User03" />
		<var name="userName4" value="Loop04 User04" />
		<var name="userScreenName2" value="loopuser02" />
		<var name="userScreenName3" value="loopuser03" />
		<var name="userScreenName4" value="loopuser04" />

		<execute macro="LoopJson#addPeople">
			<var name="personNumberList" value="02,03,04" />
		</execute>

		<execute macro="LoopJson#createGroup">
			<var name="groupDescription" value="${departmentDescription1}" />
			<var name="groupName" value="${departmentName1}" />
			<var name="groupType" value="Department" />
			<var name="memberScreenNameList" value="${userScreenName2}" />
		</execute>

		<execute macro="LoopJson#createGroup">
			<var name="groupDescription" value="${departmentDescription2}" />
			<var name="groupName" value="${departmentName2}" />
			<var name="groupType" value="Department" />
			<var name="memberScreenNameList" value="${userScreenName3}" />
		</execute>

		<execute macro="LoopGroups#gotoGroupProfile">
			<var name="groupName" value="${departmentName1}" />
			<var name="groupType" value="Department" />
		</execute>

		<execute macro="LoopFeed#addEntry">
			<var name="feedEntryAuthorName" value="${userName}" />
