			<var name="feedEntryAuthorName" value="${userName3}" />
			<var name="feedEntryContent" value="${feedEntryText2}" />
		</execute>

		<execute macro="LoopFeedEntry#viewNone">
			<var name="feedEntryContent" value="${feedEntryText1}" />
		</execute>

		<execute macro="Loop#logoutAndLogin">
			<var name="userLoginEmailAddress" value="${userEmailAddress4}" />
		</execute>

		<execute macro="LoopFeedEntry#viewNone">
			<var name="feedEntryContent" value="${feedEntryText1}" />
		</execute>

		<execute macro="LoopFeedEntry#viewNone">
			<var name="feedEntryContent" value="${feedEntryText2}" />
		</execute>

		<execute macro="LoopNavigation#gotoMyProfile" />

