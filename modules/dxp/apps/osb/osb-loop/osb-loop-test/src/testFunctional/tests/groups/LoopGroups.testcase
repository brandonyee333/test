	<command name="SyncDepartments" priority="5">
		<property name="portlet.properties.loop-portlet" value="loop.tests.enabled=true${line.separator}loop.email.addresses.admin=liferay.qa.loop2@gmail.com${line.separator}loop.email.notification.from.address=liferay.qa.loop1@gmail.com${line.separator}loop.email.notification.from.name=Joe Bloggs" />

		<var name="departmentName1" value="Department Name1" />
		<var name="departmentName2" value="Department Name2" />

		<execute macro="LoopJson#syncGroup">
			<var name="apiName" value="add" />
			<var name="groupName" value="${departmentName1}" />
			<var name="groupType" value="Department" />
		</execute>

