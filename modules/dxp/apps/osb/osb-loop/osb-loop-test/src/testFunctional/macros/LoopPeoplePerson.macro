				<not>
					<contains string="${followingGroupsCount}" substring="{followingGroupsCount}" />
				</not>
			</and>
			<then>
				<execute function="AssertTextEquals" locator1="LoopPeoplePerson#PERSON_FOLLOWING_GROUPS_TAB" value1="Groups ${followingGroupsCount}" />
			</then>
		</if>

		<execute function="AssertClick#assertPartialTextClickAt" locator1="LoopPeoplePerson#PERSON_FOLLOWING_GROUPS_TAB" value1="Groups" />
	</command>

	<command name="gotoFollowingSectionPeopleTab">
