<definition>
	<command name="activateUserCmd">
		<execute function="AssertTextEquals#assertPartialText" locator1="LoopPeoplePerson#TOGGLE_ACTIVATE_ACTIVATE_MESSAGE" value1="Are you sure you want to activate ${userName}?" />
		<execute function="AssertClick" locator1="LoopPeoplePerson#TOGGLE_ACTIVATE_CONFIRM_BUTTON" value1="Confirm" />

		<!-- Workaround until LOOP-5208 is fixed -->

		<!--<execute function="AssertTextEquals" locator1="LoopPeoplePerson#SUCCESS_MESSAGE" value1="${userName} was successfully activated." />-->
		<execute function="Pause" locator1="5000" />
	</command>

	<command name="addAdditionalEmail">
		<execute macro="LoopPeoplePerson#gotoEditContactSection" />

		<if>
			<isset var="row" />
			<then>
				<var name="key_row" value="${row}" />
			</then>
			<else>
				<var name="key_row" value="1" />
			</else>
		</if>

		<execute function="Type" locator1="LoopPeopleUpdatePerson#ADDITIONAL_EMAIL_ADDRESS_FIELD" value1="${userAdditionalEmailAddress}" />
	</command>

	<command name="addAdditionalEmailRow">
		<execute macro="LoopPeoplePerson#gotoEditContactSection" />

		<execute function="Click" locator1="LoopPeopleUpdatePerson#ADDITIONAL_EMAIL_ADD_ROW_BUTTON" />
	</command>

	<command name="addCoverPicture">
		<execute macro="LoopPeoplePerson#uploadCoverPicture">
			<var name="coverPictureFileName" value="${coverPictureFileName}" />
		</execute>

		<execute macro="LoopPeoplePerson#confirmCoverPicture" />
	</command>

	<command name="addPerson">
		<execute macro="Loop#logoutAndLogin">
			<var name="userLoginEmailAddress" value="test@liferay.com" />
		</execute>

		<execute macro="LoopNavigation#gotoPeople" />

		<execute function="Click" locator1="LoopPeople#CREATE_PERSON_LINK" />

		<execute function="Type" locator1="LoopPeopleAddPerson#EMAIL_ADDRESS_FIELD" value1="${userEmailAddress}" />
		<execute function="Type" locator1="LoopPeopleAddPerson#FIRST_NAME_FIELD" value1="${userFirstName}" />
		<execute function="Type" locator1="LoopPeopleAddPerson#LAST_NAME_FIELD" value1="${userLastName}" />

		<if>
			<isset var="userPreferredName" />
			<then>
				<execute function="Type" locator1="LoopPeopleAddPerson#PREFERRED_NAME_FIELD" value1="${userPreferredName}" />
			</then>
		</if>

		<if>
			<isset var="userEmploymentType" />
			<then>
				<execute function="Select" locator1="LoopPeopleAddPerson#EMPLOYMENT_TYPE_SELECT" value1="${userEmploymentType}" />
			</then>
		</if>

		<if>
			<isset var="jobTitleName" />
			<then>
				<execute function="Select" locator1="LoopPeopleAddPerson#JOB_TITLE_SELECT" value1="${jobTitleName}" />
			</then>
		</if>

		<execute function="AssertElementPresent" locator1="LoopPeopleAddPerson#HIRE_DATE_FIELD" />
		<execute function="AssertClick" locator1="LoopPeopleAddPerson#CREATE_BUTTON" value1="Create" />
		<execute function="AssertTextEquals" locator1="LoopPeopleAddPerson#SUCCESS_MESSAGE" value1="${userFirstName} ${userLastName} was successfully created." />
		<execute function="Pause" locator1="5000" />

		<execute macro="LoopPeoplePerson#editUserCP">
			<var name="roleNames" value="${roleNames}" />
			<var name="userEmailAddress" value="${userEmailAddress}" />
			<var name="userScreenName" value="${userScreenName}" />
		</execute>
	</command>

	<command name="addPersonWithError">
		<execute macro="Loop#logoutAndLogin">
			<var name="userLoginEmailAddress" value="test@liferay.com" />
		</execute>

		<execute macro="LoopNavigation#gotoPeople" />

		<execute function="Click" locator1="LoopPeople#CREATE_PERSON_LINK" />

		<execute function="Type" locator1="LoopPeopleAddPerson#EMAIL_ADDRESS_FIELD" value1="${userEmailAddress}" />
		<execute function="Type" locator1="LoopPeopleAddPerson#FIRST_NAME_FIELD" value1="${userFirstName}" />
		<execute function="Type" locator1="LoopPeopleAddPerson#LAST_NAME_FIELD" value1="${userLastName}" />

		<if>
			<isset var="userPreferredName" />
			<then>
				<execute function="Type" locator1="LoopPeopleAddPerson#PREFERRED_NAME_FIELD" value1="${userPreferredName}" />
			</then>
		</if>

		<if>
			<isset var="userEmploymentType" />
			<then>
				<execute function="Select" locator1="LoopPeopleAddPerson#EMPLOYMENT_TYPE_SELECT" value1="${userEmploymentType}" />
			</then>
		</if>

		<if>
			<isset var="jobTitleName" />
			<then>
				<execute function="Select" locator1="LoopPeopleAddPerson#JOB_TITLE_SELECT" value1="${jobTitleName}" />
			</then>
		</if>

		<execute function="AssertElementPresent" locator1="LoopPeopleAddPerson#HIRE_DATE_FIELD" />
		<execute function="AssertClick" locator1="LoopPeopleAddPerson#CREATE_BUTTON" value1="Create" />
		<execute function="AssertTextEquals" locator1="LoopPeopleAddPerson#ERROR_MESSAGE" value1="${errorMessage}" />
		<execute function="AssertClick" locator1="LoopPeopleAddPerson#CANCEL_BUTTON" value1="Cancel" />
	</command>

	<command name="addPhoneNumber">
		<execute macro="LoopPeoplePerson#gotoEditContactSection" />

		<if>
			<isset var="row" />
			<then>
				<var name="key_row" value="${row}" />
			</then>
			<else>
				<var name="key_row" value="1" />
			</else>
		</if>

		<execute function="Type" locator1="LoopPeopleUpdatePerson#PHONE_NUMBER_NUMBER_FIELD" value1="${userPhoneNumberNumber}" />

		<execute function="Select" locator1="LoopPeopleUpdatePerson#PHONE_NUMBER_TYPE_SELECT" value1="${userPhoneNumberType}" />
	</command>

	<command name="addPhoneNumberRow">
		<execute macro="LoopPeoplePerson#gotoEditContactSection" />

		<execute function="Click" locator1="LoopPeopleUpdatePerson#PHONE_NUMBER_ADD_ROW_BUTTON" />
	</command>

	<command name="addProfilePicture">
		<execute macro="LoopPeoplePerson#uploadProfilePicture">
			<var name="profilePictureFileName" value="${profilePictureFileName}" />
		</execute>

		<execute macro="LoopPeoplePerson#confirmProfilePicture" />

		<execute function="Pause" locator1="5000" />
	</command>

	<command name="assignDepartments">
		<execute macro="LoopPeoplePerson#gotoEditWorkSection" />

		<for list="${departmentNameList}" param="departmentName">
			<var name="key_groupName" value="${departmentName}" />

			<execute function="Type" locator1="LoopPeopleUpdatePerson#DEPARTMENTS_FIELD" value1="${departmentName}" />
			<execute function="AssertClick" locator1="LoopSearch#GROUP_NAME" value1="${departmentName}" />
			<execute function="AssertClick" locator1="LoopPeopleUpdatePerson#DEPARTMENTS_NAME" value1="${departmentName}" />
		</for>
	</command>

	<command name="assignExpertise">
		<execute macro="LoopPeoplePerson#gotoEditWorkSection" />

		<var name="key_expertiseName" value="${expertiseName}" />
		<var name="key_topicName" value="${expertiseName}" />

		<execute function="Type" locator1="LoopPeopleUpdatePerson#EXPERTISE_FIELD" value1="${expertiseName}" />
		<execute function="AssertClick" locator1="LoopSearch#TOPIC_NAME" value1="${expertiseName}" />
		<execute function="AssertClick" locator1="LoopPeopleUpdatePerson#EXPERTISE_NAME" value1="${expertiseName}" />
	</command>

	<command name="assignExpertises">
		<execute macro="LoopPeoplePerson#gotoEditWorkSection" />

		<for list="${expertiseNameList}" param="expertiseName">
			<var name="key_expertiseName" value="${expertiseName}" />
			<var name="key_topicName" value="${expertiseName}" />

			<execute function="Type" locator1="LoopPeopleUpdatePerson#EXPERTISE_FIELD" value1="${expertiseName}" />
			<execute function="AssertClick" locator1="LoopSearch#TOPIC_NAME" value1="${expertiseName}" />
			<execute function="AssertClick" locator1="LoopPeopleUpdatePerson#EXPERTISE_NAME" value1="${expertiseName}" />
		</for>
	</command>

	<command name="assignGroup">
		<execute macro="LoopPeoplePerson#gotoEditWorkSection" />

		<var name="key_groupName" value="${groupName}" />

		<if>
			<equals arg1="${groupType}" arg2="Team" />
			<then>
				<execute function="Type" locator1="LoopPeopleUpdatePerson#TEAMS_FIELD" value1="${groupName}" />
				<execute function="AssertClick" locator1="LoopSearch#GROUP_NAME" value1="${groupName}" />
				<execute function="AssertClick" locator1="LoopPeopleUpdatePerson#TEAMS_NAME" value1="${groupName}" />
			</then>
			<elseif>
				<equals arg1="${groupType}" arg2="Location" />
				<then>
					<execute function="Type" locator1="LoopPeopleUpdatePerson#LOCATIONS_FIELD" value1="${groupName}" />
					<execute function="AssertClick" locator1="LoopSearch#GROUP_NAME" value1="${groupName}" />
					<execute function="AssertClick" locator1="LoopPeopleUpdatePerson#LOCATIONS_NAME" value1="${groupName}" />
				</then>
			</elseif>
			<elseif>
				<equals arg1="${groupType}" arg2="Department" />
				<then>
					<execute function="Type" locator1="LoopPeopleUpdatePerson#DEPARTMENTS_FIELD" value1="${groupName}" />
					<execute function="AssertClick" locator1="LoopSearch#GROUP_NAME" value1="${groupName}" />
					<execute function="AssertClick" locator1="LoopPeopleUpdatePerson#DEPARTMENTS_NAME" value1="${groupName}" />
				</then>
			</elseif>
		</if>
	</command>

	<command name="assignLocations">
		<execute macro="LoopPeoplePerson#gotoEditWorkSection" />

		<for list="${locationNameList}" param="locationName">
			<var name="key_groupName" value="${locationName}" />

			<execute function="Type" locator1="LoopPeopleUpdatePerson#LOCATIONS_FIELD" value1="${locationName}" />
			<execute function="AssertClick" locator1="LoopSearch#GROUP_NAME" value1="${locationName}" />
			<execute function="AssertClick" locator1="LoopPeopleUpdatePerson#LOCATIONS_NAME" value1="${locationName}" />
		</for>
	</command>

	<command name="assignManager">
		<execute macro="LoopPeoplePerson#gotoEditWorkSection" />

		<var name="key_managerName" value="${managerName}" />
		<var name="key_userName" value="${managerName}" />

		<execute function="Type" locator1="LoopPeopleUpdatePerson#MANAGERS_FIELD" value1="${managerName}" />
		<execute function="AssertClick" locator1="LoopSearch#USER_NAME" value1="${managerName}" />
		<execute function="AssertClick" locator1="LoopPeopleUpdatePerson#MANAGERS_NAME" value1="${managerName}" />
	</command>

	<command name="assignPrimaryManager">
		<execute macro="LoopPeoplePerson#gotoEditWorkSection" />

		<var name="key_managerName" value="${managerName}" />
		<var name="key_userName" value="${managerName}" />

		<execute function="Type" locator1="LoopPeopleUpdatePerson#PRIMARY_MANAGER_FIELD" value1="${managerName}" />
		<execute function="AssertClick" locator1="LoopSearch#USER_NAME" value1="${managerName}" />
		<execute function="AssertClick" locator1="LoopPeopleUpdatePerson#MANAGERS_NAME" value1="${managerName}" />
	</command>

	<command name="assignTeams">
		<execute macro="LoopPeoplePerson#gotoEditWorkSection" />

		<for list="${teamNameList}" param="teamName">
			<var name="key_groupName" value="${teamName}" />

			<execute function="Type" locator1="LoopPeopleUpdatePerson#TEAMS_FIELD" value1="${teamName}" />
			<execute function="AssertClick" locator1="LoopSearch#GROUP_NAME" value1="${teamName}" />
			<execute function="AssertClick" locator1="LoopPeopleUpdatePerson#TEAMS_NAME" value1="${teamName}" />
		</for>
	</command>

	<command name="cancelCoverPicture">
		<execute function="Click" locator1="LoopPeoplePerson#PERSON_COVER_PICTURE_CANCEL_BUTTON" />
	</command>

	<command name="clickActivateButton">
		<execute function="Click" locator1="LoopPeoplePerson#PERSON_OPTIONS_BUTTON" />
		<execute function="AssertClick" locator1="LoopPeoplePerson#PERSON_OPTIONS_TOGGLE_ACTIVATE_LINK" value1="Activate User" />
	</command>

	<command name="clickDeactivateButton">
		<execute function="Click" locator1="LoopPeoplePerson#PERSON_OPTIONS_BUTTON" />
		<execute function="AssertClick" locator1="LoopPeoplePerson#PERSON_OPTIONS_TOGGLE_ACTIVATE_LINK" value1="Deactivate User" />
	</command>

	<command name="clickDescriptionField">
		<execute function="Click" locator1="LoopPeopleUpdatePerson#DESCRIPTION_FIELD" />
		<execute function="SelectFieldText" locator1="LoopPeopleUpdatePerson#DESCRIPTION_FIELD" />
		<execute function="KeyPress" locator1="LoopPeopleUpdatePerson#DESCRIPTION_FIELD" value1="\BACK_SPACE" />
	</command>

	<command name="clickEditButton">
		<execute function="Click" locator1="LoopPeoplePerson#PERSON_OPTIONS_BUTTON" />
		<execute function="AssertClick" locator1="LoopPeoplePerson#PERSON_OPTIONS_EDIT_LINK" value1="Edit User Information" />
	</command>

	<command name="clickExpertiseLink">
		<var name="key_expertiseName" value="${expertiseName}" />

		<execute function="AssertClick" locator1="LoopPeoplePerson#WORK_EXPERTISE" value1="${expertiseName}" />
	</command>

	<command name="clickFollowButton">
		<execute function="AssertClick" locator1="LoopPeoplePerson#PERSON_FOLLOW_BUTTON" value1="Follow" />
		<execute function="AssertTextEquals" locator1="LoopPeoplePerson#PERSON_FOLLOW_BUTTON" value1="Following" />
	</command>

	<command name="clickFollowButtonViaOverlay">
		<execute function="AssertClick" locator1="LoopPeople#PERSON_OVERLAY_FOLLOW_BUTTON" value1="Follow" />
	</command>

	<command name="clickFollowLinkViaIndex">
		<execute macro="LoopPeoplePerson#mouseOverPersonName">
			<var name="userName" value="${userName}" />
		</execute>

		<var name="key_userName" value="${userName}" />

		<if>
			<condition function="IsElementPresent" locator1="LoopPeople#PERSON_FOLLOW_MENU_BUTTON" />
			<then>
				<execute function="Click" locator1="LoopPeople#PERSON_FOLLOW_MENU_BUTTON" />
			</then>
			<elseif>
				<condition function="IsElementPresent" locator1="LoopPeople#PERSON_FOLLOW_BUTTON" />
				<then>
					<execute function="Click" locator1="LoopPeople#PERSON_FOLLOW_BUTTON" />
				</then>
			</elseif>
			<else>
				<execute macro="LoopPeoplePerson#clickFollowButtonViaOverlay" />
			</else>
		</if>
	</command>

	<command name="clickFollowOnlyPostsNotificationsLink">
		<execute function="AssertClick" locator1="LoopPeoplePerson#PERSON_ONLY_POSTS_NOTIFICATIONS_LINK" value1="Only Posts" />
	</command>

	<command name="clickFollowPostsAndCommentedPostsNotificationsLink">
		<execute function="AssertClick" locator1="LoopPeoplePerson#PERSON_POSTS_AND_COMMENTED_POSTS_NOTIFICATIONS_LINK" value1="Posts, Comments, and Mentions" />
	</command>

	<command name="clickGroupLink">
		<var name="key_groupName" value="${groupName}" />

		<execute function="AssertClick" locator1="LoopPeoplePerson#GROUPS_GROUP_NAME" value1="${groupName}" />
	</command>

	<command name="clickMoreGroupsLink">
		<execute function="AssertClick" locator1="LoopPeoplePerson#GROUPS_MORE_LINK" value1="See All" />
	</command>

	<command name="clickSeeFullNetworkLink">
		<execute function="AssertClick" locator1="LoopPeoplePerson#NETWORK_SEE_FULL_NETWORK_LINK" value1="See Full Network" />
	</command>

	<command name="clickTurnOffEmailNotification">
		<execute function="MouseOver" locator1="LoopPeoplePerson#PERSON_FOLLOW_BUTTON" />
		<execute function="Click#makeVisibleClickAt" locator1="LoopPeoplePerson#PERSON_EMAIL_NOTIFICATIONS_CHECKBOX" />
	</command>

	<command name="clickTurnOffNotifications">
		<execute function="AssertTextEquals" locator1="LoopPeoplePerson#PERSON_TOGGLE_NOTIFICATIONS_LABEL" value1="Turn off Notifications" />
		<execute function="AssertVisible" locator1="LoopPeoplePerson#PERSON_EMAIL_NOTIFICATIONS_LABEL" />

		<execute function="Click#makeVisibleClickAt" locator1="LoopPeoplePerson#PERSON_TOGGLE_NOTIFICATIONS_LINK" />

		<execute function="AssertTextEquals" locator1="LoopPeoplePerson#PERSON_TOGGLE_NOTIFICATIONS_LABEL" value1="Turn on Notifications" />
		<execute function="AssertNotVisible" locator1="LoopPeoplePerson#PERSON_EMAIL_NOTIFICATIONS_LABEL" />
	</command>

	<command name="clickTurnOffNotificationsButton">
		<execute function="MouseOver" locator1="LoopPeoplePerson#PERSON_FOLLOW_BUTTON" />

		<execute macro="LoopPeoplePerson#clickTurnOffNotifications" />
	</command>

	<command name="clickTurnOffNotificationsLinkViaIndex">
		<execute macro="LoopPeoplePerson#mouseOverPersonName">
			<var name="userName" value="${userName}" />
		</execute>

		<var name="key_userName" value="${userName}" />

		<if>
			<condition function="IsElementPresent" locator1="LoopPeople#PERSON_FOLLOW_MENU_BUTTON" />
			<then>
				<execute function="Click" locator1="LoopPeople#PERSON_FOLLOW_MENU_BUTTON" />

				<execute macro="LoopPeoplePerson#clickTurnOffNotifications" />
			</then>
			<else>
				<execute function="MouseOver" locator1="LoopPeople#PERSON_OVERLAY_FOLLOW_BUTTON" />

				<execute macro="LoopPeoplePerson#clickTurnOffNotifications" />
			</else>
		</if>
	</command>

	<command name="clickTurnOnEmailNotification">
		<execute macro="LoopPeoplePerson#clickTurnOnNotificationsButton" />

		<execute function="Click#makeVisibleClickAt" locator1="LoopPeoplePerson#PERSON_EMAIL_NOTIFICATIONS_CHECKBOX" />
	</command>

	<command name="clickTurnOnNotifications">
		<execute function="AssertTextEquals" locator1="LoopPeoplePerson#PERSON_TOGGLE_NOTIFICATIONS_LABEL" value1="Turn on Notifications" />
		<execute function="AssertNotVisible" locator1="LoopPeoplePerson#PERSON_EMAIL_NOTIFICATIONS_LABEL" />

		<execute function="Click#makeVisibleClickAt" locator1="LoopPeoplePerson#PERSON_TOGGLE_NOTIFICATIONS_LINK" />

		<execute function="AssertTextEquals" locator1="LoopPeoplePerson#PERSON_TOGGLE_NOTIFICATIONS_LABEL" value1="Turn off Notifications" />
		<execute function="AssertVisible" locator1="LoopPeoplePerson#PERSON_EMAIL_NOTIFICATIONS_LABEL" />
	</command>

	<command name="clickTurnOnNotificationsButton">
		<if>
			<condition function="IsTextEqual" locator1="LoopPeoplePerson#PERSON_FOLLOW_BUTTON" value1="Follow" />
			<then>
				<execute macro="LoopPeoplePerson#clickFollowButton" />
			</then>
		</if>

		<execute function="MouseOver" locator1="LoopPeoplePerson#PERSON_FOLLOW_BUTTON" />

		<execute macro="LoopPeoplePerson#clickTurnOnNotifications" />

		<execute function="AssertClick" locator1="LoopPeoplePerson#PERSON_POSTS_AND_COMMENTED_POSTS_NOTIFICATIONS_LINK" value1="Posts, Comments, and Mentions" />
	</command>

	<command name="clickTurnOnNotificationsLinkViaIndex">
		<execute macro="LoopPeoplePerson#mouseOverPersonName">
			<var name="userName" value="${userName}" />
		</execute>

		<var name="key_userName" value="${userName}" />

		<if>
			<condition function="IsElementPresent" locator1="LoopPeople#PERSON_FOLLOW_MENU_BUTTON" />
			<then>
				<execute function="Click" locator1="LoopPeople#PERSON_FOLLOW_MENU_BUTTON" />

				<execute macro="LoopPeoplePerson#clickTurnOnNotifications" />
			</then>
			<else>
				<if>
					<condition function="IsTextEqual" locator1="LoopPeople#PERSON_OVERLAY_FOLLOW_BUTTON" value1="Follow" />
					<then>
						<execute macro="LoopPeoplePerson#clickFollowButtonViaOverlay" />
					</then>
				</if>

				<execute function="MouseOver" locator1="LoopPeople#PERSON_OVERLAY_FOLLOW_BUTTON" />

				<execute macro="LoopPeoplePerson#clickTurnOnNotifications" />
			</else>
		</if>
	</command>

	<command name="clickUnfollowButtonViaOverlay">
		<execute function="MouseOver" locator1="LoopPeople#PERSON_OVERLAY_FOLLOW_BUTTON" />
		<execute function="Click" locator1="LoopPeoplePerson#PERSON_UNFOLLOW_LINK" />
		<execute function="AssertTextEquals" locator1="LoopPeople#PERSON_OVERLAY_FOLLOW_BUTTON" value1="Follow" />
	</command>

	<command name="clickUnfollowLink">
		<execute function="MouseOver" locator1="LoopPeoplePerson#PERSON_FOLLOW_BUTTON" />
		<execute function="Click" locator1="LoopPeoplePerson#PERSON_UNFOLLOW_LINK" />
		<execute function="AssertTextEquals" locator1="LoopPeoplePerson#PERSON_FOLLOW_BUTTON" value1="Follow" />
	</command>

	<command name="clickUnfollowLinkViaIndex">
		<execute macro="LoopPeoplePerson#mouseOverPersonName">
			<var name="userName" value="${userName}" />
		</execute>

		<var name="key_userName" value="${userName}" />

		<if>
			<condition function="IsElementPresent" locator1="LoopPeople#PERSON_FOLLOW_MENU_BUTTON" />
			<then>
				<execute function="Click" locator1="LoopPeople#PERSON_FOLLOW_MENU_BUTTON" />

				<execute function="AssertClick" locator1="LoopPeoplePerson#PERSON_UNFOLLOW_LINK" value1="Unfollow ${userName}" />
			</then>
			<elseif>
				<condition function="IsElementPresent" locator1="LoopPeople#PERSON_UNFOLLOW_BUTTON" />
				<then>
					<execute function="Click" locator1="LoopPeople#PERSON_UNFOLLOW_BUTTON" />
				</then>
			</elseif>
			<else>
				<execute macro="LoopPeoplePerson#clickUnfollowButtonViaOverlay" />
			</else>
		</if>
	</command>

	<command name="confirmCoverPicture">
		<execute function="Click" locator1="LoopPeoplePerson#PERSON_COVER_PICTURE_CONFIRM_BUTTON" />
	</command>

	<command name="confirmProfilePicture">
		<execute function="AssertClick" locator1="LoopPeopleUpdatePicture#SAVE_BUTTON" value1="Save" />
	</command>

	<command name="deactivateUserCmd">
		<execute function="AssertTextEquals#assertPartialText" locator1="LoopPeoplePerson#TOGGLE_ACTIVATE_DEACTIVATE_MESSAGE" value1="Are you sure you want to deactivate ${userName}?" />
		<execute function="AssertClick" locator1="LoopPeoplePerson#TOGGLE_ACTIVATE_CONFIRM_BUTTON" value1="Confirm" />

		<!-- Workaround until LOOP-5208 is fixed -->

		<!--<execute function="AssertTextEquals" locator1="LoopPeoplePerson#SUCCESS_MESSAGE" value1="${userName} was successfully deactivated." />-->
		<execute function="Pause" locator1="5000" />
	</command>

	<command name="deleteAdditionalEmailRow">
		<execute macro="LoopPeoplePerson#gotoEditContactSection" />

		<execute function="Click" locator1="LoopPeopleUpdatePerson#ADDITIONAL_EMAIL_DELETE_ROW_BUTTON" />
	</command>

	<command name="deletePhoneNumberRow">
		<execute macro="LoopPeoplePerson#gotoEditContactSection" />

		<execute function="Click" locator1="LoopPeopleUpdatePerson#PHONE_NUMBER_DELETE_ROW_BUTTON" />
	</command>

	<command name="disableAgeDisplay">
		<execute macro="LoopPeoplePerson#gotoEditAboutSection" />

		<execute function="Click#makeVisibleClickAt" locator1="LoopPeopleUpdatePerson#DISPLAY_AGE_CHECKBOX" />

		<execute function="AssertElementNotPresent" locator1="LoopPeopleUpdatePerson#DISPLAY_AGE_CHECKBOX_CHECKED" />
	</command>

	<command name="disableBirthdayDisplay">
		<execute macro="LoopPeoplePerson#gotoEditAboutSection" />

		<execute function="Click#makeVisibleClickAt" locator1="LoopPeopleUpdatePerson#DISPLAY_BIRTHDAY_CHECKBOX" />

		<execute function="AssertElementNotPresent" locator1="LoopPeopleUpdatePerson#DISPLAY_BIRTHDAY_CHECKBOX_CHECKED" />
	</command>

	<command name="editPasswordCP">
		<if>
			<condition function="IsNotVisible" locator1="CPUsersandorganizations#NEW_PASSWORD_FIELD" />
			<then>
				<execute function="Click" locator1="CPUsersandorganizations#EXPAND_PASSWORD" />
			</then>
		</if>

		<execute function="Type" locator1="CPUsersandorganizations#NEW_PASSWORD_FIELD" value1="test" />
		<execute function="Type" locator1="CPUsersandorganizations#NEW_PASSWORD_ENTER_AGAIN_FIELD" value1="test" />
	</command>

	<command name="editRolesCP">
		<if>
			<and>
				<isset var="roleNames" />
				<not>
					<contains string="${roleNames}" substring="{roleNames}" />
				</not>
			</and>
			<then>
				<if>
					<condition function="IsNotVisible" locator1="CPUsersandorganizations#SELECT_ROLES_BUTTON" />
					<then>
						<execute function="Click" locator1="CPUsersandorganizations#EXPAND_ROLES" />
					</then>
				</if>

				<for list="${roleNames}" param="roleName">
					<var name="key_roleName" value="${roleName}" />

					<execute function="Click" locator1="CPUsersandorganizations#SELECT_ROLES_BUTTON" />

					<execute function="SelectFrame" locator1="CPUsersandorganizations#SELECT_ROLES_FRAME" />

					<execute function="Click" locator1="CPUsersandorganizations#CHOOSE_ROLE_BUTTON" />

					<execute function="SelectWindow#selectWindowTop" />
				</for>
			</then>
		</if>
	</command>

	<command name="editUserCP">
		<execute macro="Loop#logoutAndLogin">
			<var name="userLoginEmailAddress" value="test@liferay.com" />
		</execute>

		<execute macro="Loop#openSpecificURL">
			<var name="url" value="/group/control_panel/manage?p_p_id=com_liferay_users_admin_web_portlet_UsersAdminPortlet" />
		</execute>

		<var name="key_userScreenName" value="${userScreenName}" />

		<execute function="AssertClick" locator1="CPUsersandorganizations#USER_LINK" value1="${userScreenName}" />

		<execute macro="LoopPeoplePerson#editPasswordCP" />

		<execute macro="LoopPeoplePerson#editRolesCP">
			<var name="roleNames" value="${roleNames}" />
		</execute>

		<execute function="AssertClick" locator1="CPUsersandorganizations#SAVE_BUTTON" value1="Save" />

		<execute function="AssertTextEquals" locator1="CPUsersandorganizations#SUCCESS_MESSAGE" value1="Your request completed successfully." />
		<execute function="Pause" locator1="5000" />
	</command>

