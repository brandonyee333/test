	<command name="viewManager">
		<var name="key_managerName" value="${managerName}" />

		<execute function="AssertElementPresent" locator1="LoopPeoplePerson#NETWORK_MANAGER" />
	</command>

	<command name="viewManagersFieldDisabled">
		<execute function="AssertElementPresent" locator1="LoopPeopleUpdatePerson#MANAGERS_FIELD_DISABLED" />
	</command>

	<command name="viewManagersFieldEnabled">
		<execute function="AssertElementNotPresent" locator1="LoopPeopleUpdatePerson#MANAGERS_FIELD_DISABLED" />
	</command>

	<command name="viewManagerViaNetworkSection">
		<var name="key_managerName" value="${managerName}" />

		<execute function="AssertTextEquals" locator1="LoopPeoplePerson#NETWORK_TAB_MANAGER_NAME_LINK" value1="${managerName}" />
	</command>

	<command name="viewNoAge">
		<execute function="AssertElementNotPresent" locator1="LoopPeoplePerson#ABOUT_AGE" />
	</command>

	<command name="viewNoBirthday">
		<execute function="AssertElementNotPresent" locator1="LoopPeoplePerson#ABOUT_BIRTHDAY" />
	</command>

	<command name="viewNoCreatePermissions">
		<execute macro="Loop#openSpecificURL">
			<var name="url" value="/web/guest/home/-/loop/people/_${userScreenName}/create" />
		</execute>

		<execute macro="LoopNavigation#viewPageNotFound" />
	</command>

	<command name="viewNoEditControls">
		<execute function="MouseOver" locator1="LoopPeoplePerson#PERSON_PROFILE_PICTURE" />
		<execute function="AssertElementNotPresent" locator1="LoopPeoplePerson#PERSON_PROFILE_PICTURE_SELECT_BUTTON" />
		<execute function="AssertElementNotPresent" locator1="LoopPeoplePerson#PERSON_COVER_PICTURE_SELECT_BUTTON" />
		<execute function="AssertElementNotPresent" locator1="LoopPeoplePerson#PERSON_OPTIONS_BUTTON" />
	</command>

	<command name="viewNoEditControlsForDeactivatedUser">
		<execute function="MouseOver" locator1="LoopPeoplePerson#PERSON_PROFILE_PICTURE" />
		<execute function="AssertElementNotPresent" locator1="LoopPeoplePerson#PERSON_PROFILE_PICTURE_SELECT_BUTTON" />
		<execute function="AssertElementNotPresent" locator1="LoopPeoplePerson#PERSON_COVER_PICTURE_SELECT_BUTTON" />
		<execute function="AssertElementNotPresent" locator1="LoopPeoplePerson#PERSON_OPTIONS_BUTTON" />
	</command>

	<command name="viewNoEmailAddress">
		<var name="key_userEmailAddress" value="${userEmailAddress}" />

		<execute function="AssertElementNotPresent" locator1="LoopPeoplePerson#CONTACT_EMAIL_ADDRESS" />
	</command>

	<command name="viewNoEntityInField">
		<var name="key_entityName" value="${entityName}" />
		<var name="key_fieldLabel" value="${fieldLabel}" />

		<execute function="AssertElementNotPresent" locator1="LoopPeopleUpdatePerson#SELECTED_ENTITY_NAME_GENERAL_FIELD" />
	</command>

	<command name="viewNoExpertise">
		<var name="key_expertiseName" value="${expertiseName}" />

		<execute function="AssertElementNotPresent" locator1="LoopPeoplePerson#WORK_EXPERTISE" />
	</command>

	<command name="viewNoFollowButton">
		<execute function="AssertElementNotPresent" locator1="LoopPeoplePerson#PERSON_FOLLOW_BUTTON" />
	</command>

	<command name="viewNoGroup">
		<var name="key_groupName" value="${groupName}" />

		<execute function="AssertElementNotPresent" locator1="LoopPeoplePerson#GROUPS_GROUP_NAME" />
	</command>

	<command name="viewNoGroupViaFollowingSection">
		<execute macro="LoopPeoplePerson#gotoFollowingSection" />

		<execute macro="LoopGroupsGroup#viewNoGroupViaGroupsList">
			<var name="groupName" value="${groupName}" />
		</execute>

		<execute macro="LoopPeoplePerson#gotoFollowingSectionGroupsTab">
			<var name="followingGroupsCount" value="${followingGroupsCount}" />
		</execute>

		<execute macro="LoopGroupsGroup#viewNoGroupViaGroupsList">
			<var name="groupName" value="${groupName}" />
		</execute>
	</command>

	<command name="viewNoJobTitle">
		<var name="key_jobTitleName" value="${jobTitleName}" />

		<execute function="AssertElementNotPresent" locator1="LoopPeoplePerson#PERSON_JOB_TITLE" />
	</command>

	<command name="viewNoManager">
		<var name="key_managerName" value="${managerName}" />

		<execute function="AssertElementNotPresent" locator1="LoopPeoplePerson#NETWORK_MANAGER" />
	</command>

	<command name="viewNoManagerViaNetworkSection">
		<var name="key_managerName" value="${managerName}" />

		<execute function="AssertElementNotPresent" locator1="LoopPeoplePerson#NETWORK_TAB_MANAGER_NAME_LINK" />
	</command>

	<command name="viewNoPersonViaFollowingSection">
		<execute macro="LoopPeoplePerson#gotoFollowingSection" />

		<execute macro="LoopPeoplePerson#viewNoPersonViaPeopleList">
			<var name="userName" value="${userName}" />
		</execute>

		<execute macro="LoopPeoplePerson#gotoFollowingSectionPeopleTab">
			<var name="followingPeopleCount" value="${followingPeopleCount}" />
		</execute>

		<execute macro="LoopPeoplePerson#viewNoPersonViaPeopleList">
			<var name="userName" value="${userName}" />
		</execute>
	</command>

	<command name="viewNoPersonViaPeopleList">
		<var name="key_userName" value="${userName}" />

		<if>
			<condition function="IsElementPresent" locator1="LoopPeople#PERSON_NAME" />
			<then>
				<execute function="AssertNotVisible" locator1="LoopPeople#PERSON_PROFILE_IMAGE" />
				<execute function="AssertNotVisible" locator1="LoopPeople#PERSON_NAME" />
			</then>
			<else>
				<execute function="AssertElementNotPresent" locator1="LoopPeople#PERSON_PROFILE_IMAGE" />
				<execute function="AssertElementNotPresent" locator1="LoopPeople#PERSON_NAME" />
			</else>
		</if>
	</command>

	<command name="viewNoPhoneNumber">
		<var name="key_userPhoneNumber" value="${userPhoneNumber}" />

		<execute function="AssertElementNotPresent" locator1="LoopPeoplePerson#CONTACT_PHONE" />
	</command>

	<command name="viewNoSubordinate">
		<var name="key_subordinateName" value="${subordinateName}" />

		<execute function="AssertElementNotPresent" locator1="LoopPeoplePerson#NETWORK_SUBORDINATE" />
	</command>

	<command name="viewNoSubordinateViaNetworkSection">
		<var name="key_subordinateName" value="${subordinateName}" />

		<execute function="AssertElementNotPresent" locator1="LoopPeoplePerson#NETWORK_TAB_SUBORDINATE_NAME_LINK" />
	</command>

	<command name="viewNoTopicViaFollowingSection">
		<execute macro="LoopPeoplePerson#gotoFollowingSection" />

		<execute macro="LoopTopicsTopic#viewNoTopicViaTopicsList">
			<var name="topicName" value="${topicName}" />
		</execute>

		<execute macro="LoopPeoplePerson#gotoFollowingSectionTopicsTab">
			<var name="followingTopicsCount" value="${followingTopicsCount}" />
		</execute>

		<execute macro="LoopTopicsTopic#viewNoTopicViaTopicsList">
			<var name="topicName" value="${topicName}" />
		</execute>
	</command>

	<command name="viewOccupation">
		<var name="key_jobTitleName" value="${jobTitleName}" />

		<execute function="AssertTextEquals#assertPartialText" locator1="LoopPeoplePerson#WORK_OCCUPATION" value1="${jobTitleName}" />
	</command>

	<command name="viewPeopleViaPeopleList">
		<for list="${userNameList}" param="userName">
			<var name="key_userName" value="${userName}" />

			<execute function="AssertElementPresent" locator1="LoopPeople#PERSON_PROFILE_IMAGE" />
			<execute function="AssertTextEquals" locator1="LoopPeople#PERSON_NAME" value1="${userName}" />
		</for>
	</command>

	<command name="viewPersonCount">
		<execute function="AssertTextEquals#assertPartialText" locator1="LoopPeople#PERSON_COUNT" value1="${personCount}" />
	</command>

	<command name="viewPersonOverlay">
		<execute function="AssertElementPresent" locator1="LoopPeople#PERSON_OVERLAY_AVATAR" />
		<execute function="AssertTextEquals" locator1="LoopPeople#PERSON_OVERLAY_NAME" value1="${userName}" />

		<if>
			<equals arg1="${selfOverlay}" arg2="true" />
			<then>
				<execute function="AssertElementNotPresent" locator1="LoopPeople#PERSON_OVERLAY_FOLLOW_BUTTON" />
			</then>
			<else>
				<execute function="AssertElementPresent" locator1="LoopPeople#PERSON_OVERLAY_FOLLOW_BUTTON" />
			</else>
		</if>

		<if>
			<and>
				<isset var="followerCount" />
				<not>
					<contains string="${followerCount}" substring="{followerCount}" />
				</not>
			</and>
			<then>
				<if>
					<equals arg1="${followerCount}" arg2="1" />
					<then>
						<execute function="AssertTextEquals" locator1="LoopPeople#PERSON_OVERLAY_FOLLOWERS" value1="1 Follower" />
					</then>
					<else>
						<execute function="AssertTextEquals" locator1="LoopPeople#PERSON_OVERLAY_FOLLOWERS" value1="${followerCount} Followers" />
					</else>
				</if>
			</then>
		</if>

		<if>
			<and>
				<isset var="groupCount" />
				<not>
					<contains string="${groupCount}" substring="{groupCount}" />
				</not>
			</and>
			<then>
				<if>
					<equals arg1="${groupCount}" arg2="1" />
					<then>
						<execute function="AssertTextEquals" locator1="LoopPeople#PERSON_OVERLAY_GROUPS" value1="1 Group" />
					</then>
					<else>
						<execute function="AssertTextEquals" locator1="LoopPeople#PERSON_OVERLAY_GROUPS" value1="${groupCount} Groups" />
					</else>
				</if>
			</then>
		</if>

		<if>
			<and>
				<isset var="expertiseCount" />
				<not>
					<contains string="${expertiseCount}" substring="{expertiseCount}" />
				</not>
			</and>
			<then>
				<execute function="AssertTextEquals" locator1="LoopPeople#PERSON_OVERLAY_EXPERTISE" value1="${expertiseCount} Expertise" />
			</then>
		</if>

		<execute macro="LoopNavigation#closeOverlay" />
	</command>

	<command name="viewPersonProfile">
		<execute function="AssertElementPresent" locator1="LoopPeoplePerson#PERSON_COVER_PICTURE" />
		<execute function="AssertElementPresent" locator1="LoopPeoplePerson#PERSON_PROFILE_PICTURE" />
		<execute function="AssertTextEquals" locator1="LoopPeoplePerson#PERSON_NAME" value1="${userName}" />

		<if>
			<and>
				<isset var="jobTitleName" />
				<not>
					<contains string="${jobTitleName}" substring="{jobTitleName}" />
				</not>
			</and>
			<then>
				<execute function="AssertTextEquals#assertPartialText" locator1="LoopPeoplePerson#PERSON_DESCRIPTION" value1="${jobTitleName}" />
			</then>
		</if>

		<if>
			<and>
				<isset var="userLocation" />
				<not>
					<contains string="${userLocation}" substring="{userLocation}" />
				</not>
			</and>
			<then>
				<execute function="AssertTextEquals#assertPartialText" locator1="LoopPeoplePerson#PERSON_DESCRIPTION" value1="${userLocation}" />
			</then>
		</if>

		<if>
			<and>
				<isset var="followerCount" />
				<not>
					<contains string="${followerCount}" substring="{followerCount}" />
				</not>
			</and>
			<then>
				<if>
					<equals arg1="${followerCount}" arg2="1" />
					<then>
						<execute function="AssertTextEquals" locator1="LoopPeoplePerson#PERSON_FOLLOWER_COUNT" value1="1 Follower" />
					</then>
					<else>
						<execute function="AssertTextEquals" locator1="LoopPeoplePerson#PERSON_FOLLOWER_COUNT" value1="${followerCount} Followers" />
					</else>
				</if>
			</then>
		</if>

		<if>
			<and>
				<isset var="groupCount" />
				<not>
					<contains string="${groupCount}" substring="{groupCount}" />
				</not>
			</and>
			<then>
				<if>
					<equals arg1="${groupCount}" arg2="1" />
					<then>
						<execute function="AssertTextEquals" locator1="LoopPeoplePerson#PERSON_GROUP_COUNT" value1="1 Group" />
					</then>
					<else>
						<execute function="AssertTextEquals" locator1="LoopPeoplePerson#PERSON_GROUP_COUNT" value1="${groupCount} Groups" />
					</else>
				</if>
			</then>
		</if>

		<execute macro="LoopPeoplePerson#viewEmailAddress">
			<var name="userEmailAddress" value="${userEmailAddress}" />
		</execute>
	</command>

	<command name="viewPersonViaFollowingSection">
		<var name="key_entityType" value="People" />
		<var name="key_userName" value="${userName}" />

		<execute macro="LoopPeoplePerson#gotoFollowingSection" />

		<execute macro="LoopPeoplePerson#viewPersonViaPeopleList">
			<var name="userName" value="${userName}" />
		</execute>

		<execute macro="LoopPeoplePerson#gotoFollowingSectionPeopleTab">
			<var name="followingPeopleCount" value="${followingPeopleCount}" />
		</execute>

		<execute macro="LoopPeoplePerson#viewPersonViaPeopleList">
			<var name="userName" value="${userName}" />
		</execute>
	</command>

	<command name="viewPersonViaPeopleList">
		<var name="key_userName" value="${userName}" />

		<execute function="AssertElementPresent" locator1="LoopPeople#PERSON_PROFILE_IMAGE" />
		<execute function="AssertTextEquals" locator1="LoopPeople#PERSON_NAME" value1="${userName}" />

		<if>
			<and>
				<isset var="jobTitleName" />
				<not>
					<contains string="${jobTitleName}" substring="{jobTitleName}" />
				</not>
			</and>
			<then>
				<var name="key_jobTitleName" value="${jobTitleName}" />

				<execute function="AssertTextEquals#assertPartialText" locator1="LoopPeople#PERSON_JOB_TITLE" value1="${jobTitleName}" />
			</then>
		</if>

		<if>
			<and>
				<isset var="userLocation" />
				<not>
					<contains string="${userLocation}" substring="{userLocation}" />
				</not>
			</and>
			<then>
				<var name="key_userLocation" value="${userLocation}" />

				<if>
					<condition function="IsNotVisible" locator1="LoopPeople#PERSON_LOCATION" />
					<then>
						<execute function="MouseOver" locator1="LoopPeople#PERSON_NAME" />
						<execute function="AssertTextEquals#assertPartialText" locator1="LoopPeople#PERSON_LOCATION" value1="${userLocation}" />
					</then>
					<else>
						<execute function="AssertTextEquals#assertPartialText" locator1="LoopPeople#PERSON_LOCATION" value1="${userLocation}" />
					</else>
				</if>
			</then>
		</if>
	</command>

	<command name="viewPhoneNumber">
		<var name="key_userPhoneNumber" value="${userPhoneNumber}" />

		<execute function="AssertTextEquals" locator1="LoopPeoplePerson#CONTACT_PHONE" value1="${userPhoneNumber}" />
	</command>

	<command name="viewPreferredName">
		<var name="key_userPreferredName" value="${userPreferredName}" />

		<execute function="AssertTextEquals#assertPartialText" locator1="LoopPeoplePerson#ABOUT_PREFERRED_NAME" value1="${userPreferredName}" />
	</command>

	<command name="viewPreferredNameFieldDisabled">
		<execute function="AssertElementPresent" locator1="LoopPeopleUpdatePerson#PREFERRED_NAME_FIELD_DISABLED" />
	</command>

	<command name="viewPreferredNameFieldEnabled">
		<execute function="AssertElementNotPresent" locator1="LoopPeopleUpdatePerson#PREFERRED_NAME_FIELD_DISABLED" />
	</command>

	<command name="viewSkype">
		<var name="key_userSkype" value="${userSkype}" />

		<execute function="AssertTextEquals" locator1="LoopPeoplePerson#CONTACT_SKYPE" value1="${userSkype}" />
	</command>

	<command name="viewStartDate">
		<var name="key_userHireDate" value="${userHireDate}" />

		<execute function="AssertTextEquals#assertPartialText" locator1="LoopPeoplePerson#WORK_START_DATE" value1="${userHireDate}" />
	</command>

	<command name="viewSubordinate">
		<var name="key_subordinateName" value="${subordinateName}" />

		<execute function="AssertElementPresent" locator1="LoopPeoplePerson#NETWORK_SUBORDINATE" />
	</command>

	<command name="viewSubordinates">
		<for list="${subordinateNameList}" param="subordinateName">
			<var name="key_subordinateName" value="${subordinateName}" />

			<execute function="AssertElementPresent" locator1="LoopPeoplePerson#NETWORK_SUBORDINATE" />
		</for>
	</command>

	<command name="viewSubordinatesViaNetworkSection">
		<for list="${subordinateNameList}" param="subordinateName">
			<var name="key_subordinateName" value="${subordinateName}" />

			<execute function="AssertTextEquals" locator1="LoopPeoplePerson#NETWORK_TAB_SUBORDINATE_NAME_LINK" value1="${subordinateName}" />
		</for>
	</command>

	<command name="viewSubordinateViaNetworkSection">
		<var name="key_subordinateName" value="${subordinateName}" />

		<execute function="AssertTextEquals" locator1="LoopPeoplePerson#NETWORK_TAB_SUBORDINATE_NAME_LINK" value1="${subordinateName}" />
	</command>

	<command name="viewTeamsFieldDisabled">
		<execute function="AssertElementPresent" locator1="LoopPeopleUpdatePerson#TEAMS_FIELD_DISABLED" />
	</command>

	<command name="viewTeamsFieldEnabled">
		<execute function="AssertElementNotPresent" locator1="LoopPeopleUpdatePerson#TEAMS_FIELD_DISABLED" />
	</command>

	<command name="viewTopicViaFollowingSection">
		<var name="key_entityType" value="Topics" />
		<var name="key_topicName" value="${topicName}" />

		<execute macro="LoopPeoplePerson#gotoFollowingSection" />

		<execute macro="LoopTopicsTopic#viewTopicViaTopicsList">
			<var name="topicName" value="${topicName}" />
		</execute>

		<execute macro="LoopPeoplePerson#gotoFollowingSectionTopicsTab">
			<var name="followingTopicsCount" value="${followingTopicsCount}" />
		</execute>

		<execute macro="LoopTopicsTopic#viewTopicViaTopicsList">
			<var name="topicName" value="${topicName}" />
		</execute>
	</command>

	<command name="viewTwitter">
		<var name="key_userTwitter" value="${userTwitter}" />

		<execute function="AssertTextEquals" locator1="LoopPeoplePerson#ELSEWHERE_TWITTER" value1="${userTwitter}" />
	</command>
</definition>