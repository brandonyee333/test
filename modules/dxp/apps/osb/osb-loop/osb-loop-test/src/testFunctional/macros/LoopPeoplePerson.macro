	<command name="uploadCoverPicture">
		<execute function="MouseOver" locator1="LoopPeoplePerson#PERSON_COVER_PICTURE" />
		<execute function="Click" locator1="LoopPeoplePerson#PERSON_COVER_PICTURE_SELECT_BUTTON" />

		<if>
			<equals arg1="${uploadTempFile}" arg2="true" />
			<then>
				<execute function="SikuliUploadTempFile" locator1="OS#FILE_DIALOG_BOX_FILE_NAME_FIELD_PNG" value1="${coverPictureFileName}" />
			</then>
			<else>
				<execute function="SikuliUploadCommonFile" locator1="OS#FILE_DIALOG_BOX_FILE_NAME_FIELD_PNG" value1="${coverPictureFileName}" />
			</else>
		</if>
	</command>

