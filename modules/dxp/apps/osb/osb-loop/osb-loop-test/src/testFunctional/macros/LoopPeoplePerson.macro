		<execute function="MouseOver" locator1="LoopPeoplePerson#PERSON_PROFILE_PICTURE" />
		<execute function="Click" locator1="LoopPeoplePerson#PERSON_PROFILE_PICTURE_SELECT_BUTTON" />

		<if>
			<equals arg1="${uploadTempFile}" arg2="true" />
			<then>
				<execute function="SikuliUploadTempFile" locator1="OS#FILE_DIALOG_BOX_FILE_NAME_FIELD_PNG" value1="${profilePictureFileName}" />
			</then>
			<else>
				<execute function="SikuliUploadCommonFile" locator1="OS#FILE_DIALOG_BOX_FILE_NAME_FIELD_PNG" value1="${profilePictureFileName}" />
			</else>
		</if>
