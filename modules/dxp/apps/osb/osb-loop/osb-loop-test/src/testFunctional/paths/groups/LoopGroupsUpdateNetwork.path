	<td>ADD_GROUP_FIELD</td>
	<td>//input[contains(@placeholder,'Assign')]</td>
	<td></td>
</tr>
<tr>
	<td>GROUP_NAME</td>
	<td>//span[contains(@class,'loop-icon-label') and contains(.,'${key_groupName}')]</td>
	<td></td>
</tr>
<tr>
	<td>GROUP_REMOVE_ICON</td>
	<td>//div[contains(@class,'input-list') and contains(.,'${key_groupName}')]//*[local-name()='svg' and contains(@class,'remove')]</td>
	<td></td>
</tr>
<tr>
	<td>SAVE_BUTTON</td>
	<td>//button[contains(.,'Save')]</td>
	<td></td>
</tr>
<tr>
	<td>CANCEL_BUTTON</td>
