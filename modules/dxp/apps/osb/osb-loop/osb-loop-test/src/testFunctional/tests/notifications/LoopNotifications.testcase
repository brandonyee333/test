<definition component-name="loop-notifications">
	<property name="loop.enabled" value="true" />
	<!--<property name="hook.plugins.includes" value="portal-compat-hook" />-->
	<property name="osgi.module.configuration.file.names" value="com.liferay.portal.security.auto.login.basic.auth.header.module.configuration.BasicAuthHeaderAutoLoginConfiguration.cfg:com.liferay.portal.bundle.blacklist.internal.BundleBlacklistConfiguration.cfg" />
	<property name="osgi.module.configurations" value="enabled=true:blacklistBundleSymbolicNames=['com.liferay.portal.search.elasticsearch', 'com.liferay.portal.search.elasticsearch.shield', 'com.liferay.portal.search.elasticsearch.marvel.web']" />
	<!--<property name="portlet.plugins.includes" value="asset-entry-set-portlet,asset-feed-portlet,asset-sharing-portlet,loop-portlet" />-->
	<property name="skip.clean-app-server-deploy-dir" value="true" />
	<property name="testray.main.component.name" value="Loop" />
	<property name="test.smtp.server.enabled" value="true" />

	<!--<property name="theme.plugins.includes" value="loop-theme" />
	<property name="web.plugins.includes" value="url-metadata-scraper-web" />-->

	<var name="userEmailAddress" value="loopuser01@liferay.com" />
	<var name="userFirstName" value="Loop01" />
	<var name="userLastName" value="User01" />
	<var name="userName" value="Loop01 User01" />
	<var name="userScreenName" value="loopuser01" />

	<var name="userGmailAddress" value="liferay.qa.loop1@gmail.com" />

	<set-up>
		<execute macro="Loop#firstSetupPG">
			<var name="roleNames" value="Loop Admin,Loop Global Announcer" />
		</execute>
	</set-up>

	<command name="DeleteDepartmentPagesAndViewNotification" priority="5">
		<property name="portlet.properties.loop-portlet" value="loop.topic.feedback.name=loopfeedback${line.separator}loop.tests.enabled=true${line.separator}loop.email.addresses.admin=liferay.qa.loop2@gmail.com${line.separator}loop.email.notification.from.address=liferay.qa.loop1@gmail.com${line.separator}loop.email.notification.from.name=Joe Bloggs" />

		<var name="departmentDescription" value="Department Description" />
		<var name="departmentName" value="Department Name" />
		<var name="pageText1" value="Page Text1" />
		<var name="pageText2" value="Page Text2" />
		<var name="pageTitle1" value="Page Title1" />
		<var name="pageTitle2" value="Page Title2" />
		<var name="topicName" value="loopfeedback" />
		<var name="userEmailAddress2" value="loopuser02@liferay.com" />
		<var name="userEmailAddress3" value="loopuser03@liferay.com" />
		<var name="userFirstName2" value="Loop02" />
		<var name="userFirstName3" value="Loop03" />
		<var name="userLastName2" value="User02" />
		<var name="userLastName3" value="User03" />
		<var name="userName2" value="Loop02 User02" />
		<var name="userName3" value="Loop03 User03" />
		<var name="userScreenName2" value="loopuser02" />
		<var name="userScreenName3" value="loopuser03" />

		<execute macro="LoopJson#addPeople">
			<var name="personNumberList" value="02,03" />
		</execute>

		<execute macro="LoopJson#createGroup">
			<var name="groupDescription" value="${departmentDescription}" />
			<var name="groupName" value="${departmentName}" />
			<var name="groupType" value="Department" />
			<var name="leadScreenNameList" value="${userScreenName}" />
			<var name="memberScreenNameList" value="${userScreenName2},${userScreenName3}" />
		</execute>

		<execute macro="Loop#logoutAndLogin">
			<var name="userLoginEmailAddress" value="${userEmailAddress2}" />
		</execute>

		<execute macro="LoopGroups#gotoGroupProfile">
			<var name="groupName" value="${departmentName}" />
			<var name="groupType" value="Department" />
		</execute>

		<execute macro="LoopGroupsGroup#gotoPagesSection" />

		<execute macro="LoopGroups#addPage">
			<var name="pageCreatorName" value="${userName2}" />
			<var name="pageText" value="${pageText1}" />
			<var name="pageTitle" value="${pageTitle1}" />
		</execute>

		<execute macro="LoopGroups#addPage">
			<var name="pageCreatorName" value="${userName2}" />
			<var name="pageText" value="${pageText2}" />
			<var name="pageTitle" value="${pageTitle2}" />
		</execute>

		<execute macro="LoopGroups#deletePage">
			<var name="pageTitle" value="${pageTitle2}" />
		</execute>

		<execute macro="MockMock#gotoMail" />

		<execute macro="MockMock#viewAndClickMail">
			<var name="mockMockAsset" value="[Loop Portlet] Loop Page Activiy Log" />
			<var name="mockMockRecipient" value="liferay.qa.loop2" />
			<var name="mockMockSender" value="Joe Bloggs &lt;${userGmailAddress}&gt;" />
		</execute>

		<execute macro="MockMock#viewMailMessage">
			<var name="mockMockAsset" value="${pageTitle2}" />
		</execute>

		<execute macro="MockMock#viewMailMessage">
			<var name="mockMockAsset" value="${pageText2}" />
		</execute>

		<execute macro="MockMock#viewMailMessage">
			<var name="mockMockAsset" value="&quot;action&quot;:&quot;delete&quot;" />
		</execute>

		<execute macro="MockMock#backtoInbox" />

		<execute macro="MockMock#deleteAllMail" />

		<execute macro="Loop#logoutAndLogin">
			<var name="userLoginEmailAddress" value="${userEmailAddress3}" />
		</execute>

		<execute macro="LoopGroups#gotoGroupProfile">
			<var name="groupName" value="${departmentName}" />
			<var name="groupType" value="Department" />
		</execute>

		<execute macro="LoopGroupsGroup#gotoPagesSection" />

		<execute macro="LoopGroups#deletePage">
			<var name="pageTitle" value="${pageTitle1}" />
		</execute>

		<execute macro="MockMock#gotoMail" />

		<execute macro="MockMock#viewAndClickMail">
			<var name="mockMockAsset" value="[Loop Portlet] Loop Page Activiy Log" />
			<var name="mockMockRecipient" value="liferay.qa.loop2" />
			<var name="mockMockSender" value="Joe Bloggs &lt;${userGmailAddress}&gt;" />
		</execute>

		<execute macro="MockMock#viewMailMessage">
			<var name="mockMockAsset" value="${pageTitle1}" />
		</execute>

		<execute macro="MockMock#viewMailMessage">
			<var name="mockMockAsset" value="${pageText1}" />
		</execute>

		<execute macro="MockMock#viewMailMessage">
			<var name="mockMockAsset" value="&quot;action&quot;:&quot;delete&quot;" />
		</execute>

		<execute macro="MockMock#backtoInbox" />

		<execute macro="MockMock#deleteAllMail" />
	</command>

	<command name="EditAnnouncementAndViewEmailNotification" priority="5">
		<property name="portlet.properties.loop-portlet" value="loop.topic.feedback.name=loopfeedback${line.separator}loop.email.notification.from.address=liferay.qa.loop1@gmail.com${line.separator}loop.email.notification.from.name=Joe Bloggs" />

		<var name="feedEntryStickyTimeInDays" value="2" />
		<var name="feedEntryText" value="Feed Entry Text" />
		<var name="feedEntryTextEdit" value="Edit" />
		<var name="feedEntryTitle1" value="Feed Entry1 Title" />
		<var name="feedEntryTitle2" value="Feed Entry2 Title" />
		<var name="teamDescription" value="Team Description" />
		<var name="teamName" value="Team Name" />
		<var name="topicName" value="loopfeedback" />
		<var name="userEmailAddress2" value="loopuser02@liferay.com" />
		<var name="userFirstName2" value="Loop02" />
		<var name="userLastName2" value="User02" />
		<var name="userName2" value="Loop02 User02" />
		<var name="userScreenName2" value="loopuser02" />

		<execute macro="LoopJson#addPerson">
			<var name="userEmailAddress" value="${userEmailAddress2}" />
			<var name="userFirstName" value="${userFirstName2}" />
			<var name="userLastName" value="${userLastName2}" />
			<var name="userScreenName" value="${userScreenName2}" />
		</execute>

		<execute macro="LoopJson#createGroup">
			<var name="groupDescription" value="${teamDescription}" />
			<var name="groupName" value="${teamName}" />
			<var name="groupType" value="Team" />
			<var name="leadScreenNameList" value="${userScreenName}" />
			<var name="memberScreenNameList" value="${userScreenName2}" />
		</execute>

		<execute macro="LoopFeed#addAnnouncementEntry">
			<var name="feedEntryAuthorName" value="${teamName}" />
			<var name="feedEntryContent" value="${feedEntryText}" />
			<var name="feedEntryStickyTimeInDays" value="${feedEntryStickyTimeInDays}" />
			<var name="feedEntryText" value="${feedEntryText}" />
			<var name="feedEntryTitle" value="${feedEntryTitle1}" />
			<var name="sendEmailNotification" value="false" />
		</execute>

		<execute macro="MockMock#gotoMail" />

		<execute macro="MockMock#viewNoMailCount" />

		<execute macro="Loop#openURL" />

		<execute macro="LoopFeedEntry#gotoAnnouncementsTab" />

		<execute macro="LoopFeedAnnouncements#editAnnouncementEntry">
			<var name="feedEntryAuthorName" value="${teamName}" />
			<var name="feedEntryContent" value="${feedEntryText}" />
			<var name="feedEntryContentEdit" value="${feedEntryText} ${feedEntryTextEdit}" />
			<var name="feedEntryText" value="${feedEntryText}" />
			<var name="feedEntryTextEdit" value="${feedEntryTextEdit}" />
			<var name="feedEntryTitle" value="${feedEntryTitle2}" />
			<var name="sendEmailNotification" value="true" />
		</execute>

		<execute macro="MockMock#gotoMail" />

		<execute macro="MockMock#viewAndClickMail">
			<var name="mockMockAsset" value="${feedEntryTitle2}" />
			<var name="mockMockRecipient" value="${userName2}" />
			<var name="mockMockSender" value="&quot;${teamName} (LOOP)&quot; &lt;${userGmailAddress}&gt;" />
		</execute>

		<execute macro="LoopGmail#viewMailDetails">
			<var name="notificationAction" value="${teamName} shared an announcement with you." />
			<var name="notificationDetails" value="${feedEntryText} ${feedEntryTextEdit}" />
			<var name="topicName" value="${topicName}" />
			<var name="userName" value="${teamName}" />
			<var name="userScreenName" value="Team+Name" />
		</execute>

		<execute macro="MockMock#backtoInbox" />

		<execute macro="MockMock#deleteAllMail" />
	</command>

	<command name="EditAnnouncementAndViewEmailNotificationForNewUserMention" priority="5">
		<property name="portlet.properties.loop-portlet" value="loop.topic.feedback.name=loopfeedback${line.separator}loop.email.notification.from.address=liferay.qa.loop1@gmail.com${line.separator}loop.email.notification.from.name=Joe Bloggs" />

		<var name="feedEntryStickyTimeInDays" value="2" />
		<var name="feedEntryText" value="Feed Entry Text" />
		<var name="feedEntryTextEdit" value="Edit" />
		<var name="feedEntryTitle1" value="Feed Entry1 Title" />
		<var name="feedEntryTitle2" value="Feed Entry2 Title" />
		<var name="teamDescription" value="Team Description" />
		<var name="teamName" value="Team Name" />
		<var name="topicName" value="loopfeedback" />
		<var name="userEmailAddress2" value="loopuser02@liferay.com" />
		<var name="userEmailAddress3" value="loopuser03@liferay.com" />
		<var name="userFirstName2" value="Loop02" />
		<var name="userFirstName3" value="Loop03" />
		<var name="userLastName2" value="User02" />
		<var name="userLastName3" value="User03" />
		<var name="userName2" value="Loop02 User02" />
		<var name="userName3" value="Loop03 User03" />
		<var name="userScreenName2" value="loopuser02" />
		<var name="userScreenName3" value="loopuser03" />

		<execute macro="LoopJson#addPerson">
			<var name="userEmailAddress" value="${userEmailAddress2}" />
			<var name="userFirstName" value="${userFirstName2}" />
			<var name="userLastName" value="${userLastName2}" />
			<var name="userScreenName" value="${userScreenName2}" />
		</execute>

		<execute macro="LoopJson#addPerson">
			<var name="userEmailAddress" value="${userEmailAddress3}" />
			<var name="userFirstName" value="${userFirstName3}" />
			<var name="userLastName" value="${userLastName3}" />
			<var name="userScreenName" value="${userScreenName3}" />
		</execute>

		<execute macro="LoopJson#createGroup">
			<var name="groupDescription" value="${teamDescription}" />
			<var name="groupName" value="${teamName}" />
			<var name="groupType" value="Team" />
			<var name="leadScreenNameList" value="${userScreenName}" />
			<var name="memberScreenNameList" value="${userScreenName2}" />
		</execute>

		<execute macro="LoopFeed#addAnnouncementEntry">
			<var name="feedEntryAuthorName" value="${teamName}" />
			<var name="feedEntryContent" value="${feedEntryText}" />
			<var name="feedEntryStickyTimeInDays" value="${feedEntryStickyTimeInDays}" />
			<var name="feedEntryText" value="${feedEntryText}" />
			<var name="feedEntryTitle" value="${feedEntryTitle1}" />
			<var name="sendEmailNotification" value="true" />
		</execute>

		<execute macro="MockMock#gotoMail" />

		<execute macro="MockMock#viewAndClickMail">
			<var name="mockMockAsset" value="${feedEntryTitle1}" />
			<var name="mockMockRecipient" value="${userName2}" />
			<var name="mockMockSender" value="&quot;${teamName} (LOOP)&quot; &lt;${userGmailAddress}&gt;" />
		</execute>

		<execute macro="LoopGmail#viewMailDetails">
			<var name="notificationAction" value="${teamName} shared an announcement with you." />
			<var name="notificationDetails" value="${feedEntryText}" />
			<var name="topicName" value="${topicName}" />
			<var name="userName" value="${teamName}" />
			<var name="userScreenName" value="Team+Name" />
		</execute>

		<execute macro="MockMock#backtoInbox" />

		<execute macro="MockMock#deleteAllMail" />

		<execute macro="Loop#openURL" />

		<execute macro="LoopFeedEntry#gotoAnnouncementsTab" />

		<execute macro="LoopFeedAnnouncements#editAnnouncementEntry">
			<var name="feedEntryAuthorName" value="${teamName}" />
			<var name="feedEntryContent" value="${feedEntryText}" />
			<var name="feedEntryContentEdit" value="${feedEntryText} ${feedEntryTextEdit} ${userName3}" />
			<var name="feedEntryText" value="${feedEntryText}" />
			<var name="feedEntryTextEdit" value="${feedEntryTextEdit}" />
			<var name="feedEntryTitle" value="${feedEntryTitle2}" />
			<var name="mentionUserNameList" value="${userName3}" />
			<var name="sendEmailNotification" value="false" />
		</execute>

		<execute macro="MockMock#gotoMail" />

		<execute macro="MockMock#viewNoMailFromInbox">
			<var name="mockMockAsset" value="${feedEntryTitle2}" />
			<var name="mockMockRecipient" value="${userName2}" />
		</execute>

		<execute macro="MockMock#viewAndClickMail">
			<var name="mockMockAsset" value="${feedEntryTitle2}" />
			<var name="mockMockRecipient" value="${userName3}" />
			<var name="mockMockSender" value="&quot;${teamName} (LOOP)&quot; &lt;${userGmailAddress}&gt;" />
		</execute>

		<execute macro="LoopGmail#viewMailDetails">
			<var name="notificationAction" value="${teamName} shared an announcement with you." />
			<var name="notificationDetails" value="${feedEntryText} ${feedEntryTextEdit} ${userName3}" />
			<var name="topicName" value="${topicName}" />
			<var name="userName" value="${teamName}" />
			<var name="userScreenName" value="Team+Name" />
		</execute>

		<execute macro="MockMock#backtoInbox" />

		<execute macro="MockMock#deleteAllMail" />
	</command>

	<command name="EditAnnouncementAndViewNotificationForNewUserMention" priority="5">
		<var name="feedEntryStickyTimeInDays" value="2" />
		<var name="feedEntryText" value="Feed Entry Text" />
		<var name="feedEntryTextEdit" value="Edit" />
		<var name="feedEntryTitle1" value="Feed Entry1 Title" />
		<var name="feedEntryTitle2" value="Feed Entry2 Title" />
		<var name="teamDescription" value="Team Description" />
		<var name="teamName" value="Team Name" />
		<var name="topicName" value="loopfeedback" />
		<var name="userEmailAddress2" value="loopuser02@liferay.com" />
		<var name="userEmailAddress3" value="loopuser03@liferay.com" />
		<var name="userFirstName2" value="Loop02" />
		<var name="userFirstName3" value="Loop03" />
		<var name="userLastName2" value="User02" />
		<var name="userLastName3" value="User03" />
		<var name="userName2" value="Loop02 User02" />
		<var name="userName3" value="Loop03 User03" />
		<var name="userScreenName2" value="loopuser02" />
		<var name="userScreenName3" value="loopuser03" />

		<execute macro="LoopJson#addPeople">
			<var name="personNumberList" value="02,03" />
		</execute>

		<execute macro="LoopJson#createGroup">
			<var name="groupDescription" value="${teamDescription}" />
			<var name="groupName" value="${teamName}" />
			<var name="groupType" value="Team" />
			<var name="leadScreenNameList" value="${userScreenName}" />
			<var name="memberScreenNameList" value="${userScreenName2}" />
		</execute>

		<execute macro="LoopFeed#addAnnouncementEntry">
			<var name="feedEntryAuthorName" value="${teamName}" />
			<var name="feedEntryContent" value="${feedEntryText}" />
			<var name="feedEntryStickyTimeInDays" value="${feedEntryStickyTimeInDays}" />
			<var name="feedEntryText" value="${feedEntryText}" />
			<var name="feedEntryTitle" value="${feedEntryTitle1}" />
			<var name="sendEmailNotification" value="false" />
		</execute>

		<execute macro="Loop#logoutAndLogin">
			<var name="userLoginEmailAddress" value="${userEmailAddress2}" />
		</execute>

		<execute macro="LoopNotifications#viewNotification">
			<var name="notificationAction" value="${teamName} created a new announcement." />
			<var name="notificationCount" value="1" />
			<var name="notificationDetails" value="${feedEntryTitle}" />
			<var name="userName" value="${teamName}" />
		</execute>

		<execute macro="Loop#logoutAndLogin">
			<var name="userLoginEmailAddress" value="${userEmailAddress}" />
		</execute>

		<execute macro="Loop#openURL" />

		<execute macro="LoopFeedEntry#gotoAnnouncementsTab" />

		<execute macro="LoopFeedAnnouncements#editAnnouncementEntry">
			<var name="feedEntryAuthorName" value="${teamName}" />
			<var name="feedEntryContent" value="${feedEntryText}" />
			<var name="feedEntryContentEdit" value="${feedEntryText} ${feedEntryTextEdit} ${userName3}" />
			<var name="feedEntryText" value="${feedEntryText}" />
			<var name="feedEntryTextEdit" value="${feedEntryTextEdit}" />
			<var name="feedEntryTitle" value="${feedEntryTitle2}" />
			<var name="mentionUserNameList" value="${userName3}" />
			<var name="sendEmailNotification" value="false" />
		</execute>

		<execute macro="Loop#logoutAndLogin">
			<var name="userLoginEmailAddress" value="${userEmailAddress2}" />
		</execute>

		<execute macro="LoopNotifications#viewNoNotificationCount" />

		<execute macro="LoopNotifications#viewNotification">
			<var name="notificationAction" value="${teamName} created a new announcement." />
			<var name="notificationDetails" value="${feedEntryText2}" />
			<var name="userName" value="${teamName}" />
		</execute>

		<execute macro="Loop#logoutAndLogin">
			<var name="userLoginEmailAddress" value="${userEmailAddress3}" />
		</execute>

		<execute macro="LoopNotifications#viewNotification">
			<var name="notificationAction" value="${teamName} shared an announcement with you." />
			<var name="notificationCount" value="1" />
			<var name="notificationDetails" value="${feedEntryTitle2}" />
			<var name="userName" value="${teamName}" />
		</execute>
	</command>

	<command name="EditDepartmentPagesAndViewNotification" priority="5">
		<property name="portlet.properties.loop-portlet" value="loop.topic.feedback.name=loopfeedback${line.separator}loop.tests.enabled=true${line.separator}loop.email.addresses.admin=liferay.qa.loop2@gmail.com${line.separator}loop.email.notification.from.address=liferay.qa.loop1@gmail.com${line.separator}loop.email.notification.from.name=Joe Bloggs" />

		<var name="departmentDescription" value="Department Description" />
		<var name="departmentName" value="Department Name" />
		<var name="pageText1" value="Page Text1" />
		<var name="pageText2" value="Page Text2" />
		<var name="pageTitle1" value="Page Title1" />
		<var name="pageTitle2" value="Page Title2" />
		<var name="topicName" value="loopfeedback" />
		<var name="userEmailAddress2" value="loopuser02@liferay.com" />
		<var name="userEmailAddress3" value="loopuser03@liferay.com" />
		<var name="userFirstName2" value="Loop02" />
		<var name="userFirstName3" value="Loop03" />
		<var name="userLastName2" value="User02" />
		<var name="userLastName3" value="User03" />
		<var name="userName2" value="Loop02 User02" />
		<var name="userName3" value="Loop03 User03" />
		<var name="userScreenName2" value="loopuser02" />
		<var name="userScreenName3" value="loopuser03" />

		<execute macro="LoopJson#addPeople">
			<var name="personNumberList" value="02,03" />
		</execute>

		<execute macro="LoopJson#createGroup">
			<var name="groupDescription" value="${departmentDescription}" />
			<var name="groupName" value="${departmentName}" />
			<var name="groupType" value="Department" />
			<var name="leadScreenNameList" value="${userScreenName}" />
			<var name="memberScreenNameList" value="${userScreenName2},${userScreenName3}" />
		</execute>

		<execute macro="Loop#logoutAndLogin">
			<var name="userLoginEmailAddress" value="${userEmailAddress2}" />
		</execute>

		<execute macro="LoopGroups#gotoGroupProfile">
			<var name="groupName" value="${departmentName}" />
			<var name="groupType" value="Department" />
		</execute>

		<execute macro="LoopGroupsGroup#gotoPagesSection" />

		<execute macro="LoopGroups#addPage">
			<var name="pageCreatorName" value="${userName2}" />
			<var name="pageText" value="${pageText1}" />
			<var name="pageTitle" value="${pageTitle1}" />
		</execute>

		<execute macro="LoopGroups#addPage">
			<var name="pageCreatorName" value="${userName2}" />
			<var name="pageText" value="${pageText2}" />
			<var name="pageTitle" value="${pageTitle2}" />
		</execute>

		<execute macro="LoopGroups#editPage">
			<var name="pageCreatorName" value="${userName2}" />
			<var name="pageText" value="${pageText2}" />
			<var name="pageTextEdit" value="Edit" />
			<var name="pageTitle" value="${pageTitle2}" />
			<var name="pageTitleEdit" value="Edit" />
		</execute>

		<execute macro="MockMock#gotoMail" />

		<execute macro="MockMock#viewAndClickMail">
			<var name="mockMockAsset" value="[Loop Portlet] Loop Page Activiy Log" />
			<var name="mockMockRecipient" value="liferay.qa.loop2" />
			<var name="mockMockSender" value="Joe Bloggs &lt;${userGmailAddress}&gt;" />
		</execute>

		<execute macro="MockMock#viewMailMessage">
			<var name="mockMockAsset" value="${pageTitle2} Edit" />
		</execute>

		<execute macro="MockMock#viewMailMessage">
			<var name="mockMockAsset" value="${pageText2} Edit" />
		</execute>

		<execute macro="MockMock#viewMailMessage">
			<var name="mockMockAsset" value="&quot;action&quot;:&quot;update&quot;" />
		</execute>

		<execute macro="MockMock#backtoInbox" />

		<execute macro="MockMock#deleteAllMail" />

		<execute macro="MockMock#viewNoMailCount" />

		<execute macro="Loop#logoutAndLogin">
