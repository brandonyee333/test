		<execute macro="LoopFeedEntry#clickAddCommentLink">
			<var name="feedEntryContent" value="${feedEntryText2}" />
		</execute>

		<execute macro="LoopFeedEntryComment#clickAndTypeText">
			<var name="feedEntryCommentText" value="${feedEntryCommentText2}" />
			<var name="feedEntryContent" value="${feedEntryText2}" />
		</execute>

		<execute macro="LoopFeedEntryComment#post">
			<var name="feedEntryContent" value="${feedEntryText2}" />
		</execute>

		<execute macro="Loop#logoutAndLogin">
			<var name="userLoginEmailAddress" value="${userEmailAddress}" />
		</execute>

		<execute macro="LoopNotifications#clickNotificationIcon">
			<var name="notificationCount" value="1" />
		</execute>

		<execute macro="LoopNavigation#assertNoAlert" />
	</command>
</definition>