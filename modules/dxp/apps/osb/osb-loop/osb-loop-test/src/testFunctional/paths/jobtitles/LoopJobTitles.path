</thead>
<tbody>
<tr>
	<td>SUCCESS_MESSAGE</td>
	<td>//div[contains(@class,'alert-container')]</td>
	<td></td>
</tr>
<tr>
	<td>JOB_TITLE_LIST</td>
	<td>//div[contains(@class,'entity-index')]</td>
	<td></td>
</tr>
<tr>
	<td>CREATE_JOB_TITLE_LINK</td>
	<td>//a[contains(.,'Create Job Title')]</td>
