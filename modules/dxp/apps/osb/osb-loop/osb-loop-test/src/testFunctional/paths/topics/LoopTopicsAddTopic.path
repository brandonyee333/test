<table cellpadding="1" cellspacing="1" border="1">
<thead>
<tr><td rowspan="1" colspan="3">LoopTopicsAddTopic</td></tr>
</thead>
<tbody>
<tr>
	<td>SUCCESS_MESSAGE</td>
	<td>//div[contains(@class,'alert-container')]</td>
	<td></td>
</tr>
<tr>
	<td>ERROR_MESSAGE</td>
	<td>//div[contains(@class,'error-message')]</td>
	<td></td>
</tr>
<tr>
	<td>NAME_FIELD</td>
	<td>//input[contains(@name,'name')]</td>
	<td></td>
</tr>
<tr>
	<td>DESCRIPTION_FIELD</td>
	<td>//textarea[contains(@placeholder,'Give more info about this topic')]</td>
	<td></td>
</tr>
<tr>
	<td>CREATE_BUTTON</td>
	<td>//button[contains(.,'Create')]</td>
	<td></td>
</tr>
<tr>
	<td>CANCEL_BUTTON</td>
	<td>//button[contains(.,'Cancel')]</td>
	<td></td>
</tr>
</tbody>
</table>
