			<var name="feedEntryCommentContent" value="${feedEntryCommentText4}" />
			<var name="feedEntryContent" value="${feedEntryText2}" />
		</execute>

		<execute macro="LoopNavigation#gotoMyProfile" />

		<execute macro="LoopFeedEntryComment#viewAuthorAndContent">
