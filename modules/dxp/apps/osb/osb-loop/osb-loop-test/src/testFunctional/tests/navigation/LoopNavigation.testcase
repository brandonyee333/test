<definition component-name="loop-navigation">
	<property name="loop.enabled" value="true" />
	<!--<property name="hook.plugins.includes" value="portal-compat-hook" />-->
	<property name="osgi.module.configuration.file.names" value="com.liferay.portal.security.auto.login.basic.auth.header.module.configuration.BasicAuthHeaderAutoLoginConfiguration.cfg:com.liferay.portal.bundle.blacklist.internal.BundleBlacklistConfiguration.cfg" />
	<property name="osgi.module.configurations" value="enabled=true:blacklistBundleSymbolicNames=['com.liferay.portal.search.elasticsearch', 'com.liferay.portal.search.elasticsearch.shield', 'com.liferay.portal.search.elasticsearch.marvel.web']" />
	<!--<property name="portlet.plugins.includes" value="asset-entry-set-portlet,asset-feed-portlet,asset-sharing-portlet,loop-portlet" />-->
	<property name="skip.clean-app-server-deploy-dir" value="true" />
	<property name="testray.main.component.name" value="Loop" />
	<!--<property name="theme.plugins.includes" value="loop-theme" />
	<property name="web.plugins.includes" value="url-metadata-scraper-web" />-->

	<var name="userEmailAddress" value="loopuser01@liferay.com" />
	<var name="userFirstName" value="Loop01" />
	<var name="userLastName" value="User01" />
	<var name="userName" value="Loop01 User01" />
	<var name="userScreenName" value="loopuser01" />

	<set-up>
		<execute macro="Loop#firstSetupPG">
			<var name="roleNames" value="Loop Admin,Loop Global Announcer" />
		</execute>
	</set-up>

	<command name="ViewAdminPage" priority="5">
		<var name="userEmailAddress2" value="loopuser02@liferay.com" />
		<var name="userFirstName2" value="Loop02" />
		<var name="userLastName2" value="User02" />
		<var name="userName2" value="Loop02 User02" />
		<var name="userScreenName2" value="loopuser02" />

		<execute macro="LoopJson#addPerson">
			<var name="userEmailAddress" value="${userEmailAddress2}" />
			<var name="userFirstName" value="${userFirstName2}" />
			<var name="userLastName" value="${userLastName2}" />
			<var name="userScreenName" value="${userScreenName2}" />
		</execute>

		<execute macro="Loop#openURL" />

		<execute macro="LoopNavigation#gotoAdminPage" />

		<execute macro="LoopAdmin#viewAdminPage" />

		<execute macro="Loop#logoutAndLogin">
			<var name="userLoginEmailAddress" value="${userEmailAddress2}" />
		</execute>

		<execute macro="Loop#openURL" />

		<execute macro="LoopNavigation#viewNoAdminPage" />
	</command>

	<command name="ViewHelpPage" priority="5">
		<execute macro="Loop#openURL" />

		<execute macro="LoopNavigation#gotoHelp" />

		<execute macro="LoopHelp#viewHelpPage" />
	</command>

	<command name="ViewHotkeys" priority="5">
		<var name="teamDescription" value="Team Description" />
		<var name="teamName" value="Team Name" />
		<var name="topicDescription" value="Topic Description" />
		<var name="topicName" value="TopicName" />

		<execute macro="LoopJson#createTopic">
			<var name="topicDescription" value="${topicDescription}" />
			<var name="topicName" value="${topicName}" />
		</execute>

		<execute macro="LoopJson#createGroup">
			<var name="groupDescription" value="${teamDescription}" />
			<var name="groupName" value="${teamName}" />
			<var name="groupType" value="Team" />
		</execute>

		<execute macro="Loop#openURL" />

		<execute macro="LoopNavigation#gotoSearchViaHotkeys" />

		<execute macro="LoopSearch#typeKeyword">
			<var name="keyword" value="${userName}" />
		</execute>

		<execute macro="LoopSearch#viewPerson">
			<var name="userName" value="${userName}" />
		</execute>

		<execute macro="LoopSearch#gotoPerson">
			<var name="userName" value="${userName}" />
		</execute>

		<execute macro="LoopPeoplePerson#viewPersonProfile">
			<var name="userEmailAddress" value="${userEmailAddress}" />
			<var name="userName" value="${userName}" />
		</execute>

		<execute macro="LoopNavigation#gotoKeyboardShortcutsViaHotkeys" />

		<execute macro="LoopKeyboardShortcuts#viewKeyboardShortcuts" />

		<!-- Workaround until KeyPress works for ESCAPE -->

		<!--<execute macro="LoopNavigation#closeMenuViaHotkeys" />-->

		<execute macro="LoopFeed#clickModalCloseButton" />

		<execute macro="LoopKeyboardShortcuts#viewNoKeyboardShortcuts" />

		<execute macro="LoopNavigation#gotoKeyboardShortcuts" />

		<execute macro="LoopKeyboardShortcuts#viewKeyboardShortcuts" />

		<execute macro="LoopFeed#clickModalCloseButton" />

		<execute macro="LoopNavigation#toggleNotificationsViaHotkeys" />

		<execute macro="LoopNotifications#viewNotificationSettingsLink" />

		<execute macro="LoopNavigation#toggleNotificationsViaHotkeys" />

		<execute macro="LoopNavigation#gotoGroupsViaHotkeys" />

		<execute macro="LoopGroups#gotoGroupTab">
			<var name="groupType" value="Team" />
		</execute>

		<execute macro="LoopGroupsGroup#viewGroupViaGroupsList">
			<var name="groupName" value="${teamName}" />
			<var name="groupType" value="Team" />
		</execute>

		<execute macro="LoopNavigation#gotoTopicsViaHotkeys" />

		<execute macro="LoopTopicsTopic#viewTopicViaTopicsList">
			<var name="topicName" value="${topicName}" />
		</execute>

		<execute macro="LoopNavigation#gotoPeopleViaHotkeys" />

		<execute macro="LoopPeoplePerson#viewPersonViaPeopleList">
			<var name="userName" value="${userName}" />
		</execute>

		<execute macro="LoopNavigation#gotoProfileViaHotkeys" />

		<execute macro="LoopPeoplePerson#clickEditButton" />

		<execute macro="LoopNavigation#gotoHomeViaHotkeys" />

		<execute macro="LoopNavigation#gotoNewPostViaHotkeys" />

		<execute macro="LoopFeedEntry#viewExpandedCreator" />
	</command>

	<command name="ViewToolbarAvatars" priority="5">
		<var name="imageFileName1" value="/Document_2.png" />
		<var name="imageFileName2" value="/Document_3.jpg" />
		<var name="imageFileName3" value="/Document_3.png" />
		<var name="imageFileName4" value="/Document_4.jpg" />

		<execute macro="LoopNavigation#viewToolbarAvatarDefault" />

		<execute macro="LoopNavigation#gotoMyProfile" />

		<execute macro="LoopPeoplePerson#addProfilePicture">
			<var name="profilePictureFileName" value="${imageFileName1}" />
		</execute>

		<execute macro="LoopNavigation#viewToolbarAvatar1" />

		<execute macro="Loop#openURL" />

		<execute macro="LoopNavigation#viewToolbarAvatar1" />

		<execute macro="LoopNavigation#gotoMyProfile" />

		<execute macro="LoopPeoplePerson#addProfilePicture">
			<var name="profilePictureFileName" value="${imageFileName2}" />
		</execute>

		<execute macro="LoopNavigation#viewToolbarAvatar2" />

		<execute macro="Loop#openURL" />

		<execute macro="LoopNavigation#viewToolbarAvatar2" />

		<execute macro="LoopNavigation#gotoMyProfile" />

		<execute macro="LoopPeoplePerson#addProfilePicture">
			<var name="profilePictureFileName" value="${imageFileName3}" />
		</execute>

		<execute macro="LoopNavigation#viewToolbarAvatar3" />

		<execute macro="Loop#openURL" />

		<execute macro="LoopNavigation#viewToolbarAvatar3" />

		<execute macro="LoopNavigation#gotoMyProfile" />

		<execute macro="LoopPeoplePerson#addProfilePicture">
			<var name="profilePictureFileName" value="${imageFileName4}" />
		</execute>

		<execute macro="LoopNavigation#viewToolbarAvatar4" />

		<execute macro="Loop#openURL" />

		<execute macro="LoopNavigation#viewToolbarAvatar4" />
	</command>

