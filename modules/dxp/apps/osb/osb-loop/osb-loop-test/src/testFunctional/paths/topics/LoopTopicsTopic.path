</tr>
<tr>
	<td>TOPIC_COVER_PICTURE_CONFIRM_BUTTON</td>
	<td>//div[contains(@class,'profile-container')]//div[contains(@class,'profile-header')]/span[@class='controls']//*[local-name()='svg' and contains(@class,'success')]</td>
