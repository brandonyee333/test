			<var name="shareWithGroupNameList" value="${departmentName1}" />
		</execute>

		<execute macro="Loop#logoutAndLogin">
			<var name="userLoginEmailAddress" value="${userEmailAddress2}" />
		</execute>

		<execute macro="LoopFeed#addEntryComment">
			<var name="feedEntryCommentAuthorName" value="${userName2}" />
			<var name="feedEntryCommentContent" value="${feedEntryCommentText} ${departmentName2} ${departmentName3}" />
