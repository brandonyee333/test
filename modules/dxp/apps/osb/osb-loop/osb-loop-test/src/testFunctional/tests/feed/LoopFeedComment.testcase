		<var name="feedEntryText" value="Feed Entry Text" />
		<var name="userEmailAddress2" value="loopuser02@liferay.com" />
		<var name="userFirstName2" value="Loop02" />
		<var name="userLastName2" value="User02" />
		<var name="userName2" value="Loop02 User02" />
		<var name="userScreenName2" value="loopuser02" />

		<execute macro="LoopJson#addPerson">
			<var name="userEmailAddress" value="${userEmailAddress2}" />
			<var name="userFirstName" value="${userFirstName2}" />
			<var name="userLastName" value="${userLastName2}" />
			<var name="userScreenName" value="${userScreenName2}" />
		</execute>

		<execute macro="Loop#logoutAndLogin">
			<var name="userLoginEmailAddress" value="${userEmailAddress}" />
		</execute>

		<execute macro="LoopFeed#addEntry">
			<var name="feedEntryAuthorName" value="${userName}" />
			<var name="feedEntryContent" value="${feedEntryText}" />
			<var name="feedEntryText" value="${feedEntryText}" />
			<var name="shareWithUserNameList" value="${userName2}" />
		</execute>

		<execute macro="LoopFeed#addEntryComment">
			<var name="feedEntryCommentAuthorName" value="${userName}" />
			<var name="feedEntryCommentContent" value="${feedEntryCommentText}" />
			<var name="feedEntryCommentText" value="${feedEntryCommentText}" />
			<var name="feedEntryContent" value="${feedEntryText}" />
		</execute>

		<execute macro="Loop#logoutAndLogin">
			<var name="userLoginEmailAddress" value="${userEmailAddress2}" />
		</execute>

		<execute macro="LoopFeedEntryComment#clickAddReplyLink">
			<var name="feedEntryCommentContent" value="${feedEntryCommentText}" />
			<var name="feedEntryContent" value="${feedEntryText}" />
		</execute>

		<execute macro="LoopFeedEntryComment#clickAndTypeText">
			<var name="feedEntryCommentText" value="${feedEntryCommentReplyText}" />
			<var name="feedEntryContent" value="${feedEntryText}" />
		</execute>

		<execute macro="LoopFeedEntryComment#post">
			<var name="feedEntryContent" value="${feedEntryText}" />
		</execute>

		<execute macro="LoopFeedEntryCommentReply#viewAuthorAndPartialContent">
			<var name="feedEntryCommentContent" value="${feedEntryCommentText}" />
			<var name="feedEntryCommentReplyAuthorName" value="${userName2}" />
			<var name="feedEntryCommentReplyPartialContent" value="${feedEntryCommentReplyPartialContent1}" />
		</execute>

		<execute macro="Loop#logoutAndLogin">
			<var name="userLoginEmailAddress" value="${userEmailAddress}" />
		</execute>

		<execute macro="LoopFeedEntryComment#showCommentReplies">
			<var name="feedEntryCommentContent" value="${feedEntryCommentText}" />
			<var name="feedEntryContent" value="${feedEntryText}" />
		</execute>

		<execute macro="LoopFeedEntryCommentReply#viewAuthorAndPartialContent">
			<var name="feedEntryCommentContent" value="${feedEntryCommentText}" />
			<var name="feedEntryCommentReplyAuthorName" value="${userName2}" />
			<var name="feedEntryCommentReplyPartialContent" value="${feedEntryCommentReplyPartialContent1}" />
		</execute>

		<execute macro="LoopFeedEntryComment#clickSeeMoreLink">
			<var name="feedEntryCommentPartialContent" value="${feedEntryCommentReplyPartialContent1}" />
			<var name="feedEntryContent" value="${feedEntryText}" />
		</execute>

		<execute macro="LoopFeedEntryCommentReply#viewAuthorAndPartialContent">
			<var name="feedEntryCommentContent" value="${feedEntryCommentText}" />
			<var name="feedEntryCommentReplyAuthorName" value="${userName2}" />
			<var name="feedEntryCommentReplyPartialContent" value="${feedEntryCommentReplyPartialContent2}" />
		</execute>

		<execute macro="LoopFeedEntryComment#clickSeeFullPostLink">
			<var name="feedEntryCommentPartialContent" value="${feedEntryCommentReplyPartialContent2}" />
			<var name="feedEntryContent" value="${feedEntryText}" />
		</execute>

		<execute macro="LoopFeedEntryCommentReply#viewAuthorAndContent">
			<var name="feedEntryCommentContent" value="${feedEntryCommentText}" />
			<var name="feedEntryCommentReplyAuthorName" value="${userName2}" />
			<var name="feedEntryCommentReplyContent" value="${feedEntryCommentReplyText}" />
		</execute>

		<execute macro="LoopNavigation#gotoMyProfile" />

		<execute macro="LoopFeedEntryComment#showCommentReplies">
			<var name="feedEntryCommentContent" value="${feedEntryCommentText}" />
			<var name="feedEntryContent" value="${feedEntryText}" />
		</execute>

		<execute macro="LoopFeedEntryCommentReply#viewAuthorAndPartialContent">
			<var name="feedEntryCommentContent" value="${feedEntryCommentText}" />
			<var name="feedEntryCommentReplyAuthorName" value="${userName2}" />
			<var name="feedEntryCommentReplyPartialContent" value="${feedEntryCommentReplyPartialContent1}" />
		</execute>

		<execute macro="LoopFeedEntryComment#clickSeeMoreLink">
			<var name="feedEntryCommentPartialContent" value="${feedEntryCommentReplyPartialContent1}" />
			<var name="feedEntryContent" value="${feedEntryText}" />
		</execute>

		<execute macro="LoopFeedEntryCommentReply#viewAuthorAndPartialContent">
			<var name="feedEntryCommentContent" value="${feedEntryCommentText}" />
			<var name="feedEntryCommentReplyAuthorName" value="${userName2}" />
			<var name="feedEntryCommentReplyPartialContent" value="${feedEntryCommentReplyPartialContent2}" />
		</execute>

		<execute macro="LoopFeedEntryComment#clickSeeFullPostLink">
			<var name="feedEntryCommentPartialContent" value="${feedEntryCommentReplyPartialContent2}" />
			<var name="feedEntryContent" value="${feedEntryText}" />
		</execute>

		<execute macro="LoopFeedEntryCommentReply#viewAuthorAndContent">
			<var name="feedEntryCommentContent" value="${feedEntryCommentText}" />
			<var name="feedEntryCommentReplyAuthorName" value="${userName2}" />
			<var name="feedEntryCommentReplyContent" value="${feedEntryCommentReplyText}" />
		</execute>
	</command>

