		<var name="userLastName3" value="&lt;script&gt;alert(&quot;User03&quot;);&lt;/script&gt;" />
		<var name="userName2" value="&lt;script&gt;alert(&quot;Loop02&quot;);&lt;/script&gt; &lt;script&gt;alert(&quot;User02&quot;);&lt;/script&gt;" />
		<var name="userName3" value="&lt;script&gt;alert(&quot;Loop03&quot;);&lt;/script&gt; &lt;script&gt;alert(&quot;User03&quot;);&lt;/script&gt;" />
		<var name="userScreenName2" value="loopuser02" />
		<var name="userScreenName3" value="loopuser03" />

		<execute macro="LoopJobTitles#createJobTitle">
