			<var name="feedEntryContent" value="${feedEntryText}" />
			<var name="mentionPrivateGroupNameList" value="${departmentName2},${departmentName3}" />
		</execute>

		<execute macro="Loop#logoutAndLogin">
			<var name="userLoginEmailAddress" value="${userEmailAddress3}" />
		</execute>

		<execute macro="LoopFeedEntry#viewAuthorAndContent">
			<var name="feedEntryAuthorName" value="${userName}" />
