<definition>
	<command name="applyNotificationSettings">
		<if>
			<condition function="IsElementPresent" locator1="LoopNotifications#NOTIFICATIONS_SETTING_CONFIRMATION_MESSAGE" />
			<then>
				<execute function="AssertTextEquals" locator1="LoopNotifications#NOTIFICATIONS_SETTING_CONFIRMATION_MESSAGE" value1="This change will apply to all existing notification settings for this category." />
				<execute function="AssertClick" locator1="LoopNotifications#NOTIFICATIONS_SETTING_CONFIRMATION_APPLY" value1="Apply" />
			</then>
		</if>
	</command>

	<command name="clickNotification">
		<if>
			<isset var="notificationActionPartial" />
			<then>
				<var name="key_notificationAction" value="${notificationActionPartial}" />
			</then>
			<else>
				<var name="key_notificationAction" value="${notificationAction}" />
			</else>
		</if>

		<execute function="Click" locator1="LoopNotifications#NOTIFICATION_ITEM" />

		<execute macro="LoopNavigation#assertSennaLoadComplete" />
	</command>

	<command name="clickNotificationIcon">
		<if>
			<condition function="IsElementNotPresent" locator1="LoopNotifications#NOTIFICATION_MENU_HEADER" />
			<then>
				<if>
					<and>
						<isset var="notificationCount" />
						<not>
							<contains string="${notificationCount}" substring="{notificationCount}" />
						</not>
					</and>
					<then>
						<execute function="AssertTextEquals" locator1="LoopToolbar#TOOLBAR_NOTIFICATION_COUNT" value1="${notificationCount}" />
						<execute function="Click" locator1="LoopToolbar#TOOLBAR_NOTIFICATION_LINK" />
						<execute function="AssertElementNotPresent" locator1="LoopToolbar#TOOLBAR_NOTIFICATION_COUNT" />
					</then>
					<else>
						<execute function="Click" locator1="LoopToolbar#TOOLBAR_NOTIFICATION_LINK" />
					</else>
				</if>
			</then>
		</if>
	</command>

	<command name="clickNotificationSettings">
		<execute function="Click" locator1="LoopToolbar#TOOLBAR_NOTIFICATION_LINK" />
		<execute function="Click" locator1="LoopNotifications#NOTIFICATIONS_SETTING_TOGGLE" />
	</command>

	<command name="goBacktoNotifications">
		<execute function="Click" locator1="LoopNotifications#NOTIFICATIONS_SETTING_BACK" />
	</command>

	<command name="turnEmailNotificationSettingsOffForAnythingIHaveBeenMentioned">
		<execute macro="LoopNotifications#clickNotificationSettings" />

		<execute function="MakeVisible" locator1="LoopNotifications#NOTIFICATIONS_SETTING_ANY_MENTION_EMAIL" />
		<execute function="Uncheck#clickAt" locator1="LoopNotifications#NOTIFICATIONS_SETTING_ANY_MENTION_EMAIL" />

		<execute macro="LoopNotifications#applyNotificationSettings" />

		<execute macro="LoopNotifications#goBacktoNotifications" />
	</command>

	<command name="turnEmailNotificationSettingsOffForCommentsOnMyPosts">
		<execute macro="LoopNotifications#clickNotificationSettings" />

		<execute function="MakeVisible" locator1="LoopNotifications#NOTIFICATIONS_SETTING_COMMENTS_ON_MY_POSTS_EMAIL" />
		<execute function="Uncheck#clickAt" locator1="LoopNotifications#NOTIFICATIONS_SETTING_COMMENTS_ON_MY_POSTS_EMAIL" />

		<execute macro="LoopNotifications#applyNotificationSettings" />

		<execute macro="LoopNotifications#goBacktoNotifications" />
	</command>

