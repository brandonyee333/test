		<execute macro="LoopNotifications#goBacktoNotifications" />
	</command>

	<command name="viewNoNotification">
		<if>
			<isset var="notificationActionPartial" />
			<then>
				<var name="key_notificationAction" value="${notificationActionPartial}" />
			</then>
			<else>
				<var name="key_notificationAction" value="${notificationAction}" />
			</else>
		</if>

		<execute function="Click" locator1="LoopToolbar#TOOLBAR_NOTIFICATION_LINK" />

		<if>
			<isset var="notificationDetails" />
			<then>
				<var name="key_notificationDetails" value="${notificationDetails}" />

				<execute function="AssertElementNotPresent" locator1="LoopNotifications#NOTIFICATION_DETAILS_SPECIFIC" />
			</then>
			<else>
				<execute function="AssertElementNotPresent" locator1="LoopNotifications#NOTIFICATION_ITEM" />
			</else>
		</if>
	</command>

	<command name="viewNoNotificationCount">
		<execute function="AssertElementNotPresent" locator1="LoopToolbar#TOOLBAR_NOTIFICATION_COUNT" />
	</command>

	<command name="viewNoNotificationDetails">
		<execute function="AssertTextNotPresent" value1="${notificationDetails}" />
	</command>

	<command name="viewNoNotificationDetailsSpecific">
		<var name="key_notificationAction" value="${notificationAction}" />
		<var name="key_notificationDetails" value="${notificationDetails}" />

		<execute function="AssertElementNotPresent" locator1="LoopNotifications#NOTIFICATION_DETAILS_SPECIFIC" />
	</command>

	<command name="viewNotification">
		<if>
			<isset var="notificationActionPartial" />
			<then>
				<var name="key_notificationAction" value="${notificationActionPartial}" />
			</then>
			<else>
				<var name="key_notificationAction" value="${notificationAction}" />
			</else>
		</if>

		<var name="key_userName" value="${userName}" />

		<execute macro="LoopNotifications#clickNotificationIcon">
			<var name="notificationCount" value="${notificationCount}" />
		</execute>

		<if>
			<and>
				<isset var="notificationDate" />
				<not>
					<contains string="${notificationDate}" substring="{notificationDate}" />
				</not>
			</and>
			<then>
				<execute function="AssertTextEquals" locator1="LoopNotifications#NOTIFICATION_TIMESTAMP" value1="${notificationDate}" />
			</then>
			<else>
				<execute function="AssertElementPresent" locator1="LoopNotifications#NOTIFICATION_TIMESTAMP" />
			</else>
		</if>

		<execute function="AssertElementPresent" locator1="LoopNotifications#NOTIFICATION_PROFILE_PICTURE" />
		<execute function="AssertTextEquals" locator1="LoopNotifications#NOTIFICATION_USER_NAME" value1="${userName}" />
		<execute function="AssertTextEquals" locator1="LoopNotifications#NOTIFICATION_ACTION" value1="${notificationAction}" />

		<if>
			<and>
				<isset var="notificationDetails" />
				<not>
					<contains string="${notificationDetails}" substring="{notificationDetails}" />
				</not>
			</and>
			<then>
				<execute function="AssertTextEquals" locator1="LoopNotifications#NOTIFICATION_DETAILS" value1="${notificationDetails}" />
			</then>
		</if>

		<if>
			<equals arg1="${private}" arg2="true" />
			<then>
				<execute function="AssertElementPresent" locator1="LoopNotifications#NOTIFICATION_DETAILS_PRIVATE_POST_LOCK" />
			</then>
		</if>
	</command>

	<command name="viewNotificationByDeactivatedUser">
		<if>
			<isset var="notificationActionPartial" />
			<then>
				<var name="key_notificationAction" value="${notificationActionPartial}" />
			</then>
			<else>
				<var name="key_notificationAction" value="${notificationAction}" />
			</else>
		</if>

		<var name="key_userName" value="${userName}" />

		<execute macro="LoopNotifications#clickNotificationIcon">
			<var name="notificationCount" value="${notificationCount}" />
		</execute>

		<if>
			<and>
				<isset var="notificationDate" />
				<not>
					<contains string="${notificationDate}" substring="{notificationDate}" />
				</not>
			</and>
			<then>
				<execute function="AssertTextEquals" locator1="LoopNotifications#NOTIFICATION_TIMESTAMP" value1="${notificationDate}" />
			</then>
			<else>
				<execute function="AssertElementPresent" locator1="LoopNotifications#NOTIFICATION_TIMESTAMP" />
			</else>
		</if>

		<execute function="AssertElementPresent" locator1="LoopNotifications#NOTIFICATION_PROFILE_PICTURE" />
		<execute function="AssertTextEquals" locator1="LoopNotifications#NOTIFICATION_USER_NAME_DEACTIVATED" value1="${userName}" />
		<execute function="AssertTextEquals" locator1="LoopNotifications#NOTIFICATION_ACTION" value1="${notificationAction}" />

		<if>
			<and>
				<isset var="notificationDetails" />
				<not>
					<contains string="${notificationDetails}" substring="{notificationDetails}" />
				</not>
			</and>
			<then>
				<execute function="AssertTextEquals" locator1="LoopNotifications#NOTIFICATION_DETAILS" value1="${notificationDetails}" />
			</then>
		</if>
	</command>

	<command name="viewNotificationDetailsSpecific">
		<var name="key_notificationAction" value="${notificationAction}" />
		<var name="key_notificationDetails" value="${notificationDetails}" />

		<execute function="AssertElementPresent" locator1="LoopNotifications#NOTIFICATION_DETAILS_SPECIFIC" />
	</command>

	<command name="viewNotificationForMultipleActions">
		<if>
			<isset var="notificationActionPartial" />
			<then>
				<var name="key_notificationAction" value="${notificationActionPartial}" />
			</then>
			<else>
				<var name="key_notificationAction" value="${notificationAction}" />
			</else>
		</if>

		<execute macro="LoopNotifications#clickNotificationIcon">
			<var name="notificationCount" value="${notificationCount}" />
		</execute>

		<if>
			<and>
				<isset var="notificationDate" />
				<not>
					<contains string="${notificationDate}" substring="{notificationDate}" />
				</not>
			</and>
			<then>
				<execute function="AssertTextEquals" locator1="LoopNotifications#NOTIFICATION_TIMESTAMP" value1="${notificationDate}" />
			</then>
			<else>
				<execute function="AssertElementPresent" locator1="LoopNotifications#NOTIFICATION_TIMESTAMP" />
			</else>
		</if>

		<execute function="AssertElementPresent" locator1="LoopNotifications#NOTIFICATION_PROFILE_PICTURE" />
		<execute function="AssertTextEquals" locator1="LoopNotifications#NOTIFICATION_ACTION" value1="${notificationAction}" />
	</command>

	<command name="viewNotificationSettingDefaults">
		<execute macro="LoopNotifications#clickNotificationSettings" />

		<var name="descriptionInAppOnList" value="Anything I Have Been Mentioned In,Likes on My Posts,Likes on My Comments and Replies,Comments on My Posts,Posts I Commented On,Replies to My Comments,Groups I Am a Member Of,Topics I Am an Expert Of" />

		<for list="${descriptionInAppOnList}" param="description">
			<execute macro="LoopNotifications#viewNotificationSettingInAppOn">
				<var name="notificationSettingDescription" value="${description}" />
			</execute>
		</for>

		<execute macro="LoopNotifications#viewNotificationSettingInAppOff">
			<var name="notificationSettingDescription" value="Anything I Am Following" />
		</execute>

		<execute macro="LoopNotifications#viewNotificationSettingInAppDisabled">
			<var name="notificationSettingDescription" value="Anything I Have Been Mentioned In" />
		</execute>

		<execute macro="LoopNotifications#viewNotificationSettingEmailOn">
			<var name="notificationSettingDescription" value="Anything I Have Been Mentioned In" />
		</execute>

		<var name="descriptionEmailOffList" value="Likes on My Posts,Likes on My Comments and Replies,Comments on My Posts,Posts I Commented On,Replies to My Comments,Groups I Am a Member Of,Topics I Am an Expert Of" />

		<for list="${descriptionEmailOffList}" param="description">
			<execute macro="LoopNotifications#viewNotificationSettingEmailOff">
				<var name="notificationSettingDescription" value="${description}" />
			</execute>
		</for>

		<var name="descriptionEmailDisabledList" value="Likes on My Posts,Likes on My Comments and Replies" />

		<for list="${descriptionEmailDisabledList}" param="description">
			<execute macro="LoopNotifications#viewNotificationSettingEmailDisabled">
				<var name="notificationSettingDescription" value="${description}" />
			</execute>
		</for>

		<execute macro="LoopNotifications#viewNotificationSettingDefaultsForAnythingIAmFollowing" />
	</command>

	<command name="viewNotificationSettingDefaultsForAnythingIAmFollowing">
		<execute function="AssertElementNotPresent" locator1="LoopNotifications#NOTIFICATIONS_SETTING_ANY_FOLLOWING_IN_EMAIL" />

		<execute function="MakeVisible" locator1="LoopNotifications#NOTIFICATIONS_SETTING_ANY_FOLLOWING_IN_APP" />
		<execute function="Check#clickAt" locator1="LoopNotifications#NOTIFICATIONS_SETTING_ANY_FOLLOWING_IN_APP" />

		<execute macro="LoopNotifications#applyNotificationSettings" />

		<execute function="AssertElementPresent" locator1="LoopNotifications#NOTIFICATIONS_SETTING_ANY_FOLLOWING_IN_EMAIL" />

		<execute function="MakeVisible" locator1="LoopNotifications#NOTIFICATIONS_SETTING_ANY_FOLLOWING_IN_APP" />
		<execute function="Uncheck#clickAt" locator1="LoopNotifications#NOTIFICATIONS_SETTING_ANY_FOLLOWING_IN_APP" />

		<execute macro="LoopNotifications#applyNotificationSettings" />

		<execute function="AssertElementNotPresent" locator1="LoopNotifications#NOTIFICATIONS_SETTING_ANY_FOLLOWING_IN_EMAIL" />
	</command>

	<command name="viewNotificationSettingEmailDisabled">
		<var name="key_description" value="${notificationSettingDescription}" />

		<execute function="AssertElementPresent" locator1="LoopNotifications#NOTIFICATIONS_SETTING_DISABLED_EMAIL" />
	</command>

	<command name="viewNotificationSettingEmailOff">
		<var name="key_description" value="${notificationSettingDescription}" />

		<execute function="AssertElementPresent" locator1="LoopNotifications#NOTIFICATIONS_SETTING_OFF_EMAIL" />
	</command>

	<command name="viewNotificationSettingEmailOn">
		<var name="key_description" value="${notificationSettingDescription}" />

		<execute function="AssertElementPresent" locator1="LoopNotifications#NOTIFICATIONS_SETTING_ON_EMAIL" />
	</command>

	<command name="viewNotificationSettingInAppDisabled">
		<var name="key_description" value="${notificationSettingDescription}" />

		<execute function="AssertElementPresent" locator1="LoopNotifications#NOTIFICATIONS_SETTING_DISABLED_IN_APP" />
	</command>

	<command name="viewNotificationSettingInAppOff">
		<var name="key_description" value="${notificationSettingDescription}" />

		<execute function="AssertElementPresent" locator1="LoopNotifications#NOTIFICATIONS_SETTING_OFF_IN_APP" />
	</command>

	<command name="viewNotificationSettingInAppOn">
		<var name="key_description" value="${notificationSettingDescription}" />

		<execute function="AssertElementPresent" locator1="LoopNotifications#NOTIFICATIONS_SETTING_ON_IN_APP" />
	</command>

	<command name="viewNotificationSettingsLink">
		<execute function="AssertElementPresent" locator1="LoopNotifications#NOTIFICATIONS_SETTING_TOGGLE" />
	</command>

	<command name="viewNotificationTooltip">
		<execute function="MouseOver" locator1="LoopToolbar#TOOLBAR_NOTIFICATION_LINK" />

		<execute function="AssertTextEquals" locator1="LoopToolbar#TOOLTIP" value1="Notifications" />
	</command>
</definition>