<html>
<head>
<title>LoopTopicsMergeTopic</title>
</head>
<body>
<table cellpadding="1" cellspacing="1" border="1">
<thead>
<tr><td rowspan="1" colspan="3">LoopTopicsMergeTopic</td></tr>
</thead>
<tbody>
<tr>
	<td>SUCCESS_MESSAGE</td>
	<td>//div[contains(@class,'alert-container')]</td>
	<td></td>
</tr>
<tr>
	<td>ADD_MERGE_TOPIC_FIELD</td>
	<td>//input[contains(@placeholder,'Select Topic')]</td>
	<td></td>
</tr>
<tr>
	<td>MERGE_TOPIC_NAME</td>
	<td>//span[contains(.,'${key_topicName}')]</td>
	<td></td>
</tr>
<tr>
	<td>MERGE_TOPIC_REMOVE_ICON</td>
	<td>//span[contains(.,'${key_topicName}')]//*[local-name()='svg' and contains(@class,'remove')]</td>
	<td></td>
</tr>
<tr>
	<td>MERGE_TOPIC_CONFIRMATION_MESSAGE</td>
	<td>//div[contains(@class,'modal-content')]//div[contains(@class,'description')]//div[1]</td>
	<td></td>
</tr>
<tr>
	<td>REMOVE_TOPIC_PAGE_CHECKBOX</td>
	<td>//div[@class='checkbox-container' and contains(.,'page')]//input</td>
	<td></td>
</tr>
<tr>
	<td>REMOVE_TOPIC_PAGE_CHECKBOX_DESCRIPTION</td>
	<td>//div[@class='checkbox-container' and contains(.,'page')]//label</td>
	<td></td>
</tr>
<tr>
	<td>REDIRECT_TOPIC_MENTIONS_CHECKBOX</td>
	<td>//div[@class='checkbox-container' and contains(.,'mentions')]//input</td>
	<td></td>
</tr>
<tr>
	<td>REDIRECT_TOPIC_MENTIONS_CHECKBOX_DESCRIPTION</td>
	<td>//div[@class='checkbox-container' and contains(.,'mentions')]//label</td>
	<td></td>
</tr>
<tr>
	<td>MOVE_TOPIC_FOLLOWERS_CHECKBOX</td>
	<td>//div[@class='checkbox-container' and contains(.,'followers')]//input</td>
	<td></td>
</tr>
<tr>
	<td>MOVE_TOPIC_FOLLOWERS_CHECKBOX_DESCRIPTION</td>
	<td>//div[@class='checkbox-container' and contains(.,'followers')]//label</td>
	<td></td>
</tr>
<tr>
	<td>SAVE_BUTTON</td>
	<td>//button[contains(.,'Save')]</td>
	<td></td>
</tr>
<tr>
	<td>MERGE_BUTTON</td>
	<td>//button[contains(.,'Merge')]</td>
	<td></td>
</tr>
<tr>
	<td>CANCEL_BUTTON</td>
	<td>//button[contains(.,'Cancel')]</td>
	<td></td>
</tr>
</tbody>
</table>
</body>
</html>