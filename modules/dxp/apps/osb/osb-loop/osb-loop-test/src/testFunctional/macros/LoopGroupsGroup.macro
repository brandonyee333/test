		<execute function="AssertTextEquals" locator1="LoopGroupsGroup#PAGES_NO_PAGE_YET_DESCRIPTION" value1="Pages is a place where you can find official content related to a Group." />
	</command>

	<command name="viewNoPagesSection">
		<execute function="AssertElementNotPresent" locator1="LoopGroupsGroup#GROUP_PAGES_TAB" />
	</command>

	<command name="viewNoParentGroup">
		<if>
			<condition function="IsElementPresent" locator1="LoopGroupsGroup#GROUP_PARENT_GROUP_NAME_LINK" />
			<then>
				<execute function="AssertTextEquals" locator1="LoopGroupsGroup#GROUP_PARENT_GROUP_NAME_LINK" value1="Loop Division" />
			</then>
			<else>
				<execute function="AssertElementNotPresent" locator1="LoopGroupsGroup#GROUP_PARENT_GROUP_NAME_LINK" />
			</else>
		</if>
	</command>

	<command name="viewPage">
		<execute function="AssertElementPresent" locator1="LoopGroupsGroup#PAGES_PAGE_CREATOR_PROFILE_PICTURE" />
		<execute function="AssertTextEquals" locator1="LoopGroupsGroup#PAGES_PAGE_CREATOR_NAME" value1="${pageCreatorName}" />
		<execute function="AssertTextEquals" locator1="LoopGroupsGroup#PAGES_PAGE_TITLE" value1="${pageTitle}" />
		<execute function="AssertTextEquals" locator1="LoopGroupsGroup#PAGES_PAGE_TEXT" value1="${pageText}" />
	</command>

	<command name="viewPageListItem">
		<var name="key_pageDetail" value="${pageTitle}" />

		<execute function="AssertTextEquals" locator1="LoopGroupsGroup#PAGES_LIST_ITEM_TITLE" value1="${pageTitle}" />
		<execute function="AssertTextEquals#assertPartialText" locator1="LoopGroupsGroup#PAGES_LIST_ITEM_CREATOR" value1="${pageCreatorName}" />

		<if>
			<and>
				<isset var="pageModifiedTime" />
				<not>
					<contains string="${pageModifiedTime}" substring="{pageModifiedTime}" />
				</not>
			</and>
			<then>
				<execute function="AssertTextEquals" locator1="LoopGroupsGroup#PAGES_LIST_ITEM_MODIFIED_TIME" value1="${pageModifiedTime}" />
			</then>
		</if>
	</command>

	<command name="viewPageOptions">
		<execute function="Click" locator1="LoopGroupsGroup#PAGES_PAGE_OPTIONS_BUTTON" />

		<execute function="AssertElementPresent" locator1="LoopGroupsGroup#PAGES_PAGE_OPTIONS_EDIT_LINK" />
		<execute function="AssertElementPresent" locator1="LoopGroupsGroup#PAGES_PAGE_OPTIONS_DELETE_LINK" />
	</command>

	<command name="viewParentGroup">
		<execute function="AssertTextEquals" locator1="LoopGroupsGroup#GROUP_PARENT_GROUP_NAME_LINK" value1="${parentGroupName}" />
	</command>

	<command name="viewRegionalDepartment">
		<var name="key_childGroupName" value="${childGroupName}" />

		<execute macro="LoopGroupsGroup#gotoNetworkSection" />

		<execute function="AssertTextEquals" locator1="LoopGroupsGroup#NETWORK_REGIONAL_DEPARTMENT_NAME_LINK" value1="${childGroupName}" />

		<if>
			<and>
				<isset var="followerCount" />
				<not>
					<contains string="${followerCount}" substring="{followerCount}" />
				</not>
			</and>
			<then>
				<if>
					<equals arg1="${followerCount}" arg2="1" />
					<then>
						<execute function="AssertTextEquals#assertPartialText" locator1="LoopGroupsGroup#NETWORK_REGIONAL_DEPARTMENT_DETAILS" value1="1 Follower" />
					</then>
					<else>
						<execute function="AssertTextEquals#assertPartialText" locator1="LoopGroupsGroup#NETWORK_REGIONAL_DEPARTMENT_DETAILS" value1="${followerCount} Followers" />
					</else>
				</if>
			</then>
		</if>

		<if>
			<and>
				<isset var="memberCount" />
				<not>
					<contains string="${memberCount}" substring="{memberCount}" />
				</not>
			</and>
			<then>
				<if>
					<equals arg1="${memberCount}" arg2="1" />
					<then>
						<execute function="AssertTextEquals#assertPartialText" locator1="LoopGroupsGroup#NETWORK_REGIONAL_DEPARTMENT_DETAILS" value1="1 Member" />
					</then>
					<else>
						<execute function="AssertTextEquals#assertPartialText" locator1="LoopGroupsGroup#NETWORK_REGIONAL_DEPARTMENT_DETAILS" value1="${memberCount} Members" />
					</else>
				</if>
			</then>
		</if>
	</command>
</definition>