			<execute function="AssertTextEquals" locator1="LoopGroupsGroup#NETWORK_CHILD_GROUP" value1="${childGroupName}" />
		</for>
	</command>

	<command name="viewChildGroupViaStreamTab">
		<var name="key_childGroupName" value="${childGroupName}" />

		<execute function="AssertTextEquals" locator1="LoopGroupsGroup#NETWORK_CHILD_GROUP" value1="${childGroupName}" />
	</command>

	<command name="viewDescriptionMarkdown">
		<if>
			<condition function="IsElementPresent" locator1="LoopGroupsGroup#ABOUT_DESCRIPTION_SEE_MORE_LINK" />
			<then>
				<execute function="AssertClick" locator1="LoopGroupsGroup#ABOUT_DESCRIPTION_SEE_MORE_LINK" value1="See More" />
			</then>
		</if>

		<execute function="KeyPress" locator1="LoopGroupsGroup#GROUP_PROFILE" value1="\HOME" />
		<execute function="SikuliAssertElementPresent" locator1="LoopGroupsGroup#ABOUT_DESCRIPTION_MARKDOWN_1" />
		<execute function="KeyPress" locator1="LoopGroupsGroup#GROUP_PROFILE" value1="\SPACE" />
		<execute function="SikuliAssertElementPresent" locator1="LoopGroupsGroup#ABOUT_DESCRIPTION_MARKDOWN_2" />
	</command>

	<command name="viewDisabledPublishButton">
		<execute function="AssertElementPresent" locator1="LoopGroupsGroup#PUBLISH_BUTTON_DISABLED" />
	</command>

	<command name="viewEditControls">
		<var method="selenium#getText('LoopGroupsGroup#GROUP_TYPE')" name="groupTypeFull" />

		<if>
			<contains string="${groupTypeFull}" substring="Location" />
			<then>
				<var name="groupType" value="Location" />
			</then>
			<else>
				<if>
					<contains string="${groupTypeFull}" substring="Team" />
					<then>
						<var name="groupType" value="Team" />
					</then>
					<else>
						<var name="groupType" value="Department" />
					</else>
				</if>
			</else>
		</if>

		<execute function="MouseOver" locator1="LoopGroupsGroup#GROUP_PROFILE_PICTURE" />
		<execute function="AssertElementPresent" locator1="LoopGroupsGroup#GROUP_PROFILE_PICTURE_SELECT_BUTTON" />
		<execute function="AssertElementPresent" locator1="LoopGroupsGroup#GROUP_COVER_PICTURE_SELECT_BUTTON" />
		<execute function="Click" locator1="LoopGroupsGroup#GROUP_OPTIONS_BUTTON" />
		<execute function="AssertTextEquals" locator1="LoopGroupsGroup#GROUP_OPTIONS_EDIT_LINK" value1="Edit Group" />
		<execute function="AssertTextEquals" locator1="LoopGroupsGroup#GROUP_OPTIONS_ASSIGN_PARENT_LINK" value1="Assign Parent ${groupType}" />
		<execute function="AssertTextEquals" locator1="LoopGroupsGroup#GROUP_OPTIONS_ASSIGN_CHILD_LINK" value1="Assign Child ${groupType}s" />
	</command>

	<command name="viewFollowOptionViaIndexPage">
		<var name="key_groupName" value="${groupName}" />

		<execute function="MouseOver" locator1="LoopGroups#GROUP_NAME" />

		<if>
			<condition function="IsElementNotPresent" locator1="LoopGroups#GROUP_FOLLOW_MENU_BUTTON" />
			<then>
				<execute function="AssertElementPresent" locator1="LoopGroups#GROUP_OVERLAY_FOLLOW_BUTTON" />
			</then>
			<else>
				<execute function="AssertElementPresent" locator1="LoopGroups#GROUP_FOLLOW_MENU_BUTTON" />
			</else>
		</if>
	</command>

	<command name="viewFunctionalDepartment">
		<var name="key_childGroupName" value="${childGroupName}" />

		<execute macro="LoopGroupsGroup#gotoNetworkSection" />

		<execute function="AssertTextEquals" locator1="LoopGroupsGroup#NETWORK_FUNCTIONAL_DEPARTMENT_NAME_LINK" value1="${childGroupName}" />

		<if>
			<and>
				<isset var="followerCount" />
				<not>
					<contains string="${followerCount}" substring="{followerCount}" />
				</not>
			</and>
			<then>
				<if>
					<equals arg1="${followerCount}" arg2="1" />
					<then>
						<execute function="AssertTextEquals#assertPartialText" locator1="LoopGroupsGroup#NETWORK_FUNCTIONAL_DEPARTMENT_DETAILS" value1="1 Follower" />
					</then>
					<else>
						<execute function="AssertTextEquals#assertPartialText" locator1="LoopGroupsGroup#NETWORK_FUNCTIONAL_DEPARTMENT_DETAILS" value1="${followerCount} Followers" />
					</else>
				</if>
			</then>
		</if>

		<if>
			<and>
				<isset var="memberCount" />
				<not>
					<contains string="${memberCount}" substring="{memberCount}" />
				</not>
			</and>
			<then>
				<if>
					<equals arg1="${memberCount}" arg2="1" />
					<then>
						<execute function="AssertTextEquals#assertPartialText" locator1="LoopGroupsGroup#NETWORK_FUNCTIONAL_DEPARTMENT_DETAILS" value1="1 Member" />
					</then>
					<else>
						<execute function="AssertTextEquals#assertPartialText" locator1="LoopGroupsGroup#NETWORK_FUNCTIONAL_DEPARTMENT_DETAILS" value1="${memberCount} Members" />
					</else>
				</if>
			</then>
		</if>
	</command>

	<command name="viewGroupDetails">
		<execute function="AssertTextEquals" locator1="LoopGroupsGroup#GROUP_NAME" value1="${groupName}" />
		<execute function="AssertTextEquals#assertPartialText" locator1="LoopGroupsGroup#GROUP_TYPE" value1="${groupType}" />

		<if>
			<and>
				<isset var="groupSubtype" />
				<not>
					<contains string="${groupSubtype}" substring="{groupSubtype}" />
				</not>
			</and>
			<then>
				<execute function="AssertTextEquals#assertPartialText" locator1="LoopGroupsGroup#GROUP_TYPE" value1="${groupSubtype}" />
			</then>
		</if>

		<if>
			<and>
				<isset var="followerCount" />
				<not>
					<contains string="${followerCount}" substring="{followerCount}" />
				</not>
			</and>
			<then>
				<if>
					<equals arg1="${followerCount}" arg2="1" />
					<then>
						<execute function="AssertTextEquals" locator1="LoopGroupsGroup#GROUP_FOLLOWER_COUNT" value1="1 Follower" />
					</then>
					<else>
						<execute function="AssertTextEquals" locator1="LoopGroupsGroup#GROUP_FOLLOWER_COUNT" value1="${followerCount} Followers" />
					</else>
				</if>
			</then>
		</if>

		<if>
			<and>
				<isset var="memberCount" />
				<not>
					<contains string="${memberCount}" substring="{memberCount}" />
				</not>
			</and>
			<then>
				<if>
					<equals arg1="${memberCount}" arg2="1" />
					<then>
						<execute function="AssertTextEquals" locator1="LoopGroupsGroup#GROUP_MEMBER_COUNT" value1="1 Member" />
					</then>
					<else>
						<execute function="AssertTextEquals" locator1="LoopGroupsGroup#GROUP_MEMBER_COUNT" value1="${memberCount} Members" />
					</else>
				</if>
			</then>
		</if>

		<if>
			<and>
				<isset var="groupDescription" />
				<not>
					<contains string="${groupDescription}" substring="{groupDescription}" />
				</not>
			</and>
			<then>
				<execute function="AssertTextEquals" locator1="LoopGroupsGroup#ABOUT_DESCRIPTION" value1="${groupDescription}" />
			</then>
		</if>
	</command>

	<command name="viewGroupOverlay">
		<execute function="AssertElementPresent" locator1="LoopGroups#GROUP_OVERLAY_AVATAR" />
		<execute function="AssertTextEquals" locator1="LoopGroups#GROUP_OVERLAY_NAME" value1="${groupName}" />
		<execute function="AssertElementPresent" locator1="LoopGroups#GROUP_OVERLAY_FOLLOW_BUTTON" />

		<if>
			<and>
				<isset var="groupType" />
				<not>
					<contains string="${groupType}" substring="{groupType}" />
				</not>
			</and>
			<then>
				<execute function="AssertTextEquals" locator1="LoopGroups#GROUP_OVERLAY_TYPE" value1="${groupType}" />
			</then>
		</if>

		<if>
			<and>
				<isset var="followerCount" />
				<not>
					<contains string="${followerCount}" substring="{followerCount}" />
				</not>
			</and>
			<then>
				<if>
					<equals arg1="${followerCount}" arg2="1" />
					<then>
						<execute function="AssertTextEquals" locator1="LoopGroups#GROUP_OVERLAY_FOLLOWERS" value1="1 Follower" />
					</then>
					<else>
						<execute function="AssertTextEquals" locator1="LoopGroups#GROUP_OVERLAY_FOLLOWERS" value1="${followerCount} Followers" />
					</else>
				</if>
			</then>
		</if>

		<if>
			<and>
				<isset var="memberCount" />
				<not>
					<contains string="${memberCount}" substring="{memberCount}" />
				</not>
			</and>
			<then>
				<if>
					<equals arg1="${memberCount}" arg2="1" />
					<then>
						<execute function="AssertTextEquals" locator1="LoopGroups#GROUP_OVERLAY_MEMBERS" value1="1 Member" />
					</then>
					<else>
						<execute function="AssertTextEquals" locator1="LoopGroups#GROUP_OVERLAY_MEMBERS" value1="${memberCount} Members" />
					</else>
				</if>
			</then>
		</if>

		<execute macro="LoopNavigation#closeOverlay" />
	</command>

	<command name="viewGroupsViaGroupsList">
