	<command name="viewGroupViaGroupsList">
		<var name="key_groupName" value="${groupName}" />

		<execute function="AssertTextEquals" locator1="LoopGroups#GROUP_NAME" value1="${groupName}" />

		<if>
			<equals arg1="${groupType}" arg2="Team" />
			<then>
				<execute function="AssertElementPresent" locator1="LoopGroups#TEAM_ICON" />
			</then>
			<elseif>
				<equals arg1="${groupType}" arg2="Location" />
				<then>
					<execute function="AssertElementPresent" locator1="LoopGroups#LOCATION_ICON" />
				</then>
			</elseif>
			<elseif>
				<equals arg1="${groupType}" arg2="Department" />
				<then>
					<execute function="AssertElementPresent" locator1="LoopGroups#DEPARTMENT_ICON" />
				</then>
			</elseif>
		</if>

		<if>
			<and>
				<isset var="memberCount" />
				<not>
					<contains string="${memberCount}" substring="{memberCount}" />
				</not>
			</and>
			<then>
				<if>
					<equals arg1="${memberCount}" arg2="1" />
					<then>
						<execute function="AssertTextEquals#assertPartialText" locator1="LoopGroups#GROUP_MEMBER_COUNT" value1="1 Member" />
					</then>
					<else>
						<execute function="AssertTextEquals#assertPartialText" locator1="LoopGroups#GROUP_MEMBER_COUNT" value1="${memberCount} Members" />
					</else>
				</if>
			</then>
		</if>

		<if>
			<and>
				<isset var="followerCount" />
				<not>
					<contains string="${followerCount}" substring="{followerCount}" />
				</not>
			</and>
			<then>
				<if>
					<equals arg1="${followerCount}" arg2="1" />
					<then>
						<execute function="AssertTextEquals#assertPartialText" locator1="LoopGroups#GROUP_FOLLOWER_COUNT" value1="1 Follower" />
					</then>
					<else>
						<execute function="AssertTextEquals#assertPartialText" locator1="LoopGroups#GROUP_FOLLOWER_COUNT" value1="${followerCount} Followers" />
					</else>
				</if>
			</then>
		</if>
	</command>

