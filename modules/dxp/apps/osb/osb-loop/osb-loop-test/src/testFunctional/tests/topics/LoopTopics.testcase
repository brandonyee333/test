		</execute>

		<execute macro="Loop#logoutAndLogin">
			<var name="userLoginEmailAddress" value="${userEmailAddress2}" />
		</execute>

		<execute macro="LoopNavigation#gotoProvideFeedback" />

		<execute macro="LoopFeed#addEntry">
			<var name="feedEntryAuthorName" value="${userName2}" />
			<var name="feedEntryContent" value="${feedEntryText}" />
			<var name="feedEntryText" value="${feedEntryText}" />
		</execute>

		<execute macro="Loop#openURL" />

		<execute macro="LoopFeedEntry#viewAuthorAndContent">
			<var name="feedEntryAuthorName" value="${userName2}" />
			<var name="feedEntryContent" value="${feedEntryText}" />
		</execute>

		<execute macro="LoopNavigation#gotoMyProfile" />

		<execute macro="LoopFeedEntry#viewAuthorAndContent">
			<var name="feedEntryAuthorName" value="${userName2}" />
			<var name="feedEntryContent" value="${feedEntryText}" />
		</execute>

		<execute macro="LoopTopics#gotoTopicDetails">
			<var name="topicName" value="${topicName}" />
		</execute>

		<execute macro="LoopFeedEntry#viewAuthorAndContent">
			<var name="feedEntryAuthorName" value="${userName2}" />
			<var name="feedEntryContent" value="${feedEntryText}" />
		</execute>

		<execute macro="LoopNavigation#gotoProvideFeedback" />

		<execute macro="LoopFeedEntry#viewAuthorAndContent">
			<var name="feedEntryAuthorName" value="${userName2}" />
			<var name="feedEntryContent" value="${feedEntryText}" />
		</execute>

		<execute macro="Loop#openURL" />

		<execute macro="LoopFeedEntry#viewTopicViaSharedToLink">
			<var name="feedEntryContent" value="${feedEntryText}" />
			<var name="topicDescription" value="${topicDescription}" />
			<var name="topicName" value="${topicName}" />
		</execute>

		<execute macro="Loop#logoutAndLogin">
			<var name="userLoginEmailAddress" value="${userEmailAddress}" />
		</execute>

		<execute macro="LoopFeedEntry#viewAuthorAndContent">
			<var name="feedEntryAuthorName" value="${userName2}" />
			<var name="feedEntryContent" value="${feedEntryText}" />
		</execute>

		<execute macro="LoopTopics#gotoTopicDetails">
			<var name="topicName" value="${topicName}" />
		</execute>

		<execute macro="LoopFeedEntry#viewAuthorAndContent">
			<var name="feedEntryAuthorName" value="${userName2}" />
			<var name="feedEntryContent" value="${feedEntryText}" />
		</execute>

		<execute macro="LoopNavigation#gotoProvideFeedback" />

		<execute macro="LoopFeedEntry#viewAuthorAndContent">
			<var name="feedEntryAuthorName" value="${userName2}" />
			<var name="feedEntryContent" value="${feedEntryText}" />
		</execute>

		<execute macro="Loop#openURL" />

		<execute macro="LoopFeedEntry#viewTopicViaSharedToLink">
			<var name="feedEntryContent" value="${feedEntryText}" />
			<var name="topicDescription" value="${topicDescription}" />
			<var name="topicName" value="${topicName}" />
		</execute>
