<definition component-name="loop-topics">
	<property name="loop.enabled" value="true" />
	<!--<property name="hook.plugins.includes" value="portal-compat-hook" />-->
	<property name="osgi.module.configuration.file.names" value="com.liferay.portal.security.auto.login.basic.auth.header.module.configuration.BasicAuthHeaderAutoLoginConfiguration.cfg:com.liferay.portal.bundle.blacklist.internal.BundleBlacklistConfiguration.cfg" />
	<property name="osgi.module.configurations" value="enabled=true:blacklistBundleSymbolicNames=['com.liferay.portal.search.elasticsearch', 'com.liferay.portal.search.elasticsearch.shield', 'com.liferay.portal.search.elasticsearch.marvel.web']" />
	<!--<property name="portlet.plugins.includes" value="asset-entry-set-portlet,asset-feed-portlet,asset-sharing-portlet,loop-portlet" />-->
	<property name="skip.clean-app-server-deploy-dir" value="true" />
	<property name="testray.main.component.name" value="Loop" />
	<!--<property name="theme.plugins.includes" value="loop-theme" />
	<property name="web.plugins.includes" value="url-metadata-scraper-web" />-->

	<var name="userEmailAddress" value="loopuser01@liferay.com" />
	<var name="userFirstName" value="Loop01" />
	<var name="userLastName" value="User01" />
	<var name="userName" value="Loop01 User01" />
	<var name="userScreenName" value="loopuser01" />

	<set-up>
		<execute macro="Loop#firstSetupPG">
			<var name="roleNames" value="Loop Admin" />
		</execute>
	</set-up>

	<command name="AddCoverAndProfilePictures" priority="5">
		<var name="imageFileName1" value="/Document_4.jpg" />
		<var name="imageFileName2" value="/Document_2.jpg" />
		<var name="topicDescription" value="Topic Description" />
		<var name="topicName" value="TopicName" />

		<execute macro="LoopJson#createTopic">
			<var name="topicDescription" value="${topicDescription}" />
			<var name="topicName" value="${topicName}" />
		</execute>

		<execute macro="LoopTopics#gotoTopicDetails">
			<var name="topicName" value="${topicName}" />
		</execute>

		<execute macro="LoopTopicsTopic#addProfilePicture">
			<var name="profilePictureFileName" value="${imageFileName1}" />
		</execute>

		<execute macro="LoopTopics#gotoTopicDetails">
			<var name="topicName" value="${topicName}" />
		</execute>

		<execute macro="LoopTopicsTopic#addCoverPicture">
			<var name="coverPictureFileName" value="${imageFileName2}" />
		</execute>
	</command>

	<command name="AddExpertViaTopicPage" priority="5">
		<var name="topicDescription1" value="Topic Description1" />
		<var name="topicDescription2" value="Topic Description2" />
		<var name="topicDescription3" value="Topic Description3" />
		<var name="topicDescription4" value="Topic Description4" />
		<var name="topicName1" value="TopicName1" />
		<var name="topicName2" value="TopicName2" />
		<var name="topicName3" value="TopicName3" />
		<var name="topicName4" value="TopicName4" />
		<var name="userEmailAddress2" value="loopuser02@liferay.com" />
		<var name="userFirstName2" value="Loop02" />
		<var name="userLastName2" value="User02" />
		<var name="userName2" value="Loop02 User02" />
		<var name="userScreenName2" value="loopuser02" />

		<execute macro="LoopJson#addPerson">
			<var name="userEmailAddress" value="${userEmailAddress2}" />
			<var name="userFirstName" value="${userFirstName2}" />
			<var name="userLastName" value="${userLastName2}" />
			<var name="userScreenName" value="${userScreenName2}" />
		</execute>

		<execute macro="LoopJson#createTopics">
			<var name="topicNumberList" value="1,2,3,4" />
		</execute>

		<execute macro="LoopTopics#assignSelfAsExpert">
			<var name="topicName" value="${topicName1}" />
		</execute>

		<execute macro="LoopTopics#assignSelfAsExpert">
			<var name="topicName" value="${topicName2}" />
		</execute>

		<execute macro="LoopTopics#assignSelfAsExpert">
			<var name="topicName" value="${topicName3}" />
		</execute>

		<execute macro="LoopTopics#assignSelfAsExpert">
			<var name="topicName" value="${topicName4}" />
		</execute>

		<execute macro="LoopTopics#unassignSelfAsExpert">
			<var name="topicName" value="${topicName3}" />
		</execute>

		<execute macro="LoopTopics#unassignSelfAsExpert">
			<var name="topicName" value="${topicName4}" />
		</execute>

		<execute macro="Loop#logoutAndLogin">
			<var name="userLoginEmailAddress" value="${userEmailAddress2}" />
		</execute>

		<execute macro="LoopTopics#assignSelfAsExpert">
			<var name="topicName" value="${topicName1}" />
		</execute>

		<execute macro="LoopTopics#assignSelfAsExpert">
			<var name="topicName" value="${topicName2}" />
		</execute>

		<execute macro="LoopTopics#assignSelfAsExpert">
			<var name="topicName" value="${topicName3}" />
		</execute>

		<execute macro="LoopTopics#assignSelfAsExpert">
			<var name="topicName" value="${topicName4}" />
		</execute>

		<execute macro="LoopTopics#unassignSelfAsExpert">
			<var name="topicName" value="${topicName1}" />
		</execute>

		<execute macro="LoopTopics#unassignSelfAsExpert">
			<var name="topicName" value="${topicName2}" />
		</execute>

		<execute macro="Loop#logoutAndLogin">
			<var name="userLoginEmailAddress" value="${userEmailAddress}" />
		</execute>

		<execute macro="LoopPeople#gotoPersonProfile">
			<var name="userName" value="${userName}" />
		</execute>

		<execute macro="LoopPeoplePerson#gotoAboutSection" />

		<execute macro="LoopPeoplePerson#viewExpertise">
			<var name="expertiseName" value="${topicName1}" />
		</execute>

		<execute macro="LoopPeoplePerson#viewExpertise">
			<var name="expertiseName" value="${topicName2}" />
		</execute>

		<execute macro="LoopPeoplePerson#viewNoExpertise">
			<var name="expertiseName" value="${topicName3}" />
		</execute>

		<execute macro="LoopPeoplePerson#viewNoExpertise">
			<var name="expertiseName" value="${topicName4}" />
		</execute>

		<execute macro="LoopPeople#gotoPersonProfile">
			<var name="userName" value="${userName2}" />
		</execute>

		<execute macro="LoopPeoplePerson#gotoAboutSection" />

		<execute macro="LoopPeoplePerson#viewExpertise">
			<var name="expertiseName" value="${topicName3}" />
		</execute>

		<execute macro="LoopPeoplePerson#viewExpertise">
			<var name="expertiseName" value="${topicName4}" />
		</execute>

		<execute macro="LoopPeoplePerson#viewNoExpertise">
			<var name="expertiseName" value="${topicName1}" />
		</execute>

		<execute macro="LoopPeoplePerson#viewNoExpertise">
			<var name="expertiseName" value="${topicName2}" />
		</execute>

		<execute macro="LoopTopics#viewExpert">
			<var name="expertEmailAddress" value="${userEmailAddress}" />
			<var name="expertName" value="${userName}" />
			<var name="topicName" value="${topicName1}" />
		</execute>

		<execute macro="LoopTopics#viewExpert">
			<var name="expertEmailAddress" value="${userEmailAddress}" />
			<var name="expertName" value="${userName}" />
			<var name="topicName" value="${topicName2}" />
		</execute>

		<execute macro="LoopTopics#viewExpert">
			<var name="expertEmailAddress" value="${userEmailAddress2}" />
			<var name="expertName" value="${userName2}" />
			<var name="topicName" value="${topicName3}" />
		</execute>

		<execute macro="LoopTopics#viewExpert">
			<var name="expertEmailAddress" value="${userEmailAddress2}" />
			<var name="expertName" value="${userName2}" />
			<var name="topicName" value="${topicName4}" />
		</execute>

		<execute macro="LoopTopics#viewNoExpert">
			<var name="expertName" value="${userName2}" />
			<var name="topicName" value="${topicName1}" />
		</execute>

		<execute macro="LoopTopics#viewNoExpert">
			<var name="expertName" value="${userName2}" />
			<var name="topicName" value="${topicName2}" />
		</execute>

		<execute macro="LoopTopics#viewNoExpert">
			<var name="expertName" value="${userName}" />
			<var name="topicName" value="${topicName3}" />
		</execute>

		<execute macro="LoopTopics#viewNoExpert">
			<var name="expertName" value="${userName}" />
			<var name="topicName" value="${topicName4}" />
		</execute>
	</command>

	<command name="AddFeedback" priority="5">
		<property name="portlet.properties.loop-portlet" value="loop.topic.feedback.name=loopfeedback" />

		<var name="feedEntryText" value="Feedback Text" />
		<var name="topicDescription" value="A place to add feedback for Loop" />
		<var name="topicName" value="loopfeedback" />
		<var name="userEmailAddress2" value="loopuser02@liferay.com" />
		<var name="userFirstName2" value="Loop02" />
		<var name="userLastName2" value="User02" />
		<var name="userName2" value="Loop02 User02" />
		<var name="userScreenName2" value="loopuser02" />

		<execute macro="LoopJson#addPerson">
			<var name="userEmailAddress" value="${userEmailAddress2}" />
			<var name="userFirstName" value="${userFirstName2}" />
			<var name="userLastName" value="${userLastName2}" />
