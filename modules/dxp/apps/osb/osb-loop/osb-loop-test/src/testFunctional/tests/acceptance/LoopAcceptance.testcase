	<command name="AddEntryCommentReplies" priority="5">
		<var name="feedEntryCommentReplyText1" value="Feed Entry Comment Reply1 Text" />
		<var name="feedEntryCommentReplyText2" value="Feed Entry Comment Reply2 Text" />
		<var name="feedEntryCommentReplyText3" value="Feed Entry Comment Reply3 Text" />
		<var name="feedEntryCommentText" value="Feed Entry Comment Text" />
		<var name="feedEntryText" value="Feed Entry Text" />
		<var name="userEmailAddress2" value="loopuser02@liferay.com" />
		<var name="userEmailAddress3" value="loopuser03@liferay.com" />
		<var name="userEmailAddress4" value="loopuser04@liferay.com" />
		<var name="userFirstName2" value="Loop02" />
		<var name="userFirstName3" value="Loop03" />
