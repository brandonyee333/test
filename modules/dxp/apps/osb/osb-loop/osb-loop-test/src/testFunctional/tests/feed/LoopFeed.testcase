		<execute macro="Loop#openURL" />

		<execute macro="LoopFeedEntry#clickAndTypeText">
			<var name="feedEntryText" value="${feedEntryText}" />
		</execute>

		<execute macro="LoopFeedEntry#post" />

		<execute macro="LoopFeedEntry#clickOptionsLink">
			<var name="feedEntryContent" value="${feedEntryPartialContent1}" />
		</execute>

		<execute macro="LoopFeedEntry#clickEditLink" />

		<execute macro="LoopFeedEntry#clickEditTextFieldBeginning" />

		<execute macro="LoopFeedEntry#typeTextInEditTextField">
			<var name="feedEntryText" value="${feedEntryTextEdit}" />
		</execute>

		<execute macro="LoopFeedEntry#typeSpaceInEditTextField" />

		<execute macro="LoopFeedEntry#postEdit" />

		<execute macro="LoopFeedEntry#viewAuthorAndContent">
			<var name="feedEntryAuthorName" value="${userName}" />
			<var name="feedEntryContent" value="${feedEntryTextEdit} ${feedEntryText}" />
		</execute>

		<execute macro="Loop#openURL" />

		<execute macro="LoopFeedEntry#viewAuthorAndPartialContent">
			<var name="feedEntryAuthorName" value="${userName}" />
			<var name="feedEntryPartialContent" value="${feedEntryPartialContent1Edit}" />
		</execute>

		<execute macro="LoopFeedEntry#clickSeeMoreLink">
			<var name="feedEntryPartialContent" value="${feedEntryPartialContent1Edit}" />
		</execute>

		<execute macro="LoopFeedEntry#viewAuthorAndPartialContent">
			<var name="feedEntryAuthorName" value="${userName}" />
			<var name="feedEntryPartialContent" value="${feedEntryPartialContent2Edit}" />
		</execute>

		<execute macro="LoopFeedEntry#clickSeeFullPostLink">
			<var name="feedEntryPartialContent" value="${feedEntryPartialContent2Edit}" />
		</execute>

		<execute macro="LoopFeedEntry#viewAuthorAndContent">
			<var name="feedEntryAuthorName" value="${userName}" />
			<var name="feedEntryContent" value="${feedEntryTextEdit} ${feedEntryText}" />
		</execute>

		<execute macro="Loop#openURL" />

		<execute macro="LoopFeedEntry#clickTimestamp">
			<var name="feedEntryContent" value="${feedEntryPartialContent1Edit}" />
		</execute>

		<execute macro="LoopFeedEntry#viewAuthorAndContent">
			<var name="feedEntryAuthorName" value="${userName}" />
			<var name="feedEntryContent" value="${feedEntryTextEdit} ${feedEntryText}" />
		</execute>

		<execute macro="LoopNavigation#gotoMyProfile" />

		<execute macro="LoopFeedEntry#viewAuthorAndPartialContent">
			<var name="feedEntryAuthorName" value="${userName}" />
			<var name="feedEntryPartialContent" value="${feedEntryPartialContent1Edit}" />
		</execute>

		<execute macro="LoopFeedEntry#clickSeeMoreLink">
			<var name="feedEntryPartialContent" value="${feedEntryPartialContent1Edit}" />
		</execute>

		<execute macro="LoopFeedEntry#viewAuthorAndPartialContent">
			<var name="feedEntryAuthorName" value="${userName}" />
			<var name="feedEntryPartialContent" value="${feedEntryPartialContent2Edit}" />
		</execute>

		<execute macro="LoopFeedEntry#clickSeeFullPostLink">
			<var name="feedEntryPartialContent" value="${feedEntryPartialContent2Edit}" />
		</execute>

		<execute macro="LoopFeedEntry#viewAuthorAndContent">
			<var name="feedEntryAuthorName" value="${userName}" />
			<var name="feedEntryContent" value="${feedEntryTextEdit} ${feedEntryText}" />
		</execute>

		<!-- Workaround until LOOP-5354 is fixed -->

		<execute macro="LoopNavigation#gotoMyProfile" />

		<execute macro="LoopNavigation#gotoMyProfile" />

		<execute macro="LoopFeedEntry#clickTimestamp">
			<var name="feedEntryContent" value="${feedEntryPartialContent1Edit}" />
		</execute>

		<execute macro="LoopFeedEntry#viewAuthorAndContent">
			<var name="feedEntryAuthorName" value="${userName}" />
			<var name="feedEntryContent" value="${feedEntryTextEdit} ${feedEntryText}" />
		</execute>
	</command>

