		</execute>

		<var name="feedEntryImageList" value="${feedEntryImage1},${feedEntryImage2},${feedEntryImage3}" />
		<var name="positionValue" value="0" />

		<for list="${feedEntryImageList}" param="feedEntryImage">
			<var method="MathUtil#sum('${positionValue}', '1')" name="positionValue" />

			<execute macro="LoopFeedEntry#uploadImage">
				<var name="feedEntryImage" value="${feedEntryImage}" />
			</execute>

			<execute macro="LoopFeedEntry#viewSpecificImagePreview">
				<var name="positionValue" value="${positionValue}" />
			</execute>
		</for>

