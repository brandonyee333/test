		<execute macro="LoopJson#createTopic">
			<var name="topicDescription" value="${topicDescription}" />
			<var name="topicName" value="${topicName}" />
		</execute>

		<execute macro="Loop#openURL" />

		<execute macro="LoopFeedEntry#clickAndTypeHashtag">
			<var name="topicName" value="${topicName}" />
		</execute>

		<execute macro="LoopFeedEntry#selectTopicFromDropdown">
			<var name="topicName" value="${topicName}" />
		</execute>

		<execute macro="LoopFeedEntry#typeSpace" />

		<execute macro="LoopFeedEntry#typeText">
			<var name="feedEntryText" value="${feedEntryText}" />
		</execute>

		<execute macro="LoopFeedEntry#post" />

		<execute macro="LoopFeedEntry#viewAuthorAndPartialContent">
			<var name="feedEntryAuthorName" value="${userName}" />
			<var name="feedEntryPartialContent" value="${feedEntryPartialContent1}" />
		</execute>

		<execute macro="Loop#openURL" />

		<execute macro="LoopFeedEntry#viewHashtag">
			<var name="feedEntryContent" value="${feedEntryPartialContent1}" />
			<var name="topicName" value="${topicName}" />
		</execute>

		<execute macro="Loop#openURL" />

		<execute macro="LoopFeedEntry#clickSeeMoreLink">
			<var name="feedEntryPartialContent" value="${feedEntryPartialContent1}" />
		</execute>

		<execute macro="LoopFeedEntry#viewHashtag">
			<var name="feedEntryContent" value="${feedEntryPartialContent2}" />
			<var name="topicName" value="${topicName}" />
		</execute>

		<execute macro="Loop#openURL" />

		<execute macro="LoopFeedEntry#clickSeeMoreLink">
			<var name="feedEntryPartialContent" value="${feedEntryPartialContent1}" />
		</execute>

		<execute macro="LoopFeedEntry#clickSeeFullPostLink">
			<var name="feedEntryPartialContent" value="${feedEntryPartialContent2}" />
		</execute>

		<execute macro="LoopFeedEntry#viewHashtag">
			<var name="feedEntryContent" value="#${topicName} ${feedEntryText}" />
			<var name="topicName" value="${topicName}" />
		</execute>

		<execute macro="Loop#openURL" />

		<execute macro="LoopFeedEntry#clickTimestamp">
			<var name="feedEntryContent" value="${feedEntryPartialContent1}" />
		</execute>

		<execute macro="LoopFeedEntry#viewHashtag">
			<var name="feedEntryContent" value="#${topicName} ${feedEntryText}" />
			<var name="topicName" value="${topicName}" />
		</execute>

		<execute macro="LoopNavigation#gotoMyProfile" />

		<execute macro="LoopFeedEntry#viewHashtag">
			<var name="feedEntryContent" value="${feedEntryPartialContent1}" />
			<var name="topicName" value="${topicName}" />
		</execute>

		<execute macro="LoopNavigation#gotoMyProfile" />

		<execute macro="LoopFeedEntry#clickSeeMoreLink">
			<var name="feedEntryPartialContent" value="${feedEntryPartialContent1}" />
		</execute>

		<execute macro="LoopFeedEntry#viewHashtag">
			<var name="feedEntryContent" value="${feedEntryPartialContent2}" />
			<var name="topicName" value="${topicName}" />
		</execute>

		<execute macro="LoopNavigation#gotoMyProfile" />

		<execute macro="LoopFeedEntry#clickSeeMoreLink">
			<var name="feedEntryPartialContent" value="${feedEntryPartialContent1}" />
		</execute>

		<execute macro="LoopFeedEntry#clickSeeFullPostLink">
			<var name="feedEntryPartialContent" value="${feedEntryPartialContent2}" />
		</execute>

		<execute macro="LoopFeedEntry#viewHashtag">
			<var name="feedEntryContent" value="#${topicName} ${feedEntryText}" />
			<var name="topicName" value="${topicName}" />
		</execute>

		<execute macro="LoopNavigation#gotoMyProfile" />

		<execute macro="LoopFeedEntry#clickTimestamp">
			<var name="feedEntryContent" value="${feedEntryPartialContent1}" />
		</execute>

		<execute macro="LoopFeedEntry#viewHashtag">
			<var name="feedEntryContent" value="#${topicName} ${feedEntryText}" />
			<var name="topicName" value="${topicName}" />
		</execute>
	</command>

