	<command name="ChangeEntryImages" priority="5">
		<var name="feedEntryImage1" value="/Document_1.jpg" />
		<var name="feedEntryImage2" value="/Document_2.jpg" />
		<var name="feedEntryImage3" value="/Document_3.jpg" />
