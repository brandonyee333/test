	<command name="ViewInvalidMentionsAndHashtags" priority="5">
		<var name="topicDescription1" value="Topic Description1" />
		<var name="topicDescription2" value="Topic Description2" />
		<var name="topicName1" value="TopicName1" />
		<var name="topicName2" value="TopicName2" />
		<var name="userEmailAddress2" value="loopuser02@liferay.com" />
		<var name="userEmailAddress3" value="loopuser03@liferay.com" />
		<var name="userEmailAddress4" value="loopuser04@liferay.com" />
