<definition component-name="loop-feed">
	<property name="loop.enabled" value="true" />
	<!--<property name="hook.plugins.includes" value="portal-compat-hook" />-->
	<property name="osgi.module.configuration.file.names" value="com.liferay.portal.security.auto.login.basic.auth.header.module.configuration.BasicAuthHeaderAutoLoginConfiguration.cfg:com.liferay.portal.bundle.blacklist.internal.BundleBlacklistConfiguration.cfg" />
	<property name="osgi.module.configurations" value="enabled=true:blacklistBundleSymbolicNames=['com.liferay.portal.search.elasticsearch', 'com.liferay.portal.search.elasticsearch.shield', 'com.liferay.portal.search.elasticsearch.marvel.web']" />
	<!--<property name="portlet.plugins.includes" value="asset-entry-set-portlet,asset-feed-portlet,asset-sharing-portlet,loop-portlet" />-->
	<property name="skip.clean-app-server-deploy-dir" value="true" />
	<property name="testray.main.component.name" value="Loop" />
	<!--<property name="theme.plugins.includes" value="loop-theme" />
	<property name="web.plugins.includes" value="url-metadata-scraper-web" />-->

	<var name="userEmailAddress" value="loopuser01@liferay.com" />
	<var name="userFirstName" value="Loop01" />
	<var name="userLastName" value="User01" />
	<var name="userName" value="Loop01 User01" />
	<var name="userScreenName" value="loopuser01" />

	<set-up>
		<execute macro="Loop#firstSetupPG">
			<var name="roleNames" value="Loop Admin,Loop Global Announcer,Loop Curator" />
		</execute>
	</set-up>

	<command name="AddAnimatedImageEntry" priority="5">
		<var name="feedEntryImage" value="/Document_1.gif" />
		<var name="feedEntryText" value="Feed Entry Text" />

		<execute macro="Loop#openURL" />

		<execute macro="LoopFeed#addAnimatedImageEntry">
			<var name="feedEntryAuthorName" value="${userName}" />
			<var name="feedEntryContent" value="${feedEntryText}" />
			<var name="feedEntryImage" value="${feedEntryImage}" />
			<var name="feedEntryText" value="${feedEntryText}" />
		</execute>

		<execute macro="Loop#openURL" />

		<execute macro="LoopFeed#viewAnimatedImageEntry">
			<var name="feedEntryAuthorName" value="${userName}" />
			<var name="feedEntryContent" value="${feedEntryText}" />
		</execute>

		<execute macro="LoopFeedEntry#clickTimestamp">
			<var name="feedEntryContent" value="${feedEntryText}" />
		</execute>

		<execute macro="LoopFeed#viewAnimatedImageEntry">
			<var name="feedEntryAuthorName" value="${userName}" />
			<var name="feedEntryContent" value="${feedEntryText}" />
		</execute>

		<execute macro="LoopNavigation#gotoMyProfile" />

		<execute macro="LoopFeed#viewAnimatedImageEntry">
			<var name="feedEntryAuthorName" value="${userName}" />
			<var name="feedEntryContent" value="${feedEntryText}" />
		</execute>

		<execute macro="LoopFeedEntry#clickTimestamp">
			<var name="feedEntryContent" value="${feedEntryText}" />
		</execute>

		<execute macro="LoopFeed#viewAnimatedImageEntry">
			<var name="feedEntryAuthorName" value="${userName}" />
			<var name="feedEntryContent" value="${feedEntryText}" />
		</execute>
	</command>

	<command name="AddAnimatedImagesEntry" priority="5">
		<var name="feedEntryImage1" value="/Document_1.gif" />
		<var name="feedEntryImage2" value="/Document_2.gif" />
		<var name="feedEntryImage3" value="/Document_3.gif" />
		<var name="feedEntryText" value="Feed Entry Text" />

		<execute macro="Loop#openURL" />

		<execute macro="LoopFeed#addAnimatedImagesEntry">
			<var name="feedEntryAuthorName" value="${userName}" />
			<var name="feedEntryContent" value="${feedEntryText}" />
			<var name="feedEntryImageList" value="${feedEntryImage1},${feedEntryImage2},${feedEntryImage3}" />
			<var name="feedEntryText" value="${feedEntryText}" />
			<var name="numberOfImages" value="3" />
		</execute>

		<execute macro="Loop#openURL" />

		<execute macro="LoopFeed#viewAnimatedImagesEntry">
			<var name="feedEntryAuthorName" value="${userName}" />
			<var name="feedEntryContent" value="${feedEntryText}" />
			<var name="numberOfImages" value="3" />
		</execute>

		<execute macro="LoopFeedEntry#clickTimestamp">
			<var name="feedEntryContent" value="${feedEntryText}" />
		</execute>

		<execute macro="LoopFeed#viewAnimatedImagesEntry">
			<var name="feedEntryAuthorName" value="${userName}" />
			<var name="feedEntryContent" value="${feedEntryText}" />
			<var name="numberOfImages" value="3" />
		</execute>

		<execute macro="LoopNavigation#gotoMyProfile" />

		<execute macro="LoopFeed#viewAnimatedImagesEntry">
			<var name="feedEntryAuthorName" value="${userName}" />
			<var name="feedEntryContent" value="${feedEntryText}" />
			<var name="numberOfImages" value="3" />
		</execute>

		<execute macro="LoopFeedEntry#clickTimestamp">
			<var name="feedEntryContent" value="${feedEntryText}" />
		</execute>

		<execute macro="LoopFeed#viewAnimatedImagesEntry">
			<var name="feedEntryAuthorName" value="${userName}" />
			<var name="feedEntryContent" value="${feedEntryText}" />
			<var name="numberOfImages" value="3" />
		</execute>
	</command>

	<command name="AddAnnouncementEntries" priority="5">
		<var name="feedEntryStickyTimeInDays" value="2" />
		<var name="feedEntryText1" value="Feed Entry1 Text" />
		<var name="feedEntryText2" value="Feed Entry2 Text" />
		<var name="feedEntryText3" value="Feed Entry3 Text" />
		<var name="feedEntryText4" value="Feed Entry4 Text" />
		<var name="feedEntryTitle1" value="Feed Entry1 Title" />
		<var name="feedEntryTitle2" value="Feed Entry2 Title" />
		<var name="feedEntryTitle3" value="Feed Entry3 Title" />
		<var name="feedEntryTitle4" value="Feed Entry4 Title" />

		<execute macro="Loop#openURL" />

		<execute macro="LoopFeed#addAnnouncementEntry">
			<var name="feedEntryAuthorName" value="${userName}" />
			<var name="feedEntryContent" value="${feedEntryText1}" />
			<var name="feedEntryStickyTimeInDays" value="${feedEntryStickyTimeInDays}" />
			<var name="feedEntryText" value="${feedEntryText1}" />
			<var name="feedEntryTitle" value="${feedEntryTitle1}" />
		</execute>

		<execute macro="LoopFeed#addAnnouncementEntry">
			<var name="feedEntryAuthorName" value="${userName}" />
			<var name="feedEntryContent" value="${feedEntryText2}" />
			<var name="feedEntryStickyTimeInDays" value="${feedEntryStickyTimeInDays}" />
			<var name="feedEntryText" value="${feedEntryText2}" />
			<var name="feedEntryTitle" value="${feedEntryTitle2}" />
		</execute>

		<execute macro="LoopFeed#addAnnouncementEntry">
			<var name="feedEntryAuthorName" value="${userName}" />
			<var name="feedEntryContent" value="${feedEntryText3}" />
			<var name="feedEntryStickyTimeInDays" value="${feedEntryStickyTimeInDays}" />
			<var name="feedEntryText" value="${feedEntryText3}" />
			<var name="feedEntryTitle" value="${feedEntryTitle3}" />
		</execute>

		<execute macro="LoopFeed#addAnnouncementEntry">
			<var name="feedEntryAuthorName" value="${userName}" />
			<var name="feedEntryContent" value="${feedEntryText4}" />
			<var name="feedEntryStickyTimeInDays" value="${feedEntryStickyTimeInDays}" />
			<var name="feedEntryText" value="${feedEntryText4}" />
			<var name="feedEntryTitle" value="${feedEntryTitle4}" />
		</execute>

		<execute macro="LoopFeedEntry#gotoAnnouncementsTab" />

		<execute macro="LoopFeedEntryAnnouncements#viewAnnouncementAuthorAndContent">
			<var name="feedEntryAuthorName" value="${userName}" />
			<var name="feedEntryContent" value="${feedEntryText1}" />
			<var name="feedEntryStickyTimeInDays" value="${feedEntryStickyTimeInDays}" />
			<var name="feedEntryTitle" value="${feedEntryTitle1}" />
		</execute>

		<execute macro="LoopFeedEntryAnnouncements#viewAnnouncementAuthorAndContent">
			<var name="feedEntryAuthorName" value="${userName}" />
			<var name="feedEntryContent" value="${feedEntryText2}" />
			<var name="feedEntryStickyTimeInDays" value="${feedEntryStickyTimeInDays}" />
			<var name="feedEntryTitle" value="${feedEntryTitle2}" />
		</execute>

		<execute macro="LoopFeedEntryAnnouncements#viewAnnouncementAuthorAndContent">
			<var name="feedEntryAuthorName" value="${userName}" />
			<var name="feedEntryContent" value="${feedEntryText3}" />
			<var name="feedEntryStickyTimeInDays" value="${feedEntryStickyTimeInDays}" />
			<var name="feedEntryTitle" value="${feedEntryTitle3}" />
		</execute>

		<execute macro="LoopFeedEntryAnnouncements#viewAnnouncementAuthorAndContent">
			<var name="feedEntryAuthorName" value="${userName}" />
			<var name="feedEntryContent" value="${feedEntryText4}" />
			<var name="feedEntryStickyTimeInDays" value="${feedEntryStickyTimeInDays}" />
			<var name="feedEntryTitle" value="${feedEntryTitle4}" />
		</execute>

		<execute macro="Loop#openURL" />

		<execute macro="LoopFeedEntry#viewAnnouncementAuthorAndContent">
			<var name="feedEntryAuthorName" value="${userName}" />
			<var name="feedEntryContent" value="${feedEntryText4}" />
			<var name="feedEntryTitle" value="${feedEntryTitle4}" />
		</execute>

		<execute macro="LoopFeedEntry#clickAnnouncementHeaderRightArrow" />

		<execute macro="LoopFeedEntry#viewAnnouncementAuthorAndContent">
			<var name="feedEntryAuthorName" value="${userName}" />
			<var name="feedEntryContent" value="${feedEntryText3}" />
			<var name="feedEntryTitle" value="${feedEntryTitle3}" />
		</execute>

		<execute macro="LoopFeedEntry#clickAnnouncementHeaderRightArrow" />

		<execute macro="LoopFeedEntry#viewAnnouncementAuthorAndContent">
			<var name="feedEntryAuthorName" value="${userName}" />
			<var name="feedEntryContent" value="${feedEntryText2}" />
			<var name="feedEntryTitle" value="${feedEntryTitle2}" />
		</execute>

		<execute macro="LoopFeedEntry#clickAnnouncementHeaderRightArrow" />

		<execute macro="LoopFeedEntry#viewAnnouncementAuthorAndContent">
			<var name="feedEntryAuthorName" value="${userName}" />
			<var name="feedEntryContent" value="${feedEntryText1}" />
			<var name="feedEntryTitle" value="${feedEntryTitle1}" />
		</execute>

		<execute macro="LoopFeedEntry#clickAnnouncementHeaderLeftArrow" />

		<execute macro="LoopFeedEntry#viewAnnouncementAuthorAndContent">
			<var name="feedEntryAuthorName" value="${userName}" />
			<var name="feedEntryContent" value="${feedEntryText2}" />
			<var name="feedEntryTitle" value="${feedEntryTitle2}" />
		</execute>

		<execute macro="LoopFeedEntry#clickAnnouncementHeaderLeftArrow" />

		<execute macro="LoopFeedEntry#viewAnnouncementAuthorAndContent">
			<var name="feedEntryAuthorName" value="${userName}" />
			<var name="feedEntryContent" value="${feedEntryText3}" />
			<var name="feedEntryTitle" value="${feedEntryTitle3}" />
		</execute>

		<execute macro="LoopFeedEntry#clickAnnouncementHeaderLeftArrow" />

		<execute macro="LoopFeedEntry#viewAnnouncementAuthorAndContent">
			<var name="feedEntryAuthorName" value="${userName}" />
			<var name="feedEntryContent" value="${feedEntryText4}" />
			<var name="feedEntryTitle" value="${feedEntryTitle4}" />
		</execute>
	</command>

	<command name="AddAnnouncementEntry" priority="5">
		<var name="feedEntryStickyTimeInDays" value="2" />
		<var name="feedEntryText" value="Feed Entry Text" />
		<var name="feedEntryTitle" value="Feed Entry Title" />

		<execute macro="Loop#openURL" />

		<execute macro="LoopFeed#addAnnouncementEntry">
			<var name="feedEntryAuthorName" value="${userName}" />
			<var name="feedEntryContent" value="${feedEntryText}" />
			<var name="feedEntryStickyTimeInDays" value="${feedEntryStickyTimeInDays}" />
			<var name="feedEntryText" value="${feedEntryText}" />
			<var name="feedEntryTitle" value="${feedEntryTitle}" />
		</execute>

		<execute macro="LoopFeedEntry#gotoAnnouncementsTab" />

		<execute macro="LoopFeedEntryAnnouncements#viewAnnouncementAuthorAndContent">
			<var name="feedEntryAuthorName" value="${userName}" />
			<var name="feedEntryContent" value="${feedEntryText}" />
			<var name="feedEntryStickyTimeInDays" value="${feedEntryStickyTimeInDays}" />
			<var name="feedEntryTitle" value="${feedEntryTitle}" />
		</execute>
	</command>

	<command name="AddAnnouncementEntryForGroupAsLead" priority="5">
		<var name="feedEntryStickyTimeInDays" value="2" />
		<var name="feedEntryText" value="Feed Entry Text" />
		<var name="feedEntryTitle" value="Feed Entry Title" />
		<var name="teamDescription" value="Team Description" />
		<var name="teamName" value="Team Name" />
		<var name="userEmailAddress2" value="loopuser02@liferay.com" />
		<var name="userFirstName2" value="Loop02" />
		<var name="userLastName2" value="User02" />
		<var name="userName2" value="Loop02 User02" />
		<var name="userScreenName2" value="loopuser02" />

		<execute macro="LoopJson#addPerson">
			<var name="userEmailAddress" value="${userEmailAddress2}" />
			<var name="userFirstName" value="${userFirstName2}" />
			<var name="userLastName" value="${userLastName2}" />
			<var name="userScreenName" value="${userScreenName2}" />
		</execute>

		<execute macro="LoopJson#createGroup">
			<var name="groupDescription" value="${teamDescription}" />
			<var name="groupName" value="${teamName}" />
			<var name="groupType" value="Team" />
			<var name="leadScreenNameList" value="${userScreenName}" />
			<var name="memberScreenNameList" value="${userScreenName2}" />
		</execute>

		<execute macro="Loop#openURL" />

		<execute macro="LoopFeed#addAnnouncementEntry">
			<var name="feedEntryAuthorName" value="${teamName}" />
			<var name="feedEntryContent" value="${feedEntryText}" />
			<var name="feedEntryStickyTimeInDays" value="${feedEntryStickyTimeInDays}" />
			<var name="feedEntryText" value="${feedEntryText}" />
			<var name="feedEntryTitle" value="${feedEntryTitle}" />
		</execute>

		<execute macro="Loop#logoutAndLogin">
			<var name="userLoginEmailAddress" value="${userEmailAddress2}" />
		</execute>

		<execute macro="LoopFeedEntry#gotoAnnouncementsTab" />

		<execute macro="LoopFeedEntryAnnouncements#viewAnnouncementAuthorAndContent">
			<var name="feedEntryAuthorName" value="${teamName}" />
			<var name="feedEntryContent" value="${feedEntryText}" />
			<var name="feedEntryStickyTimeInDays" value="${feedEntryStickyTimeInDays}" />
			<var name="feedEntryTitle" value="${feedEntryTitle}" />
		</execute>
	</command>

	<command name="AddEntryContainingMarkdownContent" priority="5">
		<var name="feedEntryPartialText" value="Heading" />

		<execute macro="LoopFeedEntry#clickTextField" />

		<execute macro="LoopFeed#typeMarkdownContent" />

		<execute macro="LoopFeedEntry#clickPreviewButton" />

		<execute macro="LoopFeedEntry#viewPreviewAuthorAndPartialContent">
			<var name="feedEntryAuthorName" value="${userName}" />
			<var name="feedEntryPartialContent" value="${feedEntryPartialText}" />
		</execute>

		<execute macro="LoopFeedEntry#scrollPreviewFooterIntoView" />

		<execute macro="LoopFeedEntry#viewMarkdownContent" />

		<execute macro="LoopFeedEntry#clickPreviewPostButton" />

		<execute macro="LoopFeedEntry#viewAuthorAndPartialContent">
			<var name="feedEntryAuthorName" value="${userName}" />
			<var name="feedEntryPartialContent" value="${feedEntryPartialText}" />
		</execute>

		<execute macro="LoopFeedEntry#scrollDown" />

		<execute macro="LoopFeedEntry#viewMarkdownContent" />

		<execute macro="Loop#openURL" />

		<execute macro="LoopFeedEntry#viewAuthorAndPartialContent">
			<var name="feedEntryAuthorName" value="${userName}" />
			<var name="feedEntryPartialContent" value="${feedEntryPartialText}" />
		</execute>

		<execute macro="LoopFeedEntry#scrollDown" />

		<execute macro="LoopFeedEntry#viewMarkdownContent" />

		<execute macro="LoopNavigation#gotoMyProfile" />

		<execute macro="LoopFeedEntry#viewAuthorAndPartialContent">
			<var name="feedEntryAuthorName" value="${userName}" />
			<var name="feedEntryPartialContent" value="${feedEntryPartialText}" />
		</execute>

		<execute macro="LoopFeedEntry#scrollDown" />

		<execute macro="LoopFeedEntry#viewMarkdownContent" />
	</command>

	<command name="AddEntryContainingMarkdownContentWithHashtags" priority="5">
		<var name="feedEntryPartialText" value="Heading" />
		<var name="topicDescription1" value="Topic Description1" />
		<var name="topicDescription2" value="Topic Description2" />
		<var name="topicName1" value="TopicName1" />
		<var name="topicName2" value="TopicName2" />
		<var name="userEmailAddress2" value="loopuser02@liferay.com" />
		<var name="userEmailAddress3" value="loopuser03@liferay.com" />
		<var name="userEmailAddress4" value="loopuser04@liferay.com" />
		<var name="userFirstName2" value="Loop02" />
		<var name="userFirstName3" value="Loop03" />
		<var name="userFirstName4" value="Loop04" />
		<var name="userLastName2" value="User02" />
		<var name="userLastName3" value="User03" />
		<var name="userLastName4" value="User04" />
		<var name="userName2" value="Loop02 User02" />
		<var name="userName3" value="Loop03 User03" />
		<var name="userName4" value="Loop04 User04" />
		<var name="userScreenName2" value="loopuser02" />
		<var name="userScreenName3" value="loopuser03" />
		<var name="userScreenName4" value="loopuser04" />

		<execute macro="LoopJson#addPeople">
			<var name="personNumberList" value="02,03,04" />
		</execute>

		<execute macro="LoopJson#createTopic">
			<var name="topicDescription" value="${topicDescription1}" />
			<var name="topicName" value="${topicName1}" />
		</execute>

		<execute macro="LoopJson#createTopic">
			<var name="topicDescription" value="${topicDescription2}" />
			<var name="topicName" value="${topicName2}" />
		</execute>

		<execute macro="LoopPeople#gotoPersonProfile">
			<var name="userName" value="${userName2}" />
		</execute>

		<execute macro="LoopPeople#updateExpertise">
			<var name="expertiseName" value="${topicName1}" />
		</execute>

		<execute macro="LoopPeople#gotoPersonProfile">
			<var name="userName" value="${userName3}" />
		</execute>

		<execute macro="LoopPeople#updateExpertise">
			<var name="expertiseName" value="${topicName2}" />
		</execute>

		<execute macro="Loop#openURL" />

		<execute macro="LoopFeedEntry#clickTextField" />

		<execute macro="LoopFeed#typeMarkdownContent" />

		<execute macro="LoopFeedEntry#typeReturn" />

		<execute macro="LoopFeedEntry#typeReturn" />

		<execute macro="LoopFeedEntry#typeHashtag">
			<var name="topicName" value="${topicName1}" />
		</execute>

		<execute macro="LoopFeedEntry#selectTopicFromDropdown">
			<var name="topicName" value="${topicName1}" />
		</execute>

		<execute macro="LoopFeedEntry#typeSpace" />

		<execute macro="LoopFeedEntry#typeHashtag">
			<var name="topicName" value="${topicName2}" />
		</execute>

		<execute macro="LoopFeedEntry#selectTopicFromDropdown">
			<var name="topicName" value="${topicName2}" />
		</execute>

		<execute macro="LoopFeedEntry#post" />

		<execute macro="LoopFeedEntry#viewAuthorAndPartialContent">
			<var name="feedEntryAuthorName" value="${userName}" />
			<var name="feedEntryPartialContent" value="${feedEntryPartialText}" />
		</execute>

		<execute macro="LoopFeedEntry#scrollDown" />

		<execute macro="LoopFeedEntry#viewMarkdownContent" />

		<execute macro="Loop#openURL" />

		<execute macro="LoopFeedEntry#viewAuthorAndPartialContent">
			<var name="feedEntryAuthorName" value="${userName}" />
			<var name="feedEntryPartialContent" value="${feedEntryPartialText}" />
		</execute>

		<execute macro="LoopFeedEntry#viewHashtag">
			<var name="feedEntryContent" value="${feedEntryPartialText}" />
			<var name="topicDescription" value="${topicDescription1}" />
			<var name="topicName" value="${topicName1}" />
		</execute>

		<execute macro="LoopFeedEntry#viewAuthorAndPartialContent">
			<var name="feedEntryAuthorName" value="${userName}" />
			<var name="feedEntryPartialContent" value="${feedEntryPartialText}" />
		</execute>

		<execute macro="Loop#openURL" />

		<execute macro="LoopFeedEntry#viewHashtag">
			<var name="feedEntryContent" value="${feedEntryPartialText}" />
			<var name="topicDescription" value="${topicDescription2}" />
			<var name="topicName" value="${topicName2}" />
		</execute>

		<execute macro="LoopFeedEntry#viewAuthorAndPartialContent">
			<var name="feedEntryAuthorName" value="${userName}" />
			<var name="feedEntryPartialContent" value="${feedEntryPartialText}" />
		</execute>

		<execute macro="Loop#openURL" />

		<execute macro="LoopFeedEntry#viewTopicViaSharedToList">
			<var name="feedEntryContent" value="${feedEntryPartialText}" />
			<var name="numberOfTopicShares" value="2" />
			<var name="topicDescription" value="${topicDescription1}" />
			<var name="topicName" value="${topicName1}" />
		</execute>

		<execute macro="Loop#openURL" />

		<execute macro="LoopFeedEntry#viewTopicViaSharedToList">
			<var name="feedEntryContent" value="${feedEntryPartialText}" />
			<var name="numberOfTopicShares" value="2" />
			<var name="topicDescription" value="${topicDescription2}" />
			<var name="topicName" value="${topicName2}" />
		</execute>

		<execute macro="LoopNavigation#gotoMyProfile" />

		<execute macro="LoopFeedEntry#viewAuthorAndPartialContent">
			<var name="feedEntryAuthorName" value="${userName}" />
			<var name="feedEntryPartialContent" value="${feedEntryPartialText}" />
		</execute>

		<execute macro="LoopFeedEntry#viewHashtag">
			<var name="feedEntryContent" value="${feedEntryPartialText}" />
			<var name="topicDescription" value="${topicDescription1}" />
			<var name="topicName" value="${topicName1}" />
		</execute>

		<execute macro="LoopFeedEntry#viewAuthorAndPartialContent">
			<var name="feedEntryAuthorName" value="${userName}" />
			<var name="feedEntryPartialContent" value="${feedEntryPartialText}" />
		</execute>

		<execute macro="LoopNavigation#gotoMyProfile" />

		<execute macro="LoopFeedEntry#viewHashtag">
			<var name="feedEntryContent" value="${feedEntryPartialText}" />
			<var name="topicDescription" value="${topicDescription2}" />
			<var name="topicName" value="${topicName2}" />
		</execute>

		<execute macro="LoopFeedEntry#viewAuthorAndPartialContent">
			<var name="feedEntryAuthorName" value="${userName}" />
			<var name="feedEntryPartialContent" value="${feedEntryPartialText}" />
		</execute>

		<execute macro="LoopNavigation#gotoMyProfile" />

		<execute macro="LoopFeedEntry#viewTopicViaSharedToList">
			<var name="feedEntryContent" value="${feedEntryPartialText}" />
			<var name="numberOfTopicShares" value="2" />
			<var name="topicDescription" value="${topicDescription1}" />
			<var name="topicName" value="${topicName1}" />
		</execute>

		<execute macro="LoopNavigation#gotoMyProfile" />

		<execute macro="LoopFeedEntry#viewTopicViaSharedToList">
			<var name="feedEntryContent" value="${feedEntryPartialText}" />
			<var name="numberOfTopicShares" value="2" />
			<var name="topicDescription" value="${topicDescription2}" />
			<var name="topicName" value="${topicName2}" />
		</execute>

		<execute macro="Loop#logoutAndLogin">
			<var name="userLoginEmailAddress" value="${userEmailAddress2}" />
		</execute>

		<execute macro="LoopFeedEntry#viewAuthorAndPartialContent">
			<var name="feedEntryAuthorName" value="${userName}" />
			<var name="feedEntryPartialContent" value="${feedEntryPartialText}" />
		</execute>

		<execute macro="LoopFeedEntry#viewHashtag">
			<var name="feedEntryContent" value="${feedEntryPartialText}" />
			<var name="topicDescription" value="${topicDescription1}" />
			<var name="topicName" value="${topicName1}" />
		</execute>

		<execute macro="Loop#openURL" />

		<execute macro="LoopFeedEntry#viewHashtag">
			<var name="feedEntryContent" value="${feedEntryPartialText}" />
			<var name="topicDescription" value="${topicDescription2}" />
			<var name="topicName" value="${topicName2}" />
		</execute>

		<execute macro="Loop#openURL" />

		<execute macro="LoopFeedEntry#viewTopicViaSharedToList">
			<var name="feedEntryContent" value="${feedEntryPartialText}" />
			<var name="numberOfTopicShares" value="2" />
			<var name="topicDescription" value="${topicDescription1}" />
			<var name="topicName" value="${topicName1}" />
		</execute>

		<execute macro="Loop#openURL" />

