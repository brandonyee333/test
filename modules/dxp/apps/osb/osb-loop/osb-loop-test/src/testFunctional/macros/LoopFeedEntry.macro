	<command name="typeHashtag">
		<execute macro="LoopFeedEntry#typeText">
			<var name="feedEntryText" value="#" />
		</execute>

		<execute macro="LoopFeedEntry#typeText">
			<var name="feedEntryText" value="${topicName}" />
		</execute>

		<execute macro="LoopFeedEntry#typeText">
			<var name="feedEntryText" value="s" />
		</execute>

		<execute macro="LoopFeedEntry#typeBackSpace" />
	</command>

	<command name="typeHashtagInEditTextField">
		<execute macro="LoopFeedEntry#typeTextInEditTextField">
			<var name="feedEntryText" value="#" />
		</execute>

		<execute macro="LoopFeedEntry#typeTextInEditTextField">
			<var name="feedEntryText" value="${topicName}" />
		</execute>

		<execute macro="LoopFeedEntry#typeTextInEditTextField">
			<var name="feedEntryText" value="s" />
		</execute>

		<execute macro="LoopFeedEntry#typeBackSpaceInEditTextField" />
	</command>

