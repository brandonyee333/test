			<then>
				<execute function="AssertElementNotPresent#assertNotVisible" locator1="LoopFeed#ENTRY_AUTHOR_PROFILE_PICTURE" />
				<execute function="AssertElementNotPresent#assertNotVisible" locator1="LoopFeed#ENTRY_AUTHOR" />
				<execute function="AssertElementNotPresent#assertNotVisible" locator1="LoopFeed#ENTRY_DATE" />
				<execute function="AssertElementNotPresent#assertNotVisible" locator1="LoopFeed#ENTRY_CONTENT" />
			</then>
			<else>
				<execute function="AssertElementNotPresent" locator1="LoopFeed#ENTRY_AUTHOR_PROFILE_PICTURE" />
				<execute function="AssertElementNotPresent" locator1="LoopFeed#ENTRY_AUTHOR" />
				<execute function="AssertElementNotPresent" locator1="LoopFeed#ENTRY_DATE" />
				<execute function="AssertElementNotPresent" locator1="LoopFeed#ENTRY_CONTENT" />
