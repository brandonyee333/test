	<command name="viewLineBreaks">
		<var name="key_feedEntryContent" value="${feedEntryContent}" />

		<var name="lineBreakNumber" value="1" />
		<var method="MathUtil#sum('${numberOfLineBreaks}', '1')" name="lineBreakNumberEnd" />

		<while>
			<not>
				<equals arg1="${lineBreakNumber}" arg2="${lineBreakNumberEnd}" />
			</not>
			<then>
				<var name="key_lineBreakNumber" value="${lineBreakNumber}" />
				<execute function="AssertElementPresent" locator1="LoopFeed#ENTRY_CONTENT_LINE_BREAK" />
				<var method="MathUtil#sum('${lineBreakNumber}', '1')" name="lineBreakNumber" />
			</then>
		</while>
	</command>

