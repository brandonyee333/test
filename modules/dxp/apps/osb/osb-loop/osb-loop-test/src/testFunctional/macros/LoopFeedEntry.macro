		<execute function="Click" locator1="LoopFeed#ENTRY_IMAGE_FULL_SCREEN_CLOSE_BUTTON" />
	</command>

	<command name="viewImage1">
		<execute function="SikuliAssertElementPresent" locator1="LoopFeed#ENTRY_IMAGE_1" />
	</command>

	<command name="viewImage2">
		<execute function="SikuliAssertElementPresent" locator1="LoopFeed#ENTRY_IMAGE_2" />
	</command>

	<command name="viewImage2Small">
		<execute function="SikuliAssertElementPresent" locator1="LoopFeed#ENTRY_IMAGE_2_SMALL" />
	</command>

	<command name="viewImages">
		<var name="key_feedEntryContent" value="${feedEntryContent}" />
		<var name="key_positionValue" value="${numberOfImages}" />

		<var name="imageNumber" value="1" />

		<if>
			<not>
				<or>
					<equals arg1="${numberOfImages}" arg2="0" />
					<equals arg1="${numberOfImages}" arg2="1" />
					<equals arg1="${numberOfImages}" arg2="2" />
					<equals arg1="${numberOfImages}" arg2="3" />
					<equals arg1="${numberOfImages}" arg2="4" />
					<contains string="${numberOfImages}" substring="{numberOfImages}" />
				</or>
			</not>
			<then>
				<var name="key_positionValue" value="4" />
				<var method="MathUtil#difference('${numberOfImages}', '4')" name="remainingNumberOfImages" />

				<execute function="AssertElementPresent" locator1="LoopFeed#ENTRY_IMAGE_SEE_MORE" />
				<execute function="AssertClick" locator1="LoopFeed#ENTRY_IMAGE_SEE_MORE" value1="+ ${remainingNumberOfImages}" />

				<execute function="AssertElementPresent" locator1="LoopFeed#ENTRY_IMAGE_FULL_SCREEN" />
				<execute function="AssertTextEquals" locator1="LoopFeed#ENTRY_IMAGE_FULL_SCREEN_IMAGE_COUNT" value1="4 of ${numberOfImages}" />
				<execute function="Click" locator1="LoopFeed#ENTRY_IMAGE_FULL_SCREEN_CLOSE_BUTTON" />
			</then>
		</if>

		<execute function="AssertElementPresent" locator1="LoopFeed#ENTRY_IMAGE_SPECIFIC" />

		<execute function="Click" locator1="LoopFeed#ENTRY_IMAGE" />

		<execute function="AssertElementPresent" locator1="LoopFeed#ENTRY_IMAGE_FULL_SCREEN" />
		<execute function="AssertTextEquals" locator1="LoopFeed#ENTRY_IMAGE_FULL_SCREEN_IMAGE_COUNT" value1="${imageNumber} of ${numberOfImages}" />
		<execute function="Click#makeVisibleClickAt" locator1="LoopFeed#ENTRY_IMAGE_FULL_SCREEN_NEXT_ARROW" />

		<var method="MathUtil#sum('${imageNumber}', '1')" name="imageNumber" />

		<while>
			<not>
				<equals arg1="${imageNumber}" arg2="${numberOfImages}" />
			</not>
			<then>
				<execute function="AssertElementPresent" locator1="LoopFeed#ENTRY_IMAGE_FULL_SCREEN" />
				<execute function="AssertElementPresent" locator1="LoopFeed#ENTRY_IMAGE_FULL_SCREEN_PREVIOUS_ARROW" />
				<execute function="AssertTextEquals" locator1="LoopFeed#ENTRY_IMAGE_FULL_SCREEN_IMAGE_COUNT" value1="${imageNumber} of ${numberOfImages}" />
				<execute function="Click#makeVisibleClickAt" locator1="LoopFeed#ENTRY_IMAGE_FULL_SCREEN_NEXT_ARROW" />

				<var method="MathUtil#sum('${imageNumber}', '1')" name="imageNumber" />
			</then>
		</while>

		<execute function="AssertElementPresent" locator1="LoopFeed#ENTRY_IMAGE_FULL_SCREEN" />
		<execute function="AssertTextEquals" locator1="LoopFeed#ENTRY_IMAGE_FULL_SCREEN_IMAGE_COUNT" value1="${imageNumber} of ${numberOfImages}" />
		<execute function="Click#makeVisibleClickAt" locator1="LoopFeed#ENTRY_IMAGE_FULL_SCREEN_PREVIOUS_ARROW" />

		<var method="MathUtil#difference('${imageNumber}', '1')" name="imageNumber" />

		<while>
			<not>
				<equals arg1="${imageNumber}" arg2="1" />
			</not>
			<then>
				<execute function="AssertElementPresent" locator1="LoopFeed#ENTRY_IMAGE_FULL_SCREEN" />
				<execute function="AssertElementPresent" locator1="LoopFeed#ENTRY_IMAGE_FULL_SCREEN_NEXT_ARROW" />
				<execute function="AssertTextEquals" locator1="LoopFeed#ENTRY_IMAGE_FULL_SCREEN_IMAGE_COUNT" value1="${imageNumber} of ${numberOfImages}" />
				<execute function="Click#makeVisibleClickAt" locator1="LoopFeed#ENTRY_IMAGE_FULL_SCREEN_PREVIOUS_ARROW" />

				<var method="MathUtil#difference('${imageNumber}', '1')" name="imageNumber" />
			</then>
		</while>

		<execute function="AssertElementPresent" locator1="LoopFeed#ENTRY_IMAGE_FULL_SCREEN" />
		<execute function="AssertElementPresent" locator1="LoopFeed#ENTRY_IMAGE_FULL_SCREEN_NEXT_ARROW" />
		<execute function="AssertTextEquals" locator1="LoopFeed#ENTRY_IMAGE_FULL_SCREEN_IMAGE_COUNT" value1="${imageNumber} of ${numberOfImages}" />
		<execute function="Click" locator1="LoopFeed#ENTRY_IMAGE_FULL_SCREEN_CLOSE_BUTTON" />
	</command>

