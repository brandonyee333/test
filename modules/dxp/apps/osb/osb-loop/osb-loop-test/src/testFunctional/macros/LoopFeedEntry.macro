		<execute function="AssertClick" locator1="LoopFeed#ENTRY_UNDO_MESSAGE_UNDO_LINK" value1="Undo." />
	</command>

	<command name="unfollowGroupViaSharedToList">
		<execute macro="LoopFeedEntry#clickGroupSharedToListLink">
			<var name="feedEntryContent" value="${feedEntryContent}" />
			<var name="numberOfGroupShares" value="${numberOfGroupShares}" />
		</execute>

		<execute macro="LoopGroupsGroup#clickUnfollowLinkViaIndex">
			<var name="groupName" value="${groupName}" />
		</execute>
	</command>

	<command name="unfollowTopicViaSharedToList">
		<execute macro="LoopFeedEntry#clickTopicSharedToListLink">
			<var name="feedEntryContent" value="${feedEntryContent}" />
			<var name="numberOfTopicShares" value="${numberOfTopicShares}" />
		</execute>

		<execute macro="LoopTopicsTopic#clickUnfollowLinkViaIndex">
			<var name="topicName" value="${topicName}" />
