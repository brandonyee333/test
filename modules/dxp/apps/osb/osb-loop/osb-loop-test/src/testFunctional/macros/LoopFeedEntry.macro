<definition>
	<command name="cancelNavigateAway">
		<execute function="AssertTextEquals#assertPartialText" locator1="LoopFeed#ENTRY_NAVIGATE_AWAY_MESSAGE" value1="Are you sure you want to navigate away? You have unsaved data." />
		<execute function="AssertClick" locator1="LoopFeed#ENTRY_NAVIGATE_AWAY_CANCEL_BUTTON" value1="Cancel" />
	</command>

	<command name="checkPrivatePost">
		<execute function="MakeVisible" locator1="LoopFeed#ADD_ENTRY_PRIVATE_POST_CHECKBOX" />
		<execute function="Check" locator1="LoopFeed#ADD_ENTRY_PRIVATE_POST_CHECKBOX" />
	</command>

	<command name="checkSendEmailNotification">
		<execute function="Click#makeVisibleClickAt" locator1="LoopFeed#ADD_ENTRY_ANNOUNCEMENT_EMAIL_NOTIFICATION" />
		<execute function="Check" locator1="LoopFeed#ADD_ENTRY_ANNOUNCEMENT_EMAIL_NOTIFICATION" />
		<execute function="AssertChecked" locator1="LoopFeed#ADD_ENTRY_ANNOUNCEMENT_EMAIL_NOTIFICATION" />
	</command>

	<command name="chooseLinkNextPreviewImage">
		<var name="key_feedEntryLinkImageKeyword" value="${feedEntryLinkImageKeyword}" />

		<while>
			<condition function="IsElementNotPresent" locator1="LoopFeed#ADD_ENTRY_URL_PREVIEW_IMAGE_SPECIFIC" />
			<then>
				<execute function="MouseOver" locator1="LoopFeed#ADD_ENTRY_URL_PREVIEW" />
				<execute function="Click#makeVisibleClickAt" locator1="LoopFeed#ADD_ENTRY_URL_PREVIEW_NEXT_IMAGE_LINK" />
			</then>
		</while>
	</command>

	<command name="chooseLinkPreviousPreviewImage">
		<var name="key_feedEntryLinkImageKeyword" value="${feedEntryLinkImageKeyword}" />

		<while>
			<condition function="IsElementNotPresent" locator1="LoopFeed#ADD_ENTRY_URL_PREVIEW_IMAGE_SPECIFIC" />
			<then>
				<execute function="MouseOver" locator1="LoopFeed#ADD_ENTRY_URL_PREVIEW" />
				<execute function="Click#makeVisibleClickAt" locator1="LoopFeed#ADD_ENTRY_URL_PREVIEW_PREVIOUS_IMAGE_LINK" />
			</then>
		</while>
	</command>

	<command name="clickAddCommentLink">
		<var name="key_feedEntryContent" value="${feedEntryContent}" />

		<execute function="AssertClick" locator1="LoopFeed#ENTRY_ADD_COMMENT_LINK" value1="Comment" />
	</command>

	<command name="clickAndTypeHashtag">
		<execute macro="LoopFeedEntry#clickAndTypeText">
			<var name="feedEntryText" value="#" />
		</execute>

		<execute macro="LoopFeedEntry#typeText">
			<var name="feedEntryText" value="${topicName}" />
		</execute>

		<execute macro="LoopFeedEntry#typeText">
			<var name="feedEntryText" value="s" />
		</execute>

		<execute macro="LoopFeedEntry#typeBackSpace" />
	</command>

	<command name="clickAndTypeMention">
		<execute macro="LoopFeedEntry#clickAndTypeText">
			<var name="feedEntryText" value="@" />
		</execute>

		<execute macro="LoopFeedEntry#typeText">
			<var name="feedEntryText" value="${entityName}" />
		</execute>

		<execute macro="LoopFeedEntry#typeText">
			<var name="feedEntryText" value="s" />
		</execute>

		<execute macro="LoopFeedEntry#typeBackSpace" />
	</command>

	<command name="clickAndTypeText">
		<execute macro="LoopFeedEntry#clickTextField" />

		<execute macro="LoopFeedEntry#typeText">
			<var name="feedEntryText" value="${feedEntryText}" />
		</execute>
	</command>

	<command name="clickAnnouncementHeaderLeftArrow">
		<execute function="Click#makeVisibleClickAt" locator1="LoopFeed#ENTRY_ANNOUNCEMENT_HEADER_LEFT_ARROW" />
	</command>

	<command name="clickAnnouncementHeaderRightArrow">
		<execute function="Click#makeVisibleClickAt" locator1="LoopFeed#ENTRY_ANNOUNCEMENT_HEADER_RIGHT_ARROW" />
	</command>

	<command name="clickAuthorNameLink">
		<var name="key_feedEntryContent" value="${feedEntryContent}" />

		<execute function="AssertClick" locator1="LoopFeed#ENTRY_AUTHOR" value1="${feedEntryAuthorName}" />
	</command>

	<command name="clickAuthorProfilePicture">
		<var name="key_feedEntryContent" value="${feedEntryContent}" />

		<execute function="Click" locator1="LoopFeed#ENTRY_AUTHOR_PROFILE_PICTURE" />
	</command>

	<command name="clickBookmarkLink">
		<execute function="AssertClick" locator1="LoopFeed#ENTRY_OPTIONS_BOOKMARK_POST_LINK" value1="Bookmark" />
	</command>

	<command name="clickDeleteLink">
		<execute function="AssertClick" locator1="LoopFeed#ENTRY_OPTIONS_DELETE_POST_LINK" value1="Delete" />
	</command>

	<command name="clickEditBackground">
		<execute function="MouseOver" locator1="LoopFeed#EDIT_ENTRY_BACKGROUND" />

		<execute function="Click#clickAt" locator1="LoopFeed#EDIT_ENTRY_BACKGROUND" />
	</command>

	<command name="clickEditLink">
		<execute function="AssertClick" locator1="LoopFeed#ENTRY_OPTIONS_EDIT_POST_LINK" value1="Edit" />
		<execute function="AssertElementNotPresent" locator1="LoopFeed#ENTRY_EDIT_LOAD" />
	</command>

	<command name="clickEditTextField">
		<execute function="Click" locator1="LoopFeed#EDIT_ENTRY_TEXT_FIELD" />
		<execute function="Pause" locator1="3000" />
		<execute function="SelectFieldText" locator1="LoopFeed#EDIT_ENTRY_TEXT_FIELD" />
		<execute function="KeyPress" locator1="LoopFeed#EDIT_ENTRY_TEXT_FIELD" value1="\RIGHT" />
		<!--LRQA-26661 Issue with Keypress END not working-->
		<!--<execute function="KeyPress" locator1="LoopFeed#EDIT_ENTRY_TEXT_FIELD" value1="\END" />-->
	</command>

	<command name="clickEditTextFieldBeginning">
		<execute function="Click" locator1="LoopFeed#EDIT_ENTRY_TEXT_FIELD" />
		<execute function="Pause" locator1="3000" />
		<execute function="SelectFieldText" locator1="LoopFeed#EDIT_ENTRY_TEXT_FIELD" />
		<execute function="KeyPress" locator1="LoopFeed#EDIT_ENTRY_TEXT_FIELD" value1="\LEFT" />
	</command>

	<command name="clickExitTabLink">
		<execute function="Click" locator1="LoopFeed#ADD_ENTRY_EXIT_TAB" />
	</command>

	<command name="clickExitTabLinkInEditTextField">
		<execute function="Click" locator1="LoopFeed#EDIT_ENTRY_EXIT_TAB" />
	</command>

	<command name="clickFollowEntryAuthorLink">
		<execute function="AssertClick" locator1="LoopFeed#ENTRY_AUTHOR_OVERLAY_FOLLOW_BUTTON" value1="Follow" />
	</command>

	<command name="clickFollowLink">
		<execute function="AssertClick#assertPartialTextClickAt" locator1="LoopFeed#ENTRY_OPTIONS_FOLLOW_POST_LINK" value1="Follow" />
	</command>

	<command name="clickGroupSharedToListLink">
		<var name="key_feedEntryContent" value="${feedEntryContent}" />

		<execute function="AssertClick" locator1="LoopFeed#ENTRY_SHARED_TO_GROUP_LIST_LINK" value1="${numberOfGroupShares} Groups" />
	</command>

	<command name="clickLikedLink">
		<var name="key_feedEntryContent" value="${feedEntryContent}" />

		<execute function="AssertClick" locator1="LoopFeed#ENTRY_LIKED_LINK" value1="Liked" />
	</command>

	<command name="clickLikeLink">
		<var name="key_feedEntryContent" value="${feedEntryContent}" />

		<execute function="AssertClick" locator1="LoopFeed#ENTRY_LIKE_LINK" value1="Like" />
	</command>

	<command name="clickOptionsLink">
		<var name="key_feedEntryContent" value="${feedEntryContent}" />

		<execute function="Click" locator1="LoopFeed#ENTRY_OPTIONS_LINK" />
	</command>

	<command name="clickPreviewBackButton">
		<execute function="AssertClick" locator1="LoopFeed#ENTRY_PREVIEW_BACK_BUTTON" value1="Back" />
	</command>

	<command name="clickPreviewButton">
		<execute function="Click" locator1="LoopFeed#ADD_ENTRY_PREVIEW_BUTTON" />
	</command>

	<command name="clickPreviewButtonInEditTextField">
		<execute function="Click" locator1="LoopFeed#EDIT_ENTRY_PREVIEW_BUTTON" />
	</command>

	<command name="clickPreviewEditPostButton">
		<execute function="AssertClick" locator1="LoopFeed#ENTRY_PREVIEW_POST_BUTTON" value1="Confirm" />
	</command>

	<command name="clickPreviewPostButton">
		<execute function="AssertClick" locator1="LoopFeed#ENTRY_PREVIEW_POST_BUTTON" value1="Post" />
	</command>

	<command name="clickRemoveBookmarkLink">
		<execute function="AssertClick" locator1="LoopFeed#ENTRY_OPTIONS_REMOVE_POST_FROM_BOOKMARKS_LINK" value1="Remove from Bookmarks" />
	</command>

	<command name="clickRemoveBookmarkLinkViaIcon">
		<var name="key_feedEntryContent" value="${feedEntryContent}" />

		<execute function="Click" locator1="LoopFeed#ENTRY_BOOKMARK" />
	</command>

	<command name="clickSeeFullPostLink">
		<var name="key_feedEntryContent" value="${feedEntryPartialContent}" />

		<execute function="AssertClick" locator1="LoopFeed#ENTRY_CONTENT_SEE_MORE_LINK" value1="See All" />
	</command>

	<command name="clickSeeFullPostLinkViaEntryPosition">
		<var name="key_positionValue" value="${positionValue}" />

		<execute function="AssertClick" locator1="LoopFeed#ENTRY_CONTENT_SEE_MORE_LINK_GENERIC" value1="See All" />
	</command>

	<command name="clickSeeMoreLink">
		<var name="key_feedEntryContent" value="${feedEntryPartialContent}" />

		<execute function="AssertClick" locator1="LoopFeed#ENTRY_CONTENT_SEE_MORE_LINK" value1="See More" />
	</command>

	<command name="clickSeeMoreLinkViaEntryPosition">
		<var name="key_positionValue" value="${positionValue}" />

		<execute function="AssertClick" locator1="LoopFeed#ENTRY_CONTENT_SEE_MORE_LINK_GENERIC" value1="See More" />
	</command>

	<command name="clickShareLink">
		<execute function="AssertClick" locator1="LoopFeed#ENTRY_OPTIONS_SHARE_POST_LINK" value1="Share" />
	</command>

	<command name="clickTextField">
		<execute function="Click" locator1="LoopFeed#ADD_ENTRY_TEXT_FIELD" />
		<execute function="SelectFieldText" locator1="LoopFeed#ADD_ENTRY_TEXT_FIELD" />
		<execute function="KeyPress" locator1="LoopFeed#ADD_ENTRY_TEXT_FIELD" value1="\RIGHT" />
		<!--LRQA-26661 Issue with Keypress END not working-->
		<!--<execute function="KeyPress" locator1="LoopFeed#ADD_ENTRY_TEXT_FIELD" value1="\END" />-->
	</command>

	<command name="clickTextFieldAndPause">
		<execute function="Click" locator1="LoopFeed#ADD_ENTRY_TEXT_FIELD" />
		<execute function="Pause" locator1="3000" />
		<execute function="SelectFieldText" locator1="LoopFeed#ADD_ENTRY_TEXT_FIELD" />
		<execute function="KeyPress" locator1="LoopFeed#ADD_ENTRY_TEXT_FIELD" value1="\RIGHT" />
		<!--LRQA-26661 Issue with Keypress END not working-->
		<!--<execute function="KeyPress" locator1="LoopFeed#ADD_ENTRY_TEXT_FIELD" value1="\END" />-->
	</command>

	<command name="clickTimestamp">
		<var name="key_feedEntryContent" value="${feedEntryContent}" />

		<execute function="Click" locator1="LoopFeed#ENTRY_DATE" />
	</command>

	<command name="clickTimestampViaEntryPosition">
		<var name="key_positionValue" value="${positionValue}" />

		<execute function="Click" locator1="LoopFeed#ENTRY_DATE_GENERIC" />
	</command>

	<command name="clickTopicSharedToListLink">
		<var name="key_feedEntryContent" value="${feedEntryContent}" />

		<!--Remove assertPartialTextClickAt when LOOP-3246 is fixed-->

		<execute function="AssertClick#assertPartialTextClickAt" locator1="LoopFeed#ENTRY_SHARED_TO_TOPIC_LIST_LINK" value1="${numberOfTopicShares} Topics" />
	</command>

	<command name="clickTurnOffEmailNotificationsLink">
		<execute function="MouseOver" locator1="LoopFeed#ENTRY_OPTIONS_FOLLOW_POST_LINK" />
		<execute function="Click#makeVisibleClickAt" locator1="LoopFeed#ENTRY_OPTIONS_EMAIL_NOTIFICATIONS_CHECKBOX" />
	</command>

	<command name="clickTurnOffNotificationsForEntryAuthorLink">
		<execute function="MouseOver" locator1="LoopFeed#ENTRY_AUTHOR_OVERLAY_FOLLOW_BUTTON" />

		<execute function="AssertTextEquals" locator1="LoopPeoplePerson#PERSON_TOGGLE_NOTIFICATIONS_LABEL" value1="Turn off Notifications" />
		<execute function="AssertVisible" locator1="LoopPeoplePerson#PERSON_EMAIL_NOTIFICATIONS_LABEL" />

		<execute function="Click#makeVisibleClickAt" locator1="LoopPeoplePerson#PERSON_TOGGLE_NOTIFICATIONS_LINK" />

		<execute function="AssertTextEquals" locator1="LoopPeoplePerson#PERSON_TOGGLE_NOTIFICATIONS_LABEL" value1="Turn on Notifications" />
		<execute function="AssertNotVisible" locator1="LoopPeoplePerson#PERSON_EMAIL_NOTIFICATIONS_LABEL" />
	</command>

	<command name="clickTurnOffNotificationsLink">
		<execute function="MouseOver" locator1="LoopFeed#ENTRY_OPTIONS_FOLLOW_POST_LINK" />

		<execute function="AssertTextEquals" locator1="LoopFeed#ENTRY_OPTIONS_TOGGLE_NOTIFICATIONS_LABEL" value1="Turn off Notifications" />
		<execute function="AssertVisible" locator1="LoopFeed#ENTRY_OPTIONS_EMAIL_NOTIFICATIONS_LABEL" />

		<execute function="Click#makeVisibleClickAt" locator1="LoopFeed#ENTRY_OPTIONS_TOGGLE_NOTIFICATIONS_FOR_POST_LINK" />

		<execute function="AssertTextEquals" locator1="LoopFeed#ENTRY_OPTIONS_TOGGLE_NOTIFICATIONS_LABEL" value1="Turn on Notifications" />
		<execute function="AssertNotVisible" locator1="LoopFeed#ENTRY_OPTIONS_EMAIL_NOTIFICATIONS_LABEL" />
	</command>

	<command name="clickTurnOnEmailNotificationsLink">
		<if>
			<condition function="IsTextEqual#isPartialText" locator1="LoopFeed#ENTRY_OPTIONS_FOLLOW_POST_LINK" value1="Follow" />
			<then>
				<execute function="Click" locator1="LoopFeed#ENTRY_OPTIONS_FOLLOW_POST_LINK" />
			</then>
		</if>

		<execute function="MouseOver" locator1="LoopFeed#ENTRY_OPTIONS_FOLLOW_POST_LINK" />

		<execute function="AssertTextEquals" locator1="LoopFeed#ENTRY_OPTIONS_TOGGLE_NOTIFICATIONS_LABEL" value1="Turn on Notifications" />
		<execute function="AssertNotVisible" locator1="LoopFeed#ENTRY_OPTIONS_EMAIL_NOTIFICATIONS_LABEL" />

		<execute function="Click#makeVisibleClickAt" locator1="LoopFeed#ENTRY_OPTIONS_TOGGLE_NOTIFICATIONS_FOR_POST_LINK" />

		<execute function="AssertTextEquals" locator1="LoopFeed#ENTRY_OPTIONS_TOGGLE_NOTIFICATIONS_LABEL" value1="Turn off Notifications" />
		<execute function="AssertVisible" locator1="LoopFeed#ENTRY_OPTIONS_EMAIL_NOTIFICATIONS_LABEL" />

		<execute function="Click#makeVisibleClickAt" locator1="LoopFeed#ENTRY_OPTIONS_EMAIL_NOTIFICATIONS_CHECKBOX" />
	</command>

	<command name="clickTurnOnNotificationsForEntryAuthorLink">
		<if>
			<condition function="IsTextEqual" locator1="LoopFeed#ENTRY_AUTHOR_OVERLAY_FOLLOW_BUTTON" value1="Follow" />
			<then>
				<execute macro="LoopFeedEntry#clickFollowEntryAuthorLink" />
			</then>
		</if>

		<execute function="MouseOver" locator1="LoopFeed#ENTRY_AUTHOR_OVERLAY_FOLLOW_BUTTON" />

		<execute function="AssertTextEquals" locator1="LoopPeoplePerson#PERSON_TOGGLE_NOTIFICATIONS_LABEL" value1="Turn on Notifications" />
		<execute function="AssertNotVisible" locator1="LoopPeoplePerson#PERSON_EMAIL_NOTIFICATIONS_LABEL" />

		<execute function="Click#makeVisibleClickAt" locator1="LoopPeoplePerson#PERSON_TOGGLE_NOTIFICATIONS_LINK" />

		<execute function="AssertTextEquals" locator1="LoopPeoplePerson#PERSON_TOGGLE_NOTIFICATIONS_LABEL" value1="Turn off Notifications" />
		<execute function="AssertVisible" locator1="LoopPeoplePerson#PERSON_EMAIL_NOTIFICATIONS_LABEL" />

		<execute function="AssertClick" locator1="LoopPeoplePerson#PERSON_POSTS_AND_COMMENTED_POSTS_NOTIFICATIONS_LINK" value1="Posts, Comments, and Mentions" />
	</command>

	<command name="clickTurnOnNotificationsLink">
		<if>
			<condition function="IsTextEqual#isPartialText" locator1="LoopFeed#ENTRY_OPTIONS_FOLLOW_POST_LINK" value1="Follow" />
			<then>
				<execute function="Click" locator1="LoopFeed#ENTRY_OPTIONS_FOLLOW_POST_LINK" />
			</then>
		</if>

		<execute function="MouseOver" locator1="LoopFeed#ENTRY_OPTIONS_FOLLOW_POST_LINK" />

		<execute function="AssertTextEquals" locator1="LoopFeed#ENTRY_OPTIONS_TOGGLE_NOTIFICATIONS_LABEL" value1="Turn on Notifications" />
		<execute function="AssertNotVisible" locator1="LoopFeed#ENTRY_OPTIONS_EMAIL_NOTIFICATIONS_LABEL" />

		<execute function="Click#makeVisibleClickAt" locator1="LoopFeed#ENTRY_OPTIONS_TOGGLE_NOTIFICATIONS_FOR_POST_LINK" />

		<execute function="AssertTextEquals" locator1="LoopFeed#ENTRY_OPTIONS_TOGGLE_NOTIFICATIONS_LABEL" value1="Turn off Notifications" />
		<execute function="AssertVisible" locator1="LoopFeed#ENTRY_OPTIONS_EMAIL_NOTIFICATIONS_LABEL" />
	</command>

	<command name="clickUnfollowEntryAuthorLink">
		<execute function="MouseOver" locator1="LoopFeed#ENTRY_AUTHOR_OVERLAY_FOLLOW_BUTTON" />
		<execute function="AssertTextEquals#assertPartialText" locator1="LoopFeed#ENTRY_AUTHOR_OVERLAY_UNFOLLOW_LINK" value1="Unfollow" />
		<execute function="Click" locator1="LoopFeed#ENTRY_AUTHOR_OVERLAY_UNFOLLOW_LINK" value1="Unfollow" />
	</command>

	<command name="clickUnfollowLink">
		<execute function="AssertClick#assertPartialTextClickAt" locator1="LoopFeed#ENTRY_OPTIONS_FOLLOW_POST_LINK" value1="Unfollow" />
	</command>

	<command name="clickUserSharedToListLink">
		<var name="key_feedEntryContent" value="${feedEntryContent}" />

		<execute function="AssertClick" locator1="LoopFeed#ENTRY_SHARED_TO_PERSON_LIST_LINK" value1="${numberOfUserShares} People" />
	</command>

	<command name="deleteCmd">
		<execute function="AssertTextEquals#assertPartialText" locator1="LoopFeed#ENTRY_DELETE_MESSAGE" value1="Are you sure you want to delete this" />
		<execute function="AssertClick" locator1="LoopFeed#ENTRY_DELETE_CONFIRM_BUTTON" value1="Confirm" />

		<execute macro="LoopFeedEntry#pause">
			<var name="pauseTime" value="2000" />
		</execute>
	</command>

	<command name="dragImageToBottom">
		<var name="key_positionValue" value="${positionValue}" />

		<execute function="DragAndDrop" locator1="LoopFeed#ADD_ENTRY_IMAGE_PREVIEW_IMAGE_SPECIFIC" locator2="LoopFeed#ADD_ENTRY_TOOLBAR" value1="" />
	</command>

	<command name="dragImageToBottomInEditTextField">
		<var name="key_positionValue" value="${positionValue}" />

		<execute function="DragAndDrop" locator1="LoopFeed#EDIT_ENTRY_IMAGE_PREVIEW_IMAGE_SPECIFIC" locator2="LoopFeed#EDIT_ENTRY_TOOLBAR" value1="" />
	</command>

	<command name="expandCreator">
		<if>
			<condition function="IsElementPresent" locator1="LoopFeed#ADD_ENTRY_MINIMIZED" />
			<then>
				<execute function="Click" locator1="LoopFeed#ADD_ENTRY_TEXT_FIELD_MINIMIZER" />
			</then>
		</if>
	</command>

	<command name="followGroupViaSharedToList">
		<execute macro="LoopFeedEntry#clickGroupSharedToListLink">
			<var name="feedEntryContent" value="${feedEntryContent}" />
			<var name="numberOfGroupShares" value="${numberOfGroupShares}" />
		</execute>

		<execute macro="LoopGroupsGroup#clickFollowLinkViaIndex">
			<var name="groupName" value="${groupName}" />
		</execute>
	</command>

	<command name="followTopicViaSharedToList">
		<execute macro="LoopFeedEntry#clickTopicSharedToListLink">
			<var name="feedEntryContent" value="${feedEntryContent}" />
			<var name="numberOfTopicShares" value="${numberOfTopicShares}" />
		</execute>

		<execute macro="LoopTopicsTopic#clickFollowLinkViaIndex">
			<var name="topicName" value="${topicName}" />
		</execute>
	</command>

	<command name="followUserViaLikeSummaryUserAvatarLinkOverlay">
		<execute macro="LoopFeedEntry#mouseOverLikeSummaryUserAvatarLink">
			<var name="feedEntryContent" value="${feedEntryContent}" />
			<var name="userName" value="${userName}" />
		</execute>

		<execute macro="LoopPeoplePerson#clickFollowButtonViaOverlay" />
	</command>

	<command name="followUserViaSharedToList">
		<execute macro="LoopFeedEntry#clickUserSharedToListLink">
			<var name="feedEntryContent" value="${feedEntryContent}" />
			<var name="numberOfUserShares" value="${numberOfUserShares}" />
		</execute>

		<execute macro="LoopPeoplePerson#clickFollowLinkViaIndex">
			<var name="userName" value="${userName}" />
		</execute>
	</command>

	<command name="generateLinkPreview">
		<execute function="Click" locator1="LoopFeed#ADD_ENTRY_LINK_TAB" />
		<execute function="Type" locator1="LoopFeed#ADD_ENTRY_URL_FIELD" value1="${feedEntryLinkUrl}" />
		<execute function="KeyPress" locator1="LoopFeed#ADD_ENTRY_URL_FIELD" value1="\RETURN" />
	</command>

	<command name="generateLinkPreviewInEditTextField">
		<execute function="Click" locator1="LoopFeed#EDIT_ENTRY_LINK_TAB" />
		<execute function="Type" locator1="LoopFeed#EDIT_ENTRY_URL_FIELD" value1="${feedEntryLinkUrl}" />
		<execute function="KeyPress" locator1="LoopFeed#EDIT_ENTRY_URL_FIELD" value1="\RETURN" />
	</command>

	<command name="generateLinkPreviewViaTextField">
		<execute macro="LoopFeedEntry#typeSpace" />

		<execute macro="LoopFeedEntry#typeText">
			<var name="feedEntryText" value="${feedEntryLinkUrl}" />
		</execute>

		<execute macro="LoopFeedEntry#typeSpace" />

		<execute function="AssertElementPresent" locator1="LoopFeed#ADD_ENTRY_URL_PREVIEW" />

		<execute macro="LoopFeedEntry#typeBackSpace" />
	</command>

	<command name="goDownTextField">
		<if>
			<isset var="numberOfKeyPresses" />
			<then>
				<var name="keyPressNumber" value="0" />

				<while>
					<not>
						<equals arg1="${keyPressNumber}" arg2="${numberOfKeyPresses}" />
					</not>
					<then>
						<var method="MathUtil#sum('${keyPressNumber}', '1')" name="keyPressNumber" />

						<execute function="KeyPress" locator1="LoopFeed#ADD_ENTRY_TEXT_FIELD" value1="\DOWN" />
					</then>
				</while>
			</then>
			<else>
				<execute function="KeyPress" locator1="LoopFeed#ADD_ENTRY_TEXT_FIELD" value1="\DOWN" />
			</else>
		</if>
	</command>

	<command name="goDownTextFieldInEditTextField">
		<if>
			<isset var="numberOfKeyPresses" />
			<then>
				<var name="keyPressNumber" value="0" />

				<while>
					<not>
						<equals arg1="${keyPressNumber}" arg2="${numberOfKeyPresses}" />
					</not>
					<then>
						<var method="MathUtil#sum('${keyPressNumber}', '1')" name="keyPressNumber" />

						<execute function="KeyPress" locator1="LoopFeed#EDIT_ENTRY_TEXT_FIELD" value1="\DOWN" />
					</then>
				</while>
			</then>
			<else>
				<execute function="KeyPress" locator1="LoopFeed#EDIT_ENTRY_TEXT_FIELD" value1="\DOWN" />
			</else>
		</if>
	</command>

	<command name="gotoAnnouncementsTab">
		<execute function="AssertClick" locator1="LoopFeed#ANNOUNCEMENTS_TAB" value1="Announcements" />

		<!-- Workaround until LOOP-5216 is fixed -->

		<execute macro="LoopNavigation#reloadPage" />
	</command>

	<command name="gotoBookmarksTab">
		<execute function="AssertClick" locator1="LoopFeed#BOOKMARKS_TAB" value1="Bookmarks" />

		<!-- Workaround until LOOP-5216 is fixed -->

		<execute macro="LoopNavigation#reloadPage" />
	</command>

	<command name="gotoEndOfTextLine">
		<execute function="SelectFieldText" locator1="LoopFeed#ADD_ENTRY_TEXT_FIELD" />
		<execute function="KeyPress" locator1="LoopFeed#ADD_ENTRY_TEXT_FIELD" value1="\RIGHT" />
		<!--LRQA-26661 Issue with Keypress END not working-->
		<!--<execute function="KeyPress" locator1="LoopFeed#ADD_ENTRY_TEXT_FIELD" value1="\END" />-->
	</command>

	<command name="gotoEndOfTextLineInEditTextField">
		<execute function="SelectFieldText" locator1="LoopFeed#EDIT_ENTRY_TEXT_FIELD" />
		<execute function="KeyPress" locator1="LoopFeed#EDIT_ENTRY_TEXT_FIELD" value1="\RIGHT" />
		<!--LRQA-26661 Issue with Keypress END not working-->
		<!--<execute function="KeyPress" locator1="LoopFeed#EDIT_ENTRY_TEXT_FIELD" value1="\END" />-->
	</command>

	<command name="gotoFollowingTab">
		<execute function="AssertClick" locator1="LoopFeed#FOLLOWING_TAB" value1="Following" />
	</command>

	<command name="gotoPrivatePostsTab">
		<execute function="AssertClick" locator1="LoopFeed#PRIVATE_POSTS_TAB" value1="Private Posts" />
	</command>

	<command name="gotoSingleViewViaShare">
		<var method="PropsUtil#get('portal.url')" name="portalUrl" />

		<execute macro="LoopFeedEntry#clickOptionsLink">
			<var name="feedEntryContent" value="${feedEntryContent}" />
		</execute>

		<execute macro="LoopFeedEntry#clickShareLink" />

		<var method="selenium#getText('LoopFeed#ENTRY_SHARE_LINK')" name="feedEntryUrl" />

		<if>
			<not>
				<contains string="${feedEntryUrl}" substring="${portalUrl}" />
			</not>
			<then>
				<fail message="Feed URL is missing the Portal URL" />
			</then>
		</if>

		<execute function="Click" locator1="LoopFeed#ENTRY_SHARE_CLOSE_BUTTON" />

		<var method="StringUtil#replace('${feedEntryUrl}', '${portalUrl}', '')" name="feedEntryUrl" />

		<execute macro="Loop#openSpecificURL">
			<var name="url" value="${feedEntryUrl}" />
		</execute>
	</command>

	<command name="gotoStartOfTextLine">
		<execute function="KeyPress" locator1="LoopFeed#ADD_ENTRY_TEXT_FIELD" value1="\HOME" />
	</command>

	<command name="gotoStartOfTextLineInEditTextField">
		<execute function="KeyPress" locator1="LoopFeed#EDIT_ENTRY_TEXT_FIELD" value1="\HOME" />
	</command>

	<command name="goUpTextField">
		<if>
			<isset var="numberOfKeyPresses" />
			<then>
				<var name="keyPressNumber" value="0" />

				<while>
					<not>
						<equals arg1="${keyPressNumber}" arg2="${numberOfKeyPresses}" />
					</not>
					<then>
						<var method="MathUtil#sum('${keyPressNumber}', '1')" name="keyPressNumber" />

						<execute function="KeyPress" locator1="LoopFeed#ADD_ENTRY_TEXT_FIELD" value1="\UP" />
					</then>
				</while>
			</then>
			<else>
				<execute function="KeyPress" locator1="LoopFeed#ADD_ENTRY_TEXT_FIELD" value1="\UP" />
			</else>
		</if>
	</command>

	<command name="goUpTextFieldInEditTextField">
		<if>
			<isset var="numberOfKeyPresses" />
			<then>
				<var name="keyPressNumber" value="0" />

				<while>
					<not>
						<equals arg1="${keyPressNumber}" arg2="${numberOfKeyPresses}" />
					</not>
					<then>
						<var method="MathUtil#sum('${keyPressNumber}', '1')" name="keyPressNumber" />

						<execute function="KeyPress" locator1="LoopFeed#EDIT_ENTRY_TEXT_FIELD" value1="\UP" />
					</then>
				</while>
			</then>
			<else>
				<execute function="KeyPress" locator1="LoopFeed#EDIT_ENTRY_TEXT_FIELD" value1="\UP" />
			</else>
		</if>
	</command>

	<command name="hashtagTopics">
		<for list="${hashtagTopicNameList}" param="topicName">
			<execute macro="LoopFeedEntry#typeSpace" />

			<execute macro="LoopFeedEntry#typeHashtag">
				<var name="topicName" value="${topicName}" />
			</execute>

			<execute macro="LoopFeedEntry#selectTopicFromDropdown">
				<var name="topicName" value="${topicName}" />
			</execute>
		</for>
	</command>

	<command name="hashtagTopicsInEditTextField">
		<for list="${hashtagTopicNameList}" param="topicName">
			<execute macro="LoopFeedEntry#typeSpaceInEditTextField" />

			<execute macro="LoopFeedEntry#typeHashtagInEditTextField">
				<var name="topicName" value="${topicName}" />
			</execute>

			<execute macro="LoopFeedEntry#selectTopicFromDropdown">
				<var name="topicName" value="${topicName}" />
			</execute>
		</for>
	</command>

	<command name="likeEntry">
		<execute macro="LoopFeedEntry#clickLikeLink">
			<var name="feedEntryContent" value="${feedEntryContent}" />
		</execute>

		<execute macro="LoopFeedEntry#viewLikedEntry">
			<var name="feedEntryContent" value="${feedEntryContent}" />
		</execute>
	</command>

	<command name="makeAnnouncement">
		<execute function="Click" locator1="LoopFeed#ADD_ENTRY_ANNOUNCEMENT_TAB" />

		<execute function="Type" locator1="LoopFeed#ADD_ENTRY_ANNOUNCEMENT_TITLE_FIELD" value1="${feedEntryTitle}" />

		<if>
			<and>
				<isset var="feedEntryStickyTimeInDays" />
				<not>
					<contains string="${feedEntryStickyTimeInDays}" substring="{feedEntryStickyTimeInDays}" />
				</not>
			</and>
			<then>
				<execute macro="LoopFeedEntry#selectAnnouncementStickyTime">
					<var name="feedEntryStickyTimeInDays" value="${feedEntryStickyTimeInDays}" />
				</execute>
			</then>
		</if>

		<execute macro="LoopFeedEntry#selectAnnouncementAuthorName">
			<var name="feedEntryAuthorName" value="${feedEntryAuthorName}" />
		</execute>

		<if>
			<equals arg1="${sendEmailNotification}" arg2="false" />
			<then>
				<execute macro="LoopFeedEntry#uncheckSendEmailNotification" />
			</then>
			<else>
				<execute macro="LoopFeedEntry#checkSendEmailNotification" />
			</else>
		</if>
	</command>

	<command name="makePrivate">
		<if>
			<equals arg1="${private}" arg2="true" />
			<then>
				<execute macro="LoopFeedEntry#checkPrivatePost" />
			</then>
		</if>
	</command>

	<command name="mentionGroups">
		<for list="${mentionGroupNameList}" param="groupName">
			<execute macro="LoopFeedEntry#typeSpace" />

			<execute macro="LoopFeedEntry#typeMention">
				<var name="entityName" value="${groupName}" />
			</execute>

			<execute macro="LoopFeedEntry#selectGroupFromDropdown">
				<var name="groupName" value="${groupName}" />
			</execute>
		</for>
