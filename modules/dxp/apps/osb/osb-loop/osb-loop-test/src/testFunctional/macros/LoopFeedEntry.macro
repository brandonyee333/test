	<command name="viewPostLinkViaUndoRemoveBookmarkMessage">
		<var method="PropsUtil#get('portal.url')" name="portalUrl" />

		<execute macro="LoopFeedEntryBookmarks#clickOptionsLink">
			<var name="feedEntryContent" value="${feedEntryContent}" />
		</execute>

		<execute macro="LoopFeedEntry#clickShareLink" />

		<var method="selenium#getText('LoopFeed#ENTRY_SHARE_LINK')" name="feedEntryUrl" />

		<if>
			<not>
				<contains string="${feedEntryUrl}" substring="${portalUrl}" />
			</not>
			<then>
				<fail message="Feed URL is missing the Portal URL" />
			</then>
		</if>

		<execute function="Click" locator1="LoopFeed#ENTRY_SHARE_CLOSE_BUTTON" />

		<var method="StringUtil#replace('${feedEntryUrl}', '${portalUrl}', '')" name="feedEntryUrl" />

		<execute macro="LoopFeedBookmarks#removeBookmarkFromEntry">
			<var name="feedEntryContent" value="${feedEntryContent}" />
		</execute>

		<execute macro="LoopFeedEntry#viewUndoRemoveFromBookmarksMessage" />

		<var name="key_feedEntryUrl" value="${feedEntryUrl}" />

		<execute function="AssertTextEquals" locator1="LoopFeed#ENTRY_UNDO_MESSAGE_VIEW_POST_LINK" value1="post" />
	</command>

	<command name="viewPostLinkViaUndoUnfollowMessage">
		<var method="PropsUtil#get('portal.url')" name="portalUrl" />

		<execute macro="LoopFeedEntry#clickOptionsLink">
			<var name="feedEntryContent" value="${feedEntryContent}" />
		</execute>

		<execute macro="LoopFeedEntry#clickShareLink" />

		<var method="selenium#getText('LoopFeed#ENTRY_SHARE_LINK')" name="feedEntryUrl" />

		<if>
			<not>
				<contains string="${feedEntryUrl}" substring="${portalUrl}" />
			</not>
			<then>
				<fail message="Feed URL is missing the Portal URL" />
			</then>
		</if>

		<execute function="Click" locator1="LoopFeed#ENTRY_SHARE_CLOSE_BUTTON" />

		<var method="StringUtil#replace('${feedEntryUrl}', '${portalUrl}', '')" name="feedEntryUrl" />

		<execute macro="LoopFeed#unfollowEntry">
			<var name="feedEntryContent" value="${feedEntryContent}" />
		</execute>

		<execute macro="LoopFeedEntry#viewUndoRemoveFromFollowingMessage" />

		<var name="key_feedEntryUrl" value="${feedEntryUrl}" />

		<execute function="AssertTextEquals" locator1="LoopFeed#ENTRY_UNDO_MESSAGE_VIEW_POST_LINK" value1="post" />
	</command>

	<command name="viewPreview">
		<execute macro="LoopFeedEntry#clickPreviewButton" />

		<execute macro="LoopFeedEntry#viewPreviewAuthorAndContent">
			<var name="feedEntryAuthorName" value="${feedEntryAuthorName}" />
			<var name="feedEntryContent" value="${feedEntryContent}" />
			<var name="feedEntryDate" value="${feedEntryDate}" />
		</execute>
	</command>

	<command name="viewPreviewAuthorAndContent">
		<execute function="AssertElementPresent" locator1="LoopFeed#ENTRY_PREVIEW_AUTHOR_PROFILE_PICTURE" />
		<execute function="AssertTextEquals" locator1="LoopFeed#ENTRY_PREVIEW_AUTHOR" value1="${feedEntryAuthorName}" />

		<if>
			<and>
				<isset var="feedEntryDate" />
				<not>
					<contains string="${feedEntryDate}" substring="{feedEntryDate}" />
				</not>
			</and>
			<then>
				<execute function="AssertTextEquals" locator1="LoopFeed#ENTRY_PREVIEW_DATE" value1="${feedEntryDate}" />
			</then>
			<else>
				<execute function="AssertElementPresent" locator1="LoopFeed#ENTRY_PREVIEW_DATE" />
			</else>
		</if>

		<execute function="AssertTextEquals" locator1="LoopFeed#ENTRY_PREVIEW_CONTENT" value1="${feedEntryContent}" />
	</command>

	<command name="viewPreviewAuthorAndPartialContent">
		<execute function="AssertElementPresent" locator1="LoopFeed#ENTRY_PREVIEW_AUTHOR_PROFILE_PICTURE" />
		<execute function="AssertTextEquals" locator1="LoopFeed#ENTRY_PREVIEW_AUTHOR" value1="${feedEntryAuthorName}" />

		<if>
			<and>
				<isset var="feedEntryDate" />
				<not>
					<contains string="${feedEntryDate}" substring="{feedEntryDate}" />
				</not>
			</and>
			<then>
				<execute function="AssertTextEquals" locator1="LoopFeed#ENTRY_PREVIEW_DATE" value1="${feedEntryDate}" />
			</then>
			<else>
				<execute function="AssertElementPresent" locator1="LoopFeed#ENTRY_PREVIEW_DATE" />
			</else>
		</if>

		<execute function="AssertTextEquals#assertPartialText" locator1="LoopFeed#ENTRY_PREVIEW_CONTENT" value1="${feedEntryPartialContent}" />
	</command>

