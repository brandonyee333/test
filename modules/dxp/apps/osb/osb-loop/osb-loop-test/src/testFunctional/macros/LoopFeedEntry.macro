	</command>

	<command name="viewUndoRemoveFromFollowingMessage">
		<execute function="AssertTextEquals#assertPartialText" locator1="LoopFeed#ENTRY_UNDO_MESSAGE" value1="You just unfollowed a post from the Following stream." />
	</command>

	<command name="viewUrlLink">
		<var name="key_feedEntryContent" value="${feedEntryContent}" />
		<var name="key_feedEntryLinkUrl" value="${feedEntryLinkUrl}" />

		<execute function="AssertTextEquals" locator1="LoopFeed#ENTRY_CONTENT_URL_LINK" value1="${feedEntryLinkUrl}" />
	</command>

	<command name="viewUserMention">
		<var name="key_feedEntryContent" value="${feedEntryContent}" />
		<var name="key_userName" value="${userName}" />

		<execute macro="LoopNavigation#closeOverlay" />

		<execute function="AssertClick" locator1="LoopFeed#ENTRY_CONTENT_USER_MENTION_LINK" value1="${userName}" />

		<execute macro="LoopPeoplePerson#viewPersonProfile">
			<var name="jobTitleName" value="${jobTitleName}" />
			<var name="userEmailAddress" value="${userEmailAddress}" />
			<var name="userName" value="${userName}" />
		</execute>
	</command>

	<command name="viewUserProfilePictureDefaultViaDropdownList">
		<execute function="SikuliAssertElementPresent" locator1="LoopFeed#ADD_ENTRY_DROPDOWN_LIST_USER_PROFILE_PICTURE_DEFAULT" />
	</command>

	<command name="viewUserViaLikeSummaryLink">
		<var name="key_feedEntryContent" value="${feedEntryContent}" />
		<var name="key_userName" value="${userName}" />

		<execute function="Click#clickNoMouseOver" locator1="LoopFeed#ENTRY_LIKE_SUMMARY_USER_AVATAR_LINK" />

		<execute macro="LoopPeoplePerson#viewPersonProfile">
			<var name="jobTitleName" value="${jobTitleName}" />
			<var name="userEmailAddress" value="${userEmailAddress}" />
			<var name="userName" value="${userName}" />
		</execute>
	</command>

	<command name="viewUserViaLikeSummaryList">
		<var name="key_feedEntryContent" value="${feedEntryContent}" />

		<var method="MathUtil#difference('${numberOfLikes}', '6')" name="numberOfRemainingLikes" />

		<var name="key_numberOfRemainingLikes" value="${numberOfRemainingLikes}" />

		<execute function="AssertClick" locator1="LoopFeed#ENTRY_LIKE_SUMMARY_USER_LIST" value1="+${numberOfRemainingLikes}" />

		<execute macro="LoopPeoplePerson#gotoPersonViaPeopleList">
			<var name="userName" value="${userName}" />
		</execute>

		<execute macro="LoopPeoplePerson#viewPersonProfile">
			<var name="jobTitleName" value="${jobTitleName}" />
			<var name="userEmailAddress" value="${userEmailAddress}" />
			<var name="userName" value="${userName}" />
		</execute>
	</command>

	<command name="viewUserViaSharedToLink">
		<var name="key_feedEntryContent" value="${feedEntryContent}" />
		<var name="key_userName" value="${userName}" />

		<execute function="AssertClick" locator1="LoopFeed#ENTRY_SHARED_TO_PERSON_LINK" value1="${userName}" />

		<execute macro="LoopPeoplePerson#viewPersonProfile">
			<var name="jobTitleName" value="${jobTitleName}" />
			<var name="userEmailAddress" value="${userEmailAddress}" />
			<var name="userName" value="${userName}" />
		</execute>
	</command>

	<command name="viewUserViaSharedToList">
		<execute macro="LoopFeedEntry#clickUserSharedToListLink">
			<var name="feedEntryContent" value="${feedEntryContent}" />
			<var name="numberOfUserShares" value="${numberOfUserShares}" />
		</execute>

		<execute macro="LoopPeoplePerson#gotoPersonViaPeopleList">
			<var name="userName" value="${userName}" />
		</execute>

		<execute macro="LoopPeoplePerson#viewPersonProfile">
			<var name="jobTitleName" value="${jobTitleName}" />
			<var name="userEmailAddress" value="${userEmailAddress}" />
			<var name="userName" value="${userName}" />
		</execute>
	</command>
</definition>