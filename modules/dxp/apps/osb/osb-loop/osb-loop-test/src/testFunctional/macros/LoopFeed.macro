		</execute>

		<execute macro="LoopFeedEntryComment#post">
			<var name="feedEntryContent" value="${feedEntryContent}" />
		</execute>

		<execute macro="LoopFeed#viewEntryCommentReplyWithImage">
			<var name="feedEntryCommentContent" value="${feedEntryCommentContent}" />
			<var name="feedEntryCommentReplyAuthorName" value="${feedEntryCommentReplyAuthorName}" />
			<var name="feedEntryCommentReplyContent" value="${feedEntryCommentReplyContent}" />
			<var name="feedEntryCommentReplyDate" value="${feedEntryCommentReplyDate}" />
		</execute>
	</command>

	<command name="addEntryCommentReplyWithLink">
		<execute macro="LoopFeedEntryComment#clickAddReplyLink">
			<var name="feedEntryCommentContent" value="${feedEntryCommentContent}" />
			<var name="feedEntryContent" value="${feedEntryContent}" />
		</execute>

		<execute macro="LoopFeedEntryComment#clickAndTypeText">
			<var name="feedEntryCommentText" value="${feedEntryCommentReplyText}" />
			<var name="feedEntryContent" value="${feedEntryContent}" />
		</execute>

		<execute macro="LoopFeedEntryComment#typeLink">
			<var name="feedEntryCommentLinkUrl" value="${feedEntryCommentReplyLinkUrl}" />
			<var name="feedEntryContent" value="${feedEntryContent}" />
		</execute>

		<execute macro="LoopFeed#shareEntryComment">
			<var name="feedEntryContent" value="${feedEntryContent}" />
			<var name="hashtagTopicNameList" value="${hashtagTopicNameList}" />
			<var name="mentionGroupNameList" value="${mentionGroupNameList}" />
			<var name="mentionPrivateGroupNameList" value="${mentionPrivateGroupNameList}" />
			<var name="mentionPrivateUserNameList" value="${mentionPrivateUserNameList}" />
			<var name="mentionUserNameList" value="${mentionUserNameList}" />
		</execute>

		<execute macro="LoopFeedEntryComment#post">
			<var name="feedEntryContent" value="${feedEntryContent}" />
		</execute>

		<execute macro="LoopFeed#viewEntryCommentReplyWithLink">
			<var name="feedEntryCommentContent" value="${feedEntryCommentContent}" />
			<var name="feedEntryCommentReplyAuthorName" value="${feedEntryCommentReplyAuthorName}" />
			<var name="feedEntryCommentReplyContent" value="${feedEntryCommentReplyContent}" />
			<var name="feedEntryCommentReplyDate" value="${feedEntryCommentReplyDate}" />
			<var name="feedEntryCommentReplyLinkUrl" value="${feedEntryCommentReplyLinkUrl}" />
		</execute>
	</command>

	<command name="addEntryCommentWithAnimatedImage">
		<execute macro="LoopFeedEntry#clickAddCommentLink">
			<var name="feedEntryContent" value="${feedEntryContent}" />
		</execute>

		<execute macro="LoopFeedEntryComment#clickAndTypeText">
			<var name="feedEntryCommentText" value="${feedEntryCommentText}" />
			<var name="feedEntryContent" value="${feedEntryContent}" />
		</execute>

		<execute macro="LoopFeed#shareEntryComment">
			<var name="feedEntryContent" value="${feedEntryContent}" />
			<var name="hashtagTopicNameList" value="${hashtagTopicNameList}" />
			<var name="mentionGroupNameList" value="${mentionGroupNameList}" />
			<var name="mentionPrivateGroupNameList" value="${mentionPrivateGroupNameList}" />
			<var name="mentionPrivateUserNameList" value="${mentionPrivateUserNameList}" />
			<var name="mentionUserNameList" value="${mentionUserNameList}" />
		</execute>

		<execute macro="LoopFeedEntryComment#uploadImage">
			<var name="feedEntryCommentImage" value="${feedEntryCommentImage}" />
			<var name="feedEntryContent" value="${feedEntryContent}" />
		</execute>

		<execute macro="LoopFeedEntryComment#post">
			<var name="feedEntryContent" value="${feedEntryContent}" />
		</execute>

		<execute macro="LoopFeed#viewEntryCommentWithAnimatedImage">
			<var name="feedEntryCommentAuthorName" value="${feedEntryCommentAuthorName}" />
			<var name="feedEntryCommentContent" value="${feedEntryCommentContent}" />
			<var name="feedEntryCommentDate" value="${feedEntryCommentDate}" />
			<var name="feedEntryContent" value="${feedEntryContent}" />
		</execute>
	</command>

	<command name="addEntryCommentWithImage">
		<execute macro="LoopFeedEntry#clickAddCommentLink">
			<var name="feedEntryContent" value="${feedEntryContent}" />
		</execute>

		<execute macro="LoopFeedEntryComment#clickAndTypeText">
			<var name="feedEntryCommentText" value="${feedEntryCommentText}" />
			<var name="feedEntryContent" value="${feedEntryContent}" />
		</execute>

		<execute macro="LoopFeed#shareEntryComment">
			<var name="feedEntryContent" value="${feedEntryContent}" />
			<var name="hashtagTopicNameList" value="${hashtagTopicNameList}" />
			<var name="mentionGroupNameList" value="${mentionGroupNameList}" />
			<var name="mentionPrivateGroupNameList" value="${mentionPrivateGroupNameList}" />
			<var name="mentionPrivateUserNameList" value="${mentionPrivateUserNameList}" />
			<var name="mentionUserNameList" value="${mentionUserNameList}" />
		</execute>

		<execute macro="LoopFeedEntryComment#uploadImage">
			<var name="feedEntryCommentImage" value="${feedEntryCommentImage}" />
			<var name="feedEntryContent" value="${feedEntryContent}" />
		</execute>

		<execute macro="LoopFeedEntryComment#post">
			<var name="feedEntryContent" value="${feedEntryContent}" />
		</execute>

		<execute macro="LoopFeed#viewEntryCommentWithImage">
			<var name="feedEntryCommentAuthorName" value="${feedEntryCommentAuthorName}" />
			<var name="feedEntryCommentContent" value="${feedEntryCommentContent}" />
			<var name="feedEntryCommentDate" value="${feedEntryCommentDate}" />
			<var name="feedEntryContent" value="${feedEntryContent}" />
		</execute>
	</command>

	<command name="addEntryCommentWithLink">
		<execute macro="LoopFeedEntry#clickAddCommentLink">
			<var name="feedEntryContent" value="${feedEntryContent}" />
		</execute>

		<execute macro="LoopFeedEntryComment#clickAndTypeText">
			<var name="feedEntryCommentText" value="${feedEntryCommentText}" />
			<var name="feedEntryContent" value="${feedEntryContent}" />
		</execute>

		<execute macro="LoopFeedEntryComment#typeLink">
			<var name="feedEntryCommentLinkUrl" value="${feedEntryCommentLinkUrl}" />
			<var name="feedEntryContent" value="${feedEntryContent}" />
		</execute>

		<execute macro="LoopFeed#shareEntryComment">
			<var name="feedEntryContent" value="${feedEntryContent}" />
			<var name="hashtagTopicNameList" value="${hashtagTopicNameList}" />
			<var name="mentionGroupNameList" value="${mentionGroupNameList}" />
			<var name="mentionPrivateGroupNameList" value="${mentionPrivateGroupNameList}" />
			<var name="mentionPrivateUserNameList" value="${mentionPrivateUserNameList}" />
			<var name="mentionUserNameList" value="${mentionUserNameList}" />
		</execute>

		<execute macro="LoopFeedEntryComment#post">
			<var name="feedEntryContent" value="${feedEntryContent}" />
		</execute>

		<execute macro="LoopFeed#viewEntryCommentWithLink">
			<var name="feedEntryCommentAuthorName" value="${feedEntryCommentAuthorName}" />
			<var name="feedEntryCommentContent" value="${feedEntryCommentContent}" />
			<var name="feedEntryCommentDate" value="${feedEntryCommentDate}" />
			<var name="feedEntryCommentLinkUrl" value="${feedEntryCommentLinkUrl}" />
			<var name="feedEntryContent" value="${feedEntryContent}" />
		</execute>
	</command>

	<command name="addFeaturedTopic">
		<execute macro="LoopFeed#clickFeaturedTopicsSettings" />

		<execute macro="LoopFeed#selectFeaturedTopic">
			<var name="topicName" value="${topicName}" />
		</execute>

		<execute macro="LoopFeed#clickModalCloseButton" />

		<execute macro="LoopFeed#viewFeaturedTopic">
			<var name="expertCount" value="${expertCount}" />
			<var name="followerCount" value="${followerCount}" />
			<var name="topicName" value="${topicName}" />
		</execute>
	</command>

	<command name="addImageEntry">
		<execute macro="LoopFeedEntry#clickAndTypeText">
			<var name="feedEntryText" value="${feedEntryText}" />
		</execute>

		<execute macro="LoopFeed#shareEntry">
			<var name="hashtagTopicNameList" value="${hashtagTopicNameList}" />
			<var name="mentionGroupNameList" value="${mentionGroupNameList}" />
			<var name="mentionUserNameList" value="${mentionUserNameList}" />
			<var name="shareWithGroupNameList" value="${shareWithGroupNameList}" />
			<var name="shareWithTopicNameList" value="${shareWithTopicNameList}" />
			<var name="shareWithUserNameList" value="${shareWithUserNameList}" />
		</execute>

		<execute macro="LoopFeedEntry#uploadImage">
			<var name="feedEntryImage" value="${feedEntryImage}" />
		</execute>

		<execute macro="LoopFeedEntry#makePrivate">
			<var name="private" value="${private}" />
		</execute>

		<execute macro="LoopFeedEntry#post" />

		<execute macro="LoopFeed#viewImageEntry">
			<var name="feedEntryAuthorName" value="${feedEntryAuthorName}" />
			<var name="feedEntryContent" value="${feedEntryContent}" />
			<var name="feedEntryImage" value="${feedEntryImage}" />
			<var name="private" value="${private}" />
		</execute>
	</command>

	<command name="addImagesEntry">
		<execute macro="LoopFeedEntry#clickAndTypeText">
			<var name="feedEntryText" value="${feedEntryText}" />
		</execute>

		<execute macro="LoopFeed#shareEntry">
			<var name="hashtagTopicNameList" value="${hashtagTopicNameList}" />
			<var name="mentionGroupNameList" value="${mentionGroupNameList}" />
			<var name="mentionUserNameList" value="${mentionUserNameList}" />
			<var name="shareWithGroupNameList" value="${shareWithGroupNameList}" />
			<var name="shareWithTopicNameList" value="${shareWithTopicNameList}" />
			<var name="shareWithUserNameList" value="${shareWithUserNameList}" />
		</execute>

		<var name="positionValue" value="0" />

		<for list="${feedEntryImageList}" param="feedEntryImage">
			<var method="MathUtil#sum('${positionValue}', '1')" name="positionValue" />

			<execute macro="LoopFeedEntry#uploadImage">
				<var name="feedEntryImage" value="${feedEntryImage}" />
			</execute>

			<execute macro="LoopFeedEntry#viewSpecificImagePreview">
				<var name="positionValue" value="${positionValue}" />
			</execute>
		</for>

		<execute macro="LoopFeedEntry#makePrivate">
			<var name="private" value="${private}" />
		</execute>

		<execute macro="LoopFeedEntry#post" />

		<execute macro="LoopFeed#viewImagesEntry">
			<var name="feedEntryAuthorName" value="${feedEntryAuthorName}" />
			<var name="feedEntryContent" value="${feedEntryContent}" />
			<var name="numberOfImages" value="${numberOfImages}" />
			<var name="private" value="${private}" />
		</execute>
	</command>

	<command name="addLinkEntry">
		<execute macro="LoopFeedEntry#clickAndTypeText">
			<var name="feedEntryText" value="${feedEntryText}" />
		</execute>

		<execute macro="LoopFeed#shareEntry">
			<var name="hashtagTopicNameList" value="${hashtagTopicNameList}" />
			<var name="mentionGroupNameList" value="${mentionGroupNameList}" />
			<var name="mentionUserNameList" value="${mentionUserNameList}" />
			<var name="shareWithGroupNameList" value="${shareWithGroupNameList}" />
			<var name="shareWithTopicNameList" value="${shareWithTopicNameList}" />
			<var name="shareWithUserNameList" value="${shareWithUserNameList}" />
		</execute>

		<execute macro="LoopFeedEntry#generateLinkPreview">
			<var name="feedEntryLinkUrl" value="${feedEntryLinkUrl}" />
		</execute>

		<execute macro="LoopFeedEntry#viewLinkPreviewViaTextField" />

		<execute macro="LoopFeedEntry#makePrivate">
			<var name="private" value="${private}" />
		</execute>

		<execute macro="LoopFeedEntry#post" />

		<execute macro="LoopFeed#viewLinkEntry">
			<var name="feedEntryAuthorName" value="${feedEntryAuthorName}" />
			<var name="feedEntryContent" value="${feedEntryContent}" />
			<var name="private" value="${private}" />
		</execute>
	</command>

	<command name="addLinkEntryAndViewPreviewText">
		<execute macro="LoopFeedEntry#clickAndTypeText">
			<var name="feedEntryText" value="${feedEntryText}" />
		</execute>

		<execute macro="LoopFeed#shareEntry">
			<var name="hashtagTopicNameList" value="${hashtagTopicNameList}" />
			<var name="mentionGroupNameList" value="${mentionGroupNameList}" />
			<var name="mentionUserNameList" value="${mentionUserNameList}" />
			<var name="shareWithGroupNameList" value="${shareWithGroupNameList}" />
			<var name="shareWithTopicNameList" value="${shareWithTopicNameList}" />
			<var name="shareWithUserNameList" value="${shareWithUserNameList}" />
		</execute>

		<execute macro="LoopFeedEntry#generateLinkPreview">
			<var name="feedEntryLinkUrl" value="${feedEntryLinkUrl}" />
		</execute>

		<execute macro="LoopFeedEntry#viewLinkPreviewTextViaTextField">
			<var name="feedEntryLinkDescription" value="${feedEntryLinkDescription}" />
			<var name="feedEntryLinkName" value="${feedEntryLinkName}" />
			<var name="feedEntryLinkShortUrl" value="${feedEntryLinkShortUrl}" />
		</execute>

		<execute macro="LoopFeedEntry#post" />

		<execute macro="LoopFeed#viewLinkEntryWithPreviewText">
			<var name="feedEntryAuthorName" value="${feedEntryAuthorName}" />
			<var name="feedEntryContent" value="${feedEntryContent}" />
			<var name="feedEntryLinkDescription" value="${feedEntryLinkDescription}" />
			<var name="feedEntryLinkName" value="${feedEntryLinkName}" />
			<var name="feedEntryLinkShortUrl" value="${feedEntryLinkShortUrl}" />
		</execute>
	</command>

	<command name="bookmarkEntry">
		<execute macro="LoopFeedEntry#clickOptionsLink">
			<var name="feedEntryContent" value="${feedEntryContent}" />
		</execute>

		<execute macro="LoopFeedEntry#clickBookmarkLink" />

		<execute macro="LoopFeedEntry#viewBookmark">
			<var name="feedEntryContent" value="${feedEntryContent}" />
		</execute>
	</command>

	<command name="clickFeaturedTopicsSettings">
		<execute function="Click" locator1="LoopFeed#FEATURED_TOPICS_SETTINGS" />
	</command>

	<command name="clickModalCloseButton">
		<execute function="Click" locator1="LoopFeed#MODAL_CLOSE_BUTTON" />
	</command>

	<command name="clickRemoveFeaturedTopic">
		<var name="key_topicName" value="${topicName}" />

		<execute function="Click" locator1="LoopFeed#MANAGE_FEATURED_TOPICS_TOPIC_NAME_REMOVE" />
		<execute function="AssertTextEquals" locator1="LoopFeed#SUCCESS_MESSAGE" value1="The item was successfully removed from the featured list." />
	</command>

	<command name="clickSeeAllFeaturedTopics">
		<execute function="Click" locator1="LoopFeed#FEATURED_TOPICS_MORE_LINK" />
	</command>

	<command name="clickSeeAllNewGroups">
		<execute function="Click" locator1="LoopFeed#NEW_GROUPS_MORE_LINK" />
	</command>

	<command name="clickSeeAllNewHires">
		<execute function="Click" locator1="LoopFeed#NEW_HIRES_MORE_LINK" />
	</command>

	<command name="deleteEntry">
