	<command name="unfollowGroupsViaNewGroupsList">
		<execute macro="LoopFeed#clickSeeAllNewGroups" />

		<for list="${groupNameList}" param="groupName">
			<execute macro="LoopGroupsGroup#clickUnfollowLinkViaIndex">
				<var name="groupName" value="${groupName}" />
			</execute>
		</for>
	</command>

	<command name="unfollowGroupViaNewGroupsList">
		<execute macro="LoopFeed#clickSeeAllNewGroups" />

		<execute macro="LoopGroupsGroup#clickUnfollowLinkViaIndex">
			<var name="groupName" value="${groupName}" />
		</execute>
	</command>

	<command name="unfollowPeopleViaNewHiresList">
		<execute macro="LoopFeed#clickSeeAllNewHires" />

		<for list="${userNameList}" param="userName">
			<execute macro="LoopPeoplePerson#clickUnfollowLinkViaIndex">
				<var name="userName" value="${userName}" />
			</execute>
		</for>
	</command>

	<command name="unfollowPersonViaNewHiresList">
		<execute macro="LoopFeed#clickSeeAllNewHires" />

		<execute macro="LoopPeoplePerson#clickUnfollowLinkViaIndex">
			<var name="userName" value="${userName}" />
		</execute>
	</command>

	<command name="unfollowTopicsViaFeaturedTopicsList">
		<execute macro="LoopFeed#clickSeeAllFeaturedTopics" />

		<for list="${topicNameList}" param="topicName">
			<execute macro="LoopTopicsTopic#clickUnfollowLinkViaIndex">
				<var name="topicName" value="${topicName}" />
			</execute>
		</for>
	</command>

	<command name="unfollowTopicViaFeaturedTopicsList">
		<execute macro="LoopFeed#clickSeeAllFeaturedTopics" />

		<execute macro="LoopTopicsTopic#clickUnfollowLinkViaIndex">
			<var name="topicName" value="${topicName}" />
		</execute>
	</command>

	<command name="viewAnimatedImageEntry">
		<execute macro="LoopFeedEntry#viewAuthorAndContent">
			<var name="feedEntryAuthorName" value="${feedEntryAuthorName}" />
			<var name="feedEntryContent" value="${feedEntryContent}" />
			<var name="feedEntryDate" value="${feedEntryDate}" />
			<var name="private" value="${private}" />
		</execute>

		<execute macro="LoopFeedEntry#viewAnimatedImage">
			<var name="feedEntryContent" value="${feedEntryContent}" />
			<var name="feedEntryImage" value="${feedEntryImage}" />
		</execute>
	</command>

	<command name="viewAnimatedImagesEntry">
		<execute macro="LoopFeedEntry#viewAuthorAndContent">
			<var name="feedEntryAuthorName" value="${feedEntryAuthorName}" />
			<var name="feedEntryContent" value="${feedEntryContent}" />
			<var name="feedEntryDate" value="${feedEntryDate}" />
			<var name="private" value="${private}" />
		</execute>

		<execute macro="LoopFeedEntry#viewAnimatedImages">
			<var name="feedEntryContent" value="${feedEntryContent}" />
			<var name="numberOfImages" value="${numberOfImages}" />
		</execute>
	</command>

	<command name="viewEntryAuthorViaNameLink">
		<execute macro="LoopFeedEntry#clickAuthorNameLink">
			<var name="feedEntryAuthorName" value="${feedEntryAuthorName}" />
			<var name="feedEntryContent" value="${feedEntryContent}" />
		</execute>

		<execute macro="LoopPeoplePerson#viewPersonProfile">
			<var name="userEmailAddress" value="${feedEntryAuthorEmailAddress}" />
			<var name="userName" value="${feedEntryAuthorName}" />
		</execute>
	</command>

	<command name="viewEntryAuthorViaProfilePicture">
		<execute macro="LoopFeedEntry#clickAuthorProfilePicture">
			<var name="feedEntryAuthorName" value="${feedEntryAuthorName}" />
			<var name="feedEntryContent" value="${feedEntryContent}" />
		</execute>

		<execute macro="LoopPeoplePerson#viewPersonProfile">
			<var name="userEmailAddress" value="${feedEntryAuthorEmailAddress}" />
			<var name="userName" value="${feedEntryAuthorName}" />
		</execute>
	</command>

	<command name="viewEntryCommentAuthorViaNameLink">
		<execute macro="LoopFeedEntryComment#clickAuthorNameLink">
			<var name="feedEntryCommentAuthorName" value="${feedEntryCommentAuthorName}" />
			<var name="feedEntryCommentContent" value="${feedEntryCommentContent}" />
			<var name="feedEntryContent" value="${feedEntryContent}" />
		</execute>

		<execute macro="LoopPeoplePerson#viewPersonProfile">
			<var name="userEmailAddress" value="${feedEntryCommentAuthorEmailAddress}" />
			<var name="userName" value="${feedEntryCommentAuthorName}" />
		</execute>
	</command>

	<command name="viewEntryCommentAuthorViaProfilePicture">
		<execute macro="LoopFeedEntryComment#clickAuthorProfilePicture">
			<var name="feedEntryCommentContent" value="${feedEntryCommentContent}" />
			<var name="feedEntryContent" value="${feedEntryContent}" />
		</execute>

		<execute macro="LoopPeoplePerson#viewPersonProfile">
			<var name="userEmailAddress" value="${feedEntryCommentAuthorEmailAddress}" />
			<var name="userName" value="${feedEntryCommentAuthorName}" />
		</execute>
	</command>

	<command name="viewEntryCommentReplyWithImage">
		<execute macro="LoopFeedEntryCommentReply#viewAuthorAndContent">
			<var name="feedEntryCommentContent" value="${feedEntryCommentContent}" />
			<var name="feedEntryCommentReplyAuthorName" value="${feedEntryCommentReplyAuthorName}" />
			<var name="feedEntryCommentReplyContent" value="${feedEntryCommentReplyContent}" />
			<var name="feedEntryCommentReplyDate" value="${feedEntryCommentReplyDate}" />
		</execute>

		<execute macro="LoopFeedEntryCommentReply#viewImage">
			<var name="feedEntryCommentContent" value="${feedEntryCommentContent}" />
			<var name="feedEntryCommentReplyContent" value="${feedEntryCommentReplyContent}" />
		</execute>
	</command>

	<command name="viewEntryCommentReplyWithLink">
		<execute macro="LoopFeedEntryCommentReply#viewAuthorAndContent">
			<var name="feedEntryCommentContent" value="${feedEntryCommentContent}" />
			<var name="feedEntryCommentReplyAuthorName" value="${feedEntryCommentReplyAuthorName}" />
			<var name="feedEntryCommentReplyContent" value="${feedEntryCommentReplyContent}" />
			<var name="feedEntryCommentReplyDate" value="${feedEntryCommentReplyDate}" />
		</execute>

		<execute macro="LoopFeedEntryCommentReply#viewUrlLink">
			<var name="feedEntryCommentContent" value="${feedEntryCommentContent}" />
			<var name="feedEntryCommentReplyContent" value="${feedEntryCommentReplyContent}" />
			<var name="feedEntryCommentReplyLinkUrl" value="${feedEntryCommentReplyLinkUrl}" />
		</execute>
	</command>

	<command name="viewEntryCommentWithAnimatedImage">
		<execute macro="LoopFeedEntryComment#viewAuthorAndContent">
			<var name="feedEntryCommentAuthorName" value="${feedEntryCommentAuthorName}" />
			<var name="feedEntryCommentContent" value="${feedEntryCommentContent}" />
			<var name="feedEntryCommentDate" value="${feedEntryCommentDate}" />
			<var name="feedEntryContent" value="${feedEntryContent}" />
		</execute>

		<execute macro="LoopFeedEntryComment#viewAnimatedImage">
			<var name="feedEntryCommentContent" value="${feedEntryCommentContent}" />
			<var name="feedEntryContent" value="${feedEntryContent}" />
		</execute>
	</command>

	<command name="viewEntryCommentWithImage">
		<execute macro="LoopFeedEntryComment#viewAuthorAndContent">
			<var name="feedEntryCommentAuthorName" value="${feedEntryCommentAuthorName}" />
			<var name="feedEntryCommentContent" value="${feedEntryCommentContent}" />
			<var name="feedEntryCommentDate" value="${feedEntryCommentDate}" />
			<var name="feedEntryContent" value="${feedEntryContent}" />
		</execute>

		<execute macro="LoopFeedEntryComment#viewImage">
			<var name="feedEntryCommentContent" value="${feedEntryCommentContent}" />
			<var name="feedEntryContent" value="${feedEntryContent}" />
		</execute>
	</command>

	<command name="viewEntryCommentWithLink">
		<execute macro="LoopFeedEntryComment#viewAuthorAndContent">
			<var name="feedEntryCommentAuthorName" value="${feedEntryCommentAuthorName}" />
			<var name="feedEntryCommentContent" value="${feedEntryCommentContent}" />
			<var name="feedEntryCommentDate" value="${feedEntryCommentDate}" />
			<var name="feedEntryContent" value="${feedEntryContent}" />
		</execute>

		<execute macro="LoopFeedEntryComment#viewUrlLink">
			<var name="feedEntryCommentContent" value="${feedEntryCommentContent}" />
			<var name="feedEntryCommentLinkUrl" value="${feedEntryCommentLinkUrl}" />
			<var name="feedEntryContent" value="${feedEntryContent}" />
		</execute>
	</command>

	<command name="viewEntryDeactivatedAuthorViaProfilePicture">
		<execute macro="LoopFeedEntry#clickAuthorProfilePicture">
			<var name="feedEntryAuthorName" value="${feedEntryAuthorName}" />
			<var name="feedEntryContent" value="${feedEntryContent}" />
		</execute>

		<execute macro="LoopPeoplePerson#viewDeactivatedPersonProfile">
			<var name="userEmailAddress" value="${feedEntryAuthorEmailAddress}" />
			<var name="userName" value="${feedEntryAuthorName}" />
		</execute>
	</command>

	<command name="viewFeaturedTopic">
		<var name="key_topicName" value="${topicName}" />

		<execute function="AssertTextEquals" locator1="LoopFeed#FEATURED_TOPICS_TOPIC_NAME" value1="${topicName}" />

		<if>
			<and>
				<isset var="followerCount" />
				<not>
					<contains string="${followerCount}" substring="{followerCount}" />
				</not>
			</and>
			<then>
				<if>
					<equals arg1="${followerCount}" arg2="1" />
					<then>
						<execute function="AssertTextEquals#assertPartialText" locator1="LoopFeed#FEATURED_TOPICS_TOPIC_DETAILS" value1="1 Follower" />
					</then>
					<else>
						<execute function="AssertTextEquals#assertPartialText" locator1="LoopFeed#FEATURED_TOPICS_TOPIC_DETAILS" value1="${followerCount} Followers" />
					</else>
				</if>
			</then>
		</if>

		<execute function="MouseOver" locator1="LoopFeed#FEATURED_TOPICS_TOPIC_NAME" />

		<execute macro="LoopTopicsTopic#viewTopicOverlay">
			<var name="expertCount" value="${expertCount}" />
			<var name="followerCount" value="${followerCount}" />
			<var name="topicName" value="${topicName}" />
		</execute>
	</command>

	<command name="viewFeaturedTopicsCount">
		<execute function="AssertTextEquals" locator1="LoopFeed#FEATURED_TOPICS_HEADER" value1="FEATURED TOPICS ${featuredTopicsCount}" />
	</command>

	<command name="viewGroupViaNewGroupsList">
		<execute macro="LoopFeed#clickSeeAllNewGroups" />

		<execute macro="LoopGroupsGroup#gotoGroupViaGroupsList">
			<var name="groupName" value="${groupName}" />
		</execute>

		<execute macro="LoopGroupsGroup#viewGroupDetails">
			<var name="followerCount" value="${followerCount}" />
			<var name="groupDescription" value="${groupDescription}" />
			<var name="groupName" value="${groupName}" />
			<var name="groupSubtype" value="${groupSubtype}" />
			<var name="groupType" value="${groupType}" />
			<var name="memberCount" value="${memberCount}" />
		</execute>
	</command>

	<command name="viewImageEntry">
		<execute macro="LoopFeedEntry#viewAuthorAndContent">
			<var name="feedEntryAuthorName" value="${feedEntryAuthorName}" />
			<var name="feedEntryContent" value="${feedEntryContent}" />
			<var name="feedEntryDate" value="${feedEntryDate}" />
			<var name="private" value="${private}" />
		</execute>

		<execute macro="LoopFeedEntry#viewImage">
			<var name="feedEntryContent" value="${feedEntryContent}" />
			<var name="feedEntryImage" value="${feedEntryImage}" />
		</execute>
	</command>

	<command name="viewImagesEntry">
		<execute macro="LoopFeedEntry#viewAuthorAndContent">
			<var name="feedEntryAuthorName" value="${feedEntryAuthorName}" />
			<var name="feedEntryContent" value="${feedEntryContent}" />
			<var name="feedEntryDate" value="${feedEntryDate}" />
			<var name="private" value="${private}" />
		</execute>

		<execute macro="LoopFeedEntry#viewImages">
			<var name="feedEntryContent" value="${feedEntryContent}" />
			<var name="numberOfImages" value="${numberOfImages}" />
		</execute>
	</command>

	<command name="viewLinkEntry">
		<execute macro="LoopFeedEntry#viewAuthorAndContent">
			<var name="feedEntryAuthorName" value="${feedEntryAuthorName}" />
			<var name="feedEntryContent" value="${feedEntryContent}" />
			<var name="feedEntryDate" value="${feedEntryDate}" />
			<var name="private" value="${private}" />
		</execute>

		<execute macro="LoopFeedEntry#viewLinkPreview">
			<var name="feedEntryContent" value="${feedEntryContent}" />
		</execute>
	</command>

	<command name="viewLinkEntryWithPreviewText">
		<execute macro="LoopFeedEntry#viewAuthorAndContent">
			<var name="feedEntryAuthorName" value="${feedEntryAuthorName}" />
			<var name="feedEntryContent" value="${feedEntryContent}" />
			<var name="feedEntryDate" value="${feedEntryDate}" />
			<var name="private" value="${private}" />
		</execute>

		<execute macro="LoopFeedEntry#viewLinkPreviewText">
			<var name="feedEntryContent" value="${feedEntryContent}" />
			<var name="feedEntryLinkDescription" value="${feedEntryLinkDescription}" />
			<var name="feedEntryLinkName" value="${feedEntryLinkName}" />
			<var name="feedEntryLinkShortUrl" value="${feedEntryLinkShortUrl}" />
		</execute>
	</command>

	<command name="viewNewGroup">
		<var name="key_groupName" value="${groupName}" />
		<var name="key_groupType" value="${groupType}" />
		<var name="key_memberCount" value="${memberCount}" />

		<execute function="AssertTextEquals" locator1="LoopFeed#NEW_GROUPS_GROUP_NAME" value1="${groupName}" />
		<execute function="AssertElementPresent" locator1="LoopFeed#NEW_GROUPS_GROUP_DETAILS" />

		<if>
			<and>
				<isset var="groupType" />
				<not>
					<contains string="${groupType}" substring="{groupType}" />
				</not>
			</and>
			<then>
				<execute function="AssertTextEquals#assertPartialText" locator1="LoopFeed#NEW_GROUPS_GROUP_DETAILS" value1="${groupType}" />
			</then>
		</if>

		<if>
			<and>
				<isset var="memberCount" />
				<not>
					<contains string="${memberCount}" substring="{memberCount}" />
				</not>
			</and>
			<then>
				<if>
					<equals arg1="${memberCount}" arg2="1" />
					<then>
						<execute function="AssertTextEquals#assertPartialText" locator1="LoopFeed#NEW_GROUPS_GROUP_DETAILS" value1="1 Member" />
					</then>
					<else>
						<execute function="AssertTextEquals#assertPartialText" locator1="LoopFeed#NEW_GROUPS_GROUP_DETAILS" value1="${memberCount} Members" />
					</else>
				</if>
			</then>
		</if>

		<execute function="MouseOver" locator1="LoopFeed#NEW_GROUPS_GROUP_NAME" />

		<execute macro="LoopGroupsGroup#viewGroupOverlay">
			<var name="followerCount" value="${followerCount}" />
			<var name="groupName" value="${groupName}" />
			<var name="groupType" value="${groupType}" />
			<var name="memberCount" value="${memberCount}" />
		</execute>
	</command>

	<command name="viewNewGroupsCount">
		<execute function="AssertTextEquals" locator1="LoopFeed#NEW_GROUPS_HEADER" value1="NEW GROUPS ${newGroupsCount}" />
	</command>

	<command name="viewNewHire">
		<var name="key_userName" value="${userName}" />

		<execute function="AssertTextEquals" locator1="LoopFeed#NEW_HIRES_PERSON_NAME" value1="${userName}" />

		<execute function="MouseOver" locator1="LoopFeed#NEW_HIRES_PERSON_NAME" />

		<execute macro="LoopPeoplePerson#viewPersonOverlay">
			<var name="expertiseCount" value="${expertiseCount}" />
			<var name="followerCount" value="${followerCount}" />
			<var name="groupCount" value="${groupCount}" />
			<var name="selfOverlay" value="${selfOverlay}" />
			<var name="userName" value="${userName}" />
		</execute>
	</command>

	<command name="viewNewHiresCount">
		<execute function="AssertTextEquals" locator1="LoopFeed#NEW_HIRES_HEADER" value1="NEW HIRES ${newHiresCount}" />
	</command>

	<command name="viewNoFeaturedTopic">
		<var name="key_topicName" value="${topicName}" />

		<execute function="AssertElementNotPresent" locator1="LoopFeed#FEATURED_TOPICS_TOPIC_NAME" />
	</command>

	<command name="viewPersonViaNewHiresList">
		<execute macro="LoopFeed#clickSeeAllNewHires" />

		<execute macro="LoopPeoplePerson#gotoPersonViaPeopleList">
			<var name="userName" value="${userName}" />
		</execute>

		<execute macro="LoopPeoplePerson#viewPersonProfile">
			<var name="followerCount" value="${followerCount}" />
			<var name="groupCount" value="${groupCount}" />
			<var name="jobTitleName" value="${jobTitleName}" />
			<var name="userEmailAddress" value="${userEmailAddress}" />
			<var name="userLocation" value="${userLocation}" />
			<var name="userName" value="${userName}" />
		</execute>
	</command>

	<command name="viewTopicViaFeaturedTopicsList">
		<execute macro="LoopFeed#clickSeeAllFeaturedTopics" />

		<execute macro="LoopTopicsTopic#gotoTopicViaTopicsList">
			<var name="topicName" value="${topicName}" />
		</execute>

		<execute macro="LoopTopicsTopic#viewTopicDetails">
			<var name="followerCount" value="${followerCount}" />
			<var name="topicDescription" value="${topicDescription}" />
			<var name="topicName" value="${topicName}" />
		</execute>
	</command>
</definition>