<definition>
	<command name="addAnimatedImageEntry">
		<execute macro="LoopFeedEntry#clickAndTypeText">
			<var name="feedEntryText" value="${feedEntryText}" />
		</execute>

		<execute macro="LoopFeed#shareEntry">
			<var name="hashtagTopicNameList" value="${hashtagTopicNameList}" />
			<var name="mentionGroupNameList" value="${mentionGroupNameList}" />
			<var name="mentionUserNameList" value="${mentionUserNameList}" />
			<var name="shareWithGroupNameList" value="${shareWithGroupNameList}" />
			<var name="shareWithTopicNameList" value="${shareWithTopicNameList}" />
			<var name="shareWithUserNameList" value="${shareWithUserNameList}" />
		</execute>

		<execute macro="LoopFeedEntry#uploadImage">
			<var name="feedEntryImage" value="${feedEntryImage}" />
		</execute>

		<execute macro="LoopFeedEntry#post" />

		<execute macro="LoopFeed#viewAnimatedImageEntry">
			<var name="feedEntryAuthorName" value="${feedEntryAuthorName}" />
			<var name="feedEntryContent" value="${feedEntryContent}" />
			<var name="feedEntryImage" value="${feedEntryImage}" />
		</execute>
	</command>

	<command name="addAnimatedImagesEntry">
		<execute macro="LoopFeedEntry#clickAndTypeText">
			<var name="feedEntryText" value="${feedEntryText}" />
		</execute>

		<execute macro="LoopFeed#shareEntry">
			<var name="hashtagTopicNameList" value="${hashtagTopicNameList}" />
			<var name="mentionGroupNameList" value="${mentionGroupNameList}" />
			<var name="mentionUserNameList" value="${mentionUserNameList}" />
			<var name="shareWithGroupNameList" value="${shareWithGroupNameList}" />
			<var name="shareWithTopicNameList" value="${shareWithTopicNameList}" />
			<var name="shareWithUserNameList" value="${shareWithUserNameList}" />
		</execute>

		<var name="positionValue" value="0" />

		<for list="${feedEntryImageList}" param="feedEntryImage">
			<var method="MathUtil#sum('${positionValue}', '1')" name="positionValue" />

			<execute macro="LoopFeedEntry#uploadImage">
				<var name="feedEntryImage" value="${feedEntryImage}" />
			</execute>

			<execute macro="LoopFeedEntry#viewSpecificImagePreview">
				<var name="positionValue" value="${positionValue}" />
			</execute>
		</for>

		<execute macro="LoopFeedEntry#post" />

		<execute macro="LoopFeed#viewAnimatedImagesEntry">
			<var name="feedEntryAuthorName" value="${feedEntryAuthorName}" />
			<var name="feedEntryContent" value="${feedEntryContent}" />
			<var name="numberOfImages" value="${numberOfImages}" />
		</execute>
	</command>

	<command name="addAnnouncementEntry">
		<execute macro="LoopFeedEntry#clickAndTypeText">
			<var name="feedEntryText" value="${feedEntryText}" />
		</execute>

		<execute macro="LoopFeed#shareEntry">
			<var name="hashtagTopicNameList" value="${hashtagTopicNameList}" />
			<var name="mentionGroupNameList" value="${mentionGroupNameList}" />
			<var name="mentionUserNameList" value="${mentionUserNameList}" />
			<var name="shareWithGroupNameList" value="${shareWithGroupNameList}" />
			<var name="shareWithTopicNameList" value="${shareWithTopicNameList}" />
			<var name="shareWithUserNameList" value="${shareWithUserNameList}" />
		</execute>

		<execute macro="LoopFeedEntry#makeAnnouncement">
			<var name="feedEntryAuthorName" value="${feedEntryAuthorName}" />
			<var name="feedEntryStickyTimeInDays" value="${feedEntryStickyTimeInDays}" />
			<var name="feedEntryTitle" value="${feedEntryTitle}" />
			<var name="sendEmailNotification" value="${sendEmailNotification}" />
		</execute>

		<execute macro="LoopFeedEntry#makePrivate">
			<var name="private" value="${private}" />
		</execute>

		<execute macro="LoopFeedEntry#post" />

		<execute macro="LoopFeedEntry#viewAnnouncementAuthorAndContent">
			<var name="feedEntryAuthorName" value="${feedEntryAuthorName}" />
			<var name="feedEntryContent" value="${feedEntryContent}" />
			<var name="feedEntryDate" value="${feedEntryDate}" />
			<var name="feedEntryTitle" value="${feedEntryTitle}" />
			<var name="private" value="${private}" />
		</execute>
	</command>

	<command name="addEntry">
		<execute macro="LoopFeedEntry#clickAndTypeText">
			<var name="feedEntryText" value="${feedEntryText}" />
		</execute>

		<execute macro="LoopFeed#shareEntry">
			<var name="hashtagTopicNameList" value="${hashtagTopicNameList}" />
			<var name="mentionGroupNameList" value="${mentionGroupNameList}" />
			<var name="mentionUserNameList" value="${mentionUserNameList}" />
			<var name="shareWithGroupNameList" value="${shareWithGroupNameList}" />
			<var name="shareWithTopicNameList" value="${shareWithTopicNameList}" />
			<var name="shareWithUserNameList" value="${shareWithUserNameList}" />
		</execute>

		<execute macro="LoopFeedEntry#makePrivate">
			<var name="private" value="${private}" />
		</execute>

		<execute macro="LoopFeedEntry#post" />

		<execute macro="LoopFeedEntry#viewAuthorAndContent">
			<var name="feedEntryAuthorName" value="${feedEntryAuthorName}" />
			<var name="feedEntryContent" value="${feedEntryContent}" />
			<var name="feedEntryDate" value="${feedEntryDate}" />
			<var name="private" value="${private}" />
		</execute>
	</command>

	<command name="addEntryComment">
		<execute macro="LoopFeedEntry#clickAddCommentLink">
			<var name="feedEntryContent" value="${feedEntryContent}" />
		</execute>

		<execute macro="LoopFeedEntryComment#clickAndTypeText">
			<var name="feedEntryCommentText" value="${feedEntryCommentText}" />
			<var name="feedEntryContent" value="${feedEntryContent}" />
		</execute>

		<execute macro="LoopFeed#shareEntryComment">
			<var name="feedEntryContent" value="${feedEntryContent}" />
			<var name="hashtagTopicNameList" value="${hashtagTopicNameList}" />
			<var name="mentionGroupNameList" value="${mentionGroupNameList}" />
			<var name="mentionPrivateGroupNameList" value="${mentionPrivateGroupNameList}" />
			<var name="mentionPrivateUserNameList" value="${mentionPrivateUserNameList}" />
			<var name="mentionUserNameList" value="${mentionUserNameList}" />
		</execute>

		<execute macro="LoopFeedEntryComment#post">
			<var name="feedEntryContent" value="${feedEntryContent}" />
		</execute>

		<execute macro="LoopFeedEntryComment#viewAuthorAndContent">
			<var name="feedEntryCommentAuthorName" value="${feedEntryCommentAuthorName}" />
			<var name="feedEntryCommentContent" value="${feedEntryCommentContent}" />
			<var name="feedEntryCommentDate" value="${feedEntryCommentDate}" />
			<var name="feedEntryContent" value="${feedEntryContent}" />
		</execute>
	</command>

	<command name="addEntryCommentReply">
		<execute macro="LoopFeedEntryComment#clickAddReplyLink">
			<var name="feedEntryCommentContent" value="${feedEntryCommentContent}" />
			<var name="feedEntryContent" value="${feedEntryContent}" />
		</execute>

		<execute macro="LoopFeedEntryComment#clickAndTypeText">
