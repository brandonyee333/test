			<var name="hashtagTopicNameList" value="${hashtagTopicNameList}" />
			<var name="mentionGroupNameList" value="${mentionGroupNameList}" />
			<var name="mentionPrivateGroupNameList" value="${mentionPrivateGroupNameList}" />
			<var name="mentionPrivateUserNameList" value="${mentionPrivateUserNameList}" />
			<var name="mentionUserNameList" value="${mentionUserNameList}" />
		</execute>

		<execute macro="LoopFeedEntryComment#post">
			<var name="feedEntryContent" value="${feedEntryContent}" />
		</execute>

		<execute macro="LoopFeedEntryCommentReply#viewAuthorAndContent">
			<var name="feedEntryCommentContent" value="${feedEntryCommentContent}" />
			<var name="feedEntryCommentReplyAuthorName" value="${feedEntryCommentReplyAuthorName}" />
			<var name="feedEntryCommentReplyContent" value="${feedEntryCommentReplyContent}" />
			<var name="feedEntryCommentReplyDate" value="${feedEntryCommentReplyDate}" />
		</execute>
	</command>

	<command name="addEntryCommentReplytoCommentReply">
		<execute macro="LoopFeedEntryCommentReply#clickAddReplyLink">
			<var name="feedEntryCommentContent" value="${feedEntryCommentContent}" />
			<var name="feedEntryCommentReplyContent" value="${feedEntryCommentReplyContent}" />
		</execute>

		<execute macro="LoopFeedEntryComment#clickAndTypeText">
			<var name="feedEntryCommentText" value="${feedEntryCommentReplyReplyText}" />
			<var name="feedEntryContent" value="${feedEntryContent}" />
		</execute>

		<execute macro="LoopFeed#shareEntryComment">
			<var name="feedEntryContent" value="${feedEntryContent}" />
			<var name="hashtagTopicNameList" value="${hashtagTopicNameList}" />
			<var name="mentionGroupNameList" value="${mentionGroupNameList}" />
			<var name="mentionPrivateGroupNameList" value="${mentionPrivateGroupNameList}" />
			<var name="mentionPrivateUserNameList" value="${mentionPrivateUserNameList}" />
			<var name="mentionUserNameList" value="${mentionUserNameList}" />
		</execute>

		<execute macro="LoopFeedEntryComment#post">
			<var name="feedEntryContent" value="${feedEntryContent}" />
		</execute>

		<execute macro="LoopFeedEntryCommentReply#viewAuthorAndContent">
			<var name="feedEntryCommentContent" value="${feedEntryCommentContent}" />
			<var name="feedEntryCommentReplyAuthorName" value="${feedEntryCommentReplyReplyAuthorName}" />
			<var name="feedEntryCommentReplyContent" value="${feedEntryCommentReplyReplyContent}" />
			<var name="feedEntryCommentReplyDate" value="${feedEntryCommentReplyReplyDate}" />
		</execute>
	</command>

	<command name="addEntryCommentReplyWithImage">
		<execute macro="LoopFeedEntryComment#clickAddReplyLink">
			<var name="feedEntryCommentContent" value="${feedEntryCommentContent}" />
			<var name="feedEntryContent" value="${feedEntryContent}" />
		</execute>

		<execute macro="LoopFeedEntryComment#clickAndTypeText">
			<var name="feedEntryCommentText" value="${feedEntryCommentReplyText}" />
			<var name="feedEntryContent" value="${feedEntryContent}" />
		</execute>

		<execute macro="LoopFeed#shareEntryComment">
			<var name="feedEntryContent" value="${feedEntryContent}" />
			<var name="hashtagTopicNameList" value="${hashtagTopicNameList}" />
			<var name="mentionGroupNameList" value="${mentionGroupNameList}" />
			<var name="mentionPrivateGroupNameList" value="${mentionPrivateGroupNameList}" />
			<var name="mentionPrivateUserNameList" value="${mentionPrivateUserNameList}" />
			<var name="mentionUserNameList" value="${mentionUserNameList}" />
