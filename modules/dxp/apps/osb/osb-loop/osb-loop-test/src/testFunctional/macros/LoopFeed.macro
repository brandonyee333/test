	<command name="selectFeaturedTopic">
		<var name="key_topicName" value="${topicName}" />

		<execute function="Type#sendKeys" locator1="LoopFeed#MANAGE_FEATURED_TOPICS_SEARCH" value1="${topicName}" />
		<execute function="Click" locator1="LoopFeed#MANAGE_FEATURED_TOPICS_SELECT_TOPIC" />
		<execute function="AssertTextEquals" locator1="LoopFeed#MANAGE_FEATURED_TOPICS_TOPIC_NAME" value1="${topicName}" />
		<execute function="AssertTextEquals" locator1="LoopFeed#SUCCESS_MESSAGE" value1="${topicName} was set as featured." />
	</command>

	<command name="shareEntry">
		<if>
			<and>
				<isset var="mentionUserNameList" />
				<not>
					<contains string="${mentionUserNameList}" substring="{mentionUserNameList}" />
				</not>
			</and>
			<then>
				<execute macro="LoopFeedEntry#mentionUsers">
					<var name="mentionUserNameList" value="${mentionUserNameList}" />
				</execute>
			</then>
		</if>

		<if>
			<and>
				<isset var="mentionGroupNameList" />
				<not>
					<contains string="${mentionGroupNameList}" substring="{mentionGroupNameList}" />
				</not>
			</and>
			<then>
				<execute macro="LoopFeedEntry#mentionGroups">
					<var name="mentionGroupNameList" value="${mentionGroupNameList}" />
				</execute>
			</then>
		</if>

		<if>
			<and>
				<isset var="hashtagTopicNameList" />
				<not>
					<contains string="${hashtagTopicNameList}" substring="{hashtagTopicNameList}" />
				</not>
			</and>
			<then>
				<execute macro="LoopFeedEntry#hashtagTopics">
					<var name="hashtagTopicNameList" value="${hashtagTopicNameList}" />
				</execute>
			</then>
		</if>

		<if>
			<and>
				<isset var="shareWithUserNameList" />
				<not>
					<contains string="${shareWithUserNameList}" substring="{shareWithUserNameList}" />
				</not>
			</and>
			<then>
				<execute macro="LoopFeedEntry#shareWithUsers">
					<var name="shareWithUserNameList" value="${shareWithUserNameList}" />
				</execute>
			</then>
		</if>

		<if>
			<and>
				<isset var="shareWithGroupNameList" />
				<not>
					<contains string="${shareWithGroupNameList}" substring="{shareWithGroupNameList}" />
				</not>
			</and>
			<then>
				<execute macro="LoopFeedEntry#shareWithGroups">
					<var name="shareWithGroupNameList" value="${shareWithGroupNameList}" />
				</execute>
			</then>
		</if>

		<if>
			<and>
				<isset var="shareWithTopicNameList" />
				<not>
					<contains string="${shareWithTopicNameList}" substring="{shareWithTopicNameList}" />
				</not>
			</and>
			<then>
				<execute macro="LoopFeedEntry#shareWithTopics">
					<var name="shareWithTopicNameList" value="${shareWithTopicNameList}" />
				</execute>
			</then>
		</if>
	</command>

	<command name="shareEntryComment">
		<if>
			<and>
				<isset var="mentionUserNameList" />
