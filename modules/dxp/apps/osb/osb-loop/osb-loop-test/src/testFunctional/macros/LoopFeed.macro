	<command name="typeMarkdownContent">
		<execute macro="LoopFeedEntry#typeText">
			<var name="feedEntryText" value="Heading" />
		</execute>

		<execute macro="LoopFeedEntry#typeReturn" />

		<execute macro="LoopFeedEntry#typeText">
			<var name="feedEntryText" value="=======" />
		</execute>

		<execute macro="LoopFeedEntry#typeReturn" />

		<execute macro="LoopFeedEntry#typeText">
			<var name="feedEntryText" value="Sub-heading" />
		</execute>

		<execute macro="LoopFeedEntry#typeReturn" />

		<execute macro="LoopFeedEntry#typeText">
			<var name="feedEntryText" value="-----------" />
		</execute>

		<execute macro="LoopFeedEntry#typeReturn" />

		<execute macro="LoopFeedEntry#typeReturn" />

		<execute macro="LoopFeedEntry#typeText">
			<var name="feedEntryText" value="### Another deeper heading" />
		</execute>

		<execute macro="LoopFeedEntry#typeReturn" />

		<execute macro="LoopFeedEntry#typeReturn" />

		<execute macro="LoopFeedEntry#typeText">
			<var name="feedEntryText" value="Paragraphs are separated" />
		</execute>

		<execute macro="LoopFeedEntry#typeReturn" />

		<execute macro="LoopFeedEntry#typeText">
			<var name="feedEntryText" value="by a blank line." />
		</execute>

		<execute macro="LoopFeedEntry#typeReturn" />

		<execute macro="LoopFeedEntry#typeReturn" />

		<execute macro="LoopFeedEntry#typeText">
			<var name="feedEntryText" value="Text attributes: *italic*, **bold**, inline `code` as you can see." />
		</execute>

		<execute macro="LoopFeedEntry#typeReturn" />

		<execute macro="LoopFeedEntry#typeReturn" />

		<execute macro="LoopFeedEntry#typeText">
			<var name="feedEntryText" value="Shopping list:" />
		</execute>

		<execute macro="LoopFeedEntry#typeReturn" />

		<execute macro="LoopFeedEntry#typeReturn" />

		<execute macro="LoopFeedEntry#typeText">
			<var name="feedEntryText" value="* apples" />
		</execute>

		<execute macro="LoopFeedEntry#typeReturn" />

		<execute macro="LoopFeedEntry#typeText">
			<var name="feedEntryText" value="+ oranges" />
		</execute>

		<execute macro="LoopFeedEntry#typeReturn" />

		<execute macro="LoopFeedEntry#typeText">
			<var name="feedEntryText" value="- pears" />
		</execute>

		<execute macro="LoopFeedEntry#typeReturn" />

		<execute macro="LoopFeedEntry#typeReturn" />

		<execute macro="LoopFeedEntry#typeText">
			<var name="feedEntryText" value="Numbered list:" />
		</execute>

		<execute macro="LoopFeedEntry#typeReturn" />

		<execute macro="LoopFeedEntry#typeReturn" />

		<execute macro="LoopFeedEntry#typeText">
			<var name="feedEntryText" value="1. apples" />
		</execute>

		<execute macro="LoopFeedEntry#typeReturn" />

		<execute macro="LoopFeedEntry#typeText">
			<var name="feedEntryText" value="2. oranges" />
		</execute>

		<execute macro="LoopFeedEntry#typeReturn" />

		<execute macro="LoopFeedEntry#typeReturn" />

		<execute macro="LoopFeedEntry#typeText">
			<var name="feedEntryText" value="> Blockquotes are very handy in email to emulate reply text." />
		</execute>

		<execute macro="LoopFeedEntry#typeReturn" />

		<execute macro="LoopFeedEntry#typeText">
			<var name="feedEntryText" value="> This line is part of the same quote." />
		</execute>

		<execute macro="LoopFeedEntry#typeReturn" />

		<execute macro="LoopFeedEntry#typeReturn" />

		<execute macro="LoopFeedEntry#typeText">
			<var name="feedEntryText" value="```" />
		</execute>

		<execute macro="LoopFeedEntry#typeReturn" />

		<execute macro="LoopFeedEntry#typeText">
			<var name="feedEntryText" value="Piece of code" />
		</execute>

		<execute macro="LoopFeedEntry#typeReturn" />

		<execute macro="LoopFeedEntry#typeText">
			<var name="feedEntryText" value="```" />
		</execute>

		<execute macro="LoopFeedEntry#typeReturn" />

		<execute macro="LoopFeedEntry#typeReturn" />

		<execute macro="LoopFeedEntry#typeText">
			<var name="feedEntryText" value="A [link](http://www.google.com)." />
		</execute>

		<execute macro="LoopFeedEntry#typeReturn" />

		<execute macro="LoopFeedEntry#typeReturn" />

		<execute macro="LoopFeedEntry#typeText">
			<var name="feedEntryText" value="A [number reference link][1]" />
		</execute>

		<execute macro="LoopFeedEntry#typeReturn" />

		<execute macro="LoopFeedEntry#typeReturn" />

		<execute macro="LoopFeedEntry#typeText">
			<var name="feedEntryText" value="A [text reference link]" />
		</execute>

		<execute macro="LoopFeedEntry#typeReturn" />

		<execute macro="LoopFeedEntry#typeReturn" />

		<execute macro="LoopFeedEntry#typeText">
			<var name="feedEntryText" value="[1]: http://www.yahoo.com" />
		</execute>

		<execute macro="LoopFeedEntry#typeReturn" />

		<execute macro="LoopFeedEntry#typeReturn" />

		<execute macro="LoopFeedEntry#typeText">
			<var name="feedEntryText" value="[text reference link]: http://www.bing.com" />
		</execute>
	</command>

