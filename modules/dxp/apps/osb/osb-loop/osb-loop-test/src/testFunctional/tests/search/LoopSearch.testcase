			<var name="groupName" value="${locationName2Edit}" />
			<var name="groupType" value="Location" />
			<var name="keyword" value="Location" />
			<var name="memberCount" value="3" />
		</execute>

		<execute macro="LoopSearch#searchGroup">
			<var name="groupDescription" value="${departmentDescription1Edit}" />
			<var name="groupName" value="${departmentName1Edit}" />
			<var name="groupType" value="Department" />
			<var name="keyword" value="Name1" />
			<var name="memberCount" value="3" />
		</execute>

