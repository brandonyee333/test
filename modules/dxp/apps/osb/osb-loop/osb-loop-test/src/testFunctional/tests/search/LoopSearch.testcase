			<var name="groupName" value="${teamName2Edit}" />
			<var name="groupType" value="Team" />
			<var name="keyword" value="${teamName2Edit}" />
			<var name="memberCount" value="3" />
		</execute>

		<execute macro="LoopSearch#searchGroup">
