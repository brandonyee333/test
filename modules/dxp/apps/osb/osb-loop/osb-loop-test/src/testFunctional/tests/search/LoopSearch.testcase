			<var name="groupName" value="${teamName1}" />
			<var name="groupType" value="Team" />
			<var name="leadScreenNameList" value="${userScreenName}" />
			<var name="memberScreenNameList" value="${userScreenName2},${userScreenName3}" />
		</execute>

		<execute macro="LoopJson#createGroup">
