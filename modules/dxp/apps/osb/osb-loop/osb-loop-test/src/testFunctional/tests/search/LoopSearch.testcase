		<execute macro="LoopGroups#updateGroupInformation">
			<var name="groupDescriptionEdit" value="${teamDescription2Edit}" />
			<var name="groupNameEdit" value="${teamName2Edit}" />
		</execute>

		<execute macro="Loop#logoutAndLogin">
			<var name="userLoginEmailAddress" value="${userEmailAddress2}" />
