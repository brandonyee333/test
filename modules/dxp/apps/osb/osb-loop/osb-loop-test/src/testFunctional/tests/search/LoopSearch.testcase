			<var name="groupType" value="Team" />
		</execute>

		<execute macro="LoopGroups#updateGroupInformation">
			<var name="groupDescriptionEdit" value="${teamDescription1Edit}" />
			<var name="groupNameEdit" value="${teamName1Edit}" />
		</execute>

		<execute macro="LoopGroups#gotoGroupProfile">
			<var name="groupName" value="${teamName2}" />
