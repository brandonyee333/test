			<var name="groupNameEdit" value="${departmentName1Edit}" />
		</execute>

		<execute macro="LoopGroups#gotoGroupProfile">
			<var name="groupName" value="${departmentName2}" />
			<var name="groupType" value="Department" />
		</execute>

		<execute macro="LoopGroups#updateGroupInformation">
			<var name="groupDescriptionEdit" value="${departmentDescription2Edit}" />
			<var name="groupNameEdit" value="${departmentName2Edit}" />
		</execute>

		<execute macro="LoopGroups#gotoGroupProfile">
			<var name="groupName" value="${locationName1}" />
			<var name="groupType" value="Location" />
		</execute>

		<execute macro="LoopGroups#updateGroupInformation">
			<var name="groupDescriptionEdit" value="${locationDescription1Edit}" />
			<var name="groupNameEdit" value="${locationName1Edit}" />
		</execute>

		<execute macro="LoopGroups#gotoGroupProfile">
			<var name="groupName" value="${locationName2}" />
			<var name="groupType" value="Location" />
		</execute>

		<execute macro="LoopGroups#updateGroupInformation">
			<var name="groupDescriptionEdit" value="${locationDescription2Edit}" />
			<var name="groupNameEdit" value="${locationName2Edit}" />
		</execute>

		<execute macro="LoopGroups#gotoGroupProfile">
