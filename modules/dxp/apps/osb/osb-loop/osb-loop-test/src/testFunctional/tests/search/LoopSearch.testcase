<definition component-name="loop-search">
	<property name="loop.enabled" value="true" />
	<!--<property name="hook.plugins.includes" value="portal-compat-hook" />-->
	<property name="osgi.module.configuration.file.names" value="com.liferay.portal.security.auto.login.basic.auth.header.module.configuration.BasicAuthHeaderAutoLoginConfiguration.cfg:com.liferay.portal.bundle.blacklist.internal.BundleBlacklistConfiguration.cfg" />
	<property name="osgi.module.configurations" value="enabled=true:blacklistBundleSymbolicNames=['com.liferay.portal.search.elasticsearch', 'com.liferay.portal.search.elasticsearch.shield', 'com.liferay.portal.search.elasticsearch.marvel.web']" />
	<!--<property name="portlet.plugins.includes" value="asset-entry-set-portlet,asset-feed-portlet,asset-sharing-portlet,loop-portlet" />-->
	<property name="skip.clean-app-server-deploy-dir" value="true" />
	<property name="testray.main.component.name" value="Loop" />
	<!--<property name="theme.plugins.includes" value="loop-theme" />
	<property name="web.plugins.includes" value="url-metadata-scraper-web" />-->

	<var name="userEmailAddress" value="loopuser01@liferay.com" />
	<var name="userFirstName" value="Loop01" />
	<var name="userLastName" value="User01" />
	<var name="userName" value="Loop01 User01" />
	<var name="userScreenName" value="loopuser01" />

	<set-up>
		<execute macro="Loop#firstSetupPG">
			<var name="roleNames" value="Loop Admin,Loop Global Announcer" />
		</execute>
	</set-up>

	<command name="SearchAnnouncementsViaAllResultsTab" priority="5">
		<var name="feedEntryStickyTimeInDays" value="2" />
		<var name="feedEntryText1" value="Feed Entry1 Text" />
		<var name="feedEntryText2" value="Feed Entry2 Text" />
		<var name="feedEntryText3" value="Feed Entry3 Text" />
		<var name="feedEntryTitle1" value="Feed Entry1 Title" />
		<var name="feedEntryTitle2" value="Feed Entry2 Title" />
		<var name="feedEntryTitle3" value="Feed Entry3 Title" />

		<execute macro="Loop#openURL" />

		<execute macro="LoopFeed#addAnnouncementEntry">
			<var name="feedEntryAuthorName" value="${userName}" />
			<var name="feedEntryContent" value="${feedEntryText1}" />
			<var name="feedEntryStickyTimeInDays" value="${feedEntryStickyTimeInDays}" />
			<var name="feedEntryText" value="${feedEntryText1}" />
			<var name="feedEntryTitle" value="${feedEntryTitle1}" />
		</execute>

		<execute macro="LoopFeed#addAnnouncementEntry">
			<var name="feedEntryAuthorName" value="${userName}" />
			<var name="feedEntryContent" value="${feedEntryText2}" />
			<var name="feedEntryStickyTimeInDays" value="${feedEntryStickyTimeInDays}" />
			<var name="feedEntryText" value="${feedEntryText2}" />
			<var name="feedEntryTitle" value="${feedEntryTitle2}" />
		</execute>

		<execute macro="LoopFeed#addAnnouncementEntry">
			<var name="feedEntryAuthorName" value="${userName}" />
			<var name="feedEntryContent" value="${feedEntryText3}" />
			<var name="feedEntryStickyTimeInDays" value="${feedEntryStickyTimeInDays}" />
			<var name="feedEntryText" value="${feedEntryText3}" />
			<var name="feedEntryTitle" value="${feedEntryTitle3}" />
		</execute>

		<execute macro="LoopSearch#searchAnnouncementViaAllResultsTab">
			<var name="feedEntryAuthorName" value="${userName}" />
			<var name="feedEntryContent" value="${feedEntryText1}" />
			<var name="feedEntryTitle" value="${feedEntryTitle1}" />
			<var name="keyword" value="${feedEntryTitle1}" />
		</execute>

		<execute macro="LoopSearch#searchAnnouncementViaAllResultsTab">
			<var name="feedEntryAuthorName" value="${userName}" />
			<var name="feedEntryContent" value="${feedEntryText2}" />
			<var name="feedEntryTitle" value="${feedEntryTitle2}" />
			<var name="keyword" value="${feedEntryTitle2}" />
		</execute>

		<execute macro="LoopSearch#searchAnnouncementViaAllResultsTab">
			<var name="feedEntryAuthorName" value="${userName}" />
			<var name="feedEntryContent" value="${feedEntryText3}" />
			<var name="feedEntryTitle" value="${feedEntryTitle3}" />
			<var name="keyword" value="${feedEntryTitle3}" />
		</execute>

		<execute macro="LoopSearch#searchAnnouncementViaAllResultsTab">
			<var name="feedEntryAuthorName" value="${userName}" />
			<var name="feedEntryContent" value="${feedEntryText1}" />
			<var name="feedEntryTitle" value="${feedEntryTitle1}" />
			<var name="keyword" value="${feedEntryText1}" />
		</execute>

		<execute macro="LoopSearch#searchAnnouncementViaAllResultsTab">
			<var name="feedEntryAuthorName" value="${userName}" />
			<var name="feedEntryContent" value="${feedEntryText2}" />
			<var name="feedEntryTitle" value="${feedEntryTitle2}" />
			<var name="keyword" value="${feedEntryText2}" />
		</execute>

		<execute macro="LoopSearch#searchAnnouncementViaAllResultsTab">
			<var name="feedEntryAuthorName" value="${userName}" />
			<var name="feedEntryContent" value="${feedEntryText3}" />
			<var name="feedEntryTitle" value="${feedEntryTitle3}" />
			<var name="keyword" value="${feedEntryText3}" />
		</execute>

		<execute macro="LoopSearch#searchAnnouncementViaAllResultsTab">
			<var name="feedEntryAuthorName" value="${userName}" />
			<var name="feedEntryContent" value="${feedEntryText1}" />
			<var name="feedEntryTitle" value="${feedEntryTitle1}" />
			<var name="keyword" value="Feed" />
		</execute>

		<execute macro="LoopSearch#searchAnnouncementViaAllResultsTab">
			<var name="feedEntryAuthorName" value="${userName}" />
			<var name="feedEntryContent" value="${feedEntryText2}" />
			<var name="feedEntryTitle" value="${feedEntryTitle2}" />
			<var name="keyword" value="Feed" />
		</execute>

		<execute macro="LoopSearch#searchAnnouncementViaAllResultsTab">
			<var name="feedEntryAuthorName" value="${userName}" />
			<var name="feedEntryContent" value="${feedEntryText3}" />
			<var name="feedEntryTitle" value="${feedEntryTitle3}" />
			<var name="keyword" value="Feed" />
		</execute>
	</command>

	<command name="SearchDeactivatedPeople" priority="5">
		<var name="jobTitleName2" value="QA Engineer02" />
		<var name="jobTitleName3" value="QA Engineer03" />
		<var name="jobTitleName4" value="QA Engineer04" />
		<var name="locationDescription1" value="Location Description1" />
		<var name="locationDescription2" value="Location Description2" />
		<var name="locationDescription3" value="Location Description3" />
		<var name="locationName1" value="Location Name1" />
		<var name="locationName2" value="Location Name2" />
		<var name="locationName3" value="Location Name3" />
		<var name="userEmailAddress2" value="loopuser02@liferay.com" />
		<var name="userEmailAddress3" value="loopuser03@liferay.com" />
		<var name="userEmailAddress4" value="loopuser04@liferay.com" />
		<var name="userFirstName2" value="Loop02" />
		<var name="userFirstName3" value="Loop03" />
		<var name="userFirstName4" value="Loop04" />
		<var name="userLastName2" value="User02" />
		<var name="userLastName3" value="User03" />
		<var name="userLastName4" value="User04" />
		<var name="userName2" value="Loop02 User02" />
		<var name="userName3" value="Loop03 User03" />
		<var name="userName4" value="Loop04 User04" />
		<var name="userScreenName2" value="loopuser02" />
		<var name="userScreenName3" value="loopuser03" />
		<var name="userScreenName4" value="loopuser04" />

		<execute macro="LoopJson#createJobTitles">
			<var name="jobTitleNumberList" value="02,03,04" />
		</execute>

		<execute macro="LoopJson#addPerson">
			<var name="jobTitleName" value="${jobTitleName2}" />
			<var name="userEmailAddress" value="${userEmailAddress2}" />
			<var name="userFirstName" value="${userFirstName2}" />
			<var name="userLastName" value="${userLastName2}" />
			<var name="userScreenName" value="${userScreenName2}" />
		</execute>

		<execute macro="LoopJson#addPerson">
			<var name="jobTitleName" value="${jobTitleName3}" />
			<var name="userEmailAddress" value="${userEmailAddress3}" />
			<var name="userFirstName" value="${userFirstName3}" />
			<var name="userLastName" value="${userLastName3}" />
			<var name="userScreenName" value="${userScreenName3}" />
		</execute>

		<execute macro="LoopJson#addPerson">
			<var name="jobTitleName" value="${jobTitleName4}" />
			<var name="userEmailAddress" value="${userEmailAddress4}" />
			<var name="userFirstName" value="${userFirstName4}" />
			<var name="userLastName" value="${userLastName4}" />
			<var name="userScreenName" value="${userScreenName4}" />
		</execute>

		<execute macro="LoopJson#createGroups">
			<var name="groupNumberList" value="1,2,3" />
			<var name="groupType" value="Location" />
		</execute>

		<execute macro="LoopPeople#gotoPersonProfile">
			<var name="userName" value="${userName2}" />
		</execute>

		<execute macro="LoopPeople#updateGroup">
			<var name="groupName" value="${locationName1}" />
			<var name="groupType" value="Location" />
		</execute>

		<execute macro="LoopPeople#gotoPersonProfile">
			<var name="userName" value="${userName3}" />
		</execute>

		<execute macro="LoopPeople#updateGroup">
			<var name="groupName" value="${locationName2}" />
			<var name="groupType" value="Location" />
		</execute>

		<execute macro="LoopPeople#gotoPersonProfile">
			<var name="userName" value="${userName4}" />
		</execute>

		<execute macro="LoopPeople#updateGroup">
			<var name="groupName" value="${locationName3}" />
			<var name="groupType" value="Location" />
		</execute>

		<execute macro="LoopPeople#deactivatePerson">
			<var name="userName" value="${userName2}" />
		</execute>

		<execute macro="Loop#logoutAndLogin">
			<var name="userLoginEmailAddress" value="${userEmailAddress3}" />
		</execute>

		<execute macro="LoopSearch#searchDeactivatedPerson">
			<var name="jobTitleName" value="${jobTitleName2}" />
			<var name="keyword" value="${userName2}" />
			<var name="userEmailAddress" value="${userEmailAddress2}" />
			<var name="userLocation" value="${locationName1}" />
			<var name="userName" value="${userName2}" />
		</execute>

		<execute macro="LoopSearch#searchPerson">
			<var name="jobTitleName" value="${jobTitleName3}" />
			<var name="keyword" value="${userName3}" />
			<var name="userEmailAddress" value="${userEmailAddress3}" />
			<var name="userLocation" value="${locationName2}" />
			<var name="userName" value="${userName3}" />
		</execute>

		<execute macro="LoopSearch#searchPerson">
			<var name="jobTitleName" value="${jobTitleName4}" />
			<var name="keyword" value="${userName4}" />
			<var name="userEmailAddress" value="${userEmailAddress4}" />
			<var name="userLocation" value="${locationName3}" />
			<var name="userName" value="${userName4}" />
		</execute>

		<execute macro="LoopSearch#searchDeactivatedPerson">
			<var name="jobTitleName" value="${jobTitleName2}" />
			<var name="keyword" value="${userFirstName2}" />
			<var name="userEmailAddress" value="${userEmailAddress2}" />
			<var name="userLocation" value="${locationName1}" />
			<var name="userName" value="${userName2}" />
		</execute>

		<execute macro="LoopSearch#searchPerson">
			<var name="jobTitleName" value="${jobTitleName3}" />
			<var name="keyword" value="Loop" />
			<var name="userEmailAddress" value="${userEmailAddress3}" />
			<var name="userLocation" value="${locationName2}" />
			<var name="userName" value="${userName3}" />
		</execute>

		<execute macro="LoopSearch#searchPerson">
			<var name="jobTitleName" value="${jobTitleName4}" />
			<var name="keyword" value="${userFirstName4}" />
			<var name="userEmailAddress" value="${userEmailAddress4}" />
			<var name="userLocation" value="${locationName3}" />
			<var name="userName" value="${userName4}" />
		</execute>

		<execute macro="LoopSearch#searchDeactivatedPerson">
			<var name="jobTitleName" value="${jobTitleName2}" />
			<var name="keyword" value="${userLastName2}" />
			<var name="userEmailAddress" value="${userEmailAddress2}" />
			<var name="userLocation" value="${locationName1}" />
			<var name="userName" value="${userName2}" />
		</execute>

		<execute macro="LoopSearch#searchPerson">
			<var name="jobTitleName" value="${jobTitleName3}" />
			<var name="keyword" value="User" />
			<var name="userEmailAddress" value="${userEmailAddress3}" />
			<var name="userLocation" value="${locationName2}" />
			<var name="userName" value="${userName3}" />
		</execute>

		<execute macro="LoopSearch#searchPerson">
			<var name="jobTitleName" value="${jobTitleName4}" />
			<var name="keyword" value="${userLastName4}" />
			<var name="userEmailAddress" value="${userEmailAddress4}" />
			<var name="userLocation" value="${locationName3}" />
			<var name="userName" value="${userName4}" />
		</execute>
	</command>

	<command name="SearchEditedGroups" priority="5">
		<var name="departmentDescription1" value="Department Description1" />
		<var name="departmentDescription1Edit" value="Department Description1 Edit" />
		<var name="departmentDescription2" value="Department Description2" />
		<var name="departmentDescription2Edit" value="Department Description2 Edit" />
		<var name="departmentName1" value="Department Name1" />
		<var name="departmentName1Edit" value="Department Name1 Edit" />
		<var name="departmentName2" value="Department Name2" />
		<var name="departmentName2Edit" value="Department Name2 Edit" />
		<var name="locationDescription1" value="Location Description1" />
		<var name="locationDescription1Edit" value="Location Description1 Edit" />
		<var name="locationDescription2" value="Location Description2" />
		<var name="locationDescription2Edit" value="Location Description2 Edit" />
		<var name="locationName1" value="Location Name1" />
		<var name="locationName1Edit" value="Location Name1 Edit" />
		<var name="locationName2" value="Location Name2" />
		<var name="locationName2Edit" value="Location Name2 Edit" />
		<var name="teamDescription1" value="Team Description1" />
		<var name="teamDescription1Edit" value="Team Description1 Edit" />
		<var name="teamDescription2" value="Team Description2" />
		<var name="teamDescription2Edit" value="Team Description2 Edit" />
		<var name="teamName1" value="Team Name1" />
		<var name="teamName1Edit" value="Team Name1 Edit" />
		<var name="teamName2" value="Team Name2" />
		<var name="teamName2Edit" value="Team Name2 Edit" />
		<var name="userEmailAddress2" value="loopuser02@liferay.com" />
		<var name="userEmailAddress3" value="loopuser03@liferay.com" />
		<var name="userEmailAddress4" value="loopuser04@liferay.com" />
		<var name="userFirstName2" value="Loop02" />
		<var name="userFirstName3" value="Loop03" />
		<var name="userFirstName4" value="Loop04" />
		<var name="userLastName2" value="User02" />
		<var name="userLastName3" value="User03" />
		<var name="userLastName4" value="User04" />
		<var name="userName2" value="Loop02 User02" />
		<var name="userName3" value="Loop03 User03" />
		<var name="userName4" value="Loop04 User04" />
		<var name="userScreenName2" value="loopuser02" />
		<var name="userScreenName3" value="loopuser03" />
		<var name="userScreenName4" value="loopuser04" />

		<execute macro="LoopJson#addPeople">
			<var name="personNumberList" value="02,03,04" />
		</execute>

		<execute macro="LoopJson#createGroup">
			<var name="groupDescription" value="${departmentDescription1}" />
			<var name="groupName" value="${departmentName1}" />
			<var name="groupType" value="Department" />
			<var name="leadScreenNameList" value="${userScreenName}" />
			<var name="memberScreenNameList" value="${userScreenName2},${userScreenName3}" />
		</execute>

		<execute macro="LoopJson#createGroup">
			<var name="groupDescription" value="${departmentDescription2}" />
			<var name="groupName" value="${departmentName2}" />
			<var name="groupType" value="Department" />
			<var name="leadScreenNameList" value="${userScreenName}" />
			<var name="memberScreenNameList" value="${userScreenName2},${userScreenName3}" />
