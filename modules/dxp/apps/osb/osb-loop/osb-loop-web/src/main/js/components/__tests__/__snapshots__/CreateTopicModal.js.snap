exports[`CreateTopicModal renders 1`] = `
<div class="loading-wrapper-container create-topic-modal-container">
  <div class="loading-content">
    <div class="modal-header-container">
      <h1 class="title" ref="title" tabindex="0">create-topic</h1>
      <svg tabindex="0" class="loop-icon-container loop-icon-close-long loop-icon-small-1x modal-close" data-tooltip="">
        <use href="#loop-icon-close-long-16"></use>
      </svg>
    </div>
    <div class="modal-body-container">
      <form class="form-container">
        <div class="form-input-container default">
          <label for="FormInput1" class="label-container">name (required)</label>
          <div class="input-container input-default">
            <input id="FormInput1" name="name" value="" type="text" ref="input">
          </div>
        </div>
      </form>
      <label class="label-container">description</label>
      <div class="markdown-editor-container">
        <ul class="markdown-editor-header-container">
          <li class="active">write</li>
          <li class="">preview-markdown</li>
        </ul>
        <textarea placeholder="give-more-info-about-this-topic" value="" ref="textarea"></textarea>
        <svg class="loop-icon-container loop-icon-markdown loop-icon-large-1x loop-icon-dark markdown-supported-icon-container" title="markdown-supported" data-tooltip="">
          <use href="#loop-icon-markdown-24"></use>
        </svg>
      </div>
    </div>
    <div class="modal-footer-container">
      <button class="btn btn-container btn-secondary" type="button">cancel</button>
      <button class="btn btn-container btn-primary" type="button">create</button>
    </div>
  </div>
</div>
`;
