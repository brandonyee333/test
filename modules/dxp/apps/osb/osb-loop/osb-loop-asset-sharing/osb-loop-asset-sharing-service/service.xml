<?xml version="1.0"?>
<!DOCTYPE service-builder PUBLIC "-//Liferay//DTD Service Builder 7.0.0//EN" "http://www.liferay.com/dtd/liferay-service-builder_7_0_0.dtd">

<service-builder auto-namespace-tables="false" package-path="com.liferay.osb.loop.asset.sharing">
	<namespace>AssetSharing</namespace>
	<entity local-service="true" name="AssetSharingEntry" remote-service="false">

		<!-- PK fields -->

		<column name="classNameId" primary="true" type="long" />
		<column name="classPK" primary="true" type="long" />
		<column name="sharedToClassNameId" primary="true" type="long" />
		<column name="sharedToClassPK" primary="true" type="long" />

		<!-- Finder methods -->

		<finder name="C_C" return-type="Collection">
			<finder-column name="classNameId" />
			<finder-column name="classPK" />
		</finder>
		<finder name="S_S" return-type="Collection">
			<finder-column name="sharedToClassNameId" />
			<finder-column name="sharedToClassPK" />
		</finder>
		<finder name="C_C_S" return-type="Collection">
			<finder-column name="classNameId" />
			<finder-column name="classPK" />
			<finder-column name="sharedToClassNameId" />
		</finder>
		<finder name="C_S_S" return-type="Collection">
			<finder-column name="classNameId" />
			<finder-column name="sharedToClassNameId" />
			<finder-column name="sharedToClassPK" />
		</finder>
	</entity>
</service-builder>