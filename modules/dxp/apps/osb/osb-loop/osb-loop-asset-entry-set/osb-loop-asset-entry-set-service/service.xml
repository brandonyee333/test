<?xml version="1.0"?>
<!DOCTYPE service-builder PUBLIC "-//Liferay//DTD Service Builder 7.0.0//EN" "http://www.liferay.com/dtd/liferay-service-builder_7_0_0.dtd">

<service-builder auto-namespace-tables="false" package-path="com.liferay.osb.loop.asset.entry.set">
	<namespace>AssetEntrySet</namespace>
	<entity local-service="true" name="AssetEntrySet" remote-service="true">

		<!-- PK fields -->

		<column name="assetEntrySetId" primary="true" type="long" />

		<!-- Audit fields -->

		<column name="companyId" type="long" />
		<column name="userId" type="long" />
		<column name="createTime" type="long" />
		<column name="modifiedTime" type="long" />

		<!-- Other fields -->

		<column name="assetEntryId" type="long" />
		<column name="parentAssetEntrySetId" type="long" />
		<column name="classNameId" type="long" />
		<column name="classPK" type="long" />
		<column name="creatorClassNameId" type="long" />
		<column name="creatorClassPK" type="long" />
		<column name="creatorName" type="String" />
		<column name="assetEntrySetLikesCount" type="int" />
		<column name="childAssetEntrySetsCount" type="int" />
		<column name="level" type="int" />
		<column name="payload" type="String" />
		<column name="privateAssetEntrySet" type="boolean" />
		<column name="stickyTime" type="long" />
		<column name="title" type="String" />
		<column name="type" type="int" />
		<column name="status" type="int" />

		<!-- Order -->

		<order by="desc">
			<order-column name="createTime" />
		</order>

		<!-- Finder methods -->

		<finder name="ParentAssetEntrySetId" return-type="Collection">
			<finder-column name="parentAssetEntrySetId" />
		</finder>
		<finder name="GtCT_PAESI" return-type="Collection">
			<finder-column comparator="&gt;" name="createTime" />
			<finder-column name="parentAssetEntrySetId" />
		</finder>
		<finder name="LtCT_PAESI" return-type="Collection">
			<finder-column comparator="&lt;=" name="createTime" />
			<finder-column name="parentAssetEntrySetId" />
		</finder>
		<finder name="PAESI_CCNI" return-type="Collection">
			<finder-column name="parentAssetEntrySetId" />
			<finder-column name="creatorClassNameId" />
		</finder>
		<finder name="CNI_CPK" return-type="Collection">
			<finder-column name="classNameId" />
			<finder-column name="classPK" />
		</finder>
		<finder name="PAESI_CCNI_CCPK" return-type="AssetEntrySet">
			<finder-column name="parentAssetEntrySetId" />
			<finder-column name="creatorClassNameId" />
			<finder-column name="creatorClassPK" />
		</finder>
		<finder name="CNI_CPK_Title" return-type="AssetEntrySet">
			<finder-column name="classNameId" />
			<finder-column name="classPK" />
			<finder-column name="title" />
		</finder>
		<finder name="CNI_CPK_Type" return-type="Collection">
			<finder-column name="classNameId" />
			<finder-column name="classPK" />
			<finder-column name="type" />
		</finder>

		<!-- References -->

		<reference entity="Group" package-path="com.liferay.portal" />
		<reference entity="AssetEntry" package-path="com.liferay.portlet.asset" />
		<reference entity="DLApp" package-path="com.liferay.portlet.documentlibrary" />
		<reference entity="DLFileEntry" package-path="com.liferay.portlet.documentlibrary" />
	</entity>
	<entity local-service="true" name="AssetEntrySetLike" remote-service="false">

		<!-- PK fields -->

		<column name="assetEntrySetId" primary="true" type="long" />
		<column name="classNameId" primary="true" type="long" />
		<column name="classPK" primary="true" type="long" />

		<!-- Finder methods -->

		<finder name="AssetEntrySetId" return-type="Collection">
			<finder-column name="assetEntrySetId" />
		</finder>
	</entity>
</service-builder>