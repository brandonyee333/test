<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN" "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping auto-import="false" default-lazy="false">
	<import class="com.liferay.osb.email.blacklist.model.BlacklistEntry" />
	<import class="com.liferay.osb.email.blacklist.model.BounceEntry" />
	<class name="com.liferay.osb.email.blacklist.model.impl.BlacklistEntryImpl" table="OSB_BlacklistEntry">
		<id name="blacklistEntryId" type="long">
			<generator class="assigned" />
		</id>
		<property name="createDate" type="org.hibernate.type.TimestampType" />
		<property name="emailAddress" type="com.liferay.portal.dao.orm.hibernate.StringType" />
	</class>
	<class name="com.liferay.osb.email.blacklist.model.impl.BounceEntryImpl" table="OSB_BounceEntry">
		<id name="bounceEntryId" type="long">
			<generator class="assigned" />
		</id>
		<property name="emailAddress" type="com.liferay.portal.dao.orm.hibernate.StringType" />
		<property name="bounceDate" type="org.hibernate.type.TimestampType" />
		<property name="bounceType" type="com.liferay.portal.dao.orm.hibernate.StringType" />
		<property name="bounceSubtype" type="com.liferay.portal.dao.orm.hibernate.StringType" />
	</class>
</hibernate-mapping>