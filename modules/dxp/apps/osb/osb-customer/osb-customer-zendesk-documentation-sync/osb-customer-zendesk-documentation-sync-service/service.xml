<?xml version="1.0"?>
<!DOCTYPE service-builder PUBLIC "-//Liferay//DTD Service Builder 7.0.0//EN" "http://www.liferay.com/dtd/liferay-service-builder_7_0_0.dtd">

<service-builder package-path="com.liferay.osb.customer.zendesk.documentation">
	<namespace>OSBCustomer</namespace>
	<entity local-service="true" name="ZendeskArticle" remote-service="false">

		<!-- PK fields -->

		<column name="zendeskArticleId" primary="true" type="long" />

		<!-- Audit fields -->

		<column name="modifiedDate" type="Date" />

		<!-- Other fields -->

		<column name="liferayDocsKey" type="String" />

		<!-- Finder methods -->

		<finder name="LiferayDocsKey" return-type="Collection">
			<finder-column name="liferayDocsKey" />
		</finder>
	</entity>
	<entity local-service="true" name="ZendeskArticleAttachment" remote-service="false">

		<!-- PK fields -->

		<column name="zendeskArticleAttachmentId" primary="true" type="long" />

		<!-- Other fields -->

		<column name="zendeskArticleId" type="long" />
		<column name="filePath" type="String" />
		<column name="checksum" type="String" />

		<!-- Finder methods -->

		<finder name="ZendeskArticleId" return-type="Collection">
			<finder-column name="zendeskArticleId" />
		</finder>
	</entity>
	<entity local-service="true" name="ZendeskSection" remote-service="false">

		<!-- PK fields -->

		<column name="zendeskSectionId" primary="true" type="long" />

		<!-- Audit fields -->

		<column name="modifiedDate" type="Date" />

		<!-- Other fields -->

		<column name="liferayDocsKey" type="String" />

		<!-- Finder methods -->

		<finder name="LiferayDocsKey" return-type="Collection">
			<finder-column name="liferayDocsKey" />
		</finder>
	</entity>
</service-builder>