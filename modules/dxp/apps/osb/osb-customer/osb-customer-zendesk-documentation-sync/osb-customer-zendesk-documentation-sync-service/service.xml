<?xml version="1.0"?>
<!DOCTYPE service-builder PUBLIC "-//Liferay//DTD Service Builder 7.0.0//EN" "http://www.liferay.com/dtd/liferay-service-builder_7_0_0.dtd">

<service-builder package-path="com.liferay.osb.customer.zendesk.documentation">
	<namespace>OSBCustomer</namespace>
	<entity local-service="true" name="ZendeskArticle" remote-service="false">

		<!-- PK fields -->

		<column name="zendeskArticleId" primary="true" type="long" />

		<!-- Audit fields -->

		<column name="modifiedDate" type="Date" />

		<!-- Other fields -->

		<column name="zendeskSectionId" type="long" />
		<column name="documentationKey" type="String" />
		<column name="remoteId" type="long" />
		<column name="remoteHtmlURL" type="String" />

		<!-- Finder methods -->

		<finder name="ZendeskSectionId" return-type="Collection">
			<finder-column name="zendeskSectionId" />
		</finder>
		<finder name="ZSI_DK" return-type="ZendeskArticle">
			<finder-column name="zendeskSectionId" />
			<finder-column name="documentationKey" />
		</finder>
	</entity>
	<entity local-service="true" name="ZendeskArticleAttachment" remote-service="false">

		<!-- PK fields -->

		<column name="zendeskArticleAttachmentId" primary="true" type="long" />

		<!-- Other fields -->

		<column name="zendeskArticleId" type="long" />
		<column name="filePath" type="String" />
		<column name="checksum" type="String" />
		<column name="remoteId" type="long" />
		<column name="remoteContentURL" type="String" />

		<!-- Finder methods -->

		<finder name="ZendeskArticleId" return-type="Collection">
			<finder-column name="zendeskArticleId" />
		</finder>
		<finder name="ZAI_FP" return-type="ZendeskArticleAttachment">
			<finder-column name="zendeskArticleId" />
			<finder-column name="filePath" />
		</finder>
	</entity>
	<entity local-service="true" name="ZendeskCategory" remote-service="false">

		<!-- PK fields -->

		<column name="zendeskCategoryId" primary="true" type="long" />

		<!-- Other fields -->

		<column name="documentationKey" type="String" />
		<column name="remoteId" type="long" />

		<!-- Finder methods -->

		<finder name="DocumentationKey" return-type="ZendeskCategory">
			<finder-column name="documentationKey" />
		</finder>
	</entity>
	<entity local-service="true" name="ZendeskSection" remote-service="false">

		<!-- PK fields -->

		<column name="zendeskSectionId" primary="true" type="long" />

		<!-- Audit fields -->

		<column name="modifiedDate" type="Date" />

		<!-- Other fields -->

		<column name="zendeskCategoryId" type="long" />
		<column name="documentationKey" type="String" />
		<column name="remoteId" type="long" />
		<column name="remoteHtmlURL" type="String" />

		<!-- Finder methods -->

		<finder name="ZendeskCategoryId" return-type="Collection">
			<finder-column name="zendeskCategoryId" />
		</finder>
		<finder name="ZCI_DK" return-type="ZendeskSection">
			<finder-column name="zendeskCategoryId" />
			<finder-column name="documentationKey" />
		</finder>
	</entity>
</service-builder>