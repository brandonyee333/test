<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN" "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping auto-import="false" default-lazy="false">
	<import class="com.liferay.osb.customer.zendesk.documentation.sync.model.ZendeskArticle" />
	<import class="com.liferay.osb.customer.zendesk.documentation.sync.model.ZendeskArticleAttachment" />
	<import class="com.liferay.osb.customer.zendesk.documentation.sync.model.ZendeskCategory" />
	<import class="com.liferay.osb.customer.zendesk.documentation.sync.model.ZendeskSection" />
	<class name="com.liferay.osb.customer.zendesk.documentation.sync.model.impl.ZendeskArticleImpl" table="OSBCustomer_ZendeskArticle">
		<id name="zendeskArticleId" type="long">
			<generator class="assigned" />
		</id>
		<property name="modifiedDate" type="org.hibernate.type.TimestampType" />
		<property name="zendeskSectionId" type="com.liferay.portal.dao.orm.hibernate.LongType" />
		<property name="documentationKey" type="com.liferay.portal.dao.orm.hibernate.StringType" />
		<property name="remoteId" type="com.liferay.portal.dao.orm.hibernate.LongType" />
		<property name="remoteHtmlURL" type="com.liferay.portal.dao.orm.hibernate.StringType" />
	</class>
	<class name="com.liferay.osb.customer.zendesk.documentation.sync.model.impl.ZendeskArticleAttachmentImpl" table="OSBCustomer_ZendeskArticleAttachment">
		<id name="zendeskArticleAttachmentId" type="long">
			<generator class="assigned" />
		</id>
		<property name="zendeskArticleId" type="com.liferay.portal.dao.orm.hibernate.LongType" />
		<property name="filePath" type="com.liferay.portal.dao.orm.hibernate.StringType" />
		<property name="checksum" type="com.liferay.portal.dao.orm.hibernate.StringType" />
		<property name="remoteId" type="com.liferay.portal.dao.orm.hibernate.LongType" />
		<property name="remoteContentURL" type="com.liferay.portal.dao.orm.hibernate.StringType" />
	</class>
	<class name="com.liferay.osb.customer.zendesk.documentation.sync.model.impl.ZendeskCategoryImpl" table="OSBCustomer_ZendeskCategory">
		<id name="zendeskCategoryId" type="long">
			<generator class="assigned" />
		</id>
		<property name="documentationKey" type="com.liferay.portal.dao.orm.hibernate.StringType" />
		<property name="articleLabels" type="com.liferay.portal.dao.orm.hibernate.StringType" />
		<property name="remoteId" type="com.liferay.portal.dao.orm.hibernate.LongType" />
	</class>
	<class name="com.liferay.osb.customer.zendesk.documentation.sync.model.impl.ZendeskSectionImpl" table="OSBCustomer_ZendeskSection">
		<id name="zendeskSectionId" type="long">
			<generator class="assigned" />
		</id>
		<property name="modifiedDate" type="org.hibernate.type.TimestampType" />
		<property name="zendeskCategoryId" type="com.liferay.portal.dao.orm.hibernate.LongType" />
		<property name="documentationKey" type="com.liferay.portal.dao.orm.hibernate.StringType" />
		<property name="remoteId" type="com.liferay.portal.dao.orm.hibernate.LongType" />
		<property name="remoteHtmlURL" type="com.liferay.portal.dao.orm.hibernate.StringType" />
	</class>
</hibernate-mapping>