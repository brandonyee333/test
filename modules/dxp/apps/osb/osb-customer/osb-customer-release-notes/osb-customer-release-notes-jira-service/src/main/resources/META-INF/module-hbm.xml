<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN" "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping auto-import="false" default-lazy="false">
	<import class="com.liferay.osb.customer.release.notes.jira.model.JIRAComponent" />
	<import class="com.liferay.osb.customer.release.notes.jira.model.JIRAIssue" />
	<import class="com.liferay.osb.customer.release.notes.jira.model.JIRAProject" />
	<import class="com.liferay.osb.customer.release.notes.jira.model.JIRAProjectVersion" />
	<class name="com.liferay.osb.customer.release.notes.jira.model.impl.JIRAComponentImpl" table="component">
		<id column="id" name="jiraComponentId" type="long">
			<generator class="assigned" />
		</id>
		<property column="project" name="jiraProjectId" type="com.liferay.portal.dao.orm.hibernate.LongType" />
		<property column="cname" name="name" type="com.liferay.portal.dao.orm.hibernate.StringType" />
	</class>
	<class name="com.liferay.osb.customer.release.notes.jira.model.impl.JIRAIssueImpl" table="jiraissue">
		<id column="id" name="jiraIssueId" type="long">
			<generator class="assigned" />
		</id>
		<property column="project" name="jiraProjectId" type="com.liferay.portal.dao.orm.hibernate.LongType" />
		<property column="issuenum" name="issueNumber" type="com.liferay.portal.dao.orm.hibernate.LongType" />
		<property column="issuetype" name="type" type="com.liferay.portal.dao.orm.hibernate.IntegerType" />
		<property name="summary" type="com.liferay.portal.dao.orm.hibernate.StringType" />
		<property name="description" type="com.liferay.portal.dao.orm.hibernate.StringType" />
		<property name="priority" type="com.liferay.portal.dao.orm.hibernate.IntegerType" />
	</class>
	<class name="com.liferay.osb.customer.release.notes.jira.model.impl.JIRAProjectImpl" table="project">
		<id column="id" name="jiraProjectId" type="long">
			<generator class="assigned" />
		</id>
		<property column="pkey" name="key" type="com.liferay.portal.dao.orm.hibernate.StringType" />
		<property column="pname" name="name" type="com.liferay.portal.dao.orm.hibernate.StringType" />
	</class>
	<class name="com.liferay.osb.customer.release.notes.jira.model.impl.JIRAProjectVersionImpl" table="projectversion">
		<id column="id" name="jiraProjectVersionId" type="long">
			<generator class="assigned" />
		</id>
		<property column="project" name="jiraProjectId" type="com.liferay.portal.dao.orm.hibernate.LongType" />
		<property column="vname" name="name" type="com.liferay.portal.dao.orm.hibernate.StringType" />
		<property name="released" type="com.liferay.portal.dao.orm.hibernate.StringType" />
		<property name="archived" type="com.liferay.portal.dao.orm.hibernate.StringType" />
	</class>
</hibernate-mapping>