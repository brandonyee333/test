<?xml version="1.0"?>
<!DOCTYPE service-builder PUBLIC "-//Liferay//DTD Service Builder 7.0.0//EN" "http://www.liferay.com/dtd/liferay-service-builder_7_0_0.dtd">

<service-builder package-path="com.liferay.osb.customer.release.notes.jira">
	<namespace>RN</namespace>
	<entity data-source="jiraDataSource" local-service="true" name="JIRAComponent" remote-service="false" table="component">

		<!-- PK fields -->

		<column db-name="id" name="jiraComponentId" primary="true" type="long" />

		<!-- Other fields -->

		<column db-name="project" name="jiraProjectId" type="long" />
		<column db-name="cname" name="name" type="String" />
	</entity>
	<entity data-source="jiraDataSource" local-service="true" name="JIRAIssue" remote-service="false" table="jiraissue">

		<!-- PK fields -->

		<column db-name="id" name="jiraIssueId" primary="true" type="long" />

		<!-- Other fields -->

		<column db-name="project" name="jiraProjectId" type="long" />
		<column db-name="issuenum" name="issueNumber" type="long" />
		<column db-name="issuetype" name="type" type="int" />
		<column db-name="summary" name="summary" type="String" />
		<column db-name="description" name="description" type="String" />
		<column db-name="priority" name="priority" type="int" />
	</entity>
	<entity data-source="jiraDataSource" local-service="true" name="JIRAProject" remote-service="false" table="project">

		<!-- PK fields -->

		<column db-name="id" name="jiraProjectId" primary="true" type="long" />

		<!-- Other fields -->

		<column db-name="pkey" name="key" type="String" />
		<column db-name="pname" name="name" type="String" />

		<!-- Finder methods -->

		<finder name="Key" return-type="JIRAProject">
			<finder-column name="key" />
		</finder>
	</entity>
	<entity data-source="jiraDataSource" local-service="true" name="JIRAProjectVersion" remote-service="false" table="projectversion">

		<!-- PK fields -->

		<column db-name="id" name="jiraProjectVersionId" primary="true" type="long" />

		<!-- Other fields -->

		<column db-name="project" name="jiraProjectId" type="long" />
		<column db-name="vname" name="name" type="String" />
		<column name="released" type="String" />
		<column name="archived" type="String" />
	</entity>
	<exceptions>
		<exception>DuplicateJIRAIssueKeys</exception>
		<exception>RequiredJIRAIssueKeys</exception>
		<exception>RequiredName</exception>
	</exceptions>
</service-builder>