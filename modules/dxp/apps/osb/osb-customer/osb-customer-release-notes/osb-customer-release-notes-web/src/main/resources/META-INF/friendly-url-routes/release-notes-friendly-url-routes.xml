<?xml version="1.0"?>
<!DOCTYPE routes PUBLIC "-//Liferay//DTD Friendly URL Routes 7.0.0//EN" "http://www.liferay.com/dtd/liferay-friendly-url-routes_7_0_0.dtd">

<routes>
	<route>
		<pattern></pattern>
		<implicit-parameter name="mvcPath">/view.jsp</implicit-parameter>
	</route>
	<route>
		<pattern>/service_pack/{jiraProjectVersionId:\d+}</pattern>
		<implicit-parameter name="p_p_cacheability">cacheLevelPage</implicit-parameter>
		<implicit-parameter name="p_p_lifecycle">2</implicit-parameter>
	</route>
	<route>
		<pattern>/fix_pack/{jiraLabel}</pattern>
		<implicit-parameter name="p_p_cacheability">cacheLevelPage</implicit-parameter>
		<implicit-parameter name="p_p_lifecycle">2</implicit-parameter>
	</route>
	<route>
		<pattern>/issue_pack/{uuid}</pattern>
		<implicit-parameter name="p_p_cacheability">cacheLevelPage</implicit-parameter>
		<implicit-parameter name="p_p_lifecycle">2</implicit-parameter>
	</route>
	<route>
		<pattern>/fix_pack/{jiraProjectKey}/{jiraLabel}</pattern>
		<implicit-parameter name="p_p_cacheability">cacheLevelPage</implicit-parameter>
		<implicit-parameter name="p_p_lifecycle">2</implicit-parameter>
	</route>
</routes>