<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE service-builder PUBLIC "-//Liferay//DTD Service Builder 7.0.0//EN" "http://www.liferay.com/dtd/liferay-service-builder_7_0_0.dtd">

<service-builder package-path="com.liferay.osb.customer.release.notes">
	<namespace>RN</namespace>
	<entity data-source="jiraDataSource" local-service="true" name="JIRAComponent" remote-service="false" session-factory="jiraSessionFactory" table="component" tx-manager="jiraTransactionManager">

		<!-- PK fields -->

		<column db-name="id" name="jiraComponentId" primary="true" type="long" />

		<!-- Other fields -->

		<column db-name="project" name="jiraProjectId" type="long" />
		<column db-name="cname" name="name" type="String" />
	</entity>
	<entity data-source="jiraDataSource" local-service="true" name="JIRAIssue" remote-service="false" session-factory="jiraSessionFactory" table="jiraissue" tx-manager="jiraTransactionManager">

		<!-- PK fields -->

		<column db-name="id" name="jiraIssueId" primary="true" type="long" />

		<!-- Other fields -->

		<column db-name="project" name="jiraProjectId" type="long" />
		<column db-name="issuenum" name="issueNumber" type="long" />
		<column db-name="issuetype" name="type" type="int" />
		<column name="summary" db-name="summary" type="String" />
		<column name="description" db-name="description" type="String" />
		<column name="priority" db-name="priority" type="int" />
	</entity>
	<entity data-source="jiraDataSource" local-service="true" name="JIRAProject" remote-service="false" session-factory="jiraSessionFactory" table="project" tx-manager="jiraTransactionManager">

		<!-- PK fields -->

		<column db-name="id" name="jiraProjectId" primary="true" type="long" />

		<!-- Other fields -->

		<column db-name="pkey" name="key" type="String" />
		<column db-name="pname" name="name" type="String" />

		<!-- Finder methods -->

		<finder name="Key" return-type="JIRAProject">
			<finder-column name="key" />
		</finder>
	</entity>
	<entity data-source="jiraDataSource" local-service="true" name="JIRAProjectVersion" remote-service="false" session-factory="jiraSessionFactory" table="projectversion" tx-manager="jiraTransactionManager">

		<!-- PK fields -->

		<column db-name="id" name="jiraProjectVersionId" primary="true" type="long" />

		<!-- Other fields -->

		<column db-name="project" name="jiraProjectId" type="long" />
		<column db-name="vname" name="name" type="String" />
		<column name="released" type="String" />
		<column name="archived" type="String" />
	</entity>
	<entity local-service="true" name="ReleaseNotes" remote-service="false" uuid="true">

		<!-- PK fields -->

		<column name="releaseNotesId" primary="true" type="long" />

		<!-- Audit fields -->

		<column name="userId" type="long" />
		<column name="userName" type="String" />
		<column name="createDate" type="Date" />
		<column name="modifiedDate" type="Date" />

		<!-- Other fields -->

		<column name="name" type="String" />
		<column name="jiraIssueKeys" type="String" />

		<!-- Order -->

		<order by="desc">
			<order-column name="releaseNotesId" />
		</order>

		<!-- Finder methods -->

		<finder name="Name" return-type="ReleaseNotes">
			<finder-column name="name" />
		</finder>
		<finder name="JIRAIssueKeys" return-type="ReleaseNotes">
			<finder-column name="jiraIssueKeys" />
		</finder>
		<finder name="LikeName" return-type="Collection">
			<finder-column comparator="LIKE" name="name" />
		</finder>
	</entity>
	<exceptions>
		<exception>DuplicateJIRAIssueKeys</exception>
		<exception>RequiredJIRAIssueKeys</exception>
		<exception>RequiredName</exception>
	</exceptions>
</service-builder>