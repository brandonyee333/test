<?xml version="1.0"?>
<!DOCTYPE service-builder PUBLIC "-//Liferay//DTD Service Builder 7.0.0//EN" "http://www.liferay.com/dtd/liferay-service-builder_7_0_0.dtd">

<service-builder database-name-max-length="64" package-path="com.liferay.osb.customer.admin">
	<namespace>OSB</namespace>
	<entity local-service="true" name="AccountAttachment" remote-service="true">

		<!-- PK fields -->

		<column name="accountAttachmentId" primary="true" type="long" />

		<!-- Audit fields -->

		<column name="userId" type="long" />
		<column name="userName" type="String" />
		<column name="createDate" type="Date" />

		<!-- Other fields -->

		<column name="accountEntryId" type="long" />
		<column name="accountProjectId" type="long" />
		<column name="fileName" type="String" />
		<column name="fileSize" type="long" />
		<column name="type" type="int" />

		<!-- Order -->

		<order by="asc">
			<order-column name="createDate" />
		</order>

		<!-- Finder methods -->

		<finder name="AccountEntryId" return-type="Collection">
			<finder-column name="accountEntryId" />
		</finder>
		<finder name="AEI_API" return-type="Collection">
			<finder-column name="accountEntryId" />
			<finder-column name="accountProjectId" />
		</finder>
		<finder name="AEI_API_T" return-type="Collection">
			<finder-column name="accountEntryId" />
			<finder-column name="accountProjectId" />
			<finder-column name="type" />
		</finder>
		<finder name="AEI_API_FN_T" return-type="AccountAttachment">
			<finder-column name="accountEntryId" />
			<finder-column name="accountProjectId" />
			<finder-column name="fileName" />
			<finder-column name="type" />
		</finder>
	</entity>
	<entity local-service="false" name="AccountCustomer" remote-service="true">

		<!-- References -->

		<reference entity="Role" package-path="com.liferay.portal" />
	</entity>
	<entity local-service="true" name="AccountEntry" remote-service="true">

		<!-- PK fields -->

		<column name="accountEntryId" primary="true" type="long" />

		<!-- Audit fields -->

		<column name="companyId" type="long" />
		<column name="userId" type="long" />
		<column name="userName" type="String" />
		<column name="createDate" type="Date" />
		<column name="modifiedUserId" type="long" />
		<column name="modifiedUserName" type="String" />
		<column name="modifiedDate" type="Date" />

		<!-- Other fields -->

		<column name="koroneikiAccountKey" type="String" />
		<column name="dossieraAccountKey" type="String" />
		<column name="corpProjectUuid" type="String" />
		<column name="corpProjectId" type="long" />
		<column name="name" type="String" />
		<column name="code" type="String" />
		<column name="instructions" type="String" />
		<column name="supportEndDate" type="Date" />
		<column name="activeSupport" type="boolean" />
		<column name="ticketSupportEndDate" type="Date" />
		<column name="activeTicketSupport" type="boolean" />
		<column name="lastZendeskAuditDate" type="Date" />
		<column name="status" type="int" />

		<!-- Legacy fields -->

		<column name="corpEntryName" type="String" />

		<!-- Finder methods -->

		<finder name="KoroneikiAccountKey" return-type="AccountEntry">
			<finder-column name="koroneikiAccountKey" />
		</finder>
		<finder name="DossieraAccountKey" return-type="Collection">
			<finder-column name="dossieraAccountKey" />
		</finder>
		<finder name="CorpProjectUuid" return-type="AccountEntry">
			<finder-column name="corpProjectUuid" />
		</finder>
		<finder name="N_C" return-type="Collection">
			<finder-column case-sensitive="false" comparator="LIKE" name="name" />
			<finder-column case-sensitive="false" comparator="LIKE" name="code" />
		</finder>

		<!-- References -->

		<reference entity="Organization" package-path="com.liferay.portal" />
		<reference entity="Role" package-path="com.liferay.portal" />
	</entity>
	<entity local-service="true" name="AccountEntryLanguage" remote-service="true">

		<!-- PK fields -->

		<column name="accountEntryLanguageId" primary="true" type="long" />

		<!-- Other fields -->

		<column name="accountEntryId" type="long" />
		<column name="languageId" type="String" />

		<!-- Order -->

		<order by="asc">
			<order-column name="languageId" />
		</order>

		<!-- Finder methods -->

		<finder name="AccountEntryId" return-type="Collection">
			<finder-column name="accountEntryId" />
		</finder>
	</entity>
	<entity local-service="true" name="AccountEnvironment" remote-service="true">

		<!-- PK fields -->

		<column name="accountEnvironmentId" primary="true" type="long" />

		<!-- Audit fields -->

		<column name="userId" type="long" />
		<column name="userName" type="String" />
		<column name="createDate" type="Date" />
		<column name="modifiedDate" type="Date" />

		<!-- Other fields -->

		<column name="accountEntryId" type="long" />
		<column name="productEntryId" type="long" />
		<column name="name" type="String" />
		<column name="envOS" type="int" />
		<column name="envOSCustom" type="String" />
		<column name="envDB" type="int" />
		<column name="envJVM" type="int" />
		<column name="envAS" type="int" />
		<column name="envLFR" type="int" />
		<column name="envCommerce" type="int" />
		<column name="envBrowser" type="int" />
		<column name="envCS" type="int" />
		<column name="envSearch" type="String" />

		<!-- Order -->

		<order by="asc">
			<order-column name="name" />
		</order>

		<!-- Finder -->

		<finder name="AccountEntryId" return-type="Collection">
			<finder-column name="accountEntryId" />
		</finder>
		<finder name="AEI_PEI" return-type="Collection">
			<finder-column name="accountEntryId" />
			<finder-column name="productEntryId" />
		</finder>
		<finder name="AEI_PEI_N" return-type="AccountEnvironment">
			<finder-column name="accountEntryId" />
			<finder-column name="productEntryId" />
			<finder-column name="name" />
		</finder>

		<!-- References -->

		<reference entity="ListType" package-path="com.liferay.portal" />
	</entity>
	<entity local-service="true" name="AccountEnvironmentAttachment" remote-service="true">

		<!-- PK fields -->

		<column name="accountEnvironmentAttachmentId" primary="true" type="long" />

		<!-- Audit fields -->

		<column name="userId" type="long" />
		<column name="userName" type="String" />
		<column name="createDate" type="Date" />
		<column name="modifiedDate" type="Date" />

		<!-- Other fields -->

		<column name="accountEnvironmentId" type="long" />
		<column name="fileName" type="String" />
		<column name="fileSize" type="long" />
		<column name="type" type="int" />

		<!-- Finder methods -->

		<finder name="AccountEnvironmentId" return-type="Collection">
			<finder-column name="accountEnvironmentId" />
		</finder>
		<finder name="AEI_FN" return-type="AccountEnvironmentAttachment">
			<finder-column name="accountEnvironmentId" />
			<finder-column name="fileName" />
		</finder>
		<finder name="AEI_T" return-type="AccountEnvironmentAttachment">
			<finder-column name="accountEnvironmentId" />
			<finder-column name="type" />
		</finder>
	</entity>
	<entity local-service="true" name="AuditEntry" remote-service="true">

		<!-- PK fields -->

		<column name="auditEntryId" primary="true" type="long" />

		<!-- Audit fields -->

		<column name="userId" type="long" />
		<column name="userName" type="String" />
		<column name="createDate" type="Date" />

		<!-- Other fields -->

		<column name="classNameId" type="long" />
		<column name="classPK" type="long" />
		<column name="previousAuditEntryId" type="long" />
		<column name="auditSetId" type="long" />
		<column name="fieldClassNameId" type="long" />
		<column name="fieldClassPK" type="long" />
		<column name="action" type="int" />
		<column name="field" type="int" />
		<column name="visibility" type="int" />
		<column name="oldLabel" type="String" />
		<column name="oldValue" type="String" />
		<column name="newLabel" type="String" />
		<column name="newValue" type="String" />
		<column name="description" type="String" />
		<column name="i18n" type="boolean" />

		<!-- Order -->

		<order by="asc">
			<order-column name="createDate" />
		</order>

		<!-- Finder methods -->

		<finder name="GtCD_C" return-type="Collection">
			<finder-column name="createDate" comparator=">" />
			<finder-column name="classNameId" />
		</finder>
		<finder name="C_C_V" return-type="Collection">
			<finder-column name="classNameId" />
			<finder-column name="classPK" />
			<finder-column arrayable-operator="OR" name="visibility" />
		</finder>
		<finder name="FC_FC_F" return-type="Collection">
			<finder-column name="fieldClassNameId" />
			<finder-column name="fieldClassPK" />
			<finder-column name="field" />
		</finder>
		<finder name="C_C_A_F" return-type="Collection">
			<finder-column name="classNameId" />
			<finder-column name="classPK" />
			<finder-column name="action" />
			<finder-column name="field" />
		</finder>
	</entity>
	<entity local-service="true" name="ExternalIdMapper" remote-service="false">

		<!-- PK fields -->

		<column name="externalIdMapperId" primary="true" type="long" />

		<!-- Audit fields -->

		<column name="createDate" type="Date" />
		<column name="modifiedDate" type="Date" />

		<!-- Other fields -->

		<column name="classNameId" type="long" />
		<column name="classPK" type="long" />
		<column name="type" type="int" />
		<column name="externalId" type="String" />

		<!-- Finder methods -->

		<finder name="C_C" return-type="Collection">
			<finder-column name="classNameId" />
			<finder-column name="classPK" />
		</finder>
		<finder name="C_C_T" return-type="Collection">
			<finder-column name="classNameId" />
			<finder-column name="classPK" />
			<finder-column name="type" />
		</finder>
		<finder name="C_T_EI" return-type="Collection">
			<finder-column name="classNameId" />
			<finder-column name="type" />
			<finder-column name="externalId" />
		</finder>
	</entity>
	<entity local-service="true" name="LicenseEntry" remote-service="true">

		<!-- PK fields -->

		<column name="licenseEntryId" primary="true" type="long" />

		<!-- Audit fields -->

		<column name="userId" type="long" />
		<column name="userName" type="String" />
		<column name="createDate" type="Date" />
		<column name="modifiedDate" type="Date" />

		<!-- Other fields -->

		<column name="productEntryId" type="long" />
		<column name="name" type="String" />
		<column name="type" type="String" />
		<column name="versionMin" type="int" />
		<column name="versionMax" type="int" />

		<!-- Order -->

		<order by="asc">
			<order-column case-sensitive="false" name="name" />
		</order>

		<!-- Finder methods -->

		<finder name="ProductEntryId" return-type="Collection">
			<finder-column name="productEntryId" />
		</finder>
		<finder name="PEI_T" return-type="LicenseEntry" unique="true">
			<finder-column name="productEntryId" />
			<finder-column name="type" />
		</finder>
		<finder name="PEI_V" return-type="Collection">
			<finder-column name="productEntryId" />
			<finder-column comparator="&lt;=" name="versionMin" />
		</finder>
	</entity>
	<entity local-service="true" name="ProductEntry" remote-service="true">

		<!-- PK fields -->

		<column name="productEntryId" primary="true" type="long" />

		<!-- Audit fields -->

		<column name="userId" type="long" />
		<column name="userName" type="String" />
		<column name="createDate" type="Date" />
		<column name="modifiedDate" type="Date" />

		<!-- Other fields -->

		<column accessor="true" name="koroneikiProductKey" type="String" />
		<column name="name" type="String" />
		<column name="environment" type="int" />
		<column name="accountEnvironments" type="boolean" />
		<column name="licenses" type="boolean" />
		<column name="versionsListType" type="String" />

		<!-- Order -->

		<order by="asc">
			<order-column case-sensitive="false" name="name" />
		</order>

		<!-- Finder methods -->

		<finder name="KoroneikiProductKey" return-type="ProductEntry" unique="true">
			<finder-column name="koroneikiProductKey" />
		</finder>
		<finder name="Name" return-type="ProductEntry" unique="true">
			<finder-column name="name" />
		</finder>
		<finder name="Environment" return-type="Collection">
			<finder-column name="environment" />
		</finder>
		<finder name="Licenses" return-type="Collection">
			<finder-column name="licenses" />
		</finder>
	</entity>
	<entity local-service="true" name="ProjectSolution" remote-service="false">

		<!-- PK fields -->

		<column name="salesforceProjectKey" primary="true" type="String" />

		<!-- Other fields -->

		<column name="value" type="String" />
	</entity>
	<exceptions>
		<exception>AccountAttachmentSize</exception>
		<exception>AccountEntryKoroneikiAccountKey</exception>
		<exception>AccountEntryLanguageId</exception>
		<exception>AccountEnvironmentAttachment</exception>
		<exception>AccountEnvironmentAttachmentSize</exception>
		<exception>AccountEnvironmentEnvAS</exception>
		<exception>AccountEnvironmentEnvBrowser</exception>
		<exception>AccountEnvironmentEnvCommerce</exception>
		<exception>AccountEnvironmentEnvCS</exception>
		<exception>AccountEnvironmentEnvDB</exception>
		<exception>AccountEnvironmentEnvLFR</exception>
		<exception>AccountEnvironmentEnvOS</exception>
		<exception>AccountEnvironmentEnvSearch</exception>
		<exception>AccountEnvironmentName</exception>
		<exception>DuplicateAccountAttachment</exception>
		<exception>DuplicateAccountEnvironment</exception>
		<exception>DuplicateAccountEnvironmentAttachment</exception>
		<exception>DuplicateProductEntry</exception>
		<exception>LicenseEntryName</exception>
		<exception>LicenseEntryVersion</exception>
		<exception>ProductEntryEnvironment</exception>
		<exception>ProductEntryKoroneikiProductKey</exception>
		<exception>RequiredAccountEntry</exception>
		<exception>RequiredProductEntry</exception>
		<exception>ZendeskTag</exception>
	</exceptions>
</service-builder>