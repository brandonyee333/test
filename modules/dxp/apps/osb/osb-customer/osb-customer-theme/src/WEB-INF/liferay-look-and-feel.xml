<?xml version="1.0"?>
<!DOCTYPE look-and-feel PUBLIC "-//Liferay//DTD Look and Feel 7.0.0//EN" "http://www.liferay.com/dtd/liferay-look-and-feel_7_0_0.dtd">

<look-and-feel>
	<compatibility>
		<version>7.0.10+</version>
	</compatibility>
	<theme id="osb-customer" name="OSB Customer">
		<template-extension>ftl</template-extension>
		<portlet-decorator id="barebone" name="Barebone">
			<default-portlet-decorator>true</default-portlet-decorator>
			<portlet-decorator-css-class>portlet-barebone</portlet-decorator-css-class>
		</portlet-decorator>
		<portlet-decorator id="borderless" name="Borderless">
			<portlet-decorator-css-class>portlet-borderless</portlet-decorator-css-class>
		</portlet-decorator>
		<portlet-decorator id="decorate" name="Decorate">
			<portlet-decorator-css-class>portlet-decorate</portlet-decorator-css-class>
		</portlet-decorator>
		<settings>
			<setting configurable="true" key="footer-logo" options="true,false" type="select" value="true" />
			<setting configurable="true" key="footer-social-links" options="true,false" type="select" value="true" />
			<setting configurable="true" key="site-logo-url" value="/home" />
			<setting configurable="true" key="site-name" value="Help Center" />
			<setting configurable="true" key="site-name-url" value="https://help.liferay.com" />
			<setting configurable="true" key="social-link-one-name" value="facebook" />
			<setting configurable="true" key="social-link-one-url" value="https://www.facebook.com/liferay" />
			<setting configurable="true" key="social-link-three-name" value="linkedin" />
			<setting configurable="true" key="social-link-three-url" value="https://www.linkedin.com/company/liferay-inc-" />
			<setting configurable="true" key="social-link-two-name" value="twitter" />
			<setting configurable="true" key="social-link-two-url" value="https://twitter.com/liferay" />
			<setting configurable="true" key="zendesk-url" value="" />
		</settings>
	</theme>
</look-and-feel>