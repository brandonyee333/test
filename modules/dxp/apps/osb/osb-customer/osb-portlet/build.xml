<?xml version="1.0"?>
<!DOCTYPE project>

<project basedir="." default="deploy" name="osb-portlet">
	<property file="build.${user.name}.properties" />
	<property file="build.properties" />

	<import file="${portal.base.dir}/tools/sdk/portlets/build-common-portlet.xml" />

	<target name="build-lang">
		<antcall target="build-lang-cmd">
			<param name="lang.dir" value="docroot/WEB-INF/src/content" />
			<param name="lang.file" value="Language" />
			<param name="lang.translate" value="false" />
		</antcall>
	</target>

	<target name="build-service">
		<if>
			<not>
				<resourcecontains
					resource="${portal.base.dir}/tools/sdk/dependencies/com.liferay.portal.tools.service.builder/ivy.xml"
					substring="&lt;dependency name=&quot;com.liferay.portal.tools.service.builder&quot; org=&quot;com.liferay&quot; rev=&quot;1.0.147&quot; /&gt;"
				/>
			</not>
			<then>
				<replaceregexp
					file="${portal.base.dir}/tools/sdk/dependencies/com.liferay.portal.tools.service.builder/ivy.xml"
					flags="s"
					match="&lt;dependency name=&quot;com.liferay.portal.tools.service.builder&quot; org=&quot;com.liferay&quot; rev=&quot;[0-9.]+&quot; /&gt;"
					replace="&lt;dependency name=&quot;com.liferay.portal.tools.service.builder&quot; org=&quot;com.liferay&quot; rev=&quot;1.0.147&quot; /&gt;&lt;dependency name=&quot;qdox&quot; org=&quot;com.thoughtworks.qdox&quot; rev=&quot;1.12.1&quot; /&gt;"
				/>
			</then>
		</if>

		<delete file="${portal.base.dir}/tools/sdk/dependencies/com.liferay.portal.tools.service.builder/ivy.xml.MD5" />

		<ant antfile="${portal.base.dir}/tools/sdk/portlets/build-common-portlet.xml" target="build-service" />
	</target>

	<target name="format-javadoc">
		<ant antfile="${portal.base.dir}/tools/sdk/portlets/build-common-portlet.xml" target="format-javadoc" />

		<echo file="docroot/WEB-INF/src/META-INF/javadocs-all.xml"><![CDATA[<?xml version="1.0" encoding="UTF-8"?><javadocs></javadocs>]]></echo>
		<echo file="docroot/WEB-INF/src/META-INF/javadocs-rt.xml"><![CDATA[<?xml version="1.0" encoding="UTF-8"?><javadocs></javadocs>]]></echo>
	</target>

	<target name="format-source">
		<java
			classname="com.liferay.osb.tools.SourceFormatter"
			classpathref="plugin.classpath"
			failonerror="false"
			fork="true"
			newenvironment="true"
		/>

		<ant antfile="${portal.base.dir}/tools/sdk/portlets/build-common-portlet.xml" target="format-source" />
	</target>
</project>