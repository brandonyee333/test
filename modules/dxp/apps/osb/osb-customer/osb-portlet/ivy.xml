<?xml version="1.0"?>

<ivy-module
	version="2.0"
	xmlns:m2="http://ant.apache.org/ivy/maven"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:noNamespaceSchemaLocation="http://ant.apache.org/ivy/schemas/ivy.xsd"
>
	<info module="{ivy.module.name}" organisation="com.liferay">
		<extends extendType="configurations,description,info" location="${sdk.dir}/ivy.xml" module="com.liferay.sdk" organisation="com.liferay" revision="latest.integration" />
	</info>

	<dependencies defaultconf="default">
		<dependency name="asm" org="org.ow2.asm" rev="4.0" />
		<dependency name="ant" org="org.apache.ant" rev="1.8.2" />
		<dependency name="com.liferay.ip.geocoder" org="com.liferay" rev="2.0.8" />
		<dependency name="com.liferay.petra.content" org="com.liferay" rev="1.0.0" />
		<dependency name="com.liferay.petra.json.web.service.client" org="com.liferay" rev="3.0.2" />
		<dependency name="com.liferay.portal.dao.orm.custom.sql" org="com.liferay" rev="1.0.0" />
		<dependency name="com.liferay.portal.security.audit.api" org="com.liferay" rev="2.0.1" />
		<dependency name="commons-lang3" org="org.apache.commons" rev="3.4" />

		<dependency name="commons-csv" org="org.apache.commons" rev="1.4">
			<artifact name="commons-csv" type="jar" />
		</dependency>

		<dependency name="itextpdf" org="com.itextpdf" rev="5.4.0" />
		<dependency name="jsch" org="com.jcraft" rev="0.1.49" />
		<dependency name="twitter4j-core" org="org.twitter4j" rev="3.0.6" />
	</dependencies>
</ivy-module>