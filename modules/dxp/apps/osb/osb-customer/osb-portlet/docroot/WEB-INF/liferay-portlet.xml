<?xml version="1.0"?>
<!DOCTYPE liferay-portlet-app PUBLIC "-//Liferay//DTD Portlet Application 7.0.0//EN" "http://www.liferay.com/dtd/liferay-portlet-app_7_0_0.dtd">

<liferay-portlet-app>
	<portlet>
		<portlet-name>1</portlet-name>
		<configuration-action-class>com.liferay.osb.admin.action.ConfigurationActionImpl</configuration-action-class>
		<scheduler-entry>
			<scheduler-event-listener-class>com.liferay.osb.admin.messaging.AuditAccountEntryMessageListener</scheduler-event-listener-class>
			<trigger>
				<simple>
					<simple-trigger-value>3</simple-trigger-value>
					<time-unit>hour</time-unit>
				</simple>
			</trigger>
		</scheduler-entry>
		<scheduler-entry>
			<scheduler-event-listener-class>com.liferay.osb.admin.messaging.CheckCorpProjectsMessageListener</scheduler-event-listener-class>
			<trigger>
				<simple>
					<simple-trigger-value>1</simple-trigger-value>
					<time-unit>day</time-unit>
				</simple>
			</trigger>
		</scheduler-entry>
		<scheduler-entry>
			<scheduler-event-listener-class>com.liferay.osb.admin.messaging.CheckOfferingEntryMessageListener</scheduler-event-listener-class>
			<trigger>
				<simple>
					<simple-trigger-value>1</simple-trigger-value>
					<time-unit>day</time-unit>
				</simple>
			</trigger>
		</scheduler-entry>
		<scheduler-entry>
			<scheduler-event-listener-class>com.liferay.osb.admin.messaging.CleanAuditActionMessageListener</scheduler-event-listener-class>
			<trigger>
				<simple>
					<simple-trigger-value>1</simple-trigger-value>
					<time-unit>day</time-unit>
				</simple>
			</trigger>
		</scheduler-entry>
		<scheduler-entry>
			<scheduler-event-listener-class>com.liferay.osb.admin.messaging.DeadLetterFilterMessageListener</scheduler-event-listener-class>
			<trigger>
				<simple>
					<simple-trigger-value>1</simple-trigger-value>
					<time-unit>day</time-unit>
				</simple>
			</trigger>
		</scheduler-entry>
		<scheduler-entry>
			<scheduler-event-listener-class>com.liferay.osb.admin.messaging.SynchronizeUsersMessageListener</scheduler-event-listener-class>
			<trigger>
				<simple>
					<simple-trigger-value>15</simple-trigger-value>
					<time-unit>minute</time-unit>
				</simple>
			</trigger>
		</scheduler-entry>
		<control-panel-entry-category>portal</control-panel-entry-category>
		<control-panel-entry-class>com.liferay.osb.admin.portlet.OSBAdminControlPanelEntry</control-panel-entry-class>
		<asset-renderer-factory>com.liferay.osb.admin.asset.AccountEntryAssetRendererFactory</asset-renderer-factory>
		<asset-renderer-factory>com.liferay.osb.admin.asset.OrderEntryAssetRendererFactory</asset-renderer-factory>
		<workflow-handler>com.liferay.osb.admin.workflow.AccountEntryWorkflowHandler</workflow-handler>
		<workflow-handler>com.liferay.osb.admin.workflow.OrderEntryWorkflowHandler</workflow-handler>
		<preferences-company-wide>true</preferences-company-wide>
		<preferences-unique-per-layout>false</preferences-unique-per-layout>
		<header-portlet-css>/admin/css/main.css</header-portlet-css>
		<css-class-wrapper>osb-portlet-admin</css-class-wrapper>
	</portlet>
	<portlet>
		<portlet-name>2</portlet-name>
		<indexer-class>com.liferay.osb.support.util.TicketEntryIndexer</indexer-class>
		<scheduler-entry>
			<scheduler-event-listener-class>com.liferay.osb.support.messaging.CheckInactiveTicketEntriesMessageListener</scheduler-event-listener-class>
			<trigger>
				<simple>
					<simple-trigger-value>30</simple-trigger-value>
					<time-unit>minute</time-unit>
				</simple>
			</trigger>
		</scheduler-entry>
		<scheduler-entry>
			<scheduler-event-listener-class>com.liferay.osb.support.messaging.CheckOnHoldTicketEntriesMessageListener</scheduler-event-listener-class>
			<trigger>
				<simple>
					<simple-trigger-value>1</simple-trigger-value>
					<time-unit>day</time-unit>
				</simple>
			</trigger>
		</scheduler-entry>
		<scheduler-entry>
			<scheduler-event-listener-class>com.liferay.osb.support.messaging.CheckStatusAccountEntriesMessageListener</scheduler-event-listener-class>
			<trigger>
				<simple>
					<simple-trigger-value>1</simple-trigger-value>
					<time-unit>day</time-unit>
				</simple>
			</trigger>
		</scheduler-entry>
		<scheduler-entry>
			<scheduler-event-listener-class>com.liferay.osb.support.messaging.CleanTicketAttachmentMessageListener</scheduler-event-listener-class>
			<trigger>
				<simple>
					<simple-trigger-value>1</simple-trigger-value>
					<time-unit>day</time-unit>
				</simple>
			</trigger>
		</scheduler-entry>
		<scheduler-entry>
			<scheduler-event-listener-class>com.liferay.osb.support.messaging.CustomerFeedbackNotificationMessageListener</scheduler-event-listener-class>
			<trigger>
				<simple>
					<simple-trigger-value>1</simple-trigger-value>
					<time-unit>day</time-unit>
				</simple>
			</trigger>
		</scheduler-entry>
		<scheduler-entry>
			<scheduler-event-listener-class>com.liferay.osb.support.messaging.LiferayPartnerFeedbackNotificationMessageListener</scheduler-event-listener-class>
			<trigger>
				<simple>
					<simple-trigger-value>1</simple-trigger-value>
					<time-unit>day</time-unit>
				</simple>
			</trigger>
		</scheduler-entry>
		<scheduler-entry>
			<scheduler-event-listener-class>com.liferay.osb.support.messaging.TeamFeedbackNotificationMessageListener</scheduler-event-listener-class>
			<trigger>
				<cron>
					<cron-trigger-value>0 0 12 ? * SUN</cron-trigger-value>
				</cron>
			</trigger>
		</scheduler-entry>
		<friendly-url-mapper-class>com.liferay.osb.support.SupportFriendlyURLMapper</friendly-url-mapper-class>
		<header-portlet-css>/support/2/css/main.css</header-portlet-css>
		<header-portlet-javascript>/common/javascript/dynamic_uploader.js</header-portlet-javascript>
		<header-portlet-javascript>/common/javascript/querystring_util.js</header-portlet-javascript>
		<header-portlet-javascript>/common/javascript/resumable.js</header-portlet-javascript>
		<css-class-wrapper>osb-portlet-support</css-class-wrapper>
	</portlet>
	<portlet>
		<portlet-name>3</portlet-name>
		<configuration-action-class>com.liferay.osb.downloads.action.ConfigurationActionImpl</configuration-action-class>
		<preferences-company-wide>true</preferences-company-wide>
		<preferences-unique-per-layout>false</preferences-unique-per-layout>
		<css-class-wrapper>osb-portlet-downloads</css-class-wrapper>
		<add-default-resource>true</add-default-resource>
	</portlet>
	<portlet>
		<portlet-name>4</portlet-name>
		<friendly-url-mapper-class>com.liferay.portal.kernel.portlet.DefaultFriendlyURLMapper</friendly-url-mapper-class>
		<friendly-url-mapping>license</friendly-url-mapping>
		<friendly-url-routes>com/liferay/osb/license/portlet/license-friendly-url-routes.xml</friendly-url-routes>
		<header-portlet-css>/license/css/main.css</header-portlet-css>
		<css-class-wrapper>osb-portlet-license</css-class-wrapper>
	</portlet>
	<portlet>
		<portlet-name>18</portlet-name>
		<configuration-action-class>com.liferay.osb.licenseform.action.ConfigurationActionImpl</configuration-action-class>
		<preferences-unique-per-layout>true</preferences-unique-per-layout>
		<header-portlet-css>/license_form/css/main.css</header-portlet-css>
		<css-class-wrapper>osb-portlet-license-form</css-class-wrapper>
	</portlet>
	<portlet>
		<portlet-name>32</portlet-name>
		<configuration-action-class>com.liferay.osb.securitypatch.action.ConfigurationActionImpl</configuration-action-class>
		<portlet-layout-listener-class>com.liferay.osb.securitypatch.SecurityPatchPortletLayoutListener</portlet-layout-listener-class>
		<preferences-unique-per-layout>true</preferences-unique-per-layout>
		<instanceable>true</instanceable>
		<header-portlet-css>/security_patch/css/main.css</header-portlet-css>
		<css-class-wrapper>osb-portlet-security-patch</css-class-wrapper>
	</portlet>
	<portlet>
		<portlet-name>36</portlet-name>
		<preferences-unique-per-layout>true</preferences-unique-per-layout>
		<header-portlet-css>/page_feedback/css/main.css</header-portlet-css>
		<css-class-wrapper>osb-portlet-page-feedback</css-class-wrapper>
	</portlet>
	<role-mapper>
		<role-name>administrator</role-name>
		<role-link>Administrator</role-link>
	</role-mapper>
	<role-mapper>
		<role-name>guest</role-name>
		<role-link>Guest</role-link>
	</role-mapper>
	<role-mapper>
		<role-name>power-user</role-name>
		<role-link>Power User</role-link>
	</role-mapper>
	<role-mapper>
		<role-name>user</role-name>
		<role-link>User</role-link>
	</role-mapper>
</liferay-portlet-app>