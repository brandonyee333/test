<div style="max-width: 960px;">
	<div style="background-color: #474A4B; border: 0 solid #BABEC2; color: #FFFFFF; font: 75%/1.5 Arial,Helvetica,sans-serif; font-size: 1em; font-weight: bold; height: 32px; line-height: 32px; padding: 0 18px;">
		Support
	</div>

	<div style="border-color: #BABEC2; border-style: solid; border-width: 0 1px 1px; color: #474A4B; font: 75%/1.5 Arial,Helvetica,sans-serif; padding: 18px;">
