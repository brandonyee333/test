					<div style="font-weight: bold; line-height: 1.2; margin: 0 0 -0.6em; position: relative; z-index: 1;">
						Ticket Number
					</div>

					<div style="font-size: 30px; font-weight: bold; line-height: 36px;">
						<a href="[$TICKET_ENTRY_URL$]" style="color: #009AD6; text-decoration: none;">[$TICKET_DISPLAY_ID$]</a>
					</div>
				</div>
			</div>
		</div>

		<div style="clear: both; margin-left: -10px; margin-right: -10px; text-transform: uppercase;">
			<div style="float: left; width: 50%;">
				<div style="margin: 0 10px 0 10px;">
					<div style="border: 1px solid #CCC; background-color: #FFFFFF; margin: 0 2px 9px 9px; overflow: hidden; padding: 10px 20px;">
						<div style="float: left; font-weight: bold; line-height: 1.2; margin: 0 0 -0.6em; position: relative; z-index: 1;">
							Status
						</div>

						<div style="font-size: 2em; font-weight: bold; line-height: 1.2; text-align: right;">
							[$STATUS$]
						</div>
					</div>

