<?xml version="1.0"?>
<!DOCTYPE service-builder PUBLIC "-//Liferay//DTD Service Builder 6.0.0//EN" "http://www.liferay.com/dtd/liferay-service-builder_6_0_0.dtd">

<service-builder>
	<entity name="TrainingCertificate" local-service="true" remote-service="true">

		<!-- PK fields -->

		<column name="trainingCertificateId" type="long" primary="true" />

		<!-- Audit fields -->

		<column name="userId" type="long" />
		<column name="userName" type="String" />
		<column name="createDate" type="Date" />
		<column name="modifiedDate" type="Date" />

		<!-- Other fields -->

		<column name="trainingCustomerId" type="long" />
		<column name="userProfileHistoryId" type="long" />
		<column name="key" type="String" />
		<column name="certifiedDate" type="Date" />
		<column name="comments" type="String" />
		<column name="surveyStatus" type="int" />

		<!-- Finder methods -->

		<finder name="TrainingCustomerId" return-type="TrainingCertificate" unique="true">
			<finder-column name="trainingCustomerId" />
		</finder>
		<finder name="Key" return-type="TrainingCertificate" unique="true">
			<finder-column name="key" />
		</finder>

		<!-- References -->

		<reference package-path="com.liferay.portal" entity="ListType" />
	</entity>
	<entity name="TrainingCertificateTemplate" local-service="true" remote-service="true">

		<!-- PK fields -->

		<column name="trainingCertificateTemplateId" type="long" primary="true" />

		<!-- Audit fields -->

		<column name="userId" type="long" />
		<column name="userName" type="String" />
		<column name="createDate" type="Date" />
		<column name="modifiedDate" type="Date" />

		<!-- Other fields -->

		<column name="name" type="String" />
		<column name="description" type="String" />
		<column name="type" type="int" />

		<!-- Finder methods -->

		<finder name="Type" return-type="Collection">
			<finder-column name="type" />
		</finder>
	</entity>
	<entity name="TrainingCourse" local-service="true" remote-service="true">

		<!-- PK fields -->

		<column name="trainingCourseId" type="long" primary="true" />

		<!-- Audit fields -->

		<column name="userId" type="long" />
		<column name="userName" type="String" />
		<column name="createDate" type="Date" />
		<column name="modifiedDate" type="Date" />

		<!-- Other Fields -->

		<column name="name" type="String" />
		<column name="description" type="String" />
		<column name="creditAmount" type="int" />
		<column name="courseURL" type="String" />
		<column name="archived" type="boolean" />

		<!-- Order -->

		<order by="asc">
			<order-column name="name" case-sensitive="false" />
		</order>
	</entity>
	<entity name="TrainingCustomer" local-service="true" remote-service="true">

		<!-- PK fields -->

		<column name="trainingCustomerId" type="long" primary="true" />

		<!-- Audit fields -->

		<column name="userId" type="long" />

		<!-- Other fields -->

		<column name="classNameId" type="long" />
		<column name="classPK" type="long" />
		<column name="userProfileHistoryId" type="long" />
		<column name="comments" type="String" />
		<column name="status" type="int" />

		<!-- Finder methods -->

		<finder name="UserId" return-type="Collection">
			<finder-column name="userId" />
		</finder>
		<finder name="U_C" return-type="Collection">
			<finder-column name="userId" />
			<finder-column name="classNameId" />
		</finder>
		<finder name="C_C" return-type="Collection">
			<finder-column name="classNameId" />
			<finder-column name="classPK" />
		</finder>
		<finder name="U_C_C" return-type="TrainingCustomer">
			<finder-column name="userId" />
			<finder-column name="classNameId" />
			<finder-column name="classPK" />
		</finder>
		<finder name="C_C_S" return-type="Collection">
			<finder-column name="classNameId" />
			<finder-column name="classPK" />
			<finder-column name="status" arrayable-operator="OR" />
		</finder>
	</entity>
	<entity name="TrainingEvent" local-service="true" remote-service="true">

		<!-- PK fields -->

		<column name="trainingEventId" type="long" primary="true" />

		<!-- Audit fields -->

		<column name="userId" type="long" />
		<column name="userName" type="String" />
		<column name="createDate" type="Date" />
		<column name="modifiedDate" type="Date" />

		<!-- Other Fields -->

		<column name="DDLRecordSetId" type="long" />
		<column name="partnerEntryId" type="long" />
		<column name="trainingCertificateTemplateId" type="long" />
		<column name="trainingCourseId" type="long" />
		<column name="trainingLocationId" type="long" />
		<column name="name" type="String" />
		<column name="emailAddress" type="String" />
		<column name="portalMinorVersion" type="int" />
		<column name="type" type="int" />
		<column name="languageId" type="String" />
		<column name="localizedSlides" type="boolean" />
		<column name="timeZoneId" type="String" />
		<column name="startDate" type="Date" />
		<column name="endDate" type="Date" />
		<column name="addressId" type="long" />
		<column name="maxCustomers" type="int" />
		<column name="enrollmentURL" type="String" />

		<!-- Order -->

		<order by="desc">
			<order-column name="startDate" />
		</order>

		<!-- Finder methods -->

		<finder name="DDLRecordSetId" return-type="TrainingEvent">
			<finder-column name="DDLRecordSetId" />
		</finder>
		<finder name="TrainingCertificateTemplateId" return-type="Collection">
			<finder-column name="trainingCertificateTemplateId" />
		</finder>
		<finder name="TrainingCourseId" return-type="Collection">
			<finder-column name="trainingCourseId" />
		</finder>
		<finder name="TrainingLocationId" return-type="Collection">
			<finder-column name="trainingLocationId" />
		</finder>
		<finder name="T_SD" return-type="Collection">
			<finder-column name="type" />
			<finder-column name="startDate" comparator="&gt;" />
		</finder>
		<finder name="TC_T_SD" return-type="Collection">
			<finder-column name="trainingCourseId" />
			<finder-column name="type" />
			<finder-column name="startDate" comparator="&gt;" />
		</finder>

		<!-- References -->

		<reference package-path="com.liferay.portal" entity="Address" />
		<reference package-path="com.liferay.portlet.dynamicdatalists" entity="DDLRecordSet" />
	</entity>
	<entity name="TrainingExam" local-service="true" remote-service="true">

		<!-- PK fields -->

		<column name="trainingExamId" type="long" primary="true" />

		<!-- Other Fields -->

		<column name="trainingCertificateTemplateId" type="long" />
		<column name="name" type="String" />

		<!-- Finder methods -->

		<finder name="TrainingCertificateTemplateId" return-type="Collection">
			<finder-column name="trainingCertificateTemplateId" />
		</finder>
		<finder name="Name" return-type="Collection">
			<finder-column name="name" />
		</finder>
	</entity>
	<entity name="TrainingExamResult" local-service="true" remote-service="true">

		<!-- PK fields -->

		<column name="trainingExamResultId" type="long" primary="true" />

		<!-- Audit fields -->

		<column name="createDate" type="Date" />

		<!-- Other Fields -->

		<column name="trainingExamId" type="long" />
		<column name="recordType" type="int" />
		<column name="registrationNumber" type="String" />
		<column name="formKey" type="String" />
		<column name="startDate" type="Date" />
		<column name="testScore" type="String" />
		<column name="correctCount" type="int" />
		<column name="incorrectCount" type="int" />
		<column name="skippedCount" type="int" />
		<column name="grade" type="int" />
		<column name="status" type="int" />

		<!-- Order -->

		<order by="desc">
			<order-column name="startDate" />
		</order>

		<!-- Finder methods -->

		<finder name="GtCreateDate" return-type="Collection">
			<finder-column name="createDate" comparator="&gt;" />
		</finder>
		<finder name="RegistrationNumber" return-type="TrainingExamResult" unique="true">
			<finder-column name="registrationNumber" />
		</finder>
		<finder name="GtSD_G_NotS" return-type="Collection">
			<finder-column name="startDate" comparator="&gt;" />
			<finder-column name="grade" />
			<finder-column name="status" comparator="!=" />
		</finder>
	</entity>
	<entity name="TrainingExamResultItem" local-service="true" remote-service="true">

		<!-- PK fields -->

		<column name="trainingExamResultItemId" type="long" primary="true" />

		<!-- Other Fields -->

		<column name="trainingExamResultId" type="long" />
		<column name="trainingExamResultSectionId" type="long" />
		<column name="name" type="String" />
		<column name="status" type="String" />
		<column name="key" type="String" />
		<column name="distractorCount" type="int" />
		<column name="type" type="String" />
		<column name="response" type="String" />
		<column name="score" type="String" />
		<column name="time" type="int" />
		<column name="learningResources" type="String" />

		<!-- Order -->

		<order by="asc">
			<order-column name="name" />
		</order>

		<!-- Finder methods -->

		<finder name="TrainingExamResultId" return-type="Collection">
			<finder-column name="trainingExamResultId" />
		</finder>
		<finder name="TrainingExamResultSectionId" return-type="Collection">
			<finder-column name="trainingExamResultSectionId" />
		</finder>
	</entity>
	<entity name="TrainingExamResultSection" local-service="true" remote-service="true">

		<!-- PK fields -->

		<column name="trainingExamResultSectionId" type="long" primary="true" />

		<!-- Other Fields -->

		<column name="trainingExamResultId" type="long" />
		<column name="title" type="String" />
		<column name="sectionKey" type="String" />
		<column name="scoreIndicator" type="boolean" />
