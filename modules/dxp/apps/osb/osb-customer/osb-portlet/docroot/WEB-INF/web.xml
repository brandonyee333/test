<?xml version="1.0" encoding="UTF-8"?>

<web-app version="2.4" xmlns="http://java.sun.com/xml/ns/j2ee" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://java.sun.com/xml/ns/j2ee http://java.sun.com/xml/ns/j2ee/web-app_2_4.xsd">
	<context-param>
		<param-name>portalContextConfigLocation</param-name>
		<param-value>/WEB-INF/classes/META-INF/osb-spring.xml</param-value>
	</context-param>
	<filter>
		<filter-name>OSB Secure GS JSON Filter</filter-name>
		<filter-class>com.liferay.osb.servlet.filters.OSBSecureJSONFilter</filter-class>
		<init-param>
			<param-name>token_property</param-name>
			<param-value>json.service.api.gs.token</param-value>
		</init-param>
	</filter>
	<filter>
		<filter-name>OSB Secure LCS JSON Filter</filter-name>
		<filter-class>com.liferay.osb.servlet.filters.OSBSecureJSONFilter</filter-class>
		<init-param>
			<param-name>token_property</param-name>
			<param-value>json.service.api.lcs.token</param-value>
		</init-param>
	</filter>
	<filter-mapping>
		<filter-name>OSB Secure GS JSON Filter</filter-name>
		<url-pattern>/api/jsonws/accountentry/get-account-entry-by-code/*</url-pattern>
	</filter-mapping>
	<filter-mapping>
		<filter-name>OSB Secure GS JSON Filter</filter-name>
		<url-pattern>/api/secure/jsonws/accountentry/get-account-entry-by-code/*</url-pattern>
	</filter-mapping>
	<filter-mapping>
		<filter-name>OSB Secure LCS JSON Filter</filter-name>
		<url-pattern>/api/*</url-pattern>
	</filter-mapping>
	<listener>
		<listener-class>com.liferay.osb.admin.servlet.AdminServletContextListener</listener-class>
	</listener>
	<jsp-config>
		<taglib>
			<taglib-uri>http://java.sun.com/jsp/jstl/core</taglib-uri>
			<taglib-location>/WEB-INF/tld/c.tld</taglib-location>
		</taglib>
	</jsp-config>
</web-app>