<?xml version="1.0"?>
<!DOCTYPE service-builder PUBLIC "-//Liferay//DTD Service Builder 7.0.0//EN" "http://www.liferay.com/dtd/liferay-service-builder_7_0_0.dtd">

<service-builder>
	<entity local-service="true" name="CorpProject" remote-service="true">

		<!-- PK fields -->

		<column name="corpProjectId" primary="true" type="long" />

		<!-- Audit fields -->

		<column name="userId" type="long" />
		<column name="userName" type="String" />
		<column name="createDate" type="Date" />
		<column name="modifiedDate" type="Date" />

		<!-- Other fields -->

		<column name="dossieraProjectKey" type="String" />
		<column name="salesforceProjectKey" type="String" />
		<column name="name" type="String" />
		<column name="organizationId" type="long" />
	</entity>
</service-builder>