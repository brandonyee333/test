<?xml version="1.0"?>

<deployment xmlns="http://xml.apache.org/axis/wsdd/" xmlns:java="http://xml.apache.org/axis/wsdd/providers/java">
	<service name="Plugin_OSB_ContractAuditService" provider="java:RPC" style="rpc" use="encoded">
		<operation xmlns:operNS="urn:http.service.osb.liferay.com" name="addContractAudit" qname="operNS:addContractAudit" soapAction="">
			<parameter xmlns:tns="http://www.w3.org/2001/XMLSchema" qname="contractEntryId" type="tns:long"></parameter>
			<parameter xmlns:tns="http://www.w3.org/2001/XMLSchema" qname="signatoryClassName" type="tns:string"></parameter>
			<parameter xmlns:tns="http://www.w3.org/2001/XMLSchema" qname="signatoryClassPK" type="tns:long"></parameter>
			<parameter xmlns:tns="http://www.w3.org/2001/XMLSchema" qname="productClassName" type="tns:string"></parameter>
			<parameter xmlns:tns="http://www.w3.org/2001/XMLSchema" qname="productClassPK" type="tns:long"></parameter>
		</operation>
		<parameter name="allowedMethods" value="addContractAudit" />
		<parameter name="className" value="com.liferay.osb.service.http.ContractAuditServiceSoap" />
		<parameter name="typeMappingVersion" value="1.2" />
		<parameter name="wsdlPortType" value="ContractAuditServiceSoap" />
		<parameter name="wsdlServiceElement" value="ContractAuditServiceSoapService" />
		<parameter name="wsdlServicePort" value="Plugin_OSB_ContractAuditService" />
		<parameter name="wsdlTargetNamespace" value="urn:http.service.osb.liferay.com" />
	</service>
</deployment>