<?xml version="1.0"?>
<!DOCTYPE routes PUBLIC "-//Liferay//DTD Friendly URL Routes 6.1.0//EN" "http://www.liferay.com/dtd/liferay-friendly-url-routes_6_1_0.dtd">

<routes>
	<route>
		<pattern>/catalog/{token}</pattern>
		<implicit-parameter name="p_p_lifecycle">2</implicit-parameter>
		<implicit-parameter name="p_p_resource_id">serveCatalogXML</implicit-parameter>
	</route>
	<route>
		<pattern>/application/{appEntryId}</pattern>
		<implicit-parameter name="mvcPath">/marketplace/view_app_entry.jsp</implicit-parameter>
	</route>
	<route>
		<pattern>/category/{assetCategoryId}</pattern>
		<implicit-parameter name="mvcPath">/marketplace/view_category.jsp</implicit-parameter>
	</route>
	<route>
		<pattern>/list/{assetListType}</pattern>
		<implicit-parameter name="mvcPath">/marketplace/search.jsp</implicit-parameter>
	</route>
	<route>
		<pattern>/asset/icon/{assetAttachmentId}</pattern>
		<implicit-parameter name="p_p_lifecycle">2</implicit-parameter>
		<implicit-parameter name="p_p_resource_id">serveIcon</implicit-parameter>
	</route>
	<route>
		<pattern>/application/review/{appEntryId}</pattern>
		<implicit-parameter name="mvcPath">/marketplace/edit_app_entry_review.jsp</implicit-parameter>
	</route>
	<route>
		<pattern>/category/{assetCategoryId}/browse</pattern>
		<implicit-parameter name="browse">true</implicit-parameter>
		<implicit-parameter name="keywords"></implicit-parameter>
		<implicit-parameter name="mvcPath">/marketplace/search.jsp</implicit-parameter>
	</route>
	<route>
		<pattern>/portal/{buildNumber}/browse</pattern>
		<implicit-parameter name="browse">true</implicit-parameter>
		<implicit-parameter name="keywords"></implicit-parameter>
		<implicit-parameter name="mvcPath">/marketplace/search.jsp</implicit-parameter>
	</route>
	<route>
		<pattern>/application/{appEntryId}/purchase</pattern>
		<implicit-parameter name="mvcPath">/marketplace/purchase_app_entry.jsp</implicit-parameter>
	</route>
	<route>
		<pattern>/download/{appEntryId}/{portalBuildNumber}</pattern>
		<implicit-parameter name="p_p_lifecycle">2</implicit-parameter>
		<implicit-parameter name="p_p_resource_id">serveApp</implicit-parameter>
	</route>
	<route>
		<pattern>/category/{assetCategoryId}/list/{assetListType}</pattern>
		<implicit-parameter name="mvcPath">/marketplace/search.jsp</implicit-parameter>
	</route>
	<route>
		<pattern>/application/{appEntryId}/{buildNumber}/{token}</pattern>
		<implicit-parameter name="p_p_lifecycle">2</implicit-parameter>
		<implicit-parameter name="p_p_resource_id">serveReleaseApp</implicit-parameter>
	</route>
	<route>
		<pattern>/download/auto_qa/{appPackageId}/{token}/{licensed}</pattern>
		<implicit-parameter name="p_p_lifecycle">2</implicit-parameter>
		<implicit-parameter name="p_p_resource_id">serveAutoQAApp</implicit-parameter>
	</route>
	<route>
		<pattern>/download/{appEntryId}/{version:[.\w]+}/{portalBuildNumber}</pattern>
		<implicit-parameter name="p_p_lifecycle">2</implicit-parameter>
		<implicit-parameter name="p_p_resource_id">serveApp</implicit-parameter>
	</route>
	<route>
		<pattern>/download/{appEntryId}/{version:[.\w]+}/{portalBuildNumber}/src</pattern>
		<implicit-parameter name="p_p_lifecycle">2</implicit-parameter>
		<implicit-parameter name="p_p_resource_id">serveAppPackageSrc</implicit-parameter>
	</route>
	<route>
		<pattern>/application/{appEntryId}/{buildNumber}/{version:[.\w]+}/{token}</pattern>
		<implicit-parameter name="p_p_lifecycle">2</implicit-parameter>
		<implicit-parameter name="p_p_resource_id">serveReleaseApp</implicit-parameter>
	</route>
</routes>