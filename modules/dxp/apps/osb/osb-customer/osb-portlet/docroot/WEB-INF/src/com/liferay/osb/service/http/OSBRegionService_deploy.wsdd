<?xml version="1.0"?>

<deployment xmlns="http://xml.apache.org/axis/wsdd/" xmlns:java="http://xml.apache.org/axis/wsdd/providers/java">
	<service name="Plugin_OSB_OSBRegionService" provider="java:RPC" style="rpc" use="encoded">
		<operation xmlns:operNS="urn:http.service.osb.liferay.com" xmlns:rtns="http://www.w3.org/2001/XMLSchema" name="addRegion" qname="operNS:addRegion" returnQName="addRegionReturn" returnType="rtns:anyType" soapAction="">
			<parameter xmlns:tns="http://www.w3.org/2001/XMLSchema" qname="countryId" type="tns:long"></parameter>
			<parameter xmlns:tns="http://www.w3.org/2001/XMLSchema" qname="regionCode" type="tns:string"></parameter>
			<parameter xmlns:tns="http://www.w3.org/2001/XMLSchema" qname="name" type="tns:string"></parameter>
			<parameter xmlns:tns="http://www.w3.org/2001/XMLSchema" qname="active" type="tns:boolean"></parameter>
		</operation>
		<operation xmlns:operNS="urn:http.service.osb.liferay.com" xmlns:rtns="http://www.w3.org/2001/XMLSchema" name="deleteRegion" qname="operNS:deleteRegion" returnQName="deleteRegionReturn" returnType="rtns:anyType" soapAction="">
			<parameter xmlns:tns="http://www.w3.org/2001/XMLSchema" qname="regionId" type="tns:long"></parameter>
		</operation>
		<operation xmlns:operNS="urn:http.service.osb.liferay.com" xmlns:rtns="http://www.w3.org/2001/XMLSchema" name="updateRegion" qname="operNS:updateRegion" returnQName="updateRegionReturn" returnType="rtns:anyType" soapAction="">
			<parameter xmlns:tns="http://www.w3.org/2001/XMLSchema" qname="regionId" type="tns:long"></parameter>
			<parameter xmlns:tns="http://www.w3.org/2001/XMLSchema" qname="countryId" type="tns:long"></parameter>
			<parameter xmlns:tns="http://www.w3.org/2001/XMLSchema" qname="regionCode" type="tns:string"></parameter>
			<parameter xmlns:tns="http://www.w3.org/2001/XMLSchema" qname="name" type="tns:string"></parameter>
			<parameter xmlns:tns="http://www.w3.org/2001/XMLSchema" qname="active" type="tns:boolean"></parameter>
		</operation>
		<parameter name="allowedMethods" value="addRegion deleteRegion updateRegion" />
		<parameter name="className" value="com.liferay.osb.service.http.OSBRegionServiceSoap" />
		<parameter name="typeMappingVersion" value="1.2" />
		<parameter name="wsdlPortType" value="OSBRegionServiceSoap" />
		<parameter name="wsdlServiceElement" value="OSBRegionServiceSoapService" />
		<parameter name="wsdlServicePort" value="Plugin_OSB_OSBRegionService" />
		<parameter name="wsdlTargetNamespace" value="urn:http.service.osb.liferay.com" />
	</service>
</deployment>