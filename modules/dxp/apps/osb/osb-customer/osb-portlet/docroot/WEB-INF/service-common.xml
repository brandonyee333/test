<?xml version="1.0"?>
<!DOCTYPE service-builder PUBLIC "-//Liferay//DTD Service Builder 7.0.0//EN" "http://www.liferay.com/dtd/liferay-service-builder_7_0_0.dtd">

<service-builder>
	<entity local-service="true" name="AuditAction" remote-service="true">

		<!-- PK fields -->

		<column name="auditActionId" primary="true" type="long" />

		<!-- Audit fields -->

		<column name="modifiedDate" type="Date" />

		<!-- Other fields -->

		<column name="classNameId" type="long" />
		<column name="classPK" type="long" />
		<column name="mappingClassPK" type="long" />
		<column name="action" type="int" />

		<!-- Finder methods -->

		<finder name="LtModifiedDate" return-type="Collection">
			<finder-column comparator="&lt;" name="modifiedDate" />
		</finder>
		<finder name="C_C_MC" return-type="AuditAction">
			<finder-column name="classNameId" />
			<finder-column name="classPK" />
			<finder-column name="mappingClassPK" />
		</finder>
		<finder name="GtMD_C_GtMC_A" return-type="Collection">
			<finder-column name="modifiedDate" comparator=">" />
			<finder-column name="classNameId" />
			<finder-column name="mappingClassPK" comparator=">" />
			<finder-column name="action" />
		</finder>
		<finder name="GtMD_C_MC_A" return-type="Collection">
			<finder-column name="modifiedDate" comparator=">" />
			<finder-column name="classNameId" />
			<finder-column name="mappingClassPK" />
			<finder-column name="action" />
		</finder>
		<finder name="MD_C_C_MC_A" return-type="Collection">
			<finder-column name="modifiedDate" />
			<finder-column name="classNameId" />
			<finder-column name="classPK" />
			<finder-column name="mappingClassPK" />
			<finder-column name="action" />
		</finder>
	</entity>
	<entity local-service="true" name="CorpProject" remote-service="true" uuid="true">

		<!-- PK fields -->

		<column name="corpProjectId" primary="true" type="long" />

		<!-- Audit fields -->

		<column name="userId" type="long" />
		<column name="userName" type="String" />
		<column name="createDate" type="Date" />
		<column name="modifiedDate" type="Date" />

		<!-- Other fields -->

		<column name="dossieraProjectKey" type="String" />
		<column name="salesforceProjectKey" type="String" />
		<column name="name" type="String" />
		<column name="organizationId" type="long" />

		<!-- Finder methods -->

		<finder name="DossieraProjectKey" return-type="CorpProject">
			<finder-column name="dossieraProjectKey" />
		</finder>
		<finder name="Name" return-type="Collection">
			<finder-column comparator="LIKE" name="name" />
		</finder>
		<finder name="OrganizationId" return-type="CorpProject">
			<finder-column name="organizationId" />
		</finder>

		<!-- References -->

		<reference entity="Organization" package-path="com.liferay.portal" />
		<reference entity="Role" package-path="com.liferay.portal" />
		<reference entity="UserGroupRole" package-path="com.liferay.portal" />
	</entity>
	<entity local-service="true" name="CorpProjectMessage" remote-service="true" uuid="true">

		<!-- PK fields -->

		<column name="corpProjectMessageId" primary="true" type="long" />

		<!-- Audit fields -->

		<column name="userId" type="long" />
		<column name="userName" type="String" />
		<column name="createDate" type="Date" />
		<column name="modifiedDate" type="Date" />

		<!-- Other fields -->

		<column name="corpProjectId" type="long" />
		<column name="type" type="int" />
		<column name="severityLevel" type="int" />
		<column name="title" type="String" />
		<column name="content" type="String" />
		<column name="displayCP" type="boolean" />
		<column name="displayLCS" type="boolean" />
		<column name="displayLESA" type="boolean" />

		<!-- Finder methods -->

		<finder name="CorpProjectId" return-type="Collection">
			<finder-column name="corpProjectId" />
		</finder>
		<finder name="Type" return-type="Collection">
			<finder-column name="type" />
		</finder>
		<finder name="C_T" return-type="CorpProjectMessage">
			<finder-column name="corpProjectId" />
			<finder-column name="type" />
		</finder>
	</entity>
	<entity local-service="true" name="FeedbackEntry" remote-service="true">

		<!-- PK fields -->

		<column name="feedbackEntryId" primary="true" type="long" />

		<!-- Audit fields -->

		<column name="userId" type="long" />
		<column name="userName" type="String" />
		<column name="createDate" type="Date" />

		<!-- Other fields -->

		<column name="classNameId" type="long" />
		<column name="classPK" type="long" />
		<column name="satisfied" type="int" />
		<column name="comments" type="String" />
		<column name="pageURL" type="String" />
	</entity>
	<entity local-service="true" name="LCSSubscriptionEntry" remote-service="false">

		<!-- PK fields -->

		<column name="lcsSubscriptionEntryId" primary="true" type="long" />

		<!-- Audit fields -->

		<column name="lcsProjectId" type="long" />

		<!-- Other fields -->

		<column name="product" type="String" />
		<column name="productVersion" type="int" />
		<column name="type" type="String" />
		<column name="platform" type="String" />
		<column name="platformVersion" type="String" />
		<column name="serversAllowed" type="int" />
		<column name="serversUsed" type="int" />
		<column name="instanceSize" type="int" />
		<column name="startDate" type="Date" />
		<column name="endDate" type="Date" />
		<column name="supportStartDate" type="Date" />
		<column name="supportEndDate" type="Date" />
		<column name="actualPrice" type="double" />
		<column name="currencyCode" type="String" />
		<column name="active" type="boolean" />

		<!-- References -->

		<reference entity="Role" package-path="com.liferay.portal" />
	</entity>
	<entity local-service="true" name="RemoteCorpProject" remote-service="false">

		<!-- References -->

		<reference entity="Organization" package-path="com.liferay.portal" />
		<reference entity="Role" package-path="com.liferay.portal" />
		<reference entity="User" package-path="com.liferay.portal" />
	</entity>
	<entity local-service="true" name="RemoteCorpProjectMessage" remote-service="false">

		<!-- References -->

		<reference entity="User" package-path="com.liferay.portal" />
	</entity>
	<entity local-service="true" name="RemoteUser" remote-service="false">

		<!-- References -->

		<reference entity="Organization" package-path="com.liferay.portal" />
		<reference entity="Role" package-path="com.liferay.portal" />
		<reference entity="User" package-path="com.liferay.portal" />
	</entity>
	<exceptions>
		<exception>RemoteService</exception>
	</exceptions>
</service-builder>