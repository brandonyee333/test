<?xml version="1.0"?>
<!DOCTYPE service-builder PUBLIC "-//Liferay//DTD Service Builder 7.0.0//EN" "http://www.liferay.com/dtd/liferay-service-builder_7_0_0.dtd">

<service-builder>
	<entity local-service="true" name="LCSSubscriptionEntry" remote-service="true">

		<!-- PK fields -->

		<column name="lcsSubscriptionEntryId" primary="true" type="long" />

		<!-- Audit fields -->

		<column name="lcsProjectId" type="long" />

		<!-- Other fields -->

		<column name="product" type="String" />
		<column name="productVersion" type="int" />
		<column name="type" type="String" />
		<column name="platform" type="String" />
		<column name="platformVersion" type="String" />
		<column name="serversAllowed" type="int" />
		<column name="serversUsed" type="int" />
		<column name="quantity" type="int" />
		<column name="instanceSize" type="int" />
		<column name="startDate" type="Date" />
		<column name="endDate" type="Date" />
		<column name="supportStartDate" type="Date" />
		<column name="supportEndDate" type="Date" />
		<column name="actualPrice" type="double" />
		<column name="currencyCode" type="String" />
		<column name="active" type="boolean" />

		<!-- References -->

		<reference entity="Role" package-path="com.liferay.portal" />
	</entity>
	<entity local-service="true" name="RemoteCorpEntry" remote-service="false" />
	<entity local-service="true" name="RemoteCorpProject" remote-service="false">

		<!-- References -->

		<reference entity="Organization" package-path="com.liferay.portal" />
		<reference entity="Role" package-path="com.liferay.portal" />
		<reference entity="User" package-path="com.liferay.portal" />
	</entity>
	<entity local-service="true" name="RemoteUser" remote-service="false">

		<!-- References -->

		<reference entity="ListType" package-path="com.liferay.portal" />
		<reference entity="Organization" package-path="com.liferay.portal" />
		<reference entity="Phone" package-path="com.liferay.portal" />
		<reference entity="Role" package-path="com.liferay.portal" />
		<reference entity="User" package-path="com.liferay.portal" />
		<reference entity="ExpandoColumn" package-path="com.liferay.portlet.expando" />
		<reference entity="ExpandoValue" package-path="com.liferay.portlet.expando" />
	</entity>
	<exceptions>
		<exception>RemoteService</exception>
	</exceptions>
</service-builder>