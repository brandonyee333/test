		<column name="type" type="String" />
		<column name="languageId" type="String" />
		<column name="version" type="int" />

		<!-- Finder methods -->

		<finder name="U_CEI" return-type="Collection">
			<finder-column name="userId" />
			<finder-column name="contractEntryId" />
		</finder>
		<finder name="CEI_SCN_SCP" return-type="Collection">
			<finder-column name="contractEntryId" />
