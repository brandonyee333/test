<?xml version="1.0"?>
<!DOCTYPE service-builder PUBLIC "-//Liferay//DTD Service Builder 6.0.0//EN" "http://www.liferay.com/dtd/liferay-service-builder_6_0_0.dtd">

<service-builder>
	<entity name="AuditAction" local-service="true" remote-service="true">

		<!-- PK fields -->

		<column name="auditActionId" type="long" primary="true" />

		<!-- Audit fields -->

		<column name="modifiedDate" type="Date" />

		<!-- Other fields -->

		<column name="classNameId" type="long" />
		<column name="classPK" type="long" />
		<column name="mappingClassPK" type="long" />
		<column name="action" type="int" />

		<!-- Finder methods -->

		<finder name="LtModifiedDate" return-type="Collection">
			<finder-column name="modifiedDate" comparator="&lt;" />
		</finder>
		<finder name="C_C_MC" return-type="AuditAction">
			<finder-column name="classNameId" />
			<finder-column name="classPK" />
			<finder-column name="mappingClassPK" />
		</finder>
		<finder name="GtMD_C_GtMC_A" return-type="Collection">
			<finder-column name="modifiedDate" comparator=">" />
			<finder-column name="classNameId" />
			<finder-column name="mappingClassPK" comparator=">" />
			<finder-column name="action" />
		</finder>
		<finder name="GtMD_C_MC_A" return-type="Collection">
			<finder-column name="modifiedDate" comparator=">" />
			<finder-column name="classNameId" />
			<finder-column name="mappingClassPK" />
			<finder-column name="action" />
		</finder>
		<finder name="MD_C_C_MC_A" return-type="Collection">
			<finder-column name="modifiedDate" />
			<finder-column name="classNameId" />
			<finder-column name="classPK" />
			<finder-column name="mappingClassPK" />
			<finder-column name="action" />
		</finder>
	</entity>
	<entity name="ContractAudit" local-service="true" remote-service="true">

		<!-- PK fields -->

		<column name="contractAuditId" type="long" primary="true" />

		<!-- Audit fields -->

		<column name="userId" type="long" />
		<column name="userName" type="String" />
		<column name="userEmailAddress" type="String" />
		<column name="createDate" type="Date" />
		<column name="modifiedDate" type="Date" />

		<!-- Other fields -->

		<column name="contractEntryId" type="long" />
		<column name="signatoryClassNameId" type="long" />
		<column name="signatoryClassPK" type="long" />
		<column name="productClassNameId" type="long" />
		<column name="productClassPK" type="long" />
		<column name="type" type="String" />
		<column name="languageId" type="String" />
		<column name="version" type="int" />

		<!-- Finder methods -->

		<finder name="U_CEI" return-type="Collection">
			<finder-column name="userId" />
			<finder-column name="contractEntryId" />
		</finder>
		<finder name="CEI_SCN_SCP" return-type="Collection">
			<finder-column name="contractEntryId" />
			<finder-column name="signatoryClassNameId" />
			<finder-column name="signatoryClassPK" />
		</finder>
	</entity>
	<entity name="ContractEntry" local-service="true" remote-service="true">

		<!-- PK fields -->

		<column name="contractEntryId" type="long" primary="true" />

		<!-- Audit fields -->

		<column name="userId" type="long" />
		<column name="userName" type="String" />
		<column name="createDate" type="Date" />

		<!-- Other fields -->

		<column name="classNameId" type="long" />
		<column name="classPK" type="long" />
		<column name="type" type="int" />
		<column name="version" type="int" />
		<column name="content" type="String" localized="true" />

		<!-- Finder methods -->

		<finder name="CN_CP_T" return-type="Collection">
			<finder-column name="classNameId" />
			<finder-column name="classPK" />
			<finder-column name="type" />
		</finder>
	</entity>
	<entity name="CurrencyEntry" local-service="true" remote-service="true">

		<!-- PK fields -->

		<column name="currencyEntryId" type="long" primary="true" />

		<!-- Other fields -->

		<column name="countryId" type="long" />
		<column name="currencyCode" type="String" />
		<column name="marketplaceEnabled" type="boolean" />
		<column name="marketplaceMinPrice" type="double" />

		<!-- Order -->

		<order by="asc">
			<order-column name="currencyCode" />
		</order>

		<!-- Finder methods -->

		<finder name="CurrencyCode" return-type="Currency" unique="true">
			<finder-column name="currencyCode" />
		</finder>
		<finder name="MarketplaceEnabled" return-type="Collection">
			<finder-column name="marketplaceEnabled" />
		</finder>
	</entity>
	<entity name="LCSSubscriptionEntry" local-service="true" remote-service="true">

		<!-- PK fields -->

		<column name="lcsSubscriptionEntryId" type="long" primary="true" />

		<!-- Audit fields -->

		<column name="lcsProjectId" type="long" />

		<!-- Other fields -->

		<column name="product" type="String" />
		<column name="productVersion" type="int" />
		<column name="type" type="String" />
		<column name="platform" type="String" />
		<column name="platformVersion" type="String" />
		<column name="serversAllowed" type="int" />
		<column name="serversUsed" type="int" />
		<column name="instanceSize" type="int" />
		<column name="startDate" type="Date" />
		<column name="endDate" type="Date" />
		<column name="supportStartDate" type="Date" />
		<column name="supportEndDate" type="Date" />
		<column name="actualPrice" type="double" />
		<column name="currencyCode" type="String" />
		<column name="active" type="boolean" />

		<!-- References -->

		<reference package-path="com.liferay.portal" entity="Role" />
	</entity>
	<entity name="OSBCountry" local-service="true" remote-service="true">

		<!-- References -->

		<reference package-path="com.liferay.portal" entity="Country" />
	</entity>

	<entity name="OSBRegion" local-service="true" remote-service="true">

		<!-- References -->

		<reference package-path="com.liferay.portal" entity="Country" />
		<reference package-path="com.liferay.portal" entity="Region" />
	</entity>
	<exceptions>
		<exception>CurrencyEntryCode</exception>
		<exception>CurrencyEntryCountry</exception>
		<exception>DuplicateCurrencyEntry</exception>
		<exception>UnverifiedUser</exception>
	</exceptions>
</service-builder>