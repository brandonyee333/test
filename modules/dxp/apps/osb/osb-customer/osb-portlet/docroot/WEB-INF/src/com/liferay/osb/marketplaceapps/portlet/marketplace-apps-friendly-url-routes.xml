<?xml version="1.0"?>
<!DOCTYPE routes PUBLIC "-//Liferay//DTD Friendly URL Routes 6.1.0//EN" "http://www.liferay.com/dtd/liferay-friendly-url-routes_6_1_0.dtd">

<routes>
	<route>
		<pattern>/{assetReceiptId}</pattern>
		<implicit-parameter name="mvcPath">/marketplace_apps/view_app_entry.jsp</implicit-parameter>
	</route>
	<route>
		<pattern>/application/{assetReceiptId}</pattern>
		<implicit-parameter name="p_p_lifecycle">2</implicit-parameter>
		<implicit-parameter name="p_p_resource_id">serveApp</implicit-parameter>
	</route>
	<route>
		<pattern>/media/{assetAttachmentId}</pattern>
		<implicit-parameter name="p_p_lifecycle">2</implicit-parameter>
		<implicit-parameter name="p_p_resource_id">serveMedia</implicit-parameter>
	</route>
	<route>
		<pattern>/project/{ownerClassPK}</pattern>
		<implicit-parameter name="mvcPath">/marketplace_apps/view_app_entries.jsp</implicit-parameter>
		<implicit-parameter name="ownerClassName">com.liferay.osb.model.CorpProject</implicit-parameter>
	</route>
	<route>
		<pattern>/user/{ownerClassPK}</pattern>
		<implicit-parameter name="mvcPath">/marketplace_apps/view_app_entries.jsp</implicit-parameter>
		<implicit-parameter name="ownerClassName">com.liferay.portal.model.User</implicit-parameter>
	</route>
	<route>
		<pattern>/{assetReceiptId}/versions</pattern>
		<implicit-parameter name="mvcPath">/marketplace_apps/view_app_versions.jsp</implicit-parameter>
	</route>
	<route>
		<pattern>/{assetReceiptLicenseId}/licenses</pattern>
		<implicit-parameter name="mvcPath">/marketplace_apps/view_license_keys.jsp</implicit-parameter>
	</route>
	<route>
		<pattern>/application/{assetReceiptId}/{appVersionId}</pattern>
		<implicit-parameter name="p_p_lifecycle">2</implicit-parameter>
		<implicit-parameter name="p_p_resource_id">serveApp</implicit-parameter>
	</route>
</routes>