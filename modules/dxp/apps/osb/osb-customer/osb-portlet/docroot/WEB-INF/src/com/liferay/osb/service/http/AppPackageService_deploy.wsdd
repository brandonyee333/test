<?xml version="1.0"?>

<deployment xmlns="http://xml.apache.org/axis/wsdd/" xmlns:java="http://xml.apache.org/axis/wsdd/providers/java">
	<service name="Plugin_OSB_AppPackageService" provider="java:RPC" style="rpc" use="encoded">
		<typeMapping xmlns:ns="http://model.osb.liferay.com" qname="ns:AppPackageSoap" type="java:com.liferay.osb.model.AppPackageSoap" serializer="org.apache.axis.encoding.ser.BeanSerializerFactory" deserializer="org.apache.axis.encoding.ser.BeanDeserializerFactory" encodingStyle="http://schemas.xmlsoap.org/soap/encoding/"></typeMapping>
		<operation xmlns:operNS="urn:http.service.osb.liferay.com" xmlns:rtns="http://model.osb.liferay.com" name="addAppPackage" qname="operNS:addAppPackage" returnQName="addAppPackageReturn" returnType="rtns:AppPackageSoap" soapAction="">
			<parameter xmlns:tns="http://www.w3.org/2001/XMLSchema" qname="appEntryId" type="tns:long"></parameter>
			<parameter xmlns:tns="http://www.w3.org/2001/XMLSchema" qname="appVersionId" type="tns:long"></parameter>
			<parameter xmlns:tns="http://www.w3.org/2001/XMLSchema" qname="compatibility" type="tns:int"></parameter>
			<parameter xmlns:tns="http://www.w3.org/2001/XMLSchema" qname="compatibilityPlus" type="tns:boolean"></parameter>
		</operation>
		<operation xmlns:operNS="urn:http.service.osb.liferay.com" name="deleteAppPackageSrc" qname="operNS:deleteAppPackageSrc" soapAction="">
			<parameter xmlns:tns="http://www.w3.org/2001/XMLSchema" qname="appPackageId" type="tns:long"></parameter>
		</operation>
		<operation xmlns:operNS="urn:http.service.osb.liferay.com" xmlns:rtns="http://model.osb.liferay.com" name="deleteAppPackage" qname="operNS:deleteAppPackage" returnQName="deleteAppPackageReturn" returnType="rtns:AppPackageSoap" soapAction="">
			<parameter xmlns:tns="http://www.w3.org/2001/XMLSchema" qname="appPackageId" type="tns:long"></parameter>
		</operation>
		<operation xmlns:operNS="urn:http.service.osb.liferay.com" xmlns:rtns="http://model.osb.liferay.com" name="getAppPackage" qname="operNS:getAppPackage" returnQName="getAppPackageReturn" returnType="rtns:AppPackageSoap" soapAction="">
			<parameter xmlns:tns="http://www.w3.org/2001/XMLSchema" qname="appPackageId" type="tns:long"></parameter>
		</operation>
		<operation xmlns:operNS="urn:http.service.osb.liferay.com" xmlns:rtns="http://model.osb.liferay.com" name="updateAppPackage" qname="operNS:updateAppPackage" returnQName="updateAppPackageReturn" returnType="rtns:AppPackageSoap" soapAction="">
			<parameter xmlns:tns="http://www.w3.org/2001/XMLSchema" qname="appPackageId" type="tns:long"></parameter>
			<parameter xmlns:tns="http://www.w3.org/2001/XMLSchema" qname="compatibilityPlus" type="tns:boolean"></parameter>
		</operation>
		<parameter name="allowedMethods" value="addAppPackage deleteAppPackage deleteAppPackageSrc getAppPackage updateAppPackage" />
		<parameter name="className" value="com.liferay.osb.service.http.AppPackageServiceSoap" />
		<parameter name="schemaUnqualified" value="http://model.osb.liferay.com" />
		<parameter name="typeMappingVersion" value="1.2" />
		<parameter name="wsdlPortType" value="AppPackageServiceSoap" />
