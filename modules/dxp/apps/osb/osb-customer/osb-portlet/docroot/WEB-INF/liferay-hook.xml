<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hook PUBLIC "-//Liferay//DTD Hook 6.1.0//EN" "http://www.liferay.com/dtd/liferay-hook_6_1_0.dtd">

<hook>
	<portal-properties>portal.properties</portal-properties>
	<language-properties>content/Language*.properties</language-properties>
	<service>
		<service-type>com.liferay.portal.kernel.service.UserLocalService</service-type>
		<service-impl>com.liferay.osb.hook.service.impl.OSBUserLocalServiceImpl</service-impl>
	</service>
	<service>
		<service-type>com.liferay.portal.kernel.service.UserService</service-type>
		<service-impl>com.liferay.osb.hook.service.impl.OSBUserServiceImpl</service-impl>
	</service>
	<!--<servlet-filter>
		<servlet-filter-name>IP Geocoder Filter</servlet-filter-name>
		<servlet-filter-impl>com.liferay.osb.hook.filter.IPGeocoderFilter</servlet-filter-impl>
	</servlet-filter>-->
	<servlet-filter>
		<servlet-filter-name>OSB Secure LCS JSON Filter</servlet-filter-name>
		<servlet-filter-impl>com.liferay.osb.servlet.filters.OSBSecureJSONFilter</servlet-filter-impl>
		<init-param>
			<param-name>token_property</param-name>
			<param-value>json.service.api.lcs.token</param-value>
		</init-param>
	</servlet-filter>
	<!--<servlet-filter-mapping>
		<servlet-filter-name>IP Geocoder Filter</servlet-filter-name>
		<after-filter>I18n Filter</after-filter>
		<url-pattern>/group/*</url-pattern>
		<url-pattern>/user/*</url-pattern>
		<url-pattern>/web/*</url-pattern>
		<dispatcher>FORWARD</dispatcher>
		<dispatcher>REQUEST</dispatcher>
	</servlet-filter-mapping>-->
	<servlet-filter-mapping>
		<servlet-filter-name>OSB Secure LCS JSON Filter</servlet-filter-name>
		<url-pattern>/api/jsonws/company/get-company-by-web-id/*</url-pattern>
		<url-pattern>/api/jsonws/organization/get-organization/*</url-pattern>
		<url-pattern>/api/jsonws/role/add-role/*</url-pattern>
		<url-pattern>/api/jsonws/role/get-role/*</url-pattern>
		<url-pattern>/api/jsonws/user/add-organization-users/*</url-pattern>
		<url-pattern>/api/jsonws/user/get-organization-users/*</url-pattern>
		<url-pattern>/api/jsonws/user/get-user-by-email-address/*</url-pattern>
		<url-pattern>/api/secure/jsonws/company/get-company-by-web-id/*</url-pattern>
		<url-pattern>/api/secure/jsonws/organization/get-organization/*</url-pattern>
		<url-pattern>/api/secure/jsonws/role/add-role/*</url-pattern>
		<url-pattern>/api/secure/jsonws/role/get-role/*</url-pattern>
		<url-pattern>/api/secure/jsonws/user/add-organization-users/*</url-pattern>
		<url-pattern>/api/secure/jsonws/user/get-organization-users/*</url-pattern>
		<url-pattern>/api/secure/jsonws/user/get-user-by-email-address/*</url-pattern>
		<dispatcher>FORWARD</dispatcher>
		<dispatcher>REQUEST</dispatcher>
	</servlet-filter-mapping>
	<struts-action>
		<struts-action-path>/my_workflow_instances/edit_workflow_instance_task</struts-action-path>
		<struts-action-impl>com.liferay.osb.hook.action.OSBEditWorkflowTaskAction</struts-action-impl>
	</struts-action>
	<struts-action>
		<struts-action-path>/my_workflow_tasks/edit_workflow_task</struts-action-path>
		<struts-action-impl>com.liferay.osb.hook.action.OSBEditWorkflowTaskAction</struts-action-impl>
	</struts-action>
</hook>