		<operation xmlns:operNS="urn:http.service.osb.liferay.com" name="deleteAccountWorkers" qname="operNS:deleteAccountWorkers" soapAction="">
			<parameter xmlns:tns="urn:http.service.osb.liferay.com" qname="userIds" type="tns:ArrayOf_xsd_long"></parameter>
			<parameter xmlns:tns="http://www.w3.org/2001/XMLSchema" qname="accountEntryId" type="tns:long"></parameter>
		</operation>
		<parameter name="allowedMethods" value="addAccountWorkers deleteAccountWorkers" />
		<parameter name="className" value="com.liferay.osb.service.http.AccountWorkerServiceSoap" />
		<parameter name="schemaUnqualified" value="urn:http.service.osb.liferay.com" />
