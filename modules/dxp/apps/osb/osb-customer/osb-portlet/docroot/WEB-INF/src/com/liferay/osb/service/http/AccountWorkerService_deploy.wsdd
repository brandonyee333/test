<?xml version="1.0"?>

<deployment xmlns="http://xml.apache.org/axis/wsdd/" xmlns:java="http://xml.apache.org/axis/wsdd/providers/java">
	<service name="Plugin_OSB_AccountWorkerService" provider="java:RPC" style="rpc" use="encoded">
		<arrayMapping xmlns:ns="urn:http.service.osb.liferay.com" xmlns:cmp-ns="http://www.w3.org/2001/XMLSchema" qname="ns:ArrayOf_xsd_int" type="java:int[]" innerType="cmp-ns:int" encodingStyle="http://schemas.xmlsoap.org/soap/encoding/"></arrayMapping>
		<arrayMapping xmlns:ns="urn:http.service.osb.liferay.com" xmlns:cmp-ns="http://www.w3.org/2001/XMLSchema" qname="ns:ArrayOf_xsd_long" type="java:long[]" innerType="cmp-ns:long" encodingStyle="http://schemas.xmlsoap.org/soap/encoding/"></arrayMapping>
		<operation xmlns:operNS="urn:http.service.osb.liferay.com" name="addAccountWorkers" qname="operNS:addAccountWorkers" soapAction="">
			<parameter xmlns:tns="urn:http.service.osb.liferay.com" qname="userIds" type="tns:ArrayOf_xsd_long"></parameter>
			<parameter xmlns:tns="http://www.w3.org/2001/XMLSchema" qname="accountEntryId" type="tns:long"></parameter>
			<parameter xmlns:tns="urn:http.service.osb.liferay.com" qname="roles" type="tns:ArrayOf_xsd_int"></parameter>
			<parameter xmlns:tns="urn:http.service.osb.liferay.com" qname="notifications" type="tns:ArrayOf_xsd_int"></parameter>
