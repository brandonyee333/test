<?xml version="1.0"?>
<!DOCTYPE service-builder PUBLIC "-//Liferay//DTD Service Builder 7.0.0//EN" "http://www.liferay.com/dtd/liferay-service-builder_7_0_0.dtd">

<service-builder>
	<entity local-service="true" name="AccountCustomer" remote-service="true">

		<!-- PK fields -->

		<column name="accountCustomerId" primary="true" type="long" />

		<!-- Audit fields -->

		<column name="userId" type="long" />

		<!-- Other fields -->

		<column name="accountEntryId" type="long" />
		<column name="role" type="int" />
		<column name="closedWatcher" type="boolean" />

		<!-- Finder methods -->

		<finder name="UserId" return-type="Collection">
			<finder-column name="userId" />
		</finder>
		<finder name="AccountEntryId" return-type="Collection">
			<finder-column name="accountEntryId" />
		</finder>
		<finder name="U_AEI" return-type="AccountCustomer">
			<finder-column name="userId" />
			<finder-column name="accountEntryId" />
		</finder>
		<finder name="AEI_R" return-type="Collection">
			<finder-column name="accountEntryId" />
			<finder-column name="role" />
		</finder>

		<!-- References -->

		<reference entity="Organization" package-path="com.liferay.portal" />
		<reference entity="Role" package-path="com.liferay.portal" />
	</entity>
	<entity local-service="true" name="AccountEntry" remote-service="false">

		<!-- PK fields -->

		<column name="accountEntryId" primary="true" type="long" />

		<!-- Audit fields -->

		<column name="companyId" type="long" />
		<column name="userId" type="long" />
		<column name="userName" type="String" />
		<column name="createDate" type="Date" />
		<column name="modifiedUserId" type="long" />
		<column name="modifiedUserName" type="String" />
		<column name="modifiedDate" type="Date" />

		<!-- Other fields -->

		<column name="koroneikiAccountKey" type="String" />
		<column name="dossieraAccountKey" type="String" />
		<column name="name" type="String" />
		<column name="code" type="String" />
		<column name="instructions" type="String" />
		<column name="activeSupport" type="boolean" />
		<column name="activeTicketSupport" type="boolean" />
		<column name="lastZendeskAuditDate" type="Date" />
		<column name="status" type="int" />
	</entity>
	<entity local-service="true" name="AccountInformation" remote-service="true">

		<!-- PK fields -->

		<column name="accountInformationId" primary="true" type="long" />

		<!-- Audit fields -->

		<column name="modifiedUserId" type="long" />
		<column name="modifiedUserName" type="String" />
		<column name="modifiedDate" type="Date" />

		<!-- Other fields -->

		<column name="accountEntryId" type="long" />
		<column name="accountProjectId" type="long" />
		<column name="fieldId" type="int" />
		<column name="data" type="String" />

		<!-- Finder methods -->

		<finder name="AEI_API" return-type="Collection">
			<finder-column name="accountEntryId" />
			<finder-column name="accountProjectId" />
		</finder>
		<finder name="AEI_NotAPI" return-type="Collection">
			<finder-column name="accountEntryId" />
			<finder-column comparator="!=" name="accountProjectId" />
		</finder>
		<finder name="AEI_API_FI" return-type="AccountInformation" unique="true">
			<finder-column name="accountEntryId" />
			<finder-column name="accountProjectId" />
			<finder-column name="fieldId" />
		</finder>
	</entity>
	<entity local-service="true" name="AccountProject" remote-service="true">

		<!-- PK fields -->

		<column name="accountProjectId" primary="true" type="long" />

		<!-- Audit fields -->

		<column name="modifiedUserId" type="long" />
		<column name="modifiedUserName" type="String" />
		<column name="modifiedDate" type="Date" />

		<!-- Other fields -->

		<column name="accountEntryId" type="long" />
		<column name="name" type="String" />

		<!-- Finder methods -->

		<finder name="AccountEntryId" return-type="Collection">
			<finder-column name="accountEntryId" />
		</finder>
	</entity>
	<entity local-service="true" name="AccountWorker" remote-service="true">

		<!-- PK fields -->

		<column name="accountWorkerId" primary="true" type="long" />

		<!-- Audit fields -->

		<column name="userId" type="long" />

		<!-- Other fields -->

		<column name="accountEntryId" type="long" />
		<column name="role" type="int" />

		<!-- Finder methods -->

		<finder name="UserId" return-type="Collection">
			<finder-column name="userId" />
		</finder>
		<finder name="AccountEntryId" return-type="Collection">
			<finder-column name="accountEntryId" />
		</finder>
		<finder name="U_AEI" return-type="AccountWorker">
			<finder-column name="userId" />
			<finder-column name="accountEntryId" />
		</finder>
		<finder name="U_R" return-type="Collection">
			<finder-column name="userId" />
			<finder-column name="role" />
		</finder>
		<finder name="AEI_R" return-type="Collection">
			<finder-column name="accountEntryId" />
			<finder-column name="role" />
		</finder>
	</entity>
	<entity local-service="true" name="OfferingBundle" remote-service="true">

		<!-- PK fields -->

		<column name="offeringBundleId" primary="true" type="long" />

		<!-- Audit fields -->

		<column name="companyId" type="long" />
		<column name="userId" type="long" />
		<column name="userName" type="String" />
		<column name="createDate" type="Date" />

		<!-- Relationships -->

		<column entity="OfferingDefinition" mapping-table="OfferingBundles_OfferingDefinitions" name="offeringDefinitions" type="Collection" />

		<!-- Other fields -->

		<column name="name" type="String" />

		<!-- Order -->

		<order by="asc">
			<order-column name="name" />
		</order>

		<!-- Finder methods -->

		<finder name="Name" return-type="OfferingBundle" unique="true">
			<finder-column name="name" />
		</finder>
	</entity>
	<entity local-service="true" name="OfferingDefinition" remote-service="true">

		<!-- PK fields -->

		<column name="offeringDefinitionId" primary="true" type="long" />

		<!-- Audit fields -->

		<column name="companyId" type="long" />
		<column name="userId" type="long" />
		<column name="userName" type="String" />
		<column name="createDate" type="Date" />
		<column name="modifiedDate" type="Date" />

		<!-- Relationships -->

		<column entity="OfferingBundle" mapping-table="OfferingBundles_OfferingDefinitions" name="offeringBundles" type="Collection" />

		<!-- Other fields -->

		<column name="productEntryId" type="long" />
		<column name="supportResponseId" type="long" />
		<column name="productDescription" type="String" />
		<column name="licenses" type="boolean" />
		<column name="unlimitedLicenses" type="boolean" />
		<column name="maxConcurrentUsers" type="long" />
		<column name="maxUsers" type="long" />
		<column name="supportTickets" type="boolean" />

		<!-- Order -->

		<order by="asc">
			<order-column name="productEntryId" />
			<order-column name="supportResponseId" />
		</order>

		<!-- Finder methods -->

		<finder name="ProductEntryId" return-type="Collection">
			<finder-column name="productEntryId" />
		</finder>
		<finder name="SupportResponseId" return-type="Collection">
			<finder-column name="supportResponseId" />
		</finder>
		<finder name="PEI_SRI" return-type="Collection">
			<finder-column arrayable-operator="OR" name="productEntryId" />
			<finder-column arrayable-operator="OR" name="supportResponseId" />
		</finder>
		<finder name="PEI_SRI_PD_L_UL_ST" return-type="OfferingDefinition">
			<finder-column name="productEntryId" />
			<finder-column name="supportResponseId" />
			<finder-column name="productDescription" />
			<finder-column name="licenses" />
			<finder-column name="unlimitedLicenses" />
			<finder-column name="supportTickets" />
		</finder>
	</entity>
	<entity local-service="true" name="OfferingEntry" remote-service="true">

		<!-- PK fields -->

		<column name="offeringEntryId" primary="true" type="long" />

		<!-- Audit fields -->

		<column name="userId" type="long" />
		<column name="userName" type="String" />
		<column name="createDate" type="Date" />
		<column name="modifiedDate" type="Date" />

		<!-- Other fields -->

		<column name="accountEntryId" type="long" />
		<column name="orderEntryId" type="long" />
		<column name="productEntryId" type="long" />
		<column name="supportResponseId" type="long" />
		<column name="productDescription" type="String" />
		<column name="type" type="int" />
		<column name="version" type="int" />
		<column name="platform" type="String" />
		<column name="platformVersion" type="String" />
		<column name="licenses" type="boolean" />
		<column name="licenseLifetime" type="long" />
		<column name="maxConcurrentUsers" type="long" />
		<column name="maxUsers" type="long" />
		<column name="supportTickets" type="boolean" />
		<column name="supportLifetime" type="long" />
		<column name="supportEndDate" type="Date" />
		<column name="sizing" type="int" />
		<column name="quantity" type="int" />
		<column name="status" type="int" />

		<!-- Order -->

		<order by="asc">
			<order-column name="offeringEntryId" />
		</order>

		<!-- Finder methods -->

		<finder name="AccountEntryId" return-type="Collection">
			<finder-column name="accountEntryId" />
		</finder>
		<finder name="OrderEntryId" return-type="Collection">
			<finder-column name="orderEntryId" />
		</finder>
		<finder name="AEI_T" return-type="Collection">
			<finder-column name="accountEntryId" />
			<finder-column name="type" />
		</finder>
		<finder name="AEI_PEI_T" return-type="Collection">
			<finder-column name="accountEntryId" />
			<finder-column name="productEntryId" />
			<finder-column name="type" />
		</finder>
		<finder name="U_AEI_OEI_T" return-type="Collection">
			<finder-column name="userId" />
			<finder-column name="accountEntryId" />
			<finder-column name="orderEntryId" />
			<finder-column name="type" />
		</finder>
	</entity>
	<entity local-service="true" name="OrderEntry" remote-service="true" uuid="true">

		<!-- PK fields -->

		<column name="orderEntryId" primary="true" type="long" />

		<!-- Audit fields -->

		<column name="userId" type="long" />
		<column name="userName" type="String" />
		<column name="createDate" type="Date" />
		<column name="modifiedUserId" type="long" />
		<column name="modifiedUserName" type="String" />
		<column name="modifiedDate" type="Date" />

		<!-- Other fields -->

		<column name="accountEntryId" type="long" />
		<column name="purchaseOrderKey" type="String" />
		<column name="startDate" type="Date" />
		<column name="prorated" type="boolean" />
		<column name="actualStartDate" type="Date" />
		<column name="renewCount" type="int" />
		<column name="status" type="int" />
		<column name="statusByUserId" type="long" />
		<column name="statusByUserName" type="String" />
		<column name="statusDate" type="Date" />
		<column name="statusMessage" type="String" />

		<!-- Finder methods -->

		<finder name="AccountEntryId" return-type="Collection">
			<finder-column name="accountEntryId" />
		</finder>

		<!-- References -->

		<reference entity="Role" package-path="com.liferay.portal" />
	</entity>
	<entity local-service="true" name="PartnerEntry" remote-service="true">

		<!-- PK fields -->

		<column name="partnerEntryId" primary="true" type="long" />

		<!-- Audit fields -->

		<column name="companyId" type="long" />
		<column name="userId" type="long" />
		<column name="userName" type="String" />
		<column name="createDate" type="Date" />
		<column name="modifiedUserId" type="long" />
		<column name="modifiedUserName" type="String" />
		<column name="modifiedDate" type="Date" />

		<!-- Other fields -->

		<column name="parentPartnerEntryId" type="long" />
		<column name="dossieraAccountKey" type="String" />
		<column name="jiraProjectKey" type="String" />
		<column name="code" type="String" />
		<column name="notes" type="String" />
		<column name="status" type="int" />

		<!-- Order -->

		<order by="asc">
			<order-column case-sensitive="false" name="code" />
		</order>

		<!-- Finder methods -->

		<finder name="ParentPartnerEntryId" return-type="Collection">
			<finder-column name="parentPartnerEntryId" />
		</finder>
		<finder name="DossieraAccountKey" return-type="PartnerEntry">
			<finder-column name="dossieraAccountKey" />
		</finder>
		<finder name="Code" return-type="PartnerEntry" unique="true">
			<finder-column name="code" />
		</finder>
	</entity>
	<entity local-service="true" name="PartnerWorker" remote-service="true">

		<!-- PK fields -->

		<column name="partnerWorkerId" primary="true" type="long" />

		<!-- Audit fields -->

		<column name="userId" type="long" />

		<!-- Other fields -->

		<column name="partnerEntryId" type="long" />
		<column name="role" type="int" />

		<!-- Finder methods -->

		<finder name="UserId" return-type="Collection">
			<finder-column name="userId" />
		</finder>
		<finder name="PartnerEntryId" return-type="Collection">
			<finder-column name="partnerEntryId" />
		</finder>
		<finder name="U_PEI" return-type="PartnerWorker">
			<finder-column name="userId" />
			<finder-column name="partnerEntryId" />
		</finder>
		<finder name="U_R" return-type="Collection">
			<finder-column arrayable-operator="OR" name="userId" />
			<finder-column arrayable-operator="OR" name="role" />
		</finder>
		<finder name="PEI_R" return-type="Collection">
			<finder-column name="partnerEntryId" />
			<finder-column name="role" />
		</finder>

		<!-- References -->

		<reference entity="Organization" package-path="com.liferay.portal" />
		<reference entity="Role" package-path="com.liferay.portal" />
		<reference entity="UserGroupRole" package-path="com.liferay.portal" />
	</entity>
	<entity local-service="true" name="ProductEntry" remote-service="true">

		<!-- PK fields -->

		<column name="productEntryId" primary="true" type="long" />

		<!-- Audit fields -->

		<column name="userId" type="long" />
		<column name="userName" type="String" />
		<column name="createDate" type="Date" />
		<column name="modifiedDate" type="Date" />

		<!-- Other fields -->

		<column name="name" type="String" />
		<column name="type" type="int" />
		<column name="environment" type="int" />
		<column name="versionsListType" type="String" />

		<!-- Order -->

		<order by="asc">
			<order-column case-sensitive="false" name="name" />
		</order>

		<!-- Finder methods -->

		<finder name="Name" return-type="ProductEntry" unique="true">
			<finder-column name="name" />
		</finder>
		<finder name="Environment" return-type="Collection">
			<finder-column name="environment" />
		</finder>
	</entity>
	<entity local-service="true" name="SupportResponse" remote-service="true">

		<!-- PK fields -->

		<column name="supportResponseId" primary="true" type="long" />

		<!-- Audit fields -->

		<column name="userId" type="long" />
		<column name="userName" type="String" />
		<column name="createDate" type="Date" />
		<column name="modifiedDate" type="Date" />

		<!-- Other fields -->

		<column name="name" type="String" />
		<column name="supportLevel" type="int" />
		<column name="severity1Response" type="int" />
		<column name="severity1Resolution" type="int" />
		<column name="severity2Response" type="int" />
		<column name="severity2Resolution" type="int" />
		<column name="severity3Response" type="int" />
		<column name="severity3Resolution" type="int" />

		<!-- Order -->

		<order by="asc">
			<order-column case-sensitive="false" name="name" />
		</order>

		<!-- Finder methods -->

		<finder name="Name" return-type="SupportResponse" unique="true">
			<finder-column name="name" />
		</finder>
	</entity>
	<exceptions>
		<exception>AccountProjectName</exception>
		<exception>DuplicateOfferingBundle</exception>
		<exception>DuplicateOfferingDefinition</exception>
		<exception>DuplicatePartnerEntryCode</exception>
		<exception>DuplicatePartnerEntryDossieraAccountKey</exception>
		<exception>DuplicateSupportResponse</exception>
		<exception>OfferingBundleName</exception>
		<exception>OfferingEntryQuantity</exception>
		<exception>OfferingEntrySizing</exception>
		<exception>OfferingEntryStatus</exception>
		<exception>OfferingEntrySupportExpired</exception>
		<exception>OrderEntryActualStartDate</exception>
