<?xml version="1.0"?>
<!DOCTYPE service-builder PUBLIC "-//Liferay//DTD Service Builder 7.0.0//EN" "http://www.liferay.com/dtd/liferay-service-builder_7_0_0.dtd">

<service-builder package-path="com.liferay.osb.customer.github">
	<namespace>OSBCustomer</namespace>
	<entity local-service="true" name="Collaborator">

		<!-- PK fields -->

		<column name="collaboratorId" primary="true" type="long" />

		<!-- Audit fields -->

		<column name="userId" type="long" />
		<column name="createDate" type="Date" />

		<!-- Other fields -->

		<column name="accountEntryId" type="long" />
		<column name="emailAddress" type="String" />
		<column name="fullName" type="String" />
		<column name="gitHubUserName" type="String" />
		<column name="status" type="int" />

		<!-- Finder methods -->

		<finder name="AccountEntryId" return-type="Collection">
			<finder-column name="accountEntryId" />
		</finder>
		<finder name="GitHubUserName" return-type="Collection">
			<finder-column name="gitHubUserName" />
		</finder>
		<finder name="AEI_GHUN" return-type="Collaborator">
			<finder-column name="accountEntryId" />
			<finder-column name="gitHubUserName" />
		</finder>
	</entity>
	<exceptions>
		<exception>CollaboratorEmailAddress</exception>
		<exception>CollaboratorFullName</exception>
		<exception>CollaboratorGitHubUserName</exception>
		<exception>DuplicateCollaborator</exception>
	</exceptions>
</service-builder>