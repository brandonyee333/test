<?xml version="1.0"?>
<!DOCTYPE service-builder PUBLIC "-//Liferay//DTD Service Builder 7.0.0//EN" "http://www.liferay.com/dtd/liferay-service-builder_7_0_0.dtd">

<service-builder package-path="com.liferay.osb.customer.metrics.sync">
	<namespace>OSBCustomer</namespace>
	<entity local-service="true" name="SyncState" remote-service="false">

		<!-- PK fields -->

		<column name="syncStateId" primary="true" type="long" />

		<!-- Other fields -->

		<column name="model" type="String" />
		<column name="lastRunTime" type="long" />

		<!-- Finder methods -->

		<finder name="Model" return-type="SyncState">
			<finder-column name="model" />
		</finder>
	</entity>
</service-builder>