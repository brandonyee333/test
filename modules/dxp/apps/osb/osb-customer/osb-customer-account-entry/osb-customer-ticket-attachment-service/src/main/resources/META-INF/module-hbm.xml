<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN" "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping auto-import="false" default-lazy="false">
	<import class="com.liferay.osb.customer.ticket.attachment.model.TicketAttachment" />
	<class name="com.liferay.osb.customer.ticket.attachment.model.impl.TicketAttachmentImpl" table="OSBCustomer_TicketAttachment">
		<id name="ticketAttachmentId" type="long">
			<generator class="assigned" />
		</id>
		<property name="userId" type="com.liferay.portal.dao.orm.hibernate.LongType" />
		<property name="userName" type="com.liferay.portal.dao.orm.hibernate.StringType" />
		<property name="createDate" type="org.hibernate.type.TimestampType" />
		<property name="accountEntryId" type="com.liferay.portal.dao.orm.hibernate.LongType" />
		<property name="zendeskTicketId" type="com.liferay.portal.dao.orm.hibernate.LongType" />
		<property name="fileRepositoryId" type="com.liferay.portal.dao.orm.hibernate.StringType" />
		<property name="fileName" type="com.liferay.portal.dao.orm.hibernate.StringType" />
		<property name="fileSize" type="com.liferay.portal.dao.orm.hibernate.LongType" />
		<property column="type_" name="type" type="com.liferay.portal.dao.orm.hibernate.IntegerType" />
	</class>
</hibernate-mapping>