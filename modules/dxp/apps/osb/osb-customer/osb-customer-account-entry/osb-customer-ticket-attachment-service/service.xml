<?xml version="1.0"?>
<!DOCTYPE service-builder PUBLIC "-//Liferay//DTD Service Builder 7.0.0//EN" "http://www.liferay.com/dtd/liferay-service-builder_7_0_0.dtd">

<service-builder package-path="com.liferay.osb.customer.ticket.attachment">
	<namespace>OSBCustomer</namespace>
	<entity local-service="true" name="TicketAttachment" remote-service="true">

		<!-- PK fields -->

		<column name="ticketAttachmentId" primary="true" type="long" />

		<!-- Audit fields -->

		<column name="userId" type="long" />
		<column name="userName" type="String" />
		<column name="createDate" type="Date" />

		<!-- Other fields -->

		<column name="accountEntryId" type="long" />
		<column name="zendeskTicketId" type="long" />
		<column name="fileRepositoryId" type="String" />
		<column name="fileName" type="String" />
		<column name="fileSize" type="long" />
		<column name="type" type="int" />

		<!-- Finder methods -->

		<finder name="ZendeskTicketId" return-type="Collection">
			<finder-column name="zendeskTicketId" />
		</finder>
	</entity>
</service-builder>