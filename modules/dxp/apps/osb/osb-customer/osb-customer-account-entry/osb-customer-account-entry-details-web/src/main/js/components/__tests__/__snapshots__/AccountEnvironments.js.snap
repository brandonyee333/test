          class="lexicon-icon lexicon-icon-angle-right"
        >
          <use
            xlink:href="#angle-right"
          />
        </svg>
      </button>
    </div>
    <div
      class="panel"
    >
      <button
        class="btn-link panel-header"
        role="tab"
        type="button"
      >
        <div
          class="panel-title"
        >
          <h4>
            No Search, Commerce, Cloud Services Selection
          </h4>
          <div
            class="panel-subtitle"
