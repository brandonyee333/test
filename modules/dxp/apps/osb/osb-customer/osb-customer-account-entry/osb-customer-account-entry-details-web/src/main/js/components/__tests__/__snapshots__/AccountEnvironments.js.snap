exports[`AccountEnvironments renders correctly 1`] = `
<div>
  <div
    class="card-header small-title"
  >
    environment-configurations
    <button
      aria-label="add"
      class="btn btn-md btn-primary btn-monospaced"
      type="button"
      value="add"
    >
      <svg
        class="lexicon-icon lexicon-icon-plus"
      >
        <use
          xlink:href="#plus"
        />
      </svg>
    </button>
