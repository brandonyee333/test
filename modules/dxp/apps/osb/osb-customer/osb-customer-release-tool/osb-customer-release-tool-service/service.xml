<?xml version="1.0"?>
<!DOCTYPE service-builder PUBLIC "-//Liferay//DTD Service Builder 7.0.0//EN" "http://www.liferay.com/dtd/liferay-service-builder_7_0_0.dtd">

<service-builder package-path="com.liferay.osb.customer.release.tool">
	<namespace>OSBCustomer</namespace>
	<entity local-service="true" name="ArtifactVersion" remote-service="false">

		<!-- PK fields -->

		<column name="artifactVersionId" primary="true" type="long" />

		<!-- Other fields -->

		<column name="releaseAssetCategoryId" type="long" />
		<column name="owner" type="int" />
		<column name="repository" type="int" />
		<column name="group" type="String" />
		<column name="name" type="String" />
		<column name="version" type="String" />
		<column name="packaging" type="String" />

		<!-- Order -->

		<order by="asc">
			<order-column name="group" />
			<order-column name="name" />
		</order>

		<!-- Finder methods -->

		<finder name="ReleaseAssetCategoryId" return-type="Collection">
			<finder-column name="releaseAssetCategoryId" />
		</finder>
		<finder name="RACI_G_N" return-type="ArtifactVersion">
			<finder-column name="releaseAssetCategoryId" />
			<finder-column name="group" />
			<finder-column name="name" />
		</finder>
	</entity>
	<entity local-service="true" name="JIRAComponent" remote-service="false">

		<!-- PK fields -->

		<column name="jiraComponentId" primary="true" type="long" />

		<!-- Other fields -->

		<column name="remoteId" type="long" />
		<column name="remoteProject" type="String" />
		<column name="name" type="String" />
		<column name="visible" type="boolean" />

		<!-- Order -->

		<order by="asc">
			<order-column name="name" />
		</order>

		<!-- Finder methods -->

		<finder name="RemoteProject" return-type="Collection">
			<finder-column name="remoteProject" />
		</finder>
		<finder name="RI_RP" return-type="JIRAComponent">
			<finder-column name="remoteId" />
			<finder-column name="remoteProject" />
		</finder>
		<finder name="RP_V" return-type="Collection">
			<finder-column name="remoteProject" />
			<finder-column name="visible" />
		</finder>
	</entity>
</service-builder>