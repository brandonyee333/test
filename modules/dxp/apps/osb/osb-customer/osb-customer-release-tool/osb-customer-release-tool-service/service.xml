<?xml version="1.0"?>
<!DOCTYPE service-builder PUBLIC "-//Liferay//DTD Service Builder 7.0.0//EN" "http://www.liferay.com/dtd/liferay-service-builder_7_0_0.dtd">

<service-builder package-path="com.liferay.osb.customer.release.tool">
	<namespace>OSBCustomer</namespace>
	<entity local-service="true" name="ArtifactVersion" remote-service="false">

		<!-- PK fields -->

		<column name="artifactVersionId" primary="true" type="long" />

		<!-- Other fields -->

		<column name="releaseAssetCategoryId" type="long" />
		<column name="group" type="String" />
		<column name="name" type="String" />
		<column name="version" type="String" />

		<!-- Order -->

		<order by="asc">
			<order-column name="group" />
			<order-column name="name" />
		</order>
	</entity>
</service-builder>