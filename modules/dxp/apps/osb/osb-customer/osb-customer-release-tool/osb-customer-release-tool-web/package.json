{
	"babel": {
		"plugins": [
			"@babel/plugin-proposal-class-properties"
		],
		"presets": [
			[
				"@babel/preset-env",
				{
					"corejs": 3,
					"useBuiltIns": "usage"
				}
			],
			"@babel/preset-react"
		]
	},
	"browserslist": [
		">0.25%",
		"ie 11",
		"not op_mini all"
	],
	"dependencies": {
		"axios": "^0.18.1",
		"classnames": "^2.2.6",
		"clay-css": "^2.2.0",
		"core-js": "^3.1.4",
		"es6-promise": "^4.2.5",
		"lodash.debounce": "^4.0.8",
		"lodash.times": "^4.3.2",
		"react": "^16.8.6",
		"react-dom": "^16.8.6",
		"react-transition-group": "^4.0.0"
	},
	"devDependencies": {
		"@babel/core": "^7.5.5",
		"@babel/plugin-proposal-class-properties": "^7.5.5",
		"@babel/preset-env": "^7.5.5",
		"@babel/preset-react": "^7.0.0",
		"@testing-library/react": "^8.0.7",
		"autoprefixer": "^9.0.1",
		"babel-core": "^7.0.0-bridge.0",
		"babel-eslint": "^8.2.6",
		"babel-loader": "^8.0.6",
		"css-loader": "^1.0.0",
		"eslint": "^5.3.0",
		"eslint-config-liferay": "^4.5.0",
		"eslint-plugin-jsx-a11y": "^6.2.3",
		"eslint-plugin-react": "^7.14.3",
		"jest": "^24.1.0",
		"liferay-lang-key-dev-loader": "^1.0.3",
		"mini-css-extract-plugin": "^0.4.1",
		"node-sass": "^4.12.0",
		"optimize-css-assets-webpack-plugin": "^5.0.0",
		"postcss-loader": "^2.1.6",
		"prettier": "^1.18.2",
		"prop-types": "^15.7.2",
		"react-axe": "^3.2.0",
		"sass-loader": "^7.1.0",
		"uglifyjs-webpack-plugin": "^1.2.7",
		"webpack": "^4.16.2",
		"webpack-cli": "^3.1.0",
		"webpack-dev-server": "^3.1.14",
		"webpack-merge": "^4.1.3"
	},
	"eslintConfig": {
		"extends": [
			"liferay/react",
			"plugin:jsx-a11y/recommended"
		],
		"plugins": [
			"jsx-a11y"
		]
	},
	"jest": {
		"setupFilesAfterEnv": [
			"<rootDir>/src/main/js/test/setup.js"
		]
	},
	"license": "UNLICENSED",
	"name": "osb-customer-release-tool",
	"prettier": {
		"bracketSpacing": false,
		"endOfLine": "lf",
		"jsxSingleQuote": true,
		"singleQuote": true,
		"tabWidth": 4,
		"useTabs": true
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/liferay/com-liferay-osb-customer-private.git"
	},
	"scripts": {
		"format": "prettier --write 'documentation/*.md' 'src/main/js/**/*.js'",
		"lint": "eslint 'src/main/js/**/*.js'",
		"start": "webpack-dev-server --config webpack.dev.js",
		"test": "jest",
		"webpack": "webpack --config webpack.prod.js"
	},
	"version": "1.0.0"
}
