exports[`Changelog renders details modal when a ticket summary is clicked 1`] = `
<div>
  <div
    class="changelog-filter col-md-3"
  >
    <div
      class="sidebar-filters"
    >
      <div
        class="filter-header"
      >
        <h3>
          refine-by
        </h3>
