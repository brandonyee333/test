<style>
	#day, #month, #year, #hour1, #hour2, #hour3, #minute1, #minute2, #minute3 {
		float: left;
	}

	#day, #month, #year {
		width: 300px
	}

	#hour1, #hour2, #hour3, #minute1, #minute2, #minute3 {
		width: 410px;
	}

	#hour1, #hour2, #hour3 {
		clear: left;
	}

	form div {
		margin-top: 10px;
	}

	form div input {
		width: 99.55%;
	}

	form div select {
		background-color: #FFF;
		float: left;
		height: 22px;
	}

	form div textarea {
		height: 100px;
		resize: none;
	}

	form div, form div textarea {
		display: inline-block;
		width: 100%;
	}

	form div input, form div select, form div textarea {
		outline: none;
	}

	optgroup {
		color: #CCC;
	}

	option {
		color: #000;
	}

	#comments {
		height: 80px;
	}

	.aui-button-input {
		margin-top: 20px;
	}

	.description {
		max-width: 620px;
	}

	.required:after {
		content: "*";
		color: red;
	}

	@media (min-width: 530px) {
		form div textarea {
			width: 98.5%;
		}

		.col-item select {
			width: 80%;
		}

		.col-item:nth-child(odd) {
			width: 50%;
		}

		.col-item:nth-child(odd) input {
			width: 84.55%;
		}

		.col-item:nth-child(even) {
			width: 45.2%;
		}

		.col-item:nth-child(even) input {
			width: 100%;
		}
	}
</style>

#set ($namespace = $request.portlet-namespace)

#if ($request.lifecycle == 'RENDER_PHASE')
	<script type="text/javascript">
		var submission = function() {
			AUI().ready(
				'aui-base',
				'aui-io-plugin',
				'aui-io-request',
				function(A) {
					var attendee = A.one('#${namespace}attendee').val();
					var comments = A.one('#${namespace}comments').val();
					var company = A.one('#${namespace}company').val();
					var day = A.one('#${namespace}day').val();
					var email = A.one('#${namespace}email').val();
					var hour1 = A.one('#${namespace}hour1').val();
					var hour2 = A.one('#${namespace}hour2').val();
					var hour3 = A.one('#${namespace}hour3').val();
					var minute1 = A.one('#${namespace}minute1').val();
					var minute2 = A.one('#${namespace}minute2').val();
					var minute3 = A.one('#${namespace}minute3').val();
					var month = A.one('#${namespace}month').val();
					var name = A.one('#${namespace}name').val();
					var project = A.one('#${namespace}project').val();
					var region = A.one('#${namespace}region').val();
					var year = A.one('#${namespace}year').val();

					A.io.request(
						'${request.resource-url}',
						{
							data: {
								${namespace}attendee: attendee,
								${namespace}comments: comments,
								${namespace}company: company,
								${namespace}day: day,
								${namespace}email: email,
								${namespace}hour1: hour1,
								${namespace}hour2: hour2,
								${namespace}hour3: hour3,
								${namespace}minute1: minute1,
								${namespace}minute2: minute2,
								${namespace}minute3: minute3,
								${namespace}month: month,
								${namespace}name: name,
								${namespace}project: project,
								${namespace}region: region,
								${namespace}year: year
							},
							dataType: 'json',
							on: {
								success: function(event, id, obj) {
									var form = A.one('#${namespace}onboardingFM');

									form.empty().append('<div class="portlet-msg-success">Your request completed successfully.</div>');
								},
								failure: function(event, id, obj) {
									var form = A.one('#${namespace}onboardingFM');

									form.empty().append('<div class="portlet-msg-error">Your request failed to complete.</div>');
								}
							}
						}
					);
				}
			);
		}
	</script>

	<h1>
		$header.data
	</h1>

	<p class="description">$description.data</p>

	<form id="${namespace}onboardingFM" onSubmit="event.preventDefault(); submission();">
		#foreach ($formLabel in $formLabel.siblings)
			#set ($field = $formLabel.data)
			#set ($id = "${namespace}" + "$formLabel.id.data")
			#set ($required = $formLabel.required.data)
			#set ($selectOptions = $formLabel.selectOption.siblings)
			#set ($tag = $formLabel.formTag.data)

			#if ($tag == "select")
				<div class="col-item" id="$formLabel.id.data">
					<label class="required" for="$id"><strong>$field</strong></label>

					<br />

					<select id="$id" required>
						<option selected disabled hidden value='' />

						#foreach ($selectOption in $selectOptions)
							#set ($selectChildOptions = $selectOption.child.siblings)

							#if ($selectChildOptions.size() > 1)
								<optgroup label="$selectOption.data">

								#foreach ($selectChildOption in $selectChildOptions)
									<option value="$selectChildOption.data">$selectChildOption.data</option>
								#end

								</optgroup>
							#else
								<option value="$selectOption.data">$selectOption.data</option>
							#end
						#end
					</select>
				</div>
			#else
				#set ($cssClass = "")

				#if ($tag == 'input')
					#set ($cssClass = "col-item")
				#end

				<div class="$cssClass">
					#set ($labelCssClass = "")

					#if ($required == true)
						#set ($labelCssClass = "required")
					#end

					<label class="$labelCssClass" for="$id"><strong>$field</strong></label>

					<br />

					#set ($requiredAttribute = "")

					#if ($required == true)
						#set ($requiredAttribute = "required")
					#end

					#set ($type = "")

					#if ($id == "${namespace}email")
						#set ($type = "email")
					#else
						#set ($type = "text")
					#end

					<$tag id="$id" name="$id" $requiredAttribute $type></$tag>
				</div>
			#end
		#end

		<input class="aui-button-input" id="${namespace}onboardingFMSubmit" type="submit" value="Submit" />
	</form>
