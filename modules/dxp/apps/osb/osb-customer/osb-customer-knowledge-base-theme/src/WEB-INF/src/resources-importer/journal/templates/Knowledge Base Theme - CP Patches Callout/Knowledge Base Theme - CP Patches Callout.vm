<style>
	#callout-${reserved-article-id.data} .cp-callout-header {
		background-color: $boxColor.data;
	}

	#callout-${reserved-article-id.data}.cp-callout-border-box {
		border: 1px solid $boxColor.data;
	}

	#callout-${reserved-article-id.data}.cp-callout-border-box .btn {
		background: transparent;
		border: 1px solid $boxColor.data;
		color: $boxColor.data;
		margin-left: 10px;
	}

	#callout-${reserved-article-id.data}.cp-callout-border-box .btn:hover {
		background: $boxColor.data;
		color: #FFF;
	}

	.cp-callout-box {
		margin-bottom: 15px;
	}

	.cp-callout-box .btn {
		border: 1px solid #FFF;
		background: transparent;
		color: #FFF;
	}

	.cp-callout-box .cp-callout-heading {
		font-size: 1.7em;
	}

	.cp-callout-border-box .cp-callout-header {
		color: #FFF;
	}

	.cp-callout-border-box .cp-callout-header, .cp-callout-border-box .cp-callout-container {
		padding: 15px;
	}

	.cp-callout-border-box .cp-callout-heading {
		padding: 25px 0;
	}

	.cp-callout-container a {
		text-decoration: none;
	}

	.cp-callout-container .additional-link {
		border-right: 1px solid #58585A;
		padding-right: 5px;
	}

	.cp-callout-container .additional-link.last {
		border-right-width: 0;
		padding-right: 0;
	}

	.cp-callout-container .cp-callout-dl-all {
		text-align: center;
	}

	.cp-callout-container .cp-date {
		color: #939598;
		margin-top: 3px;
	}

	.cp-callout-container .cp-heading {
		font-size: 1.5em;
	}

	.cp-callout-container .cp-heading, .cp-callout-container .cp-table-heading {
		margin-left: 10px;
	}

	.cp-callout-container .cp-table-heading {
		font-weight: bold;
	}

	.cp-callout-container .cp-table-heading .btn {
		float: right;
		margin: 0 10px 5px 0;
		padding: 0 10px;
	}

	.cp-callout-container .cp-table-wrapper td {
		padding: 0 10px;
	}

	.cp-callout-container .cp-table-wrapper.show-borders, .cp-callout-container .cp-table-wrapper.show-borders table {
		margin: 5px 0;
	}

	.cp-callout-container .cp-table-wrapper.show-borders td {
		padding: 3px 10px;
	}

	.cp-callout-container .cp-table-wrapper.show-borders tr {
		border: 1px solid #CCC;
		border-width: 0 0 1px;
	}

	.cp-callout-container .cp-table-wrapper.show-borders .first-row {
		border-top-width: 1px;
	}

	.cp-callout-container .last-col {
		text-align: right;
	}

	@media (max-width: 720px) {
		.cp-callout-border-box .cp-callout-header .w75 .right-column {
			padding: 0 !important;
		}

		.cp-callout-border-box .cp-callout-header .cp-callout-heading {
			padding: 0 10px;
		}
	}
</style>

<div class="clearfix cp-callout-border-box cp-callout-box" id="callout-$reserved-article-id.data">
	<div class="clearfix cp-callout-header">
		<div class="centered content-column icon-wrapper w25">
			<div class="content-column-content left-column">
				<img src="$icon.data" />
			</div>
		</div>

		<div class="content-column w75">
			<div class="content-column-content right-column">
				<h3 class="cp-callout-heading">
					$title.data
				</h3>
			</div>
		</div>
	</div>

	<div class="cp-callout-container">
		<div class="cp-callout-content">
			#if ($contentHeading.data != "")
				<div class="cp-callout-dl-all">
					<a class="btn cp-heading" href="$contentHeading.get("contentHeadingUrl").data">$contentHeading.data</a>

					<div class="cp-date">
						($contentHeading.get("date").data)
					</div>
				</div>
			#end

			#foreach ($section in $contentSectionHeading.siblings)
				#set ($section_css_class = "cp-table-wrapper")

				#if ($section.get("showBorders").data == "true")
					#set ($section_css_class = "$section_css_class show-borders")
				#end

				<div class="$section_css_class">
					<span class="cp-table-heading">
						$section.data

						#if (($section.get("headingLinkUrl").data != "") && $section.get("headingLinkUrl"))
							#set ($heading_link = $section.get("headingLinkUrl"))

							<a class="btn" href="$heading_link.data">$heading_link.headingLinkText.data</a>
						#end
					</span>

					<table>
						#foreach ($link in $section.linkText.siblings)
							#set ($tr_css_class = "row")

							#if ($velocityCount == 1)
								#set ($tr_css_class = "$tr_css_class first-row")
							#elseif ($velocityCount == $section.linkText.siblings.size())
								#set ($tr_css_class = "$tr_css_class last-row")
							#end

							<tr class="$tr_css_class">
								<td class="first-col">
									<a href="$link.get("linkTextUrl").data">$link.data</a>
								</td>
								<td class="last-col">
									#foreach ($additionalLink in $link.additionalLinkText.siblings)
										#if ($additionalLink.data != "")
											#set ($anchor_css_class = "additional-link")

											#if ($velocityCount == 1)
												#set ($anchor_css_class = "$anchor_css_class first")
											#end

											#if ($velocityCount == $link.additionalLinkText.siblings.size())
												#set ($anchor_css_class = "$anchor_css_class last")
											#end

											<a class="$anchor_css_class" href="$additionalLink.get("additionalLinkTextUrl").data">$additionalLink.data</a>
										#end
									#end
								</td>
							</tr>
						#end
					</table>
				</div>
			#end
		</div>

		<a class="btn" href="$buttonText.href.data">$buttonText.data</a>
	</div>
</div>