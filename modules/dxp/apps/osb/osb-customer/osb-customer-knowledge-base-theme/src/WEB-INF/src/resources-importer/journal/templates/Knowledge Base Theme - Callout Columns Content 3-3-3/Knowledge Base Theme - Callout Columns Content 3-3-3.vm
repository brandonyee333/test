<style>
	.callout-a .unit-content {
		padding-right: 20px;
	}

	.unit-table {
		display: inline-table;
		margin: 0 10px;
		min-height: 9px;
	}
</style>

<article>
	#if ($heading.data != "")
		<h1 class="section-heading">
			$heading.data
		</h1>
	#end

	<div class="callout-a">
		<div class="clearfix sub-grid">
			<div class="col-md-4">
				<div class="unit-content">
					#foreach ($eachColumn1Heading in $column1Heading.siblings)
						#if ($eachColumn1Heading.data)
							<h3 class="section-heading">
								$eachColumn1Heading.data
							</h3>
						#end

						#if ($eachColumn1Heading.column1Content.data != "")
							$eachColumn1Heading.column1Content.data
						#end
					#end
				</div>
			</div>

			<div class="col-md-4">
				<div class="unit-content">
					#foreach ($eachColumn2Heading in $column2Heading.siblings)
						#if ($eachColumn2Heading.data)
							<h3 class="section-heading">
								$eachColumn2Heading.data
							</h3>
						#end

						#if ($eachColumn2Heading.column2Content.data != "")
							$eachColumn2Heading.column2Content.data
						#end
					#end
				</div>
			</div>

			<div class="col-md-4">
				<div class="unit-content">
					#foreach ($eachColumn3Heading in $column3Heading.siblings)
						#if ($eachColumn3Heading.data)
							<h3 class="section-heading">
								$eachColumn3Heading.data
							</h3>
						#end

						#if ($eachColumn3Heading.column3Content.data != "")
							$eachColumn3Heading.column3Content.data
						#end
					#end
				</div>
			</div>
		</div>
	</div>
</article>