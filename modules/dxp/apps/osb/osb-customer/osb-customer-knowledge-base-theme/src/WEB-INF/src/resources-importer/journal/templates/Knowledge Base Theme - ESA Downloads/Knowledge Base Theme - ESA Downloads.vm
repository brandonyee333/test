	<script type="text/javascript">
		function updateDownloadDetails${articleId}(index) {
			var A = AUI();

			var articleId = '${articleId}';

			var releaseNotesURLS = '$releaseNotes'.substring(1).split(',');

			var currentDetailNode = A.one('#downloadDetail' + articleId + '_' + index);
			var detailNodes = A.all('#downloadSection' + articleId + ' .download-info');
			var detailToggler = A.one('#detailsToggler' + articleId);
			var releaseNotes = A.one('#releaseNotes' + articleId);

			if (detailNodes) {
				detailNodes.hide();
			}

			if (currentDetailNode) {
				currentDetailNode.show();
				detailToggler.show();
			}
			else {
				detailToggler.hide();
			}

			if (releaseNotes) {
				if (!releaseNotesURLS[index]) {
					releaseNotes.hide();
				}
				else {
					releaseNotes.attr('href', releaseNotesURLS[index]);
					releaseNotes.show();
				}
			}
		}

		AUI().ready(
			'aui-base',
			'aui-dialog',
			'aui-io-plugin',
			'aui-io-request',
			function(A) {
				var downloadSelect = A.one('#downloadSelect${articleId}');
				var submitButton = A.one('#downloadButton${articleId}');

				var getESADataAttempts = 0;

				var requiresESA = $requiresESA;

				var esaConfig = {
					className: 'com.liferay.portal.model.User',
					classPK: ${userId},
					columnName: 'osbESA',
					companyId: ${companyId},
					p_auth: Liferay.authToken,
					tableName: 'CUSTOM_FIELDS'
				};

				function confirmESASubmitted(obj) {
					getESADataAttempts++;

					if (obj[3] && (Number(obj[3]) >= Number($esaVersionRequired))) {
						startDownload();
					}
					else if (getESADataAttempts < 4) {
						getESAData(obj);
					}
					else {
						alert('Unable to retrieve your download at this time. Please try again later.');
					}
				}

				function getESAData(obj) {
					Liferay.Service(
						'/expandovalue/get-data',
						esaConfig,
						confirmESASubmitted
					);
				}

				function startDownload() {
					var downloadLink = '${downloadGroups.downloads.link.data}';

					if (downloadSelect) {
						var selectValue = downloadSelect.val();

						if (selectValue) {
							downloadLink = selectValue;
						}
					}

					if (downloadLink) {
						window.open(downloadLink);
					}
				}

				function submitESA() {
					if (document.esafm_${articleId} && document.esafm_${articleId}.acceptESA${articleId}.checked) {
						getESADataAttempts = 0;

						submitViaAjax();

						document.esafm_${articleId}.acceptESA${articleId}.disabled = true;
					}
					else if (!requiresESA || $articleHeader.contains('Developer Studio 3')) {
						startDownload();
					}
					else {
						alert('$unicodeLanguageUtil.get($locale, "you-must-agree-with-the-end-user-license-agreement-to-continue")');
					}
				}

				function submitViaAjax() {
					if (requiresESA) {
						A.io.request(
							'${request.resource-url}',
							{
								data: {
									${namespace}classPK: ${userId},
									${namespace}companies: '${companies}',
									${namespace}companyId: ${companyId},
									${namespace}esaLanguageId: '${esaLanguageId}',
									${namespace}esaVersion: '${esaVersion}',
									${namespace}timeStamp: '${timeStamp}'
								},
								dataType: 'json',
								on: {
									success: getESAData
								}
							}
						);
					}
				}

				if (submitButton) {
					submitButton.on(
						['click', 'keypress'],
						function(event) {
							if ((event.type == 'click') || ((event.type == 'keypress') && (event.keyCode == 13))) {
								submitESA();
							}
						}
					);
				}
			}
		);
	</script>
