<%!
public static class TestrayRowChecker extends RowChecker {

	@Override
	protected String getNamespacedValue(String value) {
		return value;
	}

	private TestrayRowChecker(RenderResponse renderResponse) {
		super(renderResponse);

		setAllRowIds(ALL_ROW_IDS);
		setFormName(FORM_NAME);
		setRowIds(ROW_IDS);
	}

}
