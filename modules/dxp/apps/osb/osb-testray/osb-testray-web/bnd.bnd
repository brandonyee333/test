Bundle-Name: Liferay OSB Testray Web
Bundle-SymbolicName: com.liferay.osb.testray.web
Bundle-Version: 1.0.0
Export-Package: com.liferay.osb.testray.web.constants
Liferay-JS-Config: /META-INF/resources/js/config.js
Provide-Capability:\
	liferay.resource.bundle;\
		resource.bundle.aggregate:String="(bundle.symbolic.name=com.liferay.osb.testray.lang)";\
		resource.bundle.base.name="content.Language"
Web-ContextPath: /osb-testray-web