{
	"cpu": 8,
	"env": {
		"ES_JAVA_OPTS": "-Xms8g -Xmx8g"
	},
	"id": "esmaster",
	"kind": "StatefulSet",
	"livenessProbe": {
		"failureThreshold": 15,
		"httpGet": {
			"path": "/_cluster/health",
			"port": 9200
		},
		"initialDelaySeconds": 60,
		"periodSeconds": 60,
		"successThreshold": 1,
		"timeoutSeconds": 60
	},
	"memory": 16384,
	"podManagementPolicy": "Parallel",
	"ports": [
		{
			"external": false,
			"port": 9200
		},
		{
			"external": false,
			"port": 9300
		}
	],
	"readinessProbe": {
		"failureThreshold": 15,
		"httpGet": {
			"path": "/",
			"port": 9200
		},
		"initialDelaySeconds": 10,
		"periodSeconds": 60,
		"successThreshold": 1,
		"timeoutSeconds": 60
	},
	"scale": 5,
	"volumes": {
		"datamaster": "/usr/share/elasticsearch/data"
	}
}