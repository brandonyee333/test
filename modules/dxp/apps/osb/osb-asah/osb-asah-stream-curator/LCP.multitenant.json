{
	"cpu": 4,
	"env": {
		"JAVA_OPTS_EXT": "-Xmx11059m",
		"LCP_ENGINE_ELASTICSEARCH_SERVER_IP": "esmaster",
		"LOGGING_PATTERN_CONSOLE": "${CONSOLE_LOG_PATTERN:%clr(${LOG_LEVEL_PATTERN:-%5p}) %clr(${PID:- }){magenta} %clr(---){faint} %clr(%X{osbAsahProjectId:-none}){green} %clr([%15.15t]){faint} %clr(%-40.40logger{39}){cyan} %clr(:){faint} %m%n${LOG_EXCEPTION_CONVERSION_WORD:-%wEx}}",
		"OSB_ASAH_MULTITENANCY_ENABLED": "true"
	},
	"id": "osbasahstreamcurator",
	"kind": "Deployment",
	"memory": 12288,
	"ports": [
		{
			"external": false,
			"port": 8080,
			"protocol": "TCP",
			"targetPort": 8080
		}
	],
	"volumes": {
		"storage": "/storage"
	}
}