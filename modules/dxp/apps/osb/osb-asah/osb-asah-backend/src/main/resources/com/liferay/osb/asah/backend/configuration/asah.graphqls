type SiteMetric {
	anonymousVisitorsMetric: Metric
	assetMetrics: [AssetMetric]
	bounceRateMetric: Metric
	knownVisitorsMetric: Metric
	sessionDurationMetric: Metric
	sessionsMetric: Metric
	sessionsPerVisitorMetric: Metric
	visitorsMetric: Metric
}

type Suppression {
	createDate: String
	dataControlTaskBatchId: String
	dataControlTaskCreateDate: String
	dataControlTaskStatus: String
	emailAddress: String
	id: String
}

type SuppressionBag {
	suppressions: [Suppression]
	total: Int
}

type TimeRange {
	default: Boolean
	endLocalDateTime: String
	key: String
	rangeKey: Int
	startLocalDateTime: String
}

type Trend {
	percentage: Float
	trendClassification: String
}

type User implements DXPEntity {
	dataSourceName: String
	id: String
	name: String
	screenName: String
}

type VariantMetrics {
	confidenceInterval: [Float]
	dxpVariantId: String
	improvement: Float
	median: Float
	probabilityToWin: Float
}