enum AcquisitionType {
	CHANNEL
	REFERRER
	SOURCE_MEDIUM
}

enum AnalysisType {
	AVERAGE
	TOTAL
	UNIQUE
}

enum AssetType {
	BLOG
	DOCUMENT
	FORM
	JOURNAL
	PAGE
}

enum DataControlTaskStatus {
	COMPLETED
	ERROR
	EXPIRED
	PENDING
	RUNNING
}

enum DataControlTaskType {
	ACCESS
	DELETE
	SUPPRESS
	UNSUPPRESS
}

enum EventAttributeDefinitionDataType {
	BOOLEAN
	DATE
	DURATION
	NUMBER
	STRING
}

enum EventAttributeDefinitionType {
	ALL
	GLOBAL
	LOCAL
}

enum EventDefinitionType {
	ALL
	CUSTOM
	DEFAULT
}

enum JobRunStatus {
	COMPLETED
	FAILED
	PUBLISHED
	RUNNING
}

enum JobRunDataPeriod {
	LAST_7_DAYS
	LAST_30_DAYS
	LAST_180_DAYS
	LAST_365_DAYS
}

enum JobRunFrequency {
	EVERY_7_DAYS
	EVERY_14_DAYS
	EVERY_30_DAYS
	MANUAL
}

enum JobStatus {
	FAILED
	PENDING
	READY
	RUNNING
	SCHEDULED
}

enum JobType {
	COMMERCE_PRODUCT_RECOMMENDATION_FREQUENT_PATTERN
	COMMERCE_PRODUCT_RECOMMENDATION_PRODUCT_CONTENT
	COMMERCE_PRODUCT_RECOMMENDATION_USER_INTERACTION
	COMMERCE_REVENUE_FORECAST_ACCOUNT
	COMMERCE_REVENUE_FORECAST_ACCOUNT_CATEGORY
	CONTENT_RECOMMENDATION_ITEM_SIMILARITY
}

enum SortType {
	ASC
	DESC
}

input DXPVariantSettings {
	control: Boolean!
	dxpVariantId: String!
	trafficSplit: Float!
}

input ExperimentSettings {
	confidenceLevel: Float!
	dxpVariantsSettings: [DXPVariantSettings]!
}

input JobParameterInput {
	name: String!
	value: String!
}

input PropertyFilter {
	negate: Boolean!
	filter: String!
}

input Sort {
	column: String!
	type: SortType!
}

interface AssetMetric {
	assetId: String
	assetMetrics: [AssetMetric]
	assetTitle: String
	assetType: String
	dataSourceId: String
	defaultMetric: Metric
	urls: [String]
}

schema {
	query: QueryType
	mutation: MutationType
}

type Activity {
	applicationId: String
	eventContext: String
	eventId: String
	eventProperties: String
	ownerId: String
	startTime: String
}

type ActivityBag {
	activities: [Activity]
	total: Int
}

type AssetMetricBag {
	assetMetrics: [AssetMetric]
	total: Int
}

type BaseDXPEntity implements DXPEntity {
	dataSourceName: String
	id: String
	name: String
}

type BlockedCustomEventDefinition {
	id: String
	lastSeenDate: String
	lastSeenURL: String
	name: String
}

type BlockedCustomEventDefinitionBag {
	blockedCustomEventDefinitions: [BlockedCustomEventDefinition]
	total: Int
}

type BlogMetric implements AssetMetric {
	assetId: String
	assetMetrics: [AssetMetric]
	assetTitle: String
	assetType: String
	canonicalUrls: [String]
	commentsMetric: Metric
	dataSourceId: String
	defaultMetric: Metric
	ratingsMetric: Metric
	readingTimeMetric: Metric
	urls: [String]
	viewsMetric: Metric
}

type CohortHeatMapMetric {
	colDimension: String
	retention: Float
	rowDimension: String
	rowKey: String
	value: Float
}

type Composition {
	name: String
	count: Int
}

type CompositionBag {
	compositions: [Composition]
	maxCount: Int
	total: Int
	totalCount: Int
}

type CustomAssetMetric implements AssetMetric {
	abandonmentsMetric: Metric
	assetId: String
	assetMetrics: [AssetMetric]
	assetTitle: String
	assetType: String
	canonicalUrls: [String]
	clicksMetric: Metric
	completionTimeMetric: Metric
	dataSourceId: String
	defaultMetric: Metric
	downloadsMetric: Metric
	readingTimeMetric: Metric
	submissionsMetric: Metric
	urls: [String]
	viewsMetric: Metric
}

type Dashboard {
	assetId: String
	assetTitle: String
	category: String
	createDate: String
	definition: String
	id: String
	modifiedByUserName: String
	modifiedDate: String
}

type DashboardBag {
	dashboards: [Dashboard]
	total: Int
}

type DataControlTask {
	batchId: String
	completeDate: String
	createDate: String
	emailAddress: String
	id: String
	ownerId: String
	startDate: String
	status: String
	type: String
}

type DataControlTaskBag {
	dataControlTasks: [DataControlTask]
	total: Int
}

type DataSource {
	id: String
	name: String
	url: String
}

type DocumentMetric implements AssetMetric {
	assetId: String
	assetMetrics: [AssetMetric]
	assetTitle: String
	assetType: String
	canonicalUrls: [String]
	commentsMetric: Metric
	dataSourceId: String
	defaultMetric: Metric
	downloadsMetric: Metric
	previewsMetric: Metric
	ratingsMetric: Metric
	urls: [String]
}

interface DXPEntity {
	dataSourceName: String
	id: String
	name: String
}

type DXPEntityBag {
	dxpEntities: [DXPEntity]
	total: Int
}

type EventAnalysis {
	count: Int
	page: Int
	totalEvents: Int
	value: Int
}

type EventAttributeDefinition {
	dataType: EventAttributeDefinitionDataType
	description: String
	displayName: String
	id: String
	name: String
	recentValues: [EventAttributeValue]
	sampleValue: String
	type: EventAttributeDefinitionType
}

type EventAttributeDefinitionBag {
	eventAttributeDefinitions: [EventAttributeDefinition]
	total: Int
}

type EventAttributeValue {
	lastSeenDate: String
	value: String
}

type EventDefinition {
	description: String
	displayName: String
	eventAttributeDefinitions: [EventAttributeDefinition]
	id: String
	name: String
	type: EventDefinitionType
}

type EventDefinitionBag {
	eventDefinitions: [EventDefinition]
	total: Int
}

type Experiment {
	channelId: String
	createDate: String
	dataSourceId: String
	description: String
	dxpExperienceName: String
	dxpSegmentName: String
	dxpVariants: [ExperimentVariant]
	finishedDate: String
	goal: Goal
	id: String
	metrics: ExperimentMetric
	metricsHistogram: [ExperimentMetric]
	modifiedDate: String
	name: String
	pageURL: String
	publishedDXPVariantId: String
	sessions: Int
	sessionsHistogram: [HistogramMetric]
	startedDate: String
	status: String
	type: String
	winnerDXPVariantId: String
}

type ExperimentBag {
	experiments: [Experiment]
	total: Int
}

type ExperimentMetric {
	completion: Float
	confidenceLevel: Float
	elapsedDays: Int
	estimatedDaysLeft: Int
	processedDate: String
	variantMetrics: [VariantMetrics]
}

type ExperimentVariant {
	changes: Int
	control: Boolean
	dxpVariantId: String
	dxpVariantName: String
	sessionsHistogram: [HistogramMetric]
	trafficSplit: Float
	uniqueVisitors: Int
}

type FormFieldMetric {
	fieldAbandonmentsMetric: Metric
	fieldEmptyMetric: Metric
	fieldInteractionDurationMetric: Metric
	fieldInteractionsMetric: Metric
	fieldName: String
	fieldRefilledMetric: Metric
}

type FormMetric implements AssetMetric {
	abandonmentsMetric: Metric
	assetId: String
	assetMetrics: [AssetMetric]
	assetTitle: String
	assetType: String
	canonicalUrls: [String]
	completionTimeMetric: Metric
	dataSourceId: String
	defaultMetric: Metric
	formPageMetrics: [FormPageMetric]
	submissionsMetric: Metric
	urls: [String]
	viewsMetric: Metric
}

type FormPageMetric {
	formFieldMetrics: [FormFieldMetric]
	pageAbandonmentsMetric: Metric
	pageIndex: String
	pageName: String
	pageViewsMetric: Metric
}

type Goal {
	metric: String
	target: String
}

type HeatMapMetric {
	colDimension: String
	rowDimension: String
	value: Float
}

type HistogramMetric {
	key: String
	previousValue: Float
	previousValueKey: String
	trend: Trend
	value: Float
	valueKey: String
}

type HistogramMetricBag {
	asymmetricComparison: Boolean
	metrics: [HistogramMetric]
	total: Int
}

type Individual {
	email: String
	id: String
	name: String
}

type IndividualBag {
	individuals: [Individual],
	total: Int
}

type IndividualMetric {
	anonymousIndividualsMetric: Metric
	knownIndividualsMetric: Metric
	totalIndividualsMetric: Metric
}

type KeyValuePair {
	key: String
	value: String
}

type Keyword {
	type: String
	value: String
}

type Job {
	id: String
	name: String
	nextRunDate: String
	parameters: [JobParameter]
	status: JobStatus
	runDate: String
	runFrequency: JobRunFrequency
	runDataPeriod: JobRunDataPeriod
	type: JobType
}

type JobBag {
	jobs: [Job]
	total: Int
}

type JobParameter {
	name: String
	value: String
}

type JobRun {
	id: String
	completedDate: String
	context: [KeyValuePair]
	status: JobRunStatus
}

type JobRunBag {
	jobRuns: [JobRun]
	total: Int
}

type JobRunsMonthlyStatistics {
	availableJobRuns: Int
	completedJobRuns: Int
	failedJobRuns: Int
	publishedJobRuns: Int
	runningJobRuns: Int
	scheduledJobRuns: Int
}

type JournalMetric implements AssetMetric {
	assetId: String
	assetMetrics: [AssetMetric]
	assetTitle: String
	assetType: String
	canonicalUrls: [String]
	dataSourceId: String
	defaultMetric: Metric
	urls: [String]
	viewsMetric: Metric
}

type Metric {
	anonymousUsersCount: Int
	browser : [Metric]
	cohortHeatMap: [CohortHeatMapMetric]
	device : [Metric]
	geolocation : [Metric]
	histogram: HistogramMetricBag
	individuals(keywords: String, size: Int!, start: Int!): IndividualBag
	knownUsersCount: Int
	metrics : [Metric]
	nonsegmentedKnownUsersCount: Int
	previousValue: Float
	previousValueKey: String
	segment : MetricBag
	segmentedKnownUsersCount: Int
	trend: Trend
	value: Float
	valueKey: String
}

type MetricBag {
	metrics: [Metric]
	total: Int
}

type MutationType {
	blockCustomEventDefinitions(
		eventDefinitionIds: [String]!
	): [Boolean]

	createJob(
		name: String!
		parameters: [JobParameterInput]
		runDataPeriod: JobRunDataPeriod
		runFrequency: JobRunFrequency
		runNow: Boolean
		type: JobType!
	): Job

	dashboard(
		dashboardId: String!
		definition: String!
		modifiedByUserId: String!
		modifiedByUserName: String!
	): Dashboard

	dataControlTasks(
		emailAddresses: [String]
		fileName: String
		ownerId: String!
		types: [DataControlTaskType]!
	): Boolean

	deleteExperiment(
		experimentId: String!
	): Boolean

	deleteJobs(
		jobIds: [String]!
	): [Boolean]

	experiment(
		experimentId: String!
		experimentSettings: ExperimentSettings
		publishedDXPVariantId: String
		status: String
	): Experiment

	preference(
		key: String!
		value: String!
	): Preference

	runJob(
		jobId: String!,
		runDataPeriod: JobRunDataPeriod!
	): Job

	timeZone(
		value: String!
	): String

	unblockCustomEventDefinitions(
		eventDefinitionIds: [String]!
	): [Boolean]

	updateEventAttributeDefinition(
		dataType: EventAttributeDefinitionDataType
		description: String
		displayName: String
		eventAttributeDefinitionId: String!
	): EventAttributeDefinition

	updateEventDefinition(
		description: String
		displayName: String
		eventDefinitionId: String!
	): EventDefinition

	updateJob(
		jobId: String!
		name: String!
		parameters: [JobParameterInput]
		runDataPeriod: JobRunDataPeriod
		runFrequency: JobRunFrequency
		runNow: Boolean
	): Job
}

type Organization implements DXPEntity{
	dataSourceName: String
	id: String
	name: String
	parentName: String
	type: String
}

type PageAsset {
	canonicalUrl: String
	description: String
	keywords: [Keyword]
	id: String
	title: String
	url: String
}

type PageAssetBag {
	pageAssets: [PageAsset]
	total: Int
}

type PageMetric implements AssetMetric {
	assetId: String
	assetMetrics: [AssetMetric]
	assetTitle: String
	assetType: String
	avgTimeOnPageMetric: Metric
	bounceRateMetric: Metric
	defaultMetric: Metric
	directAccessMetric: Metric
	dataSourceId: String
	entrancesMetric: Metric
	exitRateMetric: Metric
	indirectAccessMetric: Metric
	pageReferrerMetrics: [PageReferrerMetric]
	urls: [String]
	visitorsMetric: Metric
	viewsMetric: Metric
}

type PageReferrerMetric {
	accessMetric: Metric
	assetTitle: String
	external: Boolean
	referrer: String
}

type Preference {
	key: String
	value: String
}

type QueryType {
	accountInterests(
		accountId: String!,
		active: Boolean,
		keywords: String,
		size: Int!,
		sort: Sort!
		start: Int!
	): CompositionBag

	acquisitions(
		acquisitionType: AcquisitionType!,
		channelId: String,
		dataSourceId: String,
		rangeEnd: String,
		rangeKey: Int,
		rangeStart: String,
		size: Int!,
		start: Int!
	): CompositionBag

	activities(
		applicationId: String!
		eventId: String!
		eventContextPropertyFilters: [PropertyFilter]
		rangeKey: Int!
		size: Int!
		start: Int!
