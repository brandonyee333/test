def visitorId = doc.userId[0].toString();

if (doc.individualId.length > 0) {
	visitorId = doc.individualId[0].toString();
}

state.minDateMap.merge(visitorId, doc.eventDate.value.millis, (eventDateMillis1, eventDateMillis2) -> (eventDateMillis1 < eventDateMillis2) ? eventDateMillis1 : eventDateMillis2);