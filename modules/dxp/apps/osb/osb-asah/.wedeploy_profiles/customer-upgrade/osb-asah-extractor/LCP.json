{
	"cpu": 2,
	"env": {
		"JAVA_OPTS_EXT": "-Xmx2765m",
		"LOGGING_PATTERN_CONSOLE": "${CONSOLE_LOG_PATTERN:%clr(${LOG_LEVEL_PATTERN:-%5p}) %clr(${PID:- }){magenta} %clr(---){faint} %clr(%X{osbAsahProjectId:-none}){green} %clr([%15.15t]){faint} %clr(%-40.40logger{39}){cyan} %clr(:){faint} %m%n${LOG_EXCEPTION_CONVERSION_WORD:-%wEx}},",
		"OSB_ASAH_ANALYTICS_EVENTS_STORAGE_PATH": "/storage/analytics_events.snappy.parquet"
	},
	"id": "osbasahextractor",
	"image": "liferaycloud/com-liferay-osb-asah-private:osb-asah-extractor-20210504-30b73c2",
	"kind": "Deployment",
	"memory": 3072,
	"ports": [
		{
			"external": false,
			"port": 8080,
			"protocol": "TCP",
			"targetPort": 8080
		}
	],
	"volumes": {
		"storage": "/storage"
	}
}