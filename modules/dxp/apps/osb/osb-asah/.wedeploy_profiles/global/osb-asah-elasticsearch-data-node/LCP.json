{
	"cpu": 4,
	"env": {
		"ES_JAVA_OPTS": "-Xms8g -Xmx8g"
	},
	"environments": {
		"infra": {
			"deploy": false
		}
	},
	"id": "esdata",
	"image": "liferaycloud/com-liferay-osb-asah-private:osb-asah-elasticsearch-data-node-20210504-30b73c2",
	"kind": "StatefulSet",
	"livenessProbe": {
		"failureThreshold": 15,
		"initialDelaySeconds": 60,
		"periodSeconds": 60,
		"successThreshold": 1,
		"tcpSocket": {
			"port": 9300
		},
		"timeoutSeconds": 60
	},
	"memory": 16384,
	"ports": [
		{
			"external": false,
			"port": 9200
		},
		{
			"external": false,
			"port": 9300
		}
	],
	"readinessProbe": {
		"failureThreshold": 15,
		"initialDelaySeconds": 10,
		"periodSeconds": 60,
		"successThreshold": 1,
		"tcpSocket": {
			"port": 9300
		},
		"timeoutSeconds": 60
	},
	"scale": 6,
	"volumes": {
		"data": "/usr/share/elasticsearch/data"
	}
}