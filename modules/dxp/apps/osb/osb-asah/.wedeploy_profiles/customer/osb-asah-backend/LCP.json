{
	"cpu": 2,
	"env": {
		"JAVA_OPTS_EXT": "-Xmx2765m",
		"LOGGING_PATTERN_CONSOLE": "${CONSOLE_LOG_PATTERN:%clr(${LOG_LEVEL_PATTERN:-%5p}) %clr(${PID:- }){magenta} %clr(---){faint} %clr([%15.15t]){faint} %clr(%-40.40logger{39}){cyan} %clr(:){faint} %m%n${LOG_EXCEPTION_CONVERSION_WORD:-%wEx}}"
	},
	"id": "osbasahbackend",
	"image": "liferaycloud/com-liferay-osb-asah-private:osb-asah-backend-20200914-3106e95",
	"kind": "Deployment",
	"loadBalancer": {
		"cdn": false,
		"targetPort": 8080
	},
	"memory": 3072,
	"ports": [
		{
			"external": false,
			"port": 8080,
			"protocol": "TCP",
			"targetPort": 8080
		}
	],
	"volumes": {
		"export": "/export",
		"temp": "/temp"
	}
}