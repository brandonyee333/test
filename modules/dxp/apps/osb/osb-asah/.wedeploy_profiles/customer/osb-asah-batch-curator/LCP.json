{
	"cpu": 2,
	"env": {
		"JAVA_OPTS_EXT": "-Xmx7373m",
		"LOGGING_PATTERN_CONSOLE": "${CONSOLE_LOG_PATTERN:%clr(${LOG_LEVEL_PATTERN:-%5p}) %clr(${PID:- }){magenta} %clr(---){faint} %clr([%15.15t]){faint} %clr(%-40.40logger{39}){cyan} %clr(:){faint} %m%n${LOG_EXCEPTION_CONVERSION_WORD:-%wEx}}"
	},
	"id": "osbasahbatchcurator",
	"image": "wedeploy/com-liferay-osb-asah-private:osb-asah-batch-curator-20200120-dab72da",
	"kind": "Deployment",
	"memory": 8192,
	"ports": [
		{
			"external": false,
			"port": 8080,
			"protocol": "TCP",
			"targetPort": 8080
		}
	],
	"volumes": {
		"export": "/export",
		"temp": "/temp"
	}
}