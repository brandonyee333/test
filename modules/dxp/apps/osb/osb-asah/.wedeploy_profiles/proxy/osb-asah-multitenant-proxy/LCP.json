{
	"cpu": 2,
	"id": "osbasahmultitenantproxy",
	"image": "liferaycloud/com-liferay-osb-asah-private:osb-asah-multitenant-proxy-20230516-1ba3210",
	"livenessProbe": {
		"failureThreshold": 20,
		"httpGet": {
			"path": "/status",
			"port": 80
		},
		"initialDelaySeconds": 60,
		"timeoutSeconds": 10
	},
	"loadBalancer": {
		"targetPort": 80
	},
	"memory": 512,
	"readinessProbe": {
		"failureThreshold": 20,
		"httpGet": {
			"path": "/status",
			"port": 80
		},
		"initialDelaySeconds": 30,
		"timeoutSeconds": 10
	},
	"strategy": {
		"type": "RollingUpdate"
	}
}