{
	"cpu": 4,
	"env": {
		"JAVA_OPTS_EXT": "-Xmx5530m",
		"LOGGING_PATTERN_CONSOLE": "${CONSOLE_LOG_PATTERN:%clr(${LOG_LEVEL_PATTERN:-%5p}) %clr(${PID:- }){magenta} %clr(---){faint} %clr(%X{osbAsahProjectId:-none}){green} %clr([%15.15t]){faint} %clr(%-40.40logger{39}){cyan} %clr(:){faint} %m%n${LOG_EXCEPTION_CONVERSION_WORD:-%wEx}}",
		"OSB_FARO_FRONTEND_URL": "https://analytics.liferay.com"
	},
	"id": "osbasahbackend",
	"image": "liferaycloud/com-liferay-osb-asah-private:osb-asah-backend-20230411-b9bf070",
	"kind": "Deployment",
	"loadBalancer": {
		"cdn": false,
		"targetPort": 8080
	},
	"memory": 6144,
	"ports": [
		{
			"external": false,
			"port": 8080,
			"protocol": "TCP",
			"targetPort": 8080
		}
	],
	"volumes": {
		"export": "/export",
		"temp": "/temp"
	}
}