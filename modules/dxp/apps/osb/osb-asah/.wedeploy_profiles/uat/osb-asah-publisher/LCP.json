{
	"cpu": 2,
	"env": {
		"JAVA_OPTS_EXT": "-Xmx1843m",
		"LOGGING_PATTERN_CONSOLE": "${CONSOLE_LOG_PATTERN:%clr(${LOG_LEVEL_PATTERN:-%5p}) %clr(${PID:- }){magenta} %clr(---){faint} %clr(%X{osbAsahProjectId:-none}){green} %clr([%15.15t]){faint} %clr(%-40.40logger{39}){cyan} %clr(:){faint} %m%n${LOG_EXCEPTION_CONVERSION_WORD:-%wEx}}",
		"OSB_FARO_FRONTEND_URL": "https://analytics-uat.liferay.com"
	},
	"id": "osbasahpublisher",
	"image": "liferaycloud/com-liferay-osb-asah-private:osb-asah-publisher-20230512-b249e55",
	"kind": "Deployment",
	"loadBalancer": {
		"cdn": false,
		"targetPort": 8080
	},
	"memory": 2048,
	"ports": [
		{
			"external": false,
			"port": 8080,
			"protocol": "TCP",
			"targetPort": 8080
		}
	]
}