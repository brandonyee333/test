<?xml version="1.0"?>
<!DOCTYPE properties SYSTEM "http://java.sun.com/dtd/properties.dtd">

<properties>
	<entry key="CSVIndividual.deleteByDataSourceId">
		<![CDATA[
			DELETE FROM
				CSVIndividual
			WHERE
				dataSourceId = :dataSourceId
		]]>
	</entry>
	<entry key="CSVIndividual.deleteByDataSourceIdAndDataSourceIndividualPKIn">
		<![CDATA[
			DELETE FROM
				CSVIndividual
			WHERE
				dataSourceId = :dataSourceId AND
				dataSourceIndividualPK IN (:dataSourceIndividualPKs)
		]]>
	</entry>
</properties>