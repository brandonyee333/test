<?xml version="1.0"?>
<!DOCTYPE properties SYSTEM "http://java.sun.com/dtd/properties.dtd">

<properties>
	<entry key="BQCSVUser.deleteByDataSourceId">
		<![CDATA[
			DELETE FROM
				BQCSVUser
			WHERE
				dataSourceId = :dataSourceId
		]]>
	</entry>
	<entry key="BQCSVUser.deleteByDataSourceIdAndDataSourceUserPKIn">
		<![CDATA[
			DELETE FROM
				BQCSVUser
			WHERE
				dataSourceId = :dataSourceId AND
				dataSourceUserPK IN (:dataSourceUserPKs)
		]]>
	</entry>
</properties>