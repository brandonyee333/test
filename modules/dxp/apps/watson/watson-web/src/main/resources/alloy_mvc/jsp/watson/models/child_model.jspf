	}

	public String getNamesString() throws Exception {
		return WatsonListTypeRel.getRelValueString(getNames(getWatsonChildId()), LocaleUtil.getMostRelevantLocale());
	}

	public JSONObject getChildFormErrors() {
		JSONObject jsonObject = JSONFactoryUtil.createJSONObject();

		for (Map.Entry<String, String> errorEntry : errors.entrySet()) {
			jsonObject.put(errorEntry.getKey(), LanguageUtil.format(LocaleUtil.getMostRelevantLocale(), errorEntry.getValue(), new Object[0]));
		}

		return jsonObject;
	}

	public static String getChildName(long watsonChildId) throws Exception {
		if (watsonChildId > 0) {
			WatsonChild watsonChild = WatsonChild.fetch(watsonChildId);

			return watsonChild.getPrimaryName();
		}

		return StringPool.BLANK;
	}

	public String getPrimaryName() throws Exception {
		String secondaryName = StringPool.BLANK;

		List<WatsonListTypeRel> names = getNames(getWatsonChildId());

		if (!names.isEmpty()) {
			for (WatsonListTypeRel name : names) {
				if (name.getPrimary()) {
					return name.getValue();
				}
				else {
					secondaryName = name.getValue();
				}
			}
		}

		return secondaryName;
	}

	public boolean isValid(List<WatsonListTypeRel> activitiesInvolvedWatsonListTypeRels, List<WatsonListTypeRel> countryIDWatsonListTypeRels, List<WatsonListTypeRel> guardianNameWatsonListTypeRels, List<WatsonListTypeRel> nameWatsonListTypeRels, List<WatsonListTypeRel> parentNameWatsonListTypeRels, List<WatsonListTypeRel> vocationalTrainingWatsonListTypeRels, List<WatsonRelationship> watsonRelationships) throws Exception {
		pushError(validateWatsonChildActivitiesInvolved(activitiesInvolvedWatsonListTypeRels));
		pushError(validateWatsonChildBirthCountry(getBirthCountryId()));
		pushError(validateWatsonChildCountry(getCountryWatsonListTypeId()));
		pushError(validateWatsonChildCountryIDs(countryIDWatsonListTypeRels));
		pushError(validateWatsonChildDates(getDateAccepted(), getDateDischarged(), getDateFollowUp(), getDischargeWatsonListTypeId()));
		pushError(validateWatsonChildEthnicity(getEthnicityWatsonListTypeId()));
		pushError(validateWatsonChildGuardians(guardianNameWatsonListTypeRels));
		pushError(validateWatsonChildNames(nameWatsonListTypeRels));
		pushError(validateWatsonChildRelationships(watsonRelationships));
		pushError(validateWatsonChildParentNames(parentNameWatsonListTypeRels));
		pushError(validateWatsonChildSex(getSexWatsonListTypeId()));
		pushError(validateWatsonChildSource(getSourceWatsonListTypeId()));
		pushError(validateWatsonChildType(getTypeWatsonListTypeId()));
		pushError(validateWatsonChildVocationalTrainings(vocationalTrainingWatsonListTypeRels));

		return errors.isEmpty();
	}

	public void pushError(KeyValuePair keyValuePair) {
		if (keyValuePair != null) {
			errors.put(keyValuePair.getKey(), keyValuePair.getValue());
		}
	}

	public WatsonChild updateTranslations(HttpServletRequest request, Locale locale) throws Exception {
		BaseAlloyControllerImpl.setLocalizedProperties(this, request, locale);

		return update(this);
	}

	private static List<WatsonListTypeRel> getRels(long watsonChildId, String type) throws Exception {
		String listTypeString = getBaseModelClass().getName() + StringPool.PERIOD + type + "Type";

		return WatsonListTypeRel.query("classPK", watsonChildId, "type", listTypeString);
	}

	private static JSONArray populateJSONArrayWithRels(List<WatsonListTypeRel> watsonListTypeRels, Locale locale) throws Exception {
		JSONArray jsonArray = JSONFactoryUtil.createJSONArray();

		for (WatsonListTypeRel watsonListTypeRel : watsonListTypeRels) {
			JSONObject listTypeRelJSONObject = JSONFactoryUtil.createJSONObject();

			WatsonListType watsonListType = WatsonListType.fetch(watsonListTypeRel.getWatsonListTypeId());

			if (watsonListType != null) {
				listTypeRelJSONObject.put("label", watsonListType.getName(locale));
			}

			listTypeRelJSONObject.put("primary", watsonListTypeRel.getPrimary());
			listTypeRelJSONObject.put("value", watsonListTypeRel.getValue(locale));
			listTypeRelJSONObject.put("watsonListTypeId", watsonListTypeRel.getWatsonListTypeId());
			listTypeRelJSONObject.put("watsonListTypeRelId", watsonListTypeRel.getWatsonListTypeRelId());

			jsonArray.put(listTypeRelJSONObject);
		}

		return jsonArray;
	}

	private static JSONObject pushRelData(JSONObject jsonObject, long watsonChildId, String watsonListTypeRelType, Locale locale) throws Exception {
		List<WatsonListTypeRel> watsonListTypeRels = getRels(watsonChildId, watsonListTypeRelType);

		return pushRelData(jsonObject, watsonListTypeRels, watsonListTypeRelType, locale);
	}

	private static JSONObject pushRelData(JSONObject jsonObject, List<WatsonListTypeRel> watsonListTypeRels, String watsonListTypeRelType, Locale locale) throws Exception {
		jsonObject.put(watsonListTypeRelType.concat("WatsonListTypeRels"), populateJSONArrayWithRels(watsonListTypeRels, locale));

		jsonObject.put(watsonListTypeRelType.concat("WatsonListTypeRelString"), WatsonListTypeRel.getRelValueString(watsonListTypeRels, locale));

		return jsonObject;
	}

	protected HashMap<String, String> errors = new HashMap<>();

}
