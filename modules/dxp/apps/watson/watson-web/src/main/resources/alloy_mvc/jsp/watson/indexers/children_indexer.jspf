<%!
public static class WatsonChildrenIndexer extends BaseAlloyIndexer {

	public static WatsonChildrenIndexer getInstance() {
		return _instance;
	}

	@Override
	public void postProcessSearchQuery(BooleanQuery searchQuery, BooleanFilter fullQueryBooleanFilter, SearchContext searchContext) throws Exception {
		addSearchTerm(searchQuery, searchContext, Field.DESCRIPTION, true);
		addSearchTerm(searchQuery, searchContext, Field.NAME, true);
		addSearchTerm(searchQuery, searchContext, Field.STATUS, false);
		addSearchTerm(searchQuery, searchContext, Field.TITLE, true);
		addSearchTerm(searchQuery, searchContext, Field.USER_NAME, true);
	}

	@Override
	protected Document doGetDocument(BaseModel<?> object) throws Exception {
		WatsonChild watsonChild = new WatsonChild((com.liferay.watson.model.WatsonChild)object);

		Document document = getBaseModelDocument(WatsonPortletKeys.WATSON, watsonChild);

		document.addKeyword(Field.STATUS, watsonChild.getStatus());
		document.addKeyword("birthCountryId", watsonChild.getBirthCountryId());
		document.addKeywordSortable("childName", WatsonChild.getChildName(watsonChild.getWatsonChildId()));
		document.addKeyword("citizenshipWatsonListTypeId", watsonChild.getCitizenshipWatsonListTypeId());

		WatsonListType watsonListType = WatsonListType.fetch(watsonChild.getCountryWatsonListTypeId());

		if (watsonListType != null) {
			document.addLocalizedKeyword("country", watsonListType.getNameMap());
		}

		document.addKeyword("countryWatsonListTypeId", watsonChild.getCountryWatsonListTypeId());
		document.addDate("dateAccepted", watsonChild.getDateAccepted());
		document.addDate("dateDischarged", watsonChild.getDateDischarged());

		watsonListType = WatsonListType.fetch(watsonChild.getEthnicityWatsonListTypeId());

		if (watsonListType != null) {
			document.addLocalizedKeyword("ethnicity", watsonListType.getNameMap());
		}

		document.addKeyword("ethnicityWatsonListTypeId", watsonChild.getEthnicityWatsonListTypeId());
		document.addDate("followUpDate", watsonChild.getDateFollowUp());
		document.addKeyword("id", watsonChild.getPrimaryKey());
		document.addKeyword("nameWatsonListTypeRelString", watsonChild.getNamesString());
		document.addKeyword("primaryNameString", watsonChild.getPrimaryName());
		document.addDate("reportDate", watsonChild.getCreateDate());
		document.addKeyword("reportedBy", watsonChild.getUserName());

		watsonListType = WatsonListType.fetch(watsonChild.getSexWatsonListTypeId());

		if (watsonListType != null) {
			document.addLocalizedKeyword("sex", watsonListType.getNameMap());
		}

		document.addKeyword("sexWatsonListTypeId", watsonChild.getSexWatsonListTypeId());
		document.addKeyword("source", watsonChild.getSource());
		document.addKeyword("sourceSubtypeWatsonListTypeId", watsonChild.getSourceSubtypeWatsonListTypeId());
		document.addKeyword("sourceWatsonListTypeId", watsonChild.getSourceWatsonListTypeId());

		watsonListType = WatsonListType.fetch(watsonChild.getTypeWatsonListTypeId());

		if (watsonListType != null) {
			document.addLocalizedKeyword("type", watsonListType.getNameMap());
		}

		document.addKeyword("typeWatsonListTypeId", watsonChild.getTypeWatsonListTypeId());
		document.addKeyword("watsonChildId", watsonChild.getWatsonChildId());

		return document;
	}

	protected Summary doGetSummary(Document document, Locale locale, String snippet, PortletRequest portletRequest, PortletResponse portletResponse) throws Exception {
		return createSummary(document);
	}

	private WatsonChildrenIndexer() {
		setClassName(WatsonChild.baseModelClass.getName());
	}

	private static WatsonChildrenIndexer _instance = new WatsonChildrenIndexer();

}
%>