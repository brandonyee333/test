<%!
public static class WatsonWorkflowUtil {
	public static void sendAddressEmail(User fromUser, WatsonAddress watsonAddress, boolean sendFullAddress, boolean sendCoordinates, String description, String toEmailAddress) throws Exception {
		Locale locale = LocaleUtil.getMostRelevantLocale();

		String subject = LanguageUtil.format(locale, "x-has-sent-you-information-about-a-location", new String[] {fromUser.getFullName()});

		StringBundler email = new StringBundler();

		email.append(LanguageUtil.format(locale, "x-has-sent-you-the-following-information-about-location-x", new String[] {fromUser.getFullName(), watsonAddress.getName(locale)}));
		email.append("<br />");

		if (sendFullAddress) {
			StringBundler address = new StringBundler();

			Country country = CountryServiceUtil.fetchCountry(watsonAddress.getCountryId());

			String countryA2 = country.getA2();

			if (countryA2.equals("TH")) {
				address.append(watsonAddress.getNumber());
				address.append(StringPool.SPACE);
				address.append(watsonAddress.getBuilding(locale));
				address.append("<br />");
				address.append(watsonAddress.getStreet());
				address.append("<br />");

				WatsonListType watsonListType = WatsonListType.fetch(watsonAddress.getSubDistrictWatsonListTypeId());

				address.append(watsonListType.getName(locale));
				address.append(StringPool.COMMA_AND_SPACE);

				watsonListType = WatsonListType.fetch(watsonAddress.getDistrictWatsonListTypeId());

				address.append(watsonListType.getName(locale));

				address.append("<br />");

				watsonListType = WatsonListType.fetch(watsonAddress.getProvinceWatsonListTypeId());

				address.append(watsonListType.getName(locale));

				address.append(StringPool.SPACE);
				address.append(watsonAddress.getPostalCode());
				address.append("<br />");
				address.append(LanguageUtil.format(locale, country.getName(), new String[0]));
				address.append("<br />");
			}
			else {
				address.append(watsonAddress.getNumber());
				address.append(StringPool.SPACE);
				address.append(watsonAddress.getStreet());
				address.append(StringPool.SPACE);
				address.append(watsonAddress.getBuilding(locale));
				address.append("<br />");
				address.append(watsonAddress.getRegion());
				address.append(StringPool.COMMA);
				address.append(watsonAddress.getPostalCode());
				address.append("<br />");
				address.append(LanguageUtil.format(locale, country.getName(), new String[0]));
				address.append("<br />");
			}

			email.append(address.toString());
			email.append("<br />");
		}

		if (sendCoordinates) {
			email.append(LanguageUtil.format(locale, "coordinates-x-x", new Object[] {watsonAddress.getLatitude(), watsonAddress.getLongitude()}));
			email.append("<br />");
		}

		StringBundler mapsLink = new StringBundler();

		mapsLink.append("https://www.google.com/maps/search/?api=1&query=");
		mapsLink.append(watsonAddress.getLatitude());
		mapsLink.append(StringPool.COMMA);
		mapsLink.append(watsonAddress.getLongitude());

		String beginAddressLinkTag = "<a href=" + mapsLink.toString() + ">";
		String endAddressLinkTag = "</a>";

		email.append(LanguageUtil.format(locale, "link-to-map-x-x", new String[] {beginAddressLinkTag, endAddressLinkTag}));
		email.append("<br />");

		email.append(LanguageUtil.format(locale, "notes", new String[0]));
		email.append("<br />");
		email.append(description);

		MailMessage mailMessage = new MailMessage();

		mailMessage.setBody(email.toString());

		InternetAddress from = new InternetAddress(fromUser.getEmailAddress(), fromUser.getFullName());

		mailMessage.setFrom(from);
		mailMessage.setHTMLFormat(true);
		mailMessage.setSubject(subject);

		InternetAddress to = new InternetAddress(toEmailAddress, StringPool.BLANK);

		mailMessage.setTo(to);

		MailServiceUtil.sendEmail(mailMessage);
	}

	public static void sendCitizenshipRequestEmail(User fromUser, String childURL) throws Exception {
		UserGroup userGroup = UserGroupLocalServiceUtil.getUserGroup(fromUser.getCompanyId(), _CITIZENSHIP_USER_GROUP);

		List<User> citizenshipGroupUsers = UserLocalServiceUtil.getUserGroupUsers(userGroup.getUserGroupId());

		for (User citizenshipGroupUser : citizenshipGroupUsers) {
			MailMessage mailMessage = new MailMessage();

			StringBundler sb = new StringBundler(7);

			sb.append(LanguageUtil.format(citizenshipGroupUser.getLocale(), "dear-x", new String[] {citizenshipGroupUser.getFullName()}));
			sb.append("<br /><br />");

			String beginChildLinkTag = "<a href=" + childURL + ">";
			String endChildLinkTag = "</a>";

			sb.append(LanguageUtil.format(citizenshipGroupUser.getLocale(), "x-has-requested-that-you-begin-the-citizenship-process-for-x-x", new String[] {fromUser.getFullName(), beginChildLinkTag, endChildLinkTag}));

			sb.append("<br /><br />");
			sb.append(LanguageUtil.format(citizenshipGroupUser.getLocale(), "thank-you", new String[0]));

			mailMessage.setBody(sb.toString());

			InternetAddress from = new InternetAddress(fromUser.getEmailAddress(), fromUser.getFullName());

			mailMessage.setFrom(from);

			mailMessage.setHTMLFormat(true);

			String subject = LanguageUtil.format(citizenshipGroupUser.getLocale(), "citizenship-process-initiated", new Object[0]);

			mailMessage.setSubject(subject);

			InternetAddress to = new InternetAddress(citizenshipGroupUser.getEmailAddress(), citizenshipGroupUser.getFullName());

			mailMessage.setTo(to);

			MailServiceUtil.sendEmail(mailMessage);
		}
	}

	public static void sendTranslationEmail(User fromUser, String model, String name, String url) throws Exception {
		Role role = RoleLocalServiceUtil.getRole(fromUser.getCompanyId(), RoleConstants.WATSON_TRANSLATOR);

		List<User> translationUsers = UserLocalServiceUtil.getRoleUsers(role.getRoleId());

		for (User translationUser : translationUsers) {
			String subject = LanguageUtil.format(translationUser.getLocale(), "a-translation-has-been-requested", new Object[0]);

			StringBundler sb = new StringBundler(7);

			sb.append(LanguageUtil.format(translationUser.getLocale(), "dear-x", new String[] {translationUser.getFullName()}));
			sb.append("<br /><br />");

			String beginTranslateTag = "<a href=" + url + ">";
			String endTranslateTag = "</a>";

			sb.append(LanguageUtil.format(translationUser.getLocale(), "please-translate-the-contents-of-x-x-click-x-x", new String[] {model, name, beginTranslateTag, endTranslateTag}));
			sb.append("<br /><br />");
			sb.append(LanguageUtil.format(translationUser.getLocale(), "sincerely", new String[0]));
			sb.append("<br />");
			sb.append(fromUser.getFullName());

			MailMessage mailMessage = new MailMessage();

			mailMessage.setBody(sb.toString());

			InternetAddress from = new InternetAddress(fromUser.getEmailAddress(), fromUser.getFullName());

			mailMessage.setFrom(from);
			mailMessage.setHTMLFormat(true);
			mailMessage.setSubject(subject);

			InternetAddress to = new InternetAddress(translationUser.getEmailAddress(), translationUser.getFullName());

			mailMessage.setTo(to);

			MailServiceUtil.sendEmail(mailMessage);
		}
	}

	private static final String _CITIZENSHIP_USER_GROUP = "Citizenship Group";

}
%>