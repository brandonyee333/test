		properties = ArrayUtil.append(properties, new Object[] {"type", watsonListTypeRelType});

		return setFields(watsonListTypeRel, request, ownerModel, properties);
	}

	public static WatsonListTypeRel setFields(WatsonListTypeRel watsonListTypeRel, HttpServletRequest request, AuditedModel ownerModel, String watsonListTypeRelType, Object... properties) throws Exception {
		properties = ArrayUtil.append(properties, new Object[] {"type", watsonListTypeRelType});

		return setFields(watsonListTypeRel, request, ownerModel, properties);
	}

	public static void updateWatsonListTypeRels(HttpServletRequest request, AuditedModel watsonModel, String watsonListTypeRelType, JSONArray jsonArray) throws Exception {
		List<Long> watsonListTypeRelIds = new ArrayList<>();

		for (int i = 0; i < jsonArray.length(); i++) {
			JSONObject jsonObject = jsonArray.getJSONObject(i);

			boolean primary = jsonObject.getBoolean("primary", false);
			String textValue = jsonObject.getString("value", StringPool.BLANK);
			long watsonListTypeId = jsonObject.getLong("watsonListTypeId", 0L);
			long watsonListTypeRelId = jsonObject.getLong("watsonListTypeRelId", 0L);

			WatsonListTypeRel watsonListTypeRel = update(request, watsonModel, watsonListTypeRelId, "primary", primary, "type", watsonListTypeRelType, "value", textValue, "watsonListTypeId", watsonListTypeId);

			watsonListTypeRelIds.add(watsonListTypeRel.getWatsonListTypeRelId());
		}

		deleteMissing(watsonModel, watsonListTypeRelType, watsonListTypeRelIds);
	}

	public WatsonListTypeRel setFields(String watsonListTypeRelType, Object... properties) throws Exception {
		properties = ArrayUtil.append(properties, new Object[] {"type", watsonListTypeRelType});

		return setFields(this, null, null, properties);
	}

	public WatsonListTypeRel setFields(HttpServletRequest request, AuditedModel ownerModel, String watsonListTypeRelType, Object... properties) throws Exception {
		properties = ArrayUtil.append(properties, new Object[] {"type", watsonListTypeRelType});

		return setFields(this, request, ownerModel, properties);
	}

	protected static List<WatsonListTypeRel> generateWatsonListTypeRels(HttpServletRequest request, AuditedModel watsonModel, String watsonListTypeRelType, Collection<Long> watsonListTypeIds) throws Exception {
		List<WatsonListTypeRel> watsonListTypeRels = new ArrayList<>();

		for (long watsonListTypeId : watsonListTypeIds) {
			watsonListTypeRels.add(findOrCreate(request, watsonModel, watsonListTypeRelType, watsonListTypeId));
		}

		return watsonListTypeRels;
	}

	protected static Object[] getPropertiesFromJSONObject(JSONObject jsonObject) throws Exception {
		List<Object> properties = new ArrayList<>();

		Iterator<?> keys = jsonObject.keys();

		while (keys.hasNext()) {
			String key = GetterUtil.getString(keys.next());

			properties.add(key);

			Object object = jsonObject.get(key);

			properties.add(object);
		}

		return properties.toArray();
	}

}
