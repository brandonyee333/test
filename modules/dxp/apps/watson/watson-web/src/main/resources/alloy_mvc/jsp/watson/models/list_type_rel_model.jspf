	public static WatsonListTypeRel delete(long ownerModelId, long watsonListTypeId) throws Exception {
		List<WatsonListTypeRel> watsonListTypeRels = query("classPK", ownerModelId, "watsonListTypeId", watsonListTypeId);

		if (watsonListTypeRels.size() == 1) {
			WatsonListTypeRel watsonListTypeRel = watsonListTypeRels.get(0);

			watsonListTypeRel.delete();

			return watsonListTypeRel;
		}

		return null;
	}

	public static void deleteMissing(AuditedModel ownerModel, String watsonListTypeRelType, Collection<Long> watsonListTypeRelIds) throws Exception {
		deleteMissing((Long)ownerModel.getPrimaryKeyObj(), watsonListTypeRelType, watsonListTypeRelIds);
	}

	public static void deleteMissing(long ownerModelId, String watsonListTypeRelType, Collection<Long> watsonListTypeRelIds) throws Exception {
		List<WatsonListTypeRel> watsonListTypeRels = query("classPK", ownerModelId, "type", watsonListTypeRelType);

		for (WatsonListTypeRel watsonListTypeRel : watsonListTypeRels) {
			if (!watsonListTypeRelIds.contains(watsonListTypeRel.getWatsonListTypeRelId())) {
				watsonListTypeRel.delete();
			}
		}
	}

	public static WatsonListTypeRel findOrCreate(HttpServletRequest request, AuditedModel ownerModel, String watsonListTypeRelType, long watsonListTypeId) throws Exception {
		WatsonListTypeRel watsonListTypeRel = null;

		long classNameId = ClassNameLocalServiceUtil.getClassNameId(ownerModel.getModelClass());

		Object[] properties = {"classNameId", classNameId, "classPK", ownerModel.getPrimaryKeyObj(), "type", watsonListTypeRelType, "watsonListTypeId", watsonListTypeId};

		if (watsonListTypeId > 0) {
			List<WatsonListTypeRel> watsonListTypeRels = query(properties);

			if (watsonListTypeRels.size() > 0) {
				watsonListTypeRel = watsonListTypeRels.get(0);
			}
		}

		if (watsonListTypeRel == null) {
			watsonListTypeRel = create(0, request);
		}

		watsonListTypeRel.setFields(request, ownerModel, watsonListTypeRelType, properties);

		return watsonListTypeRel;
	}

	public static WatsonListTypeRel findOrCreate(HttpServletRequest request, AuditedModel ownerModel, long watsonListTypeRelId, String watsonListTypeRelType, Object... properties) throws Exception {
		WatsonListTypeRel watsonListTypeRel = null;

		if (watsonListTypeRelId > 0) {
			watsonListTypeRel = fetch(watsonListTypeRelId);
		}

		if (watsonListTypeRel == null) {
			watsonListTypeRel = create(watsonListTypeRelId, request);
		}

		watsonListTypeRel.setFields(request, ownerModel, watsonListTypeRelType, properties);

		return watsonListTypeRel;
	}

	public static Object[] generateValidationData(HttpServletRequest request, AuditedModel ownerModel, String watsonListTypeRelType, Collection<Long> watsonListTypeIds) throws Exception {
		List<WatsonListTypeRel> watsonListTypeRels = query("classPK", ownerModel.getPrimaryKeyObj(), "type", watsonListTypeRelType);

		List<WatsonListTypeRel> removableWatsonListTypeRels = new ArrayList<>();

		Iterator<WatsonListTypeRel> iter = watsonListTypeRels.iterator();

		while (iter.hasNext()) {
			WatsonListTypeRel watsonListTypeRel = iter.next();

			if (!watsonListTypeIds.remove(watsonListTypeRel.getWatsonListTypeId())) {
				iter.remove();

				removableWatsonListTypeRels.add(watsonListTypeRel);
			}
		}

		if (watsonListTypeIds.size() > 0) {
			watsonListTypeRels.addAll(generateWatsonListTypeRels(request, ownerModel, watsonListTypeRelType, watsonListTypeIds));
		}

		return new Object[] {watsonListTypeRels, removableWatsonListTypeRels};
	}

	public static Object[] generateValidationData(HttpServletRequest request, AuditedModel ownerModel, String watsonListTypeRelType, JSONArray watsonListTypeRelData) throws Exception {
		List<WatsonListTypeRel> watsonListTypeRels = query("classPK", ownerModel.getPrimaryKeyObj(), "type", watsonListTypeRelType);

		List<WatsonListTypeRel> resultWatsonListTypeRels = new ArrayList<>();

		for (int i = 0; i < watsonListTypeRelData.length(); i++) {
			JSONObject watsonListTypeRelEntity = watsonListTypeRelData.getJSONObject(i);

			WatsonListTypeRel matchingWatsonListTypeRel = null;

			Iterator<WatsonListTypeRel> iter = watsonListTypeRels.iterator();

			while (iter.hasNext()) {
				WatsonListTypeRel watsonListTypeRel = iter.next();

				if (watsonListTypeRel.getWatsonListTypeRelId() == GetterUtil.getLong(watsonListTypeRelEntity.get("watsonListTypeRelId"))) {
					matchingWatsonListTypeRel = watsonListTypeRel;

					iter.remove();

					break;
				}
			}

			Object[] properties = getPropertiesFromJSONObject(watsonListTypeRelEntity);

			if (matchingWatsonListTypeRel != null) {
				setFields(matchingWatsonListTypeRel, request, ownerModel, watsonListTypeRelType, properties);

				resultWatsonListTypeRels.add(matchingWatsonListTypeRel);
			}
			else {
				resultWatsonListTypeRels.add(create(request, ownerModel, watsonListTypeRelType, properties));
			}
		}

		return new Object[] {resultWatsonListTypeRels, watsonListTypeRels};
	}

	public static List<Long> getWatsonListTypeIds(long classPK, String type) throws Exception {
		DynamicQuery watsonListTypeRelDynamicQuery = baseModelAlloyServiceInvoker.buildDynamicQuery(new Object[] {"classPK", classPK, "status", WorkflowConstants.STATUS_APPROVED, "type", type});

		Projection watsonListTypeIdProjection = ProjectionFactoryUtil.property("watsonListTypeId");

		watsonListTypeRelDynamicQuery.setProjection(ProjectionFactoryUtil.distinct(watsonListTypeIdProjection));

		return baseModelAlloyServiceInvoker.executeDynamicQuery(watsonListTypeRelDynamicQuery);
	}

	public static List<WatsonListType> getWatsonListTypes(long classPK, String type) throws Exception {
		List<Long> watsonListTypeIds = getWatsonListTypeIds(classPK, type);

		List<WatsonListType> watsonListTypes = new ArrayList<>();

		for (long watsonListTypeId : watsonListTypeIds) {
			watsonListTypes.add(WatsonListType.fetch(watsonListTypeId));
		}

		return watsonListTypes;
	}

	private static String getRelValueString(List<WatsonListTypeRel> watsonListTypeRels, Locale locale) throws Exception {
		StringBundler sb = new StringBundler(watsonListTypeRels.size() * 3);

		boolean first = true;

		for (WatsonListTypeRel watsonListTypeRel : watsonListTypeRels) {
			if (!first) {
				sb.append(StringPool.COMMA);
				sb.append(StringPool.SPACE);
			}

			sb.append(watsonListTypeRel.getValue(locale));

			first = false;
		}

		return sb.toString();
	}

	public static WatsonListTypeRel update(HttpServletRequest request, AuditedModel ownerModel, long watsonListTypeRelId, Object... properties) throws Exception {
		WatsonListTypeRel watsonListTypeRel = null;

		if (watsonListTypeRelId > 0) {
			watsonListTypeRel = fetch(watsonListTypeRelId);
		}

		if (watsonListTypeRel == null) {
			return add(request, ownerModel, properties);
		}

		long classNameId = ClassNameLocalServiceUtil.getClassNameId(ownerModel.getModelClass());

		properties = ArrayUtil.append(properties, new Object[] {"classNameId", classNameId, "classPK", ownerModel.getPrimaryKeyObj()});

		WatsonAlloyControllerImpl.setBaseModelProperties(watsonListTypeRel, properties);

		return update(watsonListTypeRel, request);
	}

	public static WatsonListTypeRel setFields(WatsonListTypeRel watsonListTypeRel, HttpServletRequest request, AuditedModel ownerModel, Object... properties) throws Exception {
		if (ownerModel != null) {
			long classNameId = ClassNameLocalServiceUtil.getClassNameId(ownerModel.getModelClass());

			properties = ArrayUtil.append(properties, new Object[] {"classNameId", classNameId, "classPK", ownerModel.getPrimaryKeyObj()});
		}

		return setFields(watsonListTypeRel, request, properties);
	}

	public static WatsonListTypeRel setFields(long watsonListTypeRelId, HttpServletRequest request, AuditedModel ownerModel, String watsonListTypeRelType, Object... properties) throws Exception {
		WatsonListTypeRel watsonListTypeRel = null;

		if (watsonListTypeRelId > 0) {
			watsonListTypeRel = fetch(watsonListTypeRelId);
		}

		if (watsonListTypeRel == null) {
			watsonListTypeRel = create(0, request);
