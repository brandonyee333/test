	public static WatsonListTypeRel add(HttpServletRequest request, AuditedModel ownerModel, Object... properties) throws Exception {
		long classNameId = ClassNameLocalServiceUtil.getClassNameId(ownerModel.getModelClass());

		properties = ArrayUtil.append(properties, new Object[] {"classNameId", classNameId, "classPK", ownerModel.getPrimaryKeyObj(), "status", WorkflowConstants.STATUS_APPROVED});

		List<WatsonListTypeRel> watsonListTypeRels = query(properties);

		if (!watsonListTypeRels.isEmpty()) {
			return watsonListTypeRels.get(0);
		}

		WatsonListTypeRel watsonListTypeRel = create();

		WatsonAlloyControllerImpl.setBaseModelProperties(watsonListTypeRel, properties);

		return add(watsonListTypeRel, request);
	}

	public static void batchAdd(List<WatsonListTypeRel> watsonListTypeRels, AuditedModel ownerModel) throws Exception {
		for (WatsonListTypeRel watsonListTypeRel : watsonListTypeRels) {
			long classNameId = ClassNameLocalServiceUtil.getClassNameId(ownerModel.getModelClass());

			watsonListTypeRel.setClassNameId(classNameId);

			watsonListTypeRel.setClassPK((Long)ownerModel.getPrimaryKeyObj());
		}

		batchAdd(watsonListTypeRels);
	}

	public static void clear(AuditedModel ownerModel) throws Exception {
		clear((Long)ownerModel.getPrimaryKeyObj());
	}

	public static void clear(long ownerModelId) throws Exception {
		List<WatsonListTypeRel> watsonListTypeRels = query("classPK", ownerModelId);

		for (WatsonListTypeRel watsonListTypeRel : watsonListTypeRels) {
			watsonListTypeRel.delete();
		}
	}

	public static WatsonListTypeRel copy(HttpServletRequest request, WatsonListTypeRel oldWatsonListTypeRel) throws Exception {
		WatsonListTypeRel watsonListTypeRel = create(request);

		watsonListTypeRel.setWatsonListTypeId(oldWatsonListTypeRel.getWatsonListTypeId());
		watsonListTypeRel.setClassNameId(oldWatsonListTypeRel.getClassNameId());
		watsonListTypeRel.setValue(oldWatsonListTypeRel.getValue());
		watsonListTypeRel.setPrimary(oldWatsonListTypeRel.getPrimary());
		watsonListTypeRel.setType(oldWatsonListTypeRel.getType());

		return watsonListTypeRel;
	}

	public static List<WatsonListTypeRel> copy(HttpServletRequest request, long oldOwnerModelId, long newOwnerModelId) throws Exception {
		List<WatsonListTypeRel> watsonListTypeRels = query("classPK", oldOwnerModelId);

		List<WatsonListTypeRel> newWatsonListTypeRels = new ArrayList<>();

		for (WatsonListTypeRel watsonListTypeRel : watsonListTypeRels) {
			WatsonListTypeRel newWatsonListTypeRel = watsonListTypeRel.copy(request);

			newWatsonListTypeRel.setClassPK(newOwnerModelId);

			newWatsonListTypeRel.add();

			newWatsonListTypeRels.add(newWatsonListTypeRel);
		}

		return newWatsonListTypeRels;
	}

	public static WatsonListTypeRel create(HttpServletRequest request, AuditedModel ownerModel, String watsonListTypeRelType, Object... properties) throws Exception {
		WatsonListTypeRel watsonListTypeRel = create(0, request);

		watsonListTypeRel.setFields(request, ownerModel, watsonListTypeRelType, properties);

		return watsonListTypeRel;
