<%@ include file="/alloy_mvc/jsp/watson/models/base/incident_base_model.jspf" %>

<%!
public static class WatsonIncident extends WatsonIncidentBaseModel {

	WatsonIncident() {
		super(new com.liferay.watson.model.impl.WatsonIncidentImpl());
	}

	WatsonIncident(com.liferay.watson.model.WatsonIncident watsonIncident) {
		super(watsonIncident);
	}

	WatsonIncident(WatsonIncident watsonIncident) {
		super(watsonIncident);
	}

	WatsonIncident(WatsonIncidentBaseModel watsonIncident) {
		super(watsonIncident);
	}

	public static final int INCIDENT_STATUS_CLOSED = 2;

	public static final int INCIDENT_STATUS_INACTIVE = 1;

	public static final String INCIDENT_STATUS_LABEL_CLOSED = "closed";

	public static final String INCIDENT_STATUS_LABEL_INACTIVE = "inactive";

	public static final String INCIDENT_STATUS_LABEL_OPEN = "open";

	public static final int INCIDENT_STATUS_OPEN = 0;

	public static final int MAX_FIELD_LENGTH_TEXTAREA = 4000;

	public static void clearWatsonIncidentChildren(long watsonIncidentId) throws Exception {
		List<WatsonActivity> watsonActivities = WatsonActivity.queryAll("watsonIncidentId", watsonIncidentId);

		for (WatsonActivity watsonActivity : watsonActivities) {
			watsonActivity.delete();
		}

		List<WatsonAddress> watsonAddresses = WatsonAddress.queryAll("watsonIncidentId", watsonIncidentId);

		for (WatsonAddress watsonAddress : watsonAddresses) {
			watsonAddress.delete();
		}

		List<WatsonPerson> watsonPeople = WatsonPerson.queryAll("watsonIncidentId", watsonIncidentId);

		for (WatsonPerson watsonPerson : watsonPeople) {
			watsonPerson.delete();
		}

		List<WatsonResource> watsonResources = WatsonResource.queryAll("watsonIncidentId", watsonIncidentId);

		for (WatsonResource watsonResource : watsonResources) {
			watsonResource.delete();
		}

		List<WatsonVehicle> watsonVehicles = WatsonVehicle.queryAll("watsonIncidentId", watsonIncidentId);

		for (WatsonVehicle watsonVehicle : watsonVehicles) {
			watsonVehicle.delete();
		}
	}

	public static JSONObject getAsJSONDataArray(List<WatsonIncident> watsonIncidents, long count) throws Exception {
		JSONObject returnJSONObject = JSONFactoryUtil.createJSONObject();

		JSONArray watsonIncidentsJSONArray = JSONFactoryUtil.createJSONArray();

		for (WatsonIncident watsonIncident : watsonIncidents) {
			watsonIncidentsJSONArray.put(getAsJSONObject(watsonIncident));
		}

		returnJSONObject.put("count", count);
		returnJSONObject.put("items", watsonIncidentsJSONArray);

		return returnJSONObject;
	}

	public static JSONObject getAsJSONObject(WatsonIncident watsonIncident) throws Exception {
		return getAsJSONObject(watsonIncident, null, null, LocaleUtil.getMostRelevantLocale());
	}

	public static JSONObject getAsJSONObject(WatsonIncident watsonIncident, Locale locale) throws Exception {
		return getAsJSONObject(watsonIncident, null, null, locale);
	}

	public static JSONObject getAsJSONObject(WatsonIncident watsonIncident, List<WatsonListTypeRel> natures, List<WatsonIncidentRel> watsonIncidentRels) throws Exception {
		return getAsJSONObject(watsonIncident, natures, watsonIncidentRels, LocaleUtil.getMostRelevantLocale());
	}

	public static JSONObject getAsJSONObject(WatsonIncident watsonIncident, List<WatsonListTypeRel> natures, List<WatsonIncidentRel> watsonIncidentRels, Locale locale) throws Exception {
		JSONObject jsonObject = JSONFactoryUtil.createJSONObject();

		jsonObject.put("activities", WatsonActivity.getIdJSONArray(watsonIncident.getWatsonIncidentId()));
		jsonObject.put("addresses", WatsonAddress.getIdJSONArray(watsonIncident.getWatsonIncidentId()));
		jsonObject.put("audienceKey", watsonIncident.getAudienceKey());
		jsonObject.put("createDate", getFormattedDate(watsonIncident.getCreateDate(), locale));
		jsonObject.put("description", watsonIncident.getDescription(locale));
		jsonObject.put("disabled", hasDisabled(watsonIncident.getIncidentStatus()));
		jsonObject.put("endDate", getFormattedDate(watsonIncident.getEndDate(), locale));
		jsonObject.put("externalCaseId", watsonIncident.getExternalCaseId());
		jsonObject.put("histories", JSONFactoryUtil.createJSONArray());
		jsonObject.put("id", watsonIncident.getPrimaryKey());
		jsonObject.put("incidentName", watsonIncident.getName());
		jsonObject.put("incidentStatus", String.valueOf(watsonIncident.getIncidentStatus()));
		jsonObject.put("incidentStatusLabel", getIncidentStatusLabel(watsonIncident.getIncidentStatus()));

		Date modifiedDate = watsonIncident.getModifiedDate();

		jsonObject.put("modifiedDate", getFormattedDate(modifiedDate, locale));
		jsonObject.put("modifiedDateTimeStamp", modifiedDate.getTime());
		jsonObject.put("modifiedUserName", WatsonHistory.fetchLastModifiedUserName(watsonIncident));
		jsonObject.put("name", watsonIncident.getName());

		if (Validator.isNotNull(natures) && (natures.size() > 0)) {
			List<Long> natureIds = new ArrayList<>();

			for (WatsonListTypeRel nature : natures) {
				natureIds.add(nature.getWatsonListTypeId());
			}

			jsonObject.put("natureWatsonListType", natureIds.toArray());
		}
		else {
			jsonObject.put("natureWatsonListType", getIncidentNatureIds(watsonIncident.getWatsonIncidentId()).toArray());
		}

		jsonObject.put("people", WatsonPerson.getIdJSONArray(watsonIncident.getWatsonIncidentId()));
		jsonObject.put("relationships", JSONFactoryUtil.createJSONArray());
		jsonObject.put("reportDate", getFormattedDate(watsonIncident.getReportDate(), locale));
		jsonObject.put("reportedBy", watsonIncident.getUserName());
		jsonObject.put("resources", WatsonResource.getIdJSONArray(watsonIncident.getWatsonIncidentId()));
		jsonObject.put("sourceWatsonListTypeId", watsonIncident.getSourceWatsonListTypeId());
		jsonObject.put("startDate", getFormattedDate(watsonIncident.getStartDate(), locale));

		WatsonListType watsonListType = WatsonListType.fetch(watsonIncident.getSubtypeWatsonListTypeId());

		if (watsonListType != null) {
			jsonObject.put("subtypeLabel", watsonListType.getName(locale));
		}

		jsonObject.put("subtypeWatsonListTypeId", watsonIncident.getSubtypeWatsonListTypeId());

		watsonListType = WatsonListType.fetch(watsonIncident.getTypeWatsonListTypeId());

		if (watsonListType != null) {
			jsonObject.put("typeLabel", watsonListType.getName(locale));
		}

		jsonObject.put("typeWatsonListTypeId", watsonIncident.getTypeWatsonListTypeId());
		jsonObject.put("vehicles", WatsonVehicle.getIdJSONArray(watsonIncident.getWatsonIncidentId()));
		jsonObject.put("watsonIncidentId", watsonIncident.getWatsonIncidentId());

		if (Validator.isNotNull(watsonIncidentRels)) {
			jsonObject.put("watsonIncidentRelIds", WatsonIncidentRel.getWatsonIncidentRelClassPKs(watsonIncident.getWatsonIncidentId(), watsonIncidentRels).toArray());
			jsonObject.put("watsonIncidentRels", WatsonIncidentRel.getWatsonIncidentRelsAsJSONObject(watsonIncident.getWatsonIncidentId(), watsonIncidentRels));
		}
		else {
			jsonObject.put("watsonIncidentRelIds", WatsonIncidentRel.getWatsonIncidentRelClassPKs(watsonIncident.getWatsonIncidentId()));
			jsonObject.put("watsonIncidentRels", WatsonIncidentRel.getWatsonIncidentRelsAsJSONObject(watsonIncident));
		}

		return jsonObject;
	}

	public static String getIncidentName(long watsonIncidentId) throws Exception {
		if (watsonIncidentId > 0) {
			WatsonIncident watsonIncident = WatsonIncident.fetch(watsonIncidentId);

			return watsonIncident.getName();
		}

		return StringPool.BLANK;
	}

	public static long getIncidentStatus(long watsonIncidentId) throws Exception {
		if (watsonIncidentId > 0) {
			WatsonIncident watsonIncident = WatsonIncident.fetch(watsonIncidentId);

			return watsonIncident.getIncidentStatus();
		}

		return INCIDENT_STATUS_CLOSED;
	}

	public static String getFormattedDate(Date date, Locale locale) throws Exception {
		if (date != null) {
			return DateUtil.getDate(date, "yyyy-MM-dd", locale);
		}
		else {
			return StringPool.BLANK;
		}
	}

	public static List<Long> getIncidentNatureIds(long watsonIncidentId) throws Exception {
		return WatsonListTypeRel.getWatsonListTypeIds(watsonIncidentId, getBaseModelClass().getName() + ".nature");
	}

	public String getIncidentNatures() throws Exception {
		List<Long> incidentNatureIds = getIncidentNatureIds(getWatsonIncidentId());

		StringBundler sb = new StringBundler(incidentNatureIds.size() * 2);

		for (long incidentNatureId : incidentNatureIds) {
			sb.append(incidentNatureId);
			sb.append(StringPool.SPACE);
		}

		return sb.toString();
	}

	public static String getIncidentStatusLabel(int incidentStatus) {
		if (incidentStatus == INCIDENT_STATUS_CLOSED) {
			return INCIDENT_STATUS_LABEL_CLOSED;
		}
		else if (incidentStatus == INCIDENT_STATUS_INACTIVE) {
			return INCIDENT_STATUS_LABEL_INACTIVE;
		}

		return INCIDENT_STATUS_LABEL_OPEN;
	}

	public static List<WatsonActivity> getWatsonActivities(long watsonIncidentId, boolean includeInactive, String sort, int start, int end) throws Exception {
		if (watsonIncidentId > 0) {
			if (includeInactive) {
				return WatsonActivity.queryAll("watsonIncidentId", watsonIncidentId);
			}
			else {
				return WatsonActivity.queryRange(sort, start, end, "watsonIncidentId", watsonIncidentId);
			}
		}
		else {
			return WatsonActivity.get(start, end);
		}
	}

