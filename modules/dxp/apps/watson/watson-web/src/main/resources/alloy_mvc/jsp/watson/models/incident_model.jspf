	public static boolean hasDisabled(long currentUserId, long incidentStatus) throws Exception {
		ServiceContext serviceContext = ServiceContextThreadLocal.getServiceContext();

		User user = UserLocalServiceUtil.fetchUser(currentUserId);

		if (Validator.isNotNull(user)) {
			boolean hasAdminRole = RoleLocalServiceUtil.hasUserRole(user.getUserId(), user.getCompanyId(), RoleConstants.ADMIN, true);

			if (hasAdminRole) {
				return false;
			}
		}

		return (incidentStatus == INCIDENT_STATUS_CLOSED);
	}

	public static boolean hasDisabled(long incidentStatus) throws Exception {
		ServiceContext serviceContext = ServiceContextThreadLocal.getServiceContext();

		return hasDisabled(serviceContext.getUserId(), incidentStatus);
	}

	public static KeyValuePair validateWatsonIncidentDescription(String description) {
		if (Validator.isNull(description)) {
			return new KeyValuePair("description", "description-is-required");
		}

		if (description.length() >= MAX_FIELD_LENGTH_TEXTAREA) {
			return new KeyValuePair("description", "the-description-exceeded-the-maximum-allowed-length");
		}

		return null;
	}

	public static KeyValuePair validateWatsonIncidentIncidentStatus(int incidentStatus) {
		if ((incidentStatus != INCIDENT_STATUS_OPEN) && (incidentStatus != INCIDENT_STATUS_CLOSED) && (incidentStatus != INCIDENT_STATUS_INACTIVE)) {
			return new KeyValuePair("incidentStatus", "the-incident-status-is-invalid");
		}

		return null;
	}

	public static KeyValuePair validateWatsonIncidentNatures(List<WatsonListTypeRel> natures, boolean newIncident) throws Exception {
		if (natures.isEmpty()) {
			return new KeyValuePair("natureWatsonListType", "at-least-one-incident-nature-is-required");
		}

		for (WatsonListTypeRel watsonListTypeRel : natures) {
			if (!newIncident && (watsonListTypeRel.getClassPK() <= 0)) {
				return new KeyValuePair("natureWatsonListType", "the-incident-natures-were-invalid");
			}

			if (Validator.isNull(watsonListTypeRel.getType())) {
				return new KeyValuePair("natureWatsonListType", "the-incident-natures-were-invalid");
			}

			if (watsonListTypeRel.getWatsonListTypeId() <= 0) {
				return new KeyValuePair("natureWatsonListType", "the-incident-natures-were-invalid");
			}

			if (WatsonListType.fetch(watsonListTypeRel.getWatsonListTypeId()) == null) {
				return new KeyValuePair("natureWatsonListType", "the-incident-natures-were-invalid");
			}
		}

		return null;
	}

	public static KeyValuePair validateWatsonIncidentOccurrenceDates(Date startDate, Date endDate) {
		if (startDate == null) {
			return new KeyValuePair("startDate", "the-start-date-is-invalid");
		}

		if (startDate.after(new Date())) {
			return new KeyValuePair("startDate", "the-start-date-cannot-be-in-the-future");
		}

		if (startDate.before(new Date(0))) {
			return new KeyValuePair("startDate", "the-start-date-is-too-long-ago");
		}

		if (endDate != null) {
			if (startDate.after(endDate)) {
				return new KeyValuePair("startDate", "the-start-date-cannot-be-after-the-end-date");
			}

			if (endDate.after(new Date())) {
				return new KeyValuePair("endDate", "the-end-date-cannot-be-in-the-future");
			}

			if (endDate.before(new Date(0))) {
				return new KeyValuePair("endDate", "the-end-date-is-too-long-ago");
			}
		}

		return null;
	}

	public static KeyValuePair validateWatsonIncidentReportDate(Date reportDate) {
		if (reportDate == null) {
			return new KeyValuePair("reportDate", "the-report-date-is-invalid");
		}

		if (reportDate.after(new Date())) {
			return new KeyValuePair("reportDate", "the-report-date-cannot-be-in-the-future");
		}

		if (reportDate.before(new Date(0))) {
			return new KeyValuePair("reportDate", "the-report-date-is-too-long-ago");
		}

		return null;
	}

	public static KeyValuePair validateWatsonIncidentSource(long sourceWatsonListTypeId) throws Exception {
		if (sourceWatsonListTypeId <= 0) {
			return new KeyValuePair("sourceWatsonListTypeId", "the-incident-source-is-invalid");
		}

		if (WatsonListType.fetch(sourceWatsonListTypeId) == null) {
			return new KeyValuePair("sourceWatsonListTypeId", "the-incident-source-is-invalid");
		}

		return null;
	}

	public static KeyValuePair validateWatsonIncidentType(long typeWatsonListTypeId) throws Exception {
		if (typeWatsonListTypeId <= 0) {
			return new KeyValuePair("typeWatsonListTypeId", "the-report-type-is-invalid");
		}

		if (WatsonListType.fetch(typeWatsonListTypeId) == null) {
			return new KeyValuePair("typeWatsonListTypeId", "the-report-type-is-invalid");
		}

		return null;
	}

	public static KeyValuePair validateWatsonIncidentSubtype(long subtypeWatsonListTypeId) throws Exception {
		if (subtypeWatsonListTypeId <= 0) {
			return new KeyValuePair("subtypeWatsonListTypeId", "the-report-type-is-invalid");
		}

		if (WatsonListType.fetch(subtypeWatsonListTypeId) == null) {
			return new KeyValuePair("subtypeWatsonListTypeId", "the-report-type-is-invalid");
		}

		return null;
	}

	public static KeyValuePair validateWatsonIncidentRels(List<WatsonIncidentRel> watsonIncidentRels) throws Exception{
		if (Validator.isNotNull(watsonIncidentRels)) {
			for (WatsonIncidentRel watsonIncidentRel : watsonIncidentRels) {
				if (!watsonIncidentRel.isValid()) {
					return new KeyValuePair("watsonIncidentRels", "the-relationships-were-invalid");
				}
			}
		}

		return null;
	}

	public static WatsonIncident queryFirst(Object... properties) throws Exception {
		List<WatsonIncident> watsonIncidents = WatsonIncident.query(properties);

		if (watsonIncidents.size() > 0) {
			return watsonIncidents.get(0);
		}

		return null;
	}

	public WatsonIncident add() throws Exception {
		Calendar calendar = CalendarFactoryUtil.getCalendar();

		String year = String.valueOf(calendar.get(Calendar.YEAR));

		setName(year + StringPool.DASH + _increment(year));

		return add(this);
	}

	public WatsonIncident updateTranslations(HttpServletRequest request, Locale locale) throws Exception {
		BaseAlloyControllerImpl.setLocalizedProperties(this, request, locale);

		return update(this);
	}

	public JSONObject getIncidentFormErrors() {
		JSONObject jsonObject = JSONFactoryUtil.createJSONObject();

		for (Map.Entry<String, String> errorEntry : errors.entrySet()) {
			jsonObject.put(errorEntry.getKey(), LanguageUtil.format(LocaleUtil.getMostRelevantLocale(), errorEntry.getValue(), new Object[0]));
		}

		return jsonObject;
	}

	public boolean isValid(List<WatsonListTypeRel> natures, List<WatsonIncidentRel> watsonIncidentRels) throws Exception {
		pushError(validateWatsonIncidentDescription(getDescription()));
		pushError(validateWatsonIncidentIncidentStatus(getIncidentStatus()));
		pushError(validateWatsonIncidentNatures(natures, this.isNew()));
		pushError(validateWatsonIncidentOccurrenceDates(getStartDate(), getEndDate()));
		pushError(validateWatsonIncidentReportDate(getReportDate()));
		pushError(validateWatsonIncidentSource(getSourceWatsonListTypeId()));
		pushError(validateWatsonIncidentType(getTypeWatsonListTypeId()));
		pushError(validateWatsonIncidentSubtype(getSubtypeWatsonListTypeId()));
		pushError(validateWatsonIncidentRels(watsonIncidentRels));

		return errors.isEmpty();
	}

	public void pushError(KeyValuePair keyValuePair) {
		if (keyValuePair != null) {
			errors.put(keyValuePair.getKey(), keyValuePair.getValue());
		}
	}

	protected HashMap<String, String> errors = new HashMap<>();

	private static long _increment(String year) throws Exception {
		return CounterLocalServiceUtil.increment(getBaseModelClass().getName() + StringPool.POUND + year);
	}

}
%>