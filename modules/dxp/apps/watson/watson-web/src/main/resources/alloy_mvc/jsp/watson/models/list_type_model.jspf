	public static final long CHILD_CITIZENSHIP_TYPE_UNKNOWN = 10580;

	public static final long DOCUMENT_TYPE_HOUSE_REGISTRATION = 10529;

	public static final long DOCUMENT_TYPE_RELATIVE_TYPE_OTHER = 10543;

