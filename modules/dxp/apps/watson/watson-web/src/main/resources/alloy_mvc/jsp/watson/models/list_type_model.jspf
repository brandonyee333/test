	public WatsonListType() {
		super(new WatsonListTypeImpl());
	}

	public WatsonListType(com.liferay.watson.model.WatsonListType watsonListType) {
		super(watsonListType);
	}

	public WatsonListType(WatsonListType watsonListType) {
		super(watsonListType);
	}

	public WatsonListType(WatsonListTypeBaseModel watsonListType) {
		super(watsonListType);
	}

	public static final long ACTIVITY_RESOURCE_RELATIONSHIP_TYPE = 10481;

	public static final long ACTIVITY_TYPE_COURT_PROCEEDING = 10476;

	public static final long ACTIVITY_TYPE_INITIAL_REPORT = 1;

	public static final long ACTIVITY_TYPE_INTERVIEW = 2;

	public static final long ADDRESS_TYPE_LAST_SEEN = 9367;

	public static final long ADDRESS_TYPE_OTHER = 10578;

	public static final long CHILD_SOURCE_TYPE_OTHER = 10501;

	public static final long CHILD_CITIZENSHIP_TYPE_IN_PROGRESS = 10581;

