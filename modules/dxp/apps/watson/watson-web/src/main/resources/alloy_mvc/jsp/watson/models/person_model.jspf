	public static KeyValuePair validateWatsonPersonSex(long watsonListTypeId) throws Exception {
		if (WatsonListType.fetch(watsonListTypeId) == null) {
			return new KeyValuePair("sexWatsonListTypeId", "the-sex-is-invalid");
		}

		return null;
	}

	public static KeyValuePair validateWatsonPersonRelationships(List<WatsonRelationship> watsonRelationships) throws Exception{
		if (Validator.isNotNull(watsonRelationships)) {
			for (WatsonRelationship watsonRelationship : watsonRelationships) {
				if (!watsonRelationship.isValid()) {
					return new KeyValuePair("watsonRelationships", "the-relationships-were-invalid");
				}
			}
		}

		return null;
	}

	public String getNamesString() throws Exception {
		return WatsonListTypeRel.getRelValueString(getNames(getWatsonPersonId()), LocaleUtil.getMostRelevantLocale());
	}

	public JSONObject getPersonFormErrors() {
		JSONObject jsonObject = JSONFactoryUtil.createJSONObject();

		for (Map.Entry<String, String> errorEntry : errors.entrySet()) {
			jsonObject.put(errorEntry.getKey(), LanguageUtil.format(LocaleUtil.getMostRelevantLocale(), errorEntry.getValue(), new Object[0]));
		}

		return jsonObject;
	}

	public String getPrimaryName() throws Exception {
		String secondaryName = StringPool.BLANK;

		List<WatsonListTypeRel> names = getNames(getWatsonPersonId());

		if (names.size() > 0) {
			for (WatsonListTypeRel name : names) {
				if (name.getPrimary()) {
					return name.getValue();
				}
				else {
					secondaryName = name.getValue();
				}
			}
		}

		return secondaryName;
	}

	public boolean isValid(List<WatsonListTypeRel> countryIDWatsonListTypeRels, List<WatsonListTypeRel> nameWatsonListTypeRels, List<WatsonListTypeRel> phoneNumberWatsonListTypeRels, List<WatsonListTypeRel> socialMediaAccountWatsonListTypeRels, List<WatsonRelationship> watsonRelationships) throws Exception {
		pushError(validateWatsonPersonAgeRange(getStartAge(), getEndAge()));
		pushError(validateWatsonPersonBirthCountry(getBirthCountryId()));
		pushError(validateWatsonPersonCountry(getCountryWatsonListTypeId()));
		pushError(validateWatsonPersonCountryIDs(countryIDWatsonListTypeRels));
		pushError(validateWatsonPersonEthnicity(getEthnicityWatsonListTypeId()));
		pushError(validateWatsonPersonEyes(getEyesWatsonListTypeId()));
		pushError(validateWatsonPersonHair(getHairWatsonListTypeId()));
		pushError(validateWatsonPersonType(getTypeWatsonListTypeId()));
		pushError(validateWatsonPersonNames(nameWatsonListTypeRels));
		pushError(validateWatsonPersonPhoneNumbers(phoneNumberWatsonListTypeRels));
		pushError(validateWatsonPersonSocialMediaAccounts(socialMediaAccountWatsonListTypeRels));
		pushError(validateWatsonPersonSex(getSexWatsonListTypeId()));
		pushError(validateWatsonPersonRelationships(watsonRelationships));

		return errors.isEmpty();
	}

	public void pushError(KeyValuePair keyValuePair) {
		if (keyValuePair != null) {
			errors.put(keyValuePair.getKey(), keyValuePair.getValue());
		}
	}

	public WatsonPerson updateTranslations(HttpServletRequest request, Locale locale) throws Exception {
		BaseAlloyControllerImpl.setLocalizedProperties(this, request, locale);

		return update(this);
	}

	private static List<WatsonListTypeRel> getRels(long watsonPersonId, String type) throws Exception {
		String listTypeString = getBaseModelClass().getName() + StringPool.PERIOD + type + "Type";

		return WatsonListTypeRel.query("classPK", watsonPersonId, "type", listTypeString);
	}

	private static JSONArray populateJSONArrayWithRels(List<WatsonListTypeRel> watsonListTypeRels, Locale locale) throws Exception {
		JSONArray jsonArray = JSONFactoryUtil.createJSONArray();

		for (WatsonListTypeRel watsonListTypeRel : watsonListTypeRels) {
			JSONObject listTypeRelJSONObject = JSONFactoryUtil.createJSONObject();

			WatsonListType watsonListType = WatsonListType.fetch(watsonListTypeRel.getWatsonListTypeId());

			if (watsonListType != null) {
				listTypeRelJSONObject.put("label", watsonListType.getName(locale));
			}

			listTypeRelJSONObject.put("primary", watsonListTypeRel.getPrimary());

			listTypeRelJSONObject.put("value", watsonListTypeRel.getValue(locale));

			listTypeRelJSONObject.put("watsonListTypeId", watsonListTypeRel.getWatsonListTypeId());

			listTypeRelJSONObject.put("watsonListTypeRelId", watsonListTypeRel.getWatsonListTypeRelId());

			jsonArray.put(listTypeRelJSONObject);
		}

		return jsonArray;
	}

	private static JSONObject pushRelData(JSONObject jsonObject, long watsonPersonId, String watsonListTypeRelType, Locale locale) throws Exception {
		List<WatsonListTypeRel> watsonListTypeRels = getRels(watsonPersonId, watsonListTypeRelType);

		return pushRelData(jsonObject, watsonListTypeRels, watsonListTypeRelType, locale);
	}

	private static JSONObject pushRelData(JSONObject jsonObject, List<WatsonListTypeRel> watsonListTypeRels, String watsonListTypeRelType, Locale locale) throws Exception {
		jsonObject.put(watsonListTypeRelType.concat("WatsonListTypeRels"), populateJSONArrayWithRels(watsonListTypeRels, locale));

		jsonObject.put(watsonListTypeRelType.concat("WatsonListTypeRelString"), WatsonListTypeRel.getRelValueString(watsonListTypeRels, locale));

		return jsonObject;
	}

	public static List<Long> getOriginalWatsonPersonIds(long watsonIncidentId) throws Exception {
		DynamicQuery watsonPersonIdsDynamicQuery = baseModelAlloyServiceInvoker.buildDynamicQuery(new Object[] {"watsonIncidentId", watsonIncidentId});

		Projection originalWatsonPersonIdProjection = ProjectionFactoryUtil.property("originalWatsonPersonId");

		watsonPersonIdsDynamicQuery.setProjection(ProjectionFactoryUtil.distinct(originalWatsonPersonIdProjection));

		return baseModelAlloyServiceInvoker.executeDynamicQuery(watsonPersonIdsDynamicQuery);
	}

	public static List<WatsonPerson> getUnrelatedWatsonPeople(long watsonIncidentId, int start, int end) throws Exception {
		List<WatsonPerson> unrelatedWatsonPeople = new ArrayList<>();

		List<Long> currentWatsonPeople = getOriginalWatsonPersonIds(watsonIncidentId);

		DynamicQuery unrelatedPeopleDynamicQuery = baseModelAlloyServiceInvoker.buildDynamicQuery();

		unrelatedPeopleDynamicQuery.add(RestrictionsFactoryUtil.ne("watsonIncidentId", watsonIncidentId));

		List<WatsonPerson> otherWatsonPeople = getAlloyModels(baseModelAlloyServiceInvoker.executeDynamicQuery(unrelatedPeopleDynamicQuery, start, end));

		for (WatsonPerson watsonPerson : otherWatsonPeople) {
			if (!ArrayUtil.contains(currentWatsonPeople.toArray(), watsonPerson.getWatsonPersonId())) {
				unrelatedWatsonPeople.add(watsonPerson);
			}
		}

		return unrelatedWatsonPeople;
	}

	protected HashMap<String, String> errors = new HashMap<>();

}
