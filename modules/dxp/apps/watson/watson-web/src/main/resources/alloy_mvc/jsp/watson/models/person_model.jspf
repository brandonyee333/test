<%!
public static class WatsonPerson extends WatsonPersonBaseModel {

	WatsonPerson() {
		super(new com.liferay.watson.model.impl.WatsonPersonImpl());
	}

	WatsonPerson(com.liferay.watson.model.WatsonPerson watsonPerson) {
		super(watsonPerson);
	}

	WatsonPerson(WatsonPerson watsonPerson) {
		super(watsonPerson);
	}

	WatsonPerson(WatsonPersonBaseModel watsonPerson) {
		super(watsonPerson);
	}

	public static JSONObject getAsJSONDataArray(List<WatsonPerson> watsonPeople, long count) throws Exception {
		JSONObject returnJSONObject = JSONFactoryUtil.createJSONObject();

		JSONArray watsonPeopleJSONArray = JSONFactoryUtil.createJSONArray();

		for (WatsonPerson watsonPerson : watsonPeople) {
			watsonPeopleJSONArray.put(getAsJSONObject(watsonPerson));
		}

		returnJSONObject.put("count", count);
		returnJSONObject.put("items", watsonPeopleJSONArray);

		return returnJSONObject;
	}

	public static JSONObject getAsJSONObject(WatsonPerson watsonPerson) throws Exception {
		return getAsJSONObject(watsonPerson, null, null, null, null, null, LocaleUtil.getMostRelevantLocale());
	}

	public static JSONObject getAsJSONObject(WatsonPerson watsonPerson, Locale locale) throws Exception {
		return getAsJSONObject(watsonPerson, null, null, null, null, null, locale);
	}

	public static JSONObject getAsJSONObject(WatsonPerson watsonPerson, List<WatsonListTypeRel> countryIDWatsonListTypeRels, List<WatsonListTypeRel> nameWatsonListTypeRels, List<WatsonListTypeRel> phoneNumberWatsonListTypeRels, List<WatsonListTypeRel> socialMediaAccountWatsonListTypeRels, List<WatsonRelationship> watsonRelationships) throws Exception {
		return getAsJSONObject(watsonPerson, countryIDWatsonListTypeRels, nameWatsonListTypeRels, phoneNumberWatsonListTypeRels, socialMediaAccountWatsonListTypeRels, watsonRelationships, LocaleUtil.getMostRelevantLocale());
	}

	public static JSONObject getAsJSONObject(WatsonPerson watsonPerson, List<WatsonListTypeRel> countryIDWatsonListTypeRels, List<WatsonListTypeRel> nameWatsonListTypeRels, List<WatsonListTypeRel> phoneNumberWatsonListTypeRels, List<WatsonListTypeRel> socialMediaAccountWatsonListTypeRels, List<WatsonRelationship> watsonRelationships, Locale locale) throws Exception {
		JSONObject jsonObject = JSONFactoryUtil.createJSONObject();

		jsonObject.put("accepted", watsonPerson.getAccepted());

		List<WatsonIncident> affiliatedIncidents = getAffiliatedIncidents(watsonPerson);

		jsonObject.put("affiliatedIncidents", affiliatedIncidents.size());
		jsonObject.put("birthCountryId", watsonPerson.getBirthCountryId());
		jsonObject.put("birthDate", getFormattedDate(watsonPerson.getBirthDate(), locale));
		jsonObject.put("citizenshipWatsonListTypeId", watsonPerson.getCitizenshipWatsonListTypeId());

		if (countryIDWatsonListTypeRels != null) {
			pushRelData(jsonObject, countryIDWatsonListTypeRels, "countryID", locale);
		}
		else {
			pushRelData(jsonObject, watsonPerson.getWatsonPersonId(), "countryID", locale);
		}

		jsonObject.put("createDate", getFormattedDate(watsonPerson.getCreateDate(), locale));

		WatsonListType watsonListType = WatsonListType.fetch(watsonPerson.getCountryWatsonListTypeId());

		if (watsonListType != null) {
			jsonObject.put("country", watsonListType.getName(locale));
		}

		jsonObject.put("countryWatsonListTypeId", watsonPerson.getCountryWatsonListTypeId());
		jsonObject.put("dateAccepted", getFormattedDate(watsonPerson.getDateAccepted(), locale));
		jsonObject.put("dateRescued", getFormattedDate(watsonPerson.getDateRescued(), locale));
		jsonObject.put("description", watsonPerson.getDescription(locale));
		jsonObject.put("endAge", watsonPerson.getEndAge());

		watsonListType = WatsonListType.fetch(watsonPerson.getEthnicityWatsonListTypeId());

		if (watsonListType != null) {
			jsonObject.put("ethnicity", watsonListType.getName(locale));
		}

		jsonObject.put("ethnicityWatsonListTypeId", watsonPerson.getEthnicityWatsonListTypeId());

		watsonListType = WatsonListType.fetch(watsonPerson.getEyesWatsonListTypeId());

		if (watsonListType != null) {
			jsonObject.put("eyes", watsonListType.getName(locale));
		}

		jsonObject.put("eyesWatsonListTypeId", watsonPerson.getEyesWatsonListTypeId());

		watsonListType = WatsonListType.fetch(watsonPerson.getHairWatsonListTypeId());

		if (watsonListType != null) {
			jsonObject.put("hair", watsonListType.getName(locale));
		}

		jsonObject.put("hairWatsonListTypeId", watsonPerson.getHairWatsonListTypeId());
		jsonObject.put("height", watsonPerson.getHeight());
		jsonObject.put("id", watsonPerson.getPrimaryKey());
		jsonObject.put("imagePayload", JSONFactoryUtil.createJSONObject(watsonPerson.getImagePayload()));
		jsonObject.put("incidentName", WatsonIncident.getIncidentName(watsonPerson.getWatsonIncidentId()));

		Date modifiedDate = watsonPerson.getModifiedDate();

		jsonObject.put("modifiedDate", getFormattedDate(modifiedDate, locale));
		jsonObject.put("modifiedDateTimeStamp", modifiedDate.getTime());
		jsonObject.put("modifiedUserName", WatsonHistory.fetchLastModifiedUserName(watsonPerson));
		jsonObject.put("name", watsonPerson.getPrimaryName());

		if (nameWatsonListTypeRels != null) {
			pushRelData(jsonObject, nameWatsonListTypeRels, "name", locale);
		}
		else {
			pushRelData(jsonObject, watsonPerson.getWatsonPersonId(), "name", locale);
		}

		jsonObject.put("occupation", watsonPerson.getOccupation(locale));

		if (phoneNumberWatsonListTypeRels != null) {
			pushRelData(jsonObject, phoneNumberWatsonListTypeRels, "phoneNumber", locale);
		}
		else {
			pushRelData(jsonObject, watsonPerson.getWatsonPersonId(), "phoneNumber", locale);
		}

		jsonObject.put("primaryNameString", watsonPerson.getPrimaryName());
		jsonObject.put("reportDate", getFormattedDate(watsonPerson.getCreateDate(), locale));
		jsonObject.put("reportedBy", watsonPerson.getUserName());
		jsonObject.put("rescued", watsonPerson.getRescued());

		watsonListType = WatsonListType.fetch(watsonPerson.getSexWatsonListTypeId());

		if (watsonListType != null) {
			jsonObject.put("sex", watsonListType.getName(locale));
		}

		jsonObject.put("sexWatsonListTypeId", watsonPerson.getSexWatsonListTypeId());

		if (socialMediaAccountWatsonListTypeRels != null) {
			pushRelData(jsonObject, socialMediaAccountWatsonListTypeRels, "socialMediaAccount", locale);
		}
		else {
			pushRelData(jsonObject, watsonPerson.getWatsonPersonId(), "socialMediaAccount", locale);
		}

		jsonObject.put("startAge", watsonPerson.getStartAge());

		watsonListType = WatsonListType.fetch(watsonPerson.getTypeWatsonListTypeId());

		if (watsonListType != null) {
			jsonObject.put("type", watsonListType.getName(locale));
		}

		jsonObject.put("typeWatsonListTypeId", watsonPerson.getTypeWatsonListTypeId());
		jsonObject.put("watsonIncidentId", watsonPerson.getWatsonIncidentId());
		jsonObject.put("watsonPersonId", watsonPerson.getWatsonPersonId());

		if (Validator.isNotNull(watsonRelationships)) {
			jsonObject.put("watsonRelationships", WatsonRelationship.getWatsonRelationshipsAsJSONArray(watsonPerson.getWatsonPersonId(), watsonRelationships));
		}
		else {
			jsonObject.put("watsonRelationships", WatsonRelationship.getWatsonRelationshipsAsJSONArray(watsonPerson));
		}

		jsonObject.put("weight", watsonPerson.getWeight());

		return jsonObject;
	}

	public static JSONObject getMetricsArray(String field, String dateField) throws Exception {
		JSONObject formattedJSONObject = JSONFactoryUtil.createJSONObject();

		long[] yearsArray = {};
		long[] dataArray = {};

		for (int year = 2010; year <= 2018; year++) {
			DynamicQuery personDynamicQuery = baseModelAlloyServiceInvoker.buildDynamicQuery(new Object[] {"status", WorkflowConstants.STATUS_APPROVED, field, true});

			Calendar calendar = Calendar.getInstance();

			calendar.set(Calendar.YEAR, year);
			calendar.set(Calendar.DAY_OF_YEAR, 1);

			Date startDate = calendar.getTime();

			calendar.set(Calendar.MONTH, 11);
			calendar.set(Calendar.DAY_OF_MONTH, 31);

			Date endDate = calendar.getTime();

			personDynamicQuery.add(RestrictionsFactoryUtil.between(dateField, startDate, endDate));

			dataArray = ArrayUtil.append(dataArray, baseModelAlloyServiceInvoker.executeDynamicQueryCount(personDynamicQuery));
			yearsArray = ArrayUtil.append(yearsArray, year);
		}

		formattedJSONObject.put(field, LanguageUtil.format(LocaleUtil.getMostRelevantLocale(), field, new String[0]));
		formattedJSONObject.put("key", field);
		formattedJSONObject.put("values", dataArray);
		formattedJSONObject.put("year", yearsArray);

		return formattedJSONObject;
	}

	public static String getFormattedDate(Date date, Locale locale) {
		if (date != null) {
			return DateUtil.getDate(date, "yyyy-MM-dd", locale);
		}
		else {
			return StringPool.BLANK;
		}
	}

	public static JSONArray getIdJSONArray(long watsonIncidentId) throws Exception {
		JSONArray jsonArray = JSONFactoryUtil.createJSONArray();

		List<WatsonPerson> watsonPeople = query("watsonIncidentId", watsonIncidentId);

		for (WatsonPerson watsonPerson : watsonPeople) {
			JSONObject jsonObject = JSONFactoryUtil.createJSONObject();

			jsonObject.put("id", watsonPerson.getWatsonPersonId());
			jsonObject.put("name", watsonPerson.getPrimaryName());

			jsonArray.put(jsonObject);
		}

		return jsonArray;
	}

	public static JSONArray getIdJSONArray(List<WatsonPerson> watsonPeople) throws Exception {
		JSONArray jsonArray = JSONFactoryUtil.createJSONArray();

		for (WatsonPerson watsonPerson : watsonPeople) {
			JSONObject jsonObject = JSONFactoryUtil.createJSONObject();

			jsonObject.put("id", watsonPerson.getWatsonPersonId());
			jsonObject.put("name", watsonPerson.getPrimaryName());
			jsonObject.put("watsonIncidentId", watsonPerson.getWatsonIncidentId());

			jsonArray.put(jsonObject);
		}

		return jsonArray;
	}

	public static List<WatsonListTypeRel> getCountryIds(long watsonPersonId) throws Exception {
		return getRels(watsonPersonId, "countryID");
	}

	public static List<WatsonListTypeRel> getNames(long watsonPersonId) throws Exception {
		return getRels(watsonPersonId, "name");
	}

	public static List<WatsonListTypeRel> getPhoneNumbers(long watsonPersonId) throws Exception {
		return getRels(watsonPersonId, "phoneNumber");
	}

	public static List<WatsonListTypeRel> getSocialMediaAccounts(long watsonPersonId) throws Exception {
		return getRels(watsonPersonId, "socialMediaAccount");
	}

	public static List<WatsonIncident> getAffiliatedIncidents(WatsonPerson watsonPerson) throws Exception {
		List<WatsonIncident> affiliatedIncidents = new ArrayList<>();

		long originalWatsonPersonId = watsonPerson.getOriginalWatsonPersonId();

		if (originalWatsonPersonId > 0) {
			List<WatsonPerson> watsonPeople = query("originalWatsonPersonId", originalWatsonPersonId);

			Set<Long> addedWatsonIncidentIds = new HashSet<>();

			for (WatsonPerson currentWatsonPerson : watsonPeople) {
				long watsonIncidentId = currentWatsonPerson.getWatsonIncidentId();

				if ((watsonIncidentId > 0) && !addedWatsonIncidentIds.contains(watsonIncidentId)) {
					affiliatedIncidents.add(WatsonIncident.fetch(currentWatsonPerson.getWatsonIncidentId()));

					addedWatsonIncidentIds.add(watsonIncidentId);
				}
			}
		}

		return affiliatedIncidents;
	}

	public static KeyValuePair validateWatsonPersonAgeRange(String startAge, String endAge) {
		if (!Validator.isNull(startAge) && !Validator.isNull(endAge)) {
			long endAgeLong = GetterUtil.getLong(endAge);

			if ((endAgeLong > 0) && (GetterUtil.getLong(startAge) > endAgeLong)) {
				return new KeyValuePair("startAge", "the-start-age-cannot-be-greater-than-the-end-age");
			}
		}

		return null;
	}

	public static KeyValuePair validateWatsonPersonBirthCountry(long countryId) throws Exception {
		if ((countryId != 0) && (CountryServiceUtil.fetchCountry(countryId) == null)) {
			return new KeyValuePair("countryWatsonListTypeId", "the-country-is-invalid");
		}

		return null;
	}

	public static KeyValuePair validateWatsonPersonCountry(long watsonListTypeId) throws Exception {
		if (WatsonListType.fetch(watsonListTypeId) == null) {
			return new KeyValuePair("countryWatsonListTypeId", "the-country-is-invalid");
		}

		return null;
	}

	public static KeyValuePair validateWatsonPersonCountryIDs(List<WatsonListTypeRel> watsonListTypeRels) throws Exception {
		for (WatsonListTypeRel watsonListTypeRel : watsonListTypeRels) {
			if (WatsonListType.fetch(watsonListTypeRel.getWatsonListTypeId()) == null) {
				return new KeyValuePair("countryIDWatsonListTypeRels", "the-country-id-type-is-invalid");
			}

			if (Validator.isNull(watsonListTypeRel.getValue())) {
				return new KeyValuePair("countryIDWatsonListTypeRels", "the-country-id-cannot-be-blank");
			}
		}

		return null;
	}

	public static KeyValuePair validateWatsonPersonEthnicity(long watsonListTypeId) throws Exception {
		if ((watsonListTypeId != 0) && (WatsonListType.fetch(watsonListTypeId) == null)) {
			return new KeyValuePair("ethnicityWatsonListTypeId", "the-ethnicity-is-invalid");
		}

		return null;
	}

	public static KeyValuePair validateWatsonPersonEyes(long watsonListTypeId) throws Exception {
		if ((watsonListTypeId != 0) && (WatsonListType.fetch(watsonListTypeId) == null)) {
			return new KeyValuePair("eyesWatsonListTypeId", "the-eye-color-is-invalid");
		}

		return null;
	}

	public static KeyValuePair validateWatsonPersonHair(long watsonListTypeId) throws Exception {
		if ((watsonListTypeId != 0) && (WatsonListType.fetch(watsonListTypeId) == null)) {
			return new KeyValuePair("hairWatsonListTypeId", "the-hair-color-is-invalid");
		}

		return null;
	}

	public static KeyValuePair validateWatsonPersonType(long typeWatsonListTypeId) throws Exception {
		if (typeWatsonListTypeId <= 0) {
			return new KeyValuePair("typeWatsonListTypeId", "the-person-involvement-is-invalid");
		}

		if (WatsonListType.fetch(typeWatsonListTypeId) == null) {
			return new KeyValuePair("typeWatsonListTypeId", "the-person-involvement-is-invalid");
		}

		return null;
	}

	public static KeyValuePair validateWatsonPersonNames(List<WatsonListTypeRel> watsonListTypeRels) throws Exception {
		if (watsonListTypeRels.isEmpty()) {
			return new KeyValuePair("nameWatsonListTypeRels", "at-least-one-person-name-is-required");
		}

		boolean hasPrimary = false;

		for (WatsonListTypeRel watsonListTypeRel : watsonListTypeRels) {
			if (WatsonListType.fetch(watsonListTypeRel.getWatsonListTypeId()) == null) {
				return new KeyValuePair("nameWatsonListTypeRels", "the-name-type-is-invalid");
			}

			if (Validator.isNull(watsonListTypeRel.getValue())) {
				return new KeyValuePair("nameWatsonListTypeRels", "a-name-cannot-be-blank");
			}

			if (watsonListTypeRel.getPrimary()) {
				if (hasPrimary) {
					return new KeyValuePair("nameWatsonListTypeRels", "there-can-be-only-one-primary-name");
				}
				else {
					hasPrimary = true;
				}
			}
		}

		if (!hasPrimary) {
			return new KeyValuePair("nameWatsonListTypeRels", "there-must-be-a-primary-name");
		}

		return null;
	}

