	public static WatsonListType add(WatsonListType watsonListType, HttpServletRequest request, boolean ignoreRequest) throws Exception {
		if ((request != null) && !ignoreRequest) {
			BeanPropertiesUtil.setProperties(watsonListType, request, watsonListType.getLocalizedProperties());

			BaseAlloyControllerImpl.setLocalizedProperties(watsonListType, request, request.getLocale());
		}

		BaseAlloyControllerImpl.setAuditedModel(watsonListType, request);

		validateAdd(watsonListType);

		watsonListType.setStatus(WorkflowConstants.STATUS_APPROVED);

		if (watsonListType.getWatsonListTypeId() <= 0) {
			long watsonListTypeId = CounterLocalServiceUtil.increment();

			watsonListType.setWatsonListTypeId(watsonListTypeId);
		}

		return new WatsonListType((com.liferay.watson.model.WatsonListType)baseModelAlloyServiceInvoker.addModel(watsonListType));
	}

	public static List<WatsonListType> batchAdd(List<WatsonListType> watsonListTypes) throws Exception {
		List<WatsonListType> resultWatsonListTypes = new ArrayList<>();

		for (WatsonListType watsonListType : watsonListTypes) {
			long watsonListTypeId = watsonListType.getWatsonListTypeId();

			if (watsonListTypeId > 0) {
				resultWatsonListTypes.add(add(watsonListType));
			}
			else {
				watsonListTypeId = CounterLocalServiceUtil.increment();

				watsonListType.setWatsonListTypeId(watsonListTypeId);

				resultWatsonListTypes.add(add(watsonListType));
			}
		}

		return resultWatsonListTypes;
	}

	public static List<WatsonListType> batchDelete(List<WatsonListType> watsonListTypes) throws Exception {
		List<WatsonListType> resultWatsonListTypes = new ArrayList<>();

		for (WatsonListType watsonListType : watsonListTypes) {
			resultWatsonListTypes.add(delete(watsonListType));
		}

		return resultWatsonListTypes;
	}

	public static List<WatsonListType> batchUpdate(List<WatsonListType> watsonListTypes) throws Exception {
