	public static List<WatsonListType> getAlloyModels(List<com.liferay.watson.model.WatsonListType> watsonListTypes, boolean includeInactive) throws Exception {
		List<WatsonListType> alloyWatsonListTypes = new ArrayList<>();

		for (com.liferay.watson.model.WatsonListType watsonListType : watsonListTypes) {
