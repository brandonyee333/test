--%>

<%
String lcsClusterEntryName = GetterUtil.getString(request.getAttribute(LCSClientWebKeys.LCS_CLUSTER_ENTRY_NAME));
String lcsClusterNodeName = GetterUtil.getString(request.getAttribute(LCSClientWebKeys.LCS_CLUSTER_NODE_NAME));
String lcsProjectName = GetterUtil.getString(request.getAttribute(LCSClientWebKeys.LCS_PROJECT_NAME));
%>

<c:choose>
	<c:when test="<%= Validator.isNull(lcsClusterNodeName) || Validator.isNull(lcsClusterEntryName) %>">
		<c:choose>
			<c:when test='<%= SessionErrors.contains(liferayPortletRequest, "generalPluginAccess") %>'>
				<div class="alert alert-danger">
					<liferay-ui:message key="an-error-occurred-while-accessing-liferay-connected-services" />
				</div>
			</c:when>
			<c:otherwise>
				<div class="alert alert-danger">
					<liferay-ui:message key="this-server-is-no-longer-registered-in-liferay-connected-services" />
				</div>
			</c:otherwise>
		</c:choose>
	</c:when>
	<c:otherwise>
		<c:if test="<%= lcsAlerts.contains(LCSAlert.WARNING_LCS_PORTLET_NEW_VERSION_AVAILABLE) %>">
			<div class="alert alert-warning lcs-alert">
				<liferay-ui:message arguments="<%= LCSInfo.LRDCOM_LCS_CLIENT_DOWNLOAD_URL %>" key="<%= LCSAlert.WARNING_LCS_PORTLET_NEW_VERSION_AVAILABLE.getLabel() %>" />
			</div>
		</c:if>

		<%
		LCSGatewayClient lcsGatewayClient = (LCSGatewayClient)request.getAttribute(LCSGatewayClient.class.getName());

		boolean ready = lcsGatewayClient.isAvailable();

		String connectionStatusCSSClass = "alert-success";
		String connectionStatusLabel = "connected";

		if (!ready) {
			connectionStatusCSSClass = "alert-danger";
			connectionStatusLabel = "disconnected";
		}

		long lastHandshakeSuccess = lcsGatewayClient.getLastHandshakeSuccess();
		%>

		<div class="alert alert-connection <%= connectionStatusCSSClass %>" id="<portlet:namespace />connectionStatus">
			<strong class="lead">
				<liferay-ui:message key="<%= connectionStatusLabel %>" />
			</strong>
		</div>

		<div class="alert alert-danger lcs-alert <%= ready ? "hide" : StringPool.BLANK %>" id="<portlet:namespace />lcsGatewayUnavailable">
			<liferay-ui:message key="unable-to-access-liferay-connected-services-gateway" />
		</div>

		<ul class="list-group">
			<li class="list-group-heading">
				<liferay-ui:message key="connection" />
			</li>
			<li class="list-group-item">
				<aui:row>
					<aui:col width="<%= 50 %>">
						<liferay-ui:message key="connection-uptime" />

						<liferay-ui:icon-help message="connection-uptime-help" />
					</aui:col>

					<aui:col width="<%= 50 %>">
						<div id="<portlet:namespace />duration">
							<c:choose>
								<c:when test="<%= ready && (lastHandshakeSuccess != 0) %>">

									<%
									Date handshakeTimeDate = new Date(System.currentTimeMillis() - GetterUtil.getLong(lastHandshakeSuccess));
									%>

									<%= intervalDateFormatDate.format(handshakeTimeDate) %>
								</c:when>
								<c:otherwise>
									<%= intervalDateFormatDate.format(new Date(0)) %>
								</c:otherwise>
							</c:choose>
						</div>
					</aui:col>
				</aui:row>
			</li>
			<li class="list-group-item">
				<aui:row>
					<aui:col width="<%= 50 %>">
						<liferay-ui:message key="last-message-received" />

						<liferay-ui:icon-help message="last-message-received-help" />
					</aui:col>

					<aui:col width="<%= 50 %>">
						<c:if test="<%= lcsGatewayClient.getLastMessageReceived() != 0 %>">

							<%
							Date messageTaskTimeDate = new Date(lcsGatewayClient.getLastMessageReceived());
							%>

							<%= dateFormatDate.format(messageTaskTimeDate) %>
						</c:if>
					</aui:col>
				</aui:row>
			</li>
		</ul>

		<ul class="list-group">
			<li class="list-group-heading">
				<liferay-ui:message key="services" />
			</li>

			<%
			Set<String> activeServiceLabels = (Set<String>)request.getAttribute(LCSClientWebKeys.LCS_ACTIVE_SERVICES);

			LCSClusterEntryTokenAdvisor lcsClusterEntryTokenAdvisor = (LCSClusterEntryTokenAdvisor)request.getAttribute(LCSClusterEntryTokenAdvisor.class.getName());
			%>

			<%
			for (String activeTaskLabel : activeServiceLabels) {
			%>

				<li class="list-group-item">
					<aui:row>
						<aui:col width="<%= 100 %>">
							<liferay-ui:message key="<%= activeTaskLabel %>" />
						</aui:col>
					</aui:row>
				</li>

				<c:if test='<%= activeTaskLabel.contains("portal-properties") && Validator.isNotNull(lcsClusterEntryTokenAdvisor.getPortalPropertiesBlacklist()) %>'>

					<%
					String portalPropertiesBlacklist = lcsClusterEntryTokenAdvisor.getPortalPropertiesBlacklist();
					%>

					<li class="list-group-item">
						<aui:row>
							<aui:col width="<%= 50 %>">
								<liferay-ui:message key="additional-blacklisted-properties" />
							</aui:col>

							<aui:col width="<%= 50 %>">
								<%= portalPropertiesBlacklist.replaceAll(StringPool.COMMA, "<br />") %>
							</aui:col>
						</aui:row>
					</li>
				</c:if>

			<%
			}
			%>

		</ul>

		<div class="lcs-note">
			<liferay-ui:message arguments="<%= GetterUtil.getString(request.getAttribute(LCSClientWebKeys.REGISTRATION_LAYOUT_URL)) %>" key="to-enable-or-disable-services-you-need-to-regenerate-the-token" />
		</div>

		<ul class="list-group">
			<li class="list-group-heading">
				<liferay-ui:message key="liferay-connected-services-sites" />
			</li>
			<li class="list-group-item">
				<aui:row>
					<aui:col width="<%= 50 %>">
						<liferay-ui:message key="project-home" />
					</aui:col>

					<aui:col width="<%= 50 %>">
						<aui:a href="<%= GetterUtil.getString(request.getAttribute(LCSClientWebKeys.LCS_PROJECT_LAYOUT_URL)) %>" target="_blank">
							<%= HtmlUtil.escape(lcsProjectName) %>
						</aui:a>
					</aui:col>
				</aui:row>
			</li>
			<li class="list-group-item">
				<aui:row>
					<aui:col width="<%= 50 %>">
						<liferay-ui:message key="environment" />
					</aui:col>

					<aui:col width="<%= 50 %>">
						<aui:a href="<%= GetterUtil.getString(request.getAttribute(LCSClientWebKeys.LCS_CLUSTER_ENTRY_LAYOUT_URL)) %>" target="_blank">
							<%= HtmlUtil.escape(lcsClusterEntryName) %>
						</aui:a>
					</aui:col>
				</aui:row>
			</li>
			<li class="list-group-item">
				<aui:row>
					<aui:col width="<%= 50 %>">
						<liferay-ui:message key="server-dashboard" />
					</aui:col>

					<aui:col width="<%= 50 %>">
						<aui:a href="<%= GetterUtil.getString(request.getAttribute(LCSClientWebKeys.LCS_CLUSTER_NODE_LAYOUT_URL)) %>" target="_blank">
							<%= HtmlUtil.escape(lcsClusterNodeName) %>
						</aui:a>
					</aui:col>
				</aui:row>
			</li>
		</ul>

		<%
		List<Map<String, Object>> clusterNodeInfos = (List<Map<String, Object>>)request.getAttribute(LCSClientWebKeys.CLUSTER_NODE_INFOS);
		%>

		<c:if test="<%= !clusterNodeInfos.isEmpty() %>">
			<ul class="list-group">
				<li class="list-group-heading">
					<liferay-ui:message key="cluster" />
				</li>
				<li class="list-group-item">
					<aui:row>
						<aui:col width="<%= 50 %>">
							<liferay-ui:message key="local-server-address" />
						</aui:col>

						<aui:col width="<%= 50 %>">
							<%= GetterUtil.getString(request.getAttribute(LCSClientWebKeys.LOCAL_CLUSTER_NODE_ADDRESS)) %>
						</aui:col>
					</aui:row>
				</li>

				<%
				for (Map<String, Object> clusterNodeInfo : clusterNodeInfos) {
				%>

					<li class="list-group-item">
						<aui:row>
							<aui:col width="<%= 50 %>">
								<liferay-ui:message key="sibling-server-address" />
							</aui:col>

							<aui:col width="<%= 50 %>">
								<div class="cluster-node-key">
									<%= clusterNodeInfo.get("address") %>
								</div>

								<c:if test='<%= !clusterNodeInfo.containsKey("key") %>'>
									<div class="alert alert-danger">
										<liferay-ui:message key="this-cluster-node-does-not-have-liferay-connected-services-client-installed" />
									</div>
								</c:if>
							</aui:col>
						</aui:row>
					</li>

				<%
				}
				%>

			</ul>
		</c:if>

		<aui:script use="lcs">
			var lcsPortlet = new Liferay.Portlet.LCS(
				{
					namespace: '<portlet:namespace />'
				}
			);

			lcsPortlet.initializeConnectionPage(
				{
					connectionStatusURL: '<portlet:resourceURL id="serveConnectionStatus" />',
					handshakeTime: <%= lastHandshakeSuccess %>,
					labels: {
						connected: '<%= UnicodeLanguageUtil.get(request, "connected") %>',
						disconnected: '<%= UnicodeLanguageUtil.get(request, "disconnected") %>',
						unableToDisplayConnectionStatus: '<%= UnicodeLanguageUtil.get(request, "unable-to-display-connection-status") %>'
					},
					lcsConstants: {
						JSON_KEY_RESULT: 'result',
						JSON_VALUE_FAILURE: 'failure'
					},
					ready: <%= ready %>
				}
			);
		</aui:script>
	</c:otherwise>
</c:choose>