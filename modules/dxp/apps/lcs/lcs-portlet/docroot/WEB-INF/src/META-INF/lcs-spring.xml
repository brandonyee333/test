<?xml version="1.0"?>

<beans
	default-destroy-method="destroy"
	default-init-method="afterPropertiesSet"
	xmlns="http://www.springframework.org/schema/beans"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans-3.0.xsd"
>

	<!-- Advisors -->

	<bean class="com.liferay.lcs.advisor.LCSAlertAdvisor" id="com.liferay.lcs.advisor.LCSAlertAdvisor">
		<constructor-arg ref="com.liferay.lcs.platform.gateway.LCSGatewayClient" />
	</bean>
	<bean class="com.liferay.lcs.advisor.LCSClusterEntryTokenAdvisor" id="com.liferay.lcs.advisor.LCSClusterEntryTokenAdvisor" />
	<bean class="com.liferay.lcs.advisor.LCSKeyAdvisor" id="com.liferay.lcs.advisor.LCSKeyAdvisor" />
	<bean class="com.liferay.lcs.advisor.LCSPortletStateAdvisor" id="com.liferay.lcs.advisor.LCSPortletStateAdvisor">
		<property name="LCSKeyAdvisor" ref="com.liferay.lcs.advisor.LCSKeyAdvisor" />
		<property name="LCSSubscriptionEntryClient" ref="com.liferay.lcs.rest.client.internal.LCSSubscriptionEntryClientImpl" />
	</bean>
	<bean class="com.liferay.lcs.task.advisor.TaskAdvisor" id="com.liferay.lcs.task.advisor.TaskAdvisor" />

	<!-- Aggregator -->

	<bean class="com.liferay.lcs.metrics.PortalMetricsAggregator" id="com.liferay.lcs.metrics.PortalMetricsAggregator" />

	<!-- Command -->

	<bean class="com.liferay.lcs.command.CheckHeartbeatCommand" id="com.liferay.lcs.command.CheckHeartbeatCommand">
		<constructor-arg ref="com.liferay.lcs.platform.gateway.LCSGatewayClient" />
		<constructor-arg ref="com.liferay.lcs.advisor.LCSKeyAdvisor" />
	</bean>
	<bean class="com.liferay.lcs.command.DownloadPatchCommand" id="com.liferay.lcs.command.DownloadPatchCommand">
		<constructor-arg ref="com.liferay.lcs.platform.gateway.LCSGatewayClient" />
	</bean>
	<bean class="com.liferay.lcs.command.ExecuteScriptCommand" id="com.liferay.lcs.command.ExecuteScriptCommand">
		<constructor-arg ref="com.liferay.lcs.platform.gateway.LCSGatewayClient" />
	</bean>
	<bean class="com.liferay.lcs.command.MessageBusCommand" id="com.liferay.lcs.command.MessageBusCommand" />
	<bean class="com.liferay.lcs.command.ScheduleMessageListenersCommand" id="com.liferay.lcs.command.ScheduleMessageListenersCommand">
		<constructor-arg ref="com.liferay.lcs.messaging.advisor.MessageBusListenerAdvisor" />
	</bean>
	<bean class="com.liferay.lcs.command.ScheduleTasksCommand" id="com.liferay.lcs.command.ScheduleTasksCommand">
		<property name="taskSchedulerService" ref="com.liferay.lcs.scheduler.TaskSchedulerService" />
	</bean>
	<bean class="com.liferay.lcs.command.SendInstallationEnvironmentCommand" id="com.liferay.lcs.command.SendInstallationEnvironmentCommand">
		<constructor-arg ref="com.liferay.lcs.platform.gateway.LCSGatewayClient" />
	</bean>
	<bean class="com.liferay.lcs.command.SendPatchesCommand" id="com.liferay.lcs.command.SendPatchesCommand">
		<constructor-arg ref="com.liferay.lcs.platform.gateway.LCSGatewayClient" />
		<constructor-arg ref="com.liferay.lcs.task.advisor.TaskAdvisor" />
	</bean>
	<bean class="com.liferay.lcs.command.SendPortalPropertiesCommand" id="com.liferay.lcs.command.SendPortalPropertiesCommand">
		<constructor-arg ref="com.liferay.lcs.advisor.LCSClusterEntryTokenAdvisor" />
		<constructor-arg ref="com.liferay.lcs.platform.gateway.LCSGatewayClient" />
		<constructor-arg ref="com.liferay.lcs.task.advisor.TaskAdvisor" />
	</bean>
	<bean class="com.liferay.lcs.command.SignOffCommand" id="com.liferay.lcs.command.SignOffCommand">
		<constructor-arg ref="com.liferay.lcs.advisor.LCSClusterEntryTokenAdvisor" />
		<constructor-arg ref="com.liferay.lcs.scheduler.TaskSchedulerService" />
		<constructor-arg ref="com.liferay.lcs.advisor.UptimeAdvisor" />
	</bean>

	<!-- JSON -->

	<bean class="com.liferay.lcs.jsonwebserviceclient.OAuthJSONWebServiceClientImpl" id="osbLCSPortletJSONWebServiceClient">
		<property name="hostName" value="#{T(com.liferay.lcs.util.SystemEnvironmentUtil).getValue(T(com.liferay.lcs.util.SystemEnvironmentUtil).OSB_LCS_PORTLET_HOST_NAME, T(com.liferay.lcs.util.PortletPropsValues).OSB_LCS_PORTLET_HOST_NAME)}" />
		<property name="hostPort" value="#{T(com.liferay.lcs.util.SystemEnvironmentUtil).getValue(T(com.liferay.lcs.util.SystemEnvironmentUtil).OSB_LCS_PORTLET_HOST_PORT, T(com.liferay.lcs.util.PortletPropsValues).OSB_LCS_PORTLET_HOST_PORT)}" />
		<property name="keyStore">
			<bean class="com.liferay.lcs.security.KeyStoreFactory" factory-method="getInstance">
				<constructor-arg type="java.lang.String" value="#{T(com.liferay.lcs.util.PortletPropsValues).OSB_LCS_PORTLET_KEY_STORE_PATH}" />
				<constructor-arg type="java.lang.String" value="#{T(com.liferay.lcs.util.PortletPropsValues).OSB_LCS_PORTLET_KEY_STORE_TYPE}" />
			</bean>
		</property>
		<property name="protocol" value="#{T(com.liferay.lcs.util.SystemEnvironmentUtil).getValue(T(com.liferay.lcs.util.SystemEnvironmentUtil).OSB_LCS_PORTLET_PROTOCOL, T(com.liferay.lcs.util.PortletPropsValues).OSB_LCS_PORTLET_PROTOCOL)}" />
		<property name="proxyAuthType" value="#{T(com.liferay.lcs.util.ProxyHostUtil).getProxyAuthType()}" />
		<property name="proxyDomain" value="#{T(com.liferay.lcs.util.ProxyHostUtil).getProxyDomain()}" />
		<property name="proxyHostName" value="#{T(com.liferay.lcs.util.ProxyHostUtil).getProxyHostName()}" />
		<property name="proxyHostPort" value="#{T(com.liferay.lcs.util.ProxyHostUtil).getProxyHostPort()}" />
		<property name="proxyLogin" value="#{T(com.liferay.lcs.util.ProxyHostUtil).getProxyHostLogin()}" />
		<property name="proxyPassword" value="#{T(com.liferay.lcs.util.ProxyHostUtil).getProxyHostPassword()}" />
		<property name="proxyWorkstation" value="#{T(com.liferay.lcs.util.ProxyHostUtil).getProxyWorkstation()}" />
	</bean>
	<bean class="com.liferay.petra.json.web.service.client.internal.JSONWebServiceClientImpl" id="osbLCSGatewayWebJSONWebServiceClient">
		<property name="headers">
			<map>
				<entry key="OSB_LCS_API_Token" value="#{T(com.liferay.lcs.util.PortletPropsValues).OSB_LCS_GATEWAY_WEB_SECURE_API_TOKEN}" />
			</map>
		</property>
		<property name="hostName" value="#{T(com.liferay.lcs.util.SystemEnvironmentUtil).getValue(T(com.liferay.lcs.util.SystemEnvironmentUtil).OSB_LCS_GATEWAY_WEB_HOST_NAME, T(com.liferay.lcs.util.PortletPropsValues).OSB_LCS_GATEWAY_WEB_HOST_NAME)}" />
		<property name="hostPort" value="#{T(com.liferay.lcs.util.SystemEnvironmentUtil).getValue(T(com.liferay.lcs.util.SystemEnvironmentUtil).OSB_LCS_GATEWAY_WEB_HOST_PORT, T(com.liferay.lcs.util.PortletPropsValues).OSB_LCS_GATEWAY_WEB_HOST_PORT)}" />
		<property name="keyStore">
			<bean class="com.liferay.lcs.security.KeyStoreFactory" factory-method="getInstance">
				<constructor-arg type="java.lang.String" value="#{T(com.liferay.lcs.util.PortletPropsValues).OSB_LCS_GATEWAY_WEB_KEY_STORE_PATH}" />
				<constructor-arg type="java.lang.String" value="#{T(com.liferay.lcs.util.PortletPropsValues).OSB_LCS_GATEWAY_WEB_KEY_STORE_TYPE}" />
			</bean>
		</property>
		<property name="protocol" value="#{T(com.liferay.lcs.util.SystemEnvironmentUtil).getValue(T(com.liferay.lcs.util.SystemEnvironmentUtil).OSB_LCS_GATEWAY_WEB_PROTOCOL, T(com.liferay.lcs.util.PortletPropsValues).OSB_LCS_GATEWAY_WEB_PROTOCOL)}" />
		<property name="proxyAuthType" value="#{T(com.liferay.lcs.util.ProxyHostUtil).getProxyAuthType()}" />
		<property name="proxyDomain" value="#{T(com.liferay.lcs.util.ProxyHostUtil).getProxyDomain()}" />
		<property name="proxyHostName" value="#{T(com.liferay.lcs.util.ProxyHostUtil).getProxyHostName()}" />
		<property name="proxyHostPort" value="#{T(com.liferay.lcs.util.ProxyHostUtil).getProxyHostPort()}" />
		<property name="proxyLogin" value="#{T(com.liferay.lcs.util.ProxyHostUtil).getProxyHostLogin()}" />
		<property name="proxyPassword" value="#{T(com.liferay.lcs.util.ProxyHostUtil).getProxyHostPassword()}" />
		<property name="proxyWorkstation" value="#{T(com.liferay.lcs.util.ProxyHostUtil).getProxyWorkstation()}" />
	</bean>

	<!-- Management -->

	<bean class="com.liferay.lcs.management.MBeanServerServiceImpl" id="com.liferay.lcs.management.MBeanServerService">
		<property name="MBeanServer">
			<bean class="org.springframework.jmx.support.MBeanServerFactoryBean">
				<property name="locateExistingServerIfPossible" value="true" />
			</bean>
		</property>
	</bean>

	<!-- REST -->

	<bean class="com.liferay.lcs.rest.LCSClusterEntryClientUtil" id="com.liferay.lcs.rest.LCSClusterEntryClientUtil">
		<property name="LCSClusterEntryService" ref="com.liferay.lcs.rest.client.internal.LCSClusterEntryClientImpl" />
	</bean>
	<bean class="com.liferay.lcs.rest.LCSClusterNodeClientUtil" id="com.liferay.lcs.rest.LCSClusterNodeClientUtil">
		<property name="LCSClusterNodeService" ref="com.liferay.lcs.rest.client.internal.LCSClusterNodeClientImpl" />
		<property name="LCSKeyAdvisor" ref="com.liferay.lcs.advisor.LCSKeyAdvisor" />
	</bean>
	<bean class="com.liferay.lcs.rest.LCSProjectClientUtil" id="com.liferay.lcs.rest.LCSProjectClientUtil">
		<property name="LCSProjectService" ref="com.liferay.lcs.rest.client.internal.LCSProjectClientImpl" />
	</bean>
	<bean class="com.liferay.lcs.rest.client.internal.LCSClusterEntryClientImpl" id="com.liferay.lcs.rest.client.internal.LCSClusterEntryClientImpl">
		<property name="JSONWebServiceClient" ref="osbLCSPortletJSONWebServiceClient" />
	</bean>
	<bean class="com.liferay.lcs.rest.client.internal.LCSClusterEntryTokenClientImpl" id="com.liferay.lcs.rest.client.internal.LCSClusterEntryTokenClientImpl">
		<property name="JSONWebServiceClient" ref="osbLCSPortletJSONWebServiceClient" />
	</bean>
	<bean class="com.liferay.lcs.rest.client.internal.LCSClusterNodeClientImpl" id="com.liferay.lcs.rest.client.internal.LCSClusterNodeClientImpl">
		<property name="JSONWebServiceClient" ref="osbLCSPortletJSONWebServiceClient" />
	</bean>
	<bean class="com.liferay.lcs.rest.client.internal.LCSProjectClientImpl" id="com.liferay.lcs.rest.client.internal.LCSProjectClientImpl">
		<property name="JSONWebServiceClient" ref="osbLCSPortletJSONWebServiceClient" />
	</bean>
	<bean class="com.liferay.lcs.rest.client.internal.LCSSubscriptionEntryClientImpl" id="com.liferay.lcs.rest.client.internal.LCSSubscriptionEntryClientImpl">
		<property name="JSONWebServiceClient" ref="osbLCSPortletJSONWebServiceClient" />
	</bean>

	<!-- Runnable -->

	<bean class="com.liferay.lcs.runnable.LCSThreadFactory" id="com.liferay.lcs.runnable.LCSThreadFactory" />

	<!-- Security -->

	<bean class="com.liferay.lcs.messaging.internal.security.DigitalSignatureImpl" name="com.liferay.lcs.messaging.security.DigitalSignature">
		<property name="keyName" value="#{T(com.liferay.lcs.util.PortletPropsValues).DIGITAL_SIGNATURE_KEY_NAME}" />
		<property name="keyStorePath" value="#{T(com.liferay.lcs.util.PortletPropsValues).DIGITAL_SIGNATURE_KEY_STORE_PATH}" />
		<property name="keyStoreType" value="#{T(com.liferay.lcs.util.PortletPropsValues).DIGITAL_SIGNATURE_KEY_STORE_TYPE}" />
		<property name="signingAlgorithm" value="#{T(com.liferay.lcs.util.PortletPropsValues).DIGITAL_SIGNATURE_SIGNING_ALGORITHM}" />
	</bean>

	<!-- Service -->

	<bean class="com.liferay.lcs.platform.gateway.impl.LCSGatewayClientImpl" id="com.liferay.lcs.platform.gateway.LCSGatewayClient">
		<property name="JSONWebServiceClient" ref="osbLCSGatewayWebJSONWebServiceClient" />
	</bean>

	<!-- Task -->

	<bean class="com.liferay.lcs.task.CacheMetricsTask" id="com.liferay.lcs.task.CacheMetricsTask">
		<property name="LCSGatewayService" ref="com.liferay.lcs.platform.gateway.LCSGatewayClient" />
		<property name="LCSKeyAdvisor" ref="com.liferay.lcs.advisor.LCSKeyAdvisor" />
		<property name="mBeanServerService" ref="com.liferay.lcs.management.MBeanServerService" />
	</bean>
	<bean class="com.liferay.lcs.task.ClusterHealthTask" id="com.liferay.lcs.task.ClusterHealthTask">
		<property name="LCSGatewayService" ref="com.liferay.lcs.platform.gateway.LCSGatewayClient" />
		<property name="LCSKeyAdvisor" ref="com.liferay.lcs.advisor.LCSKeyAdvisor" />
	</bean>
	<bean class="com.liferay.lcs.task.JVMMetricsTask" id="com.liferay.lcs.task.JVMMetricsTask">
		<property name="LCSGatewayService" ref="com.liferay.lcs.platform.gateway.LCSGatewayClient" />
		<property name="LCSKeyAdvisor" ref="com.liferay.lcs.advisor.LCSKeyAdvisor" />
	</bean>
	<bean class="com.liferay.lcs.task.LicenseManagerTask" id="com.liferay.lcs.task.LicenseManagerTask">
		<constructor-arg name="lcsGatewayClient" ref="com.liferay.lcs.platform.gateway.LCSGatewayClient" />
		<constructor-arg name="lcsPortletStateAdvisor" ref="com.liferay.lcs.advisor.LCSPortletStateAdvisor" />
	</bean>
	<bean class="com.liferay.lcs.task.OrganizationsTask" id="com.liferay.lcs.task.OrganizationsTask">
		<property name="LCSGatewayService" ref="com.liferay.lcs.platform.gateway.LCSGatewayClient" />
		<property name="LCSKeyAdvisor" ref="com.liferay.lcs.advisor.LCSKeyAdvisor" />
		<property name="pageSize" value="#{T(com.liferay.lcs.util.PortletPropsValues).SCHEDULED_TASK_PAGE_SIZE}" />
		<property name="pauseInterval" value="#{T(com.liferay.lcs.util.PortletPropsValues).SCHEDULED_TASK_PAUSE_INTERVAL}" />
	</bean>
	<bean class="com.liferay.lcs.task.PortalMetricsTask" id="com.liferay.lcs.task.PortalMetricsTask">
		<property name="LCSGatewayService" ref="com.liferay.lcs.platform.gateway.LCSGatewayClient" />
		<property name="LCSKeyAdvisor" ref="com.liferay.lcs.advisor.LCSKeyAdvisor" />
		<property name="portalMetricsAggregator" ref="com.liferay.lcs.metrics.PortalMetricsAggregator" />
	</bean>
	<bean factory-bean="com.liferay.lcs.task.ServerMetricsTaskFactory" factory-method="getInstance" id="com.liferay.lcs.task.ServerMetricsTask" />
	<bean class="com.liferay.lcs.task.ServerMetricsTaskFactory" id="com.liferay.lcs.task.ServerMetricsTaskFactory">
		<constructor-arg name="lcsGatewayClient" ref="com.liferay.lcs.platform.gateway.LCSGatewayClient" />
		<constructor-arg name="lcsKeyAdvisor" ref="com.liferay.lcs.advisor.LCSKeyAdvisor" />
		<constructor-arg name="mBeanServerService" ref="com.liferay.lcs.management.MBeanServerService" />
	</bean>
	<bean class="com.liferay.lcs.task.SitesTask" id="com.liferay.lcs.task.SitesTask">
		<property name="LCSGatewayService" ref="com.liferay.lcs.platform.gateway.LCSGatewayClient" />
		<property name="LCSKeyAdvisor" ref="com.liferay.lcs.advisor.LCSKeyAdvisor" />
		<property name="pageSize" value="#{T(com.liferay.lcs.util.PortletPropsValues).SCHEDULED_TASK_PAGE_SIZE}" />
		<property name="pauseInterval" value="#{T(com.liferay.lcs.util.PortletPropsValues).SCHEDULED_TASK_PAUSE_INTERVAL}" />
	</bean>
	<bean class="com.liferay.lcs.task.UserGroupsTask" id="com.liferay.lcs.task.UserGroupsTask">
		<property name="LCSGatewayService" ref="com.liferay.lcs.platform.gateway.LCSGatewayClient" />
		<property name="LCSKeyAdvisor" ref="com.liferay.lcs.advisor.LCSKeyAdvisor" />
		<property name="pageSize" value="#{T(com.liferay.lcs.util.PortletPropsValues).SCHEDULED_TASK_PAGE_SIZE}" />
		<property name="pauseInterval" value="#{T(com.liferay.lcs.util.PortletPropsValues).SCHEDULED_TASK_PAUSE_INTERVAL}" />
	</bean>

	<!--  Task scheduler -->

	<bean class="com.liferay.lcs.task.scheduler.impl.TaskSchedulerServiceImpl" id="com.liferay.lcs.scheduler.TaskSchedulerService">
		<constructor-arg name="defaultInterval" value="#{T(com.liferay.lcs.util.PortletPropsValues).COMMAND_SCHEDULE_DEFAULT_INTERVAL}" />
		<constructor-arg name="lcsAlertAdvisor" ref="com.liferay.lcs.advisor.LCSAlertAdvisor" />
		<constructor-arg name="lcsClusterEntryTokenAdvisor" ref="com.liferay.lcs.advisor.LCSClusterEntryTokenAdvisor" />
		<constructor-arg name="lcsGatewayClient" ref="com.liferay.lcs.platform.gateway.LCSGatewayClient" />
		<constructor-arg name="lcsKeyAdvisor" ref="com.liferay.lcs.advisor.LCSKeyAdvisor" />
		<constructor-arg name="scheduleDelayMax" value="#{T(com.liferay.lcs.util.PortletPropsValues).COMMAND_SCHEDULE_DELAY_MAX}" />
		<constructor-arg name="taskAdvisor" ref="com.liferay.lcs.task.advisor.TaskAdvisor" />
		<constructor-arg name="threadFactory" ref="com.liferay.lcs.runnable.LCSThreadFactory" />
		<constructor-arg name="uptimeAdvisor" ref="com.liferay.lcs.advisor.UptimeAdvisor" />
	</bean>

	<!-- Uptime -->

	<bean class="com.liferay.lcs.advisor.UptimeAdvisor" id="com.liferay.lcs.advisor.UptimeAdvisor">
		<constructor-arg ref="com.liferay.lcs.advisor.LCSKeyAdvisor" />
	</bean>

	<!-- Util -->

	<bean class="com.liferay.lcs.util.ClusterNodeUtil" id="com.liferay.lcs.util.ClusterNodeUtil">
		<property name="LCSKeyAdvisor" ref="com.liferay.lcs.advisor.LCSKeyAdvisor" />
		<property name="LCSPortletStateAdvisor" ref="com.liferay.lcs.advisor.LCSPortletStateAdvisor" />
	</bean>
	<bean class="com.liferay.lcs.util.LCSUtil" id="com.liferay.lcs.util.LCSUtil">
		<property name="JSONWebServiceClient" ref="osbLCSPortletJSONWebServiceClient" />
		<property name="LCSAlertAdvisor" ref="com.liferay.lcs.advisor.LCSAlertAdvisor" />
	</bean>
</beans>