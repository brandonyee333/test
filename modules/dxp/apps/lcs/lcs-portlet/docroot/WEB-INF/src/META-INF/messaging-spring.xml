<?xml version="1.0"?>

<beans
	default-destroy-method="destroy"
	default-init-method="afterPropertiesSet"
	xmlns="http://www.springframework.org/schema/beans"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans-3.0.xsd"
>

	<!-- Destinations -->

	<bean class="com.liferay.portal.kernel.messaging.ParallelDestination" id="destination.lcs_commands">
		<property name="name" value="liferay/lcs_commands" />
	</bean>
	<bean class="com.liferay.portal.kernel.messaging.ParallelDestination" id="destination.lcs_message_bus">
		<property name="name" value="liferay/lcs_message_bus" />
	</bean>
	<bean class="com.liferay.portal.kernel.messaging.ParallelDestination" id="destination.lcs_request">
		<property name="name" value="#{T(com.liferay.portal.kernel.license.messaging.LicenseManagerMessageType).MESSAGE_BUS_DESTINATION_REQUEST}" />
		<property name="workersCoreSize" value="1" />
		<property name="workersMaxSize" value="1" />
	</bean>

	<!-- Listeners -->

	<bean class="com.liferay.lcs.license.messaging.LicenseManagerValidateLCSMessageListener" id="messageListener.license_manager_validate_lcs" />
	<bean class="com.liferay.lcs.license.messaging.LicenseManagerValidateSubscriptionMessageListener" id="messageListener.license_manager_validate_subscription" />
	<bean class="com.liferay.lcs.messaging.CommandMessageListener" id="messageListener.lcs_commands">
		<constructor-arg name="commands">
			<map>
				<entry key="com.liferay.lcs.messaging.CheckHeartbeatCommandMessage" value-ref="com.liferay.lcs.command.CheckHeartbeatCommand" />
				<entry key="com.liferay.lcs.messaging.DownloadPatchCommandMessage" value-ref="com.liferay.lcs.command.DownloadPatchCommand" />
				<entry key="com.liferay.lcs.messaging.ExecuteScriptCommandMessage" value-ref="com.liferay.lcs.command.ExecuteScriptCommand" />
				<entry key="com.liferay.lcs.messaging.MessageBusCommandMessage" value-ref="com.liferay.lcs.command.MessageBusCommand" />
				<entry key="com.liferay.lcs.messaging.ScheduleMessageListenersCommandMessage" value-ref="com.liferay.lcs.command.ScheduleMessageListenersCommand" />
				<entry key="com.liferay.lcs.messaging.ScheduleTasksCommandMessage" value-ref="com.liferay.lcs.command.ScheduleTasksCommand" />
				<entry key="com.liferay.lcs.messaging.SendInstallationEnvironmentCommandMessage" value-ref="com.liferay.lcs.command.SendInstallationEnvironmentCommand" />
				<entry key="com.liferay.lcs.messaging.SendPatchesCommandMessage" value-ref="com.liferay.lcs.command.SendPatchesCommand" />
				<entry key="com.liferay.lcs.messaging.SendPortalPropertiesCommandMessage" value-ref="com.liferay.lcs.command.SendPortalPropertiesCommand" />
				<entry key="com.liferay.lcs.messaging.SignOffCommandMessage" value-ref="com.liferay.lcs.command.SignOffCommand" />
			</map>
		</constructor-arg>
		<constructor-arg name="digitalSignature" ref="com.liferay.lcs.messaging.security.DigitalSignature" />
		<constructor-arg name="lcsGatewayClient" ref="com.liferay.lcs.platform.gateway.LCSGatewayClient" />
	</bean>
	<bean class="com.liferay.lcs.messaging.LCSLifecycleManager" id="messageListener.lcs_lifecycle_manager">
		<constructor-arg name="taskSchedulerService" ref="com.liferay.lcs.scheduler.TaskSchedulerService" />
	</bean>
	<bean class="com.liferay.lcs.messaging.LCSMessageBusMessageListener" id="messageListener.lcs_message_bus">
		<constructor-arg name="lcsGatewayClient" ref="com.liferay.lcs.platform.gateway.LCSGatewayClient" />
		<constructor-arg name="lcsKeyAdvisor" ref="com.liferay.lcs.advisor.LCSKeyAdvisor" />
	</bean>
	<bean class="com.liferay.lcs.messaging.PortalMetricsMessageListener" id="messageListener.monitoring">
		<constructor-arg name="lcsGatewayClient" ref="com.liferay.lcs.platform.gateway.LCSGatewayClient" />
		<constructor-arg name="portalMetricsAggregator" ref="com.liferay.lcs.metrics.PortalMetricsAggregator" />
	</bean>

	<!-- Configurator -->

	<bean class="com.liferay.portal.kernel.messaging.config.PluginMessagingConfigurator" id="messagingConfigurator">
		<property name="destinations">
			<list>
				<ref bean="destination.lcs_commands" />
				<ref bean="destination.lcs_message_bus" />
				<ref bean="destination.lcs_request" />
			</list>
		</property>
		<property name="messageListeners">
			<map key-type="java.lang.String" value-type="java.util.List">
				<entry key="#{T(com.liferay.portal.kernel.license.messaging.LicenseManagerMessageType).MESSAGE_BUS_DESTINATION_REQUEST}">
					<list value-type="com.liferay.portal.kernel.messaging.MessageListener">
						<ref bean="messageListener.license_manager_validate_lcs" />
						<ref bean="messageListener.license_manager_validate_subscription" />
					</list>
				</entry>
				<entry key="liferay/hot_deploy">
					<list value-type="com.liferay.portal.kernel.messaging.MessageListener">
						<ref bean="messageListener.lcs_lifecycle_manager" />
					</list>
				</entry>
				<entry key="liferay/lcs_commands">
					<list value-type="com.liferay.portal.kernel.messaging.MessageListener">
						<ref bean="messageListener.lcs_commands" />
					</list>
				</entry>
				<entry key="liferay/lcs_message_bus">
					<list value-type="com.liferay.portal.kernel.messaging.MessageListener">
						<ref bean="messageListener.lcs_message_bus" />
					</list>
				</entry>
			</map>
		</property>
	</bean>

	<!-- Scheduler -->

	<bean class="com.liferay.lcs.messaging.advisor.MessageBusListenerAdvisor" id="com.liferay.lcs.messaging.advisor.MessageBusListenerAdvisor">
		<constructor-arg ref="com.liferay.lcs.platform.gateway.LCSGatewayClient" />
	</bean>
</beans>