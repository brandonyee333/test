	com.liferay.portal.kernel.bean;version="[7.1.0,99.0.0)",\
	com.liferay.portal.kernel.cluster;version="[7.0.0,99.0.0)",\
	com.liferay.portal.kernel.dao.orm;version="[7.0.0,99.0.0)",\
	com.liferay.portal.kernel.exception;version="[7.0.0,99.0.0)",\
	com.liferay.portal.kernel.io.unsync;version="[6.2.0,99.0.0)",\
	com.liferay.portal.kernel.json;version="[7.0.0,99.0.0)",\
	com.liferay.portal.kernel.license.messaging;version="[1.0.0,99.0.0)",\
	com.liferay.portal.kernel.messaging;version="[7.0.0,99.0.0)",\
	com.liferay.portal.kernel.model;version="[1.0.0,99.0.0)",\
	com.liferay.portal.kernel.monitoring;version="[7.0.0,99.0.0)",\
	com.liferay.portal.kernel.portlet;version="[7.0.0,99.0.0)",\
	com.liferay.portal.kernel.scripting;version="[7.0.0,99.0.0)",\
