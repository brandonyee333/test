<%
String tabs1Names = "all-tasks";

if (group.isUser()) {
	tabs1Names = "assigned-to-me,i-have-created";
}
else if (themeDisplay.isSignedIn()) {
	tabs1Names = tabs1Names + ",assigned-to-me,i-have-created";
}
%>

<liferay-ui:tabs
	names="<%= tabs1Names %>"
	param="tabs1"
	url="<%= portletURL.toString() %>"
/>