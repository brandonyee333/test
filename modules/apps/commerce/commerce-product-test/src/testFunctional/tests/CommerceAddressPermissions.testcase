@component-name = "portal-commerce"
definition {

	property custom.properties = "jsonws.web.service.paths.excludes=${line.separator}company.security.strangers.verify=false";
	property portal.release = "true";
	property portal.upstream = "true";
	property release.feature.flags.disable.DISABLE_PRIVATE_LAYOUTS = "true";
	property testray.main.component.name = "Order Management";

	setUp {
		CommerceConfiguration.commerceSetUp();

        task ("Setup: Create an account with a buyer user") {
			CommerceEntry.addAccountEntryUser(
				accountName = "Commerce Account",
				accountType = "Business",
				agreeToTermsAndAnswerReminderQuery = "true",
				createNewAccount = "true",
				requireReset = "false",
				userEmailAddress = "buyer@liferay.com",
				userFirstName = "Buyer",
				userLastName = "User",
				userRole = "Buyer",
				userScreenName = "buyeruser",
				userSiteMembership = "Minium");
		}

		task ("Setup: 3 addresses are added to the account(Billing, Shipping, Billing & Shipping)") {
			 Accounts.openAccountsAdmin();

			LexiconEntry.gotoEntry(rowEntry = "Commerce Account");

			Accounts.gotoAssigneeTab(assigneeTab = "Addresses");

			for (var typeList : list "Billing,Shipping,Billing and Shipping") {
				Accounts.addAddressViaSetDefaultAddress(
					addressCity = "Diamond Bar",
					addressCountry = "United States",
					addressName = "Liferay ${typeList}",
					addressPostalCode = "91765",
					addressRegion = "California",
					addressStreet1 = "1400 Montefino Ave",
					addressType = "${typeList}",
					phoneNumber = "+1-877-543-3729");
     	   }
		}

		task ("Setup: The buyer doesn't have permission to manage addresses(Accounts > Account Entry: Manage Addresses)") {
			ApplicationsMenu.gotoPortlet(
				category = "Users",
				panel = "Control Panel",
				portlet = "Roles");

			Navigator.gotoNavItem(navItem = "Account Roles");

			Search.searchCP(searchTerm = "Buyer");

			Accounts.goToEntryMenuItem(
				menuItem = "Edit",
				rowEntry = "Buyer");

			Navigator.gotoNavItem(navItem = "Define Permissions");

			Type(
				locator1 = "RolesPermissionsNavigation#SEARCH_FIELD",
				value1 = "Accounts");

			ClickNoError(
				locator1 = "RolesPermissionsNavigation#PERMISSIONS_NAVITEM_SUBITEM",
				key_navItem = "Accounts",
				key_subItem = "Accounts");
				
			Uncheck.uncheckNotVisible(
				locator1 = "RolesPermissionsNavigation#PERMISSIONS_ITEM_CHECKBOX",
				key_itemName = "Account Entry",
				key_checkboxName = "MANAGE_ADDRESSES");

			Button.clickSave();
		}

        task ("Setup: login with a buyer user") {
			User.logoutPG();

			CommerceLogin.miniumLogin(
				password = "test",
				urlAppend = "web/minium",
				userEmailAddress = "buyer@liferay.com");

            FrontStore.addInitializerProductToCart(
                productName = "ABS Sensor",
                productQuantity = "1");
		}
	}

	tearDown {
		CommerceConfiguration.commerceTearDown();
	}

    @description = "COMMERCE-9364 | Without Manage Address permission, user cannot add new shipping address and only can select pre-defined addresses"
	@priority = "3"
	test CanOnlySelectPreDefinedShippingAddressWhithouPermission {
		task ("When the buyer reach the Billing Address step") {
			CommerceCheckout.gotoCheckout();
		}

		task ("Then the buyer can select a billing address between the pre-defined list of existing billing addresses") {
			AssertElementPresent(
				key_selectFieldLabel = "Choose Shipping Address",
				locator1 = "Select#ANY",
				value1 = "Liferay Shipping");

			Select(
				key_selectFieldLabel = "Choose Shipping Address",
				locator1 = "Select#ANY",
				value1 = "Liferay Shipping");

			AssertElementPresent(
				key_selectFieldLabel = "Choose Shipping Address",
				locator1 = "Select#ANY",
				value1 = "Liferay Billing and Shipping");

			Select(
				key_selectFieldLabel = "Choose Shipping Address",
				locator1 = "Select#ANY",
				value1 = "Liferay Billing and Shipping");
		}

		task ("And then the 'Use shipping address as billing address' checkbox is not visible") {
			AssertElementNotPresent(
				locator1 = "Checkbox#ANY_CHECKBOX",
				checkboxName = "Use shipping address as billing address");
		}

		task ("But the buyer is not able to add a new shipping address as fields are disabled") {
			AssertElementPresent(
				key_fieldName = "Name",
				locator1 = "CommerceAccelerators#CHECKOUT_GENERIC_TEXT_INPUT_DISABLED");

			AssertElementPresent(
				key_fieldName = "Address",
				locator1 = "CommerceAccelerators#CHECKOUT_GENERIC_TEXT_INPUT_DISABLED");

			AssertElementPresent(
				key_fieldName = "Zip",
				locator1 = "CommerceAccelerators#CHECKOUT_GENERIC_TEXT_INPUT_DISABLED");
		}
    }


}