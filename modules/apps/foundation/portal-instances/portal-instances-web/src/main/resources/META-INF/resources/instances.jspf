--%>

<liferay-ui:error exception="<%= RequiredCompanyException.class %>" message="the-default-company-is-required" />

<liferay-ui:search-container
	iteratorURL="<%= portletURL %>"
	total="<%= CompanyLocalServiceUtil.getCompaniesCount(false) %>"
>
	<liferay-ui:search-container-results
		results="<%= CompanyLocalServiceUtil.getCompanies(false, searchContainer.getStart(), searchContainer.getEnd()) %>"
	/>

	<liferay-ui:search-container-row
		className="com.liferay.portal.kernel.model.Company"
		modelVar="curCompany"
	>

		<%
		PortletURL rowURL = renderResponse.createRenderURL();

		rowURL.setParameter("mvcRenderCommandName", "/portal_instances/edit_instance");
		rowURL.setParameter("redirect", currentURL);
		rowURL.setParameter("companyId", String.valueOf(curCompany.getCompanyId()));
		%>

		<liferay-ui:search-container-column-text
			href="<%= rowURL %>"
			name="instance-id"
			property="companyId"
		/>

		<liferay-ui:search-container-column-text
			cssClass="table-cell-content"
			href="<%= rowURL %>"
			name="web-id"
			value="<%= HtmlUtil.escape(curCompany.getWebId()) %>"
		/>

		<liferay-ui:search-container-column-text
			cssClass="table-cell-content"
			href="<%= rowURL %>"
			name="virtual-host"
			value="<%= curCompany.getVirtualHostname() %>"
		/>

		<liferay-ui:search-container-column-text
			cssClass="table-cell-content"
			href="<%= rowURL %>"
			name="mail-domain"
			property="mx"
		/>

		<liferay-ui:search-container-column-text
			href="<%= rowURL %>"
			name="num-of-users"
			value="<%= String.valueOf(UserLocalServiceUtil.searchCount(curCompany.getCompanyId(), null, WorkflowConstants.STATUS_APPROVED, null)) %>"
		/>

		<%
		int maxUsers = curCompany.getMaxUsers();
		%>

		<liferay-ui:search-container-column-text
			href="<%= rowURL %>"
			name="max-num-of-users"
			value='<%= (maxUsers > 0) ? String.valueOf(maxUsers) : LanguageUtil.get(request, "unlimited") %>'
		/>

		<liferay-ui:search-container-column-text
			href="<%= rowURL %>"
			name="active"
			value='<%= LanguageUtil.get(request, curCompany.isActive() ? "yes" : "no") %>'
		/>

		<liferay-ui:search-container-column-jsp
			path="/instance_actions.jsp"
		/>
	</liferay-ui:search-container-row>

	<liferay-ui:search-iterator
		markupView="lexicon"
		searchContainer="<%= searchContainer %>"
	/>
</liferay-ui:search-container>

<portlet:renderURL var="addURL">
	<portlet:param name="mvcRenderCommandName" value="/portal_instances/edit_instance" />
	<portlet:param name="redirect" value="<%= currentURL %>" />
</portlet:renderURL>

<liferay-frontend:add-menu>
	<liferay-frontend:add-menu-item
		title='<%= LanguageUtil.get(request, "add") %>'
		url="<%= addURL.toString() %>"
	/>
</liferay-frontend:add-menu>