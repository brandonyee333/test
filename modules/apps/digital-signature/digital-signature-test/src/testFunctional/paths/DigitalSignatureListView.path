<html>
<head>
<title>DigitalSignatureListView</title>
</head>

<body>
<table border="1" cellpadding="1" cellspacing="1">
<thead>
<tr><td rowspan="1" colspan="3">DigitalSignatureListView</td></tr>
</thead>

<tbody>
<tr>
	<td>DIGITAL_SIGNATURE_STATUS</td>
	<td>//span[contains(@class,'label-item') and contains(.,'${dsStatus}')]</td>
	<td></td>
</tr>
<tr>
	<td>DIGITAL_SIGNATURE_RECIPIENTS_BADGE</td>
	<td>//span[contains(@class, 'badge-item')]</td>
	<td></td>
</tr>
<tr>
	<td>DIGITAL_SIGNATURE_NAVIGATE_NEXT</td>
	<td>//a[contains(@aria-label, 'next')]</td>
	<td></td>
</tr>
<tr>
	<td>DIGITAL_SIGNATURE_ENVELOPE_HEADER</td>
	<td>//div[contains(@class, "envelope-view__header")]//span[contains(., '${emailSubject}')]</td>
	<td></td>
</tr>
<tr>
	<td>DIGITAL_SIGNATURE_ENVELOPE_FILE_PREVIEW</td>
	<td>//div[contains(@class, "preview-file")]//img[contains(@src, '${dmDocumentFile}')]</td>
	<td></td>
</tr>
<tr>
	<td>DIGITAL_SIGNATURE_ENVELOPE_RECIPIENT</td>
	<td>//b[contains(text(),'To:')]//following-sibling::span[contains(text(), '${recipientEmail}')]</td>
	<td></td>
</tr>
<tr>
	<td>DIGITAL_SIGNATURE_ENVELOPE_BODY</td>
	<td>//div[contains(@class, "envelope-view__details")]//p[contains(., '${emailMessage}')]</td>
	<td></td>
</tr>
<tr>
	<td>DIGITAL_SIGNATURE_ADD_RECIPIENT</td>
	<td>//button[contains(@class, 'mb-4 btn btn-unstyled')]</td>
	<td></td>
</tr>
<tr>
	<td>DIGITAL_SIGNATURE_EXTRA_RECIPIENT_NAME</td>
	<td>//input[contains(@id,'recipients[1].fullName')]</td>
	<td></td>
</tr>
<tr>
	<td>DIGITAL_SIGNATURE_EXTRA_RECIPIENT_EMAIL</td>
	<td>//input[contains(@id,'recipients[1].email')]</td>
	<td></td>
</tr>
<tr>
	<td>DIGITAL_SIGNATURE_ENVELOPE_NAME</td>
	<td>//a[contains(., '${envelopeName}')]</td>
	<td></td>
</tr>
<tr>
	<td>DIGITAL_SIGNATURE_DOWNLOAD_BUTTON</td>
	<td>//button[contains(@type, 'button') and contains(., 'Download')]</td>
	<td></td>
</tr>
<tr>
	<td>DIGITAL_SIGNATURE_ELLIPSIS_BUTTON</td>
	<td>//tr[contains(@class, '') and contains(., '${envelopeName}')]//button[contains(@class, 'dropdown')]</td>
	<td></td>
</tr>
<tr>
	<td>DIGITAL_SIGNATURE_DOWNLOAD_BY_LIST</td>
	<td>//button[contains(., 'Download')]</td>
	<td></td>
</tr>
<tr>
	<td>DIGITAL_SIGNATURE_RECENT_CREATE_DATE</td>
	<td>//td[contains(., 'a few seconds ago')]</td>
	<td></td>
</tr>
</tbody>
</table>
</body>
</html>