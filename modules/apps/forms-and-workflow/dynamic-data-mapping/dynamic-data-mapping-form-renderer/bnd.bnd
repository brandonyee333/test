Bundle-Name: Liferay Dynamic Data Mapping Form Renderer
Bundle-SymbolicName: com.liferay.dynamic.data.mapping.form.renderer
Bundle-Version: 2.1.42
Export-Package: com.liferay.dynamic.data.mapping.form.renderer
Liferay-JS-Config: /META-INF/resources/js/config.js
Liferay-Releng-Module-Group-Title: Dynamic Data Mapping
Provide-Capability:\
	liferay.resource.bundle;\
		resource.bundle.aggregate:String="(bundle.symbolic.name=com.liferay.dynamic.data.mapping.lang)";\
		resource.bundle.base.name="content.Language"
Web-ContextPath: /dynamic-data-mapping-form-renderer
-dsannotations-options: inherit