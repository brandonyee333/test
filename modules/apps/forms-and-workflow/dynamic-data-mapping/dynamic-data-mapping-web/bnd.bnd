Bundle-Name: Liferay Dynamic Data Mapping Web
Bundle-SymbolicName: com.liferay.dynamic.data.mapping.web
Bundle-Version: 1.0.165
Liferay-JS-Config: /META-INF/resources/js/config.js
Liferay-Releng-Module-Group-Title: Dynamic Data Mapping
Provide-Capability:\
	liferay.resource.bundle;\
		resource.bundle.aggregate:String="(bundle.symbolic.name=com.liferay.dynamic.data.mapping.lang), (bundle.symbolic.name=com.liferay.dynamic.data.mapping.web)";\
		resource.bundle.base.name="content.Language";\
		service.ranking="1"
Web-ContextPath: /dynamic-data-mapping-web
-dsannotations-options: inherit