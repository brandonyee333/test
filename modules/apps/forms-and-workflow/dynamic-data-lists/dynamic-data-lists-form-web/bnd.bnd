Bundle-Name: Liferay Dynamic Data Lists Form Web
Bundle-SymbolicName: com.liferay.dynamic.data.lists.form.web
Bundle-Version: 2.0.49
Liferay-JS-Config: /META-INF/resources/admin/js/config.js
Liferay-Releng-Module-Group-Title: Dynamic Data Lists
Provide-Capability:\
	liferay.resource.bundle;\
		resource.bundle.aggregate:String="(bundle.symbolic.name=com.liferay.dynamic.data.lists.form.web), (bundle.symbolic.name=com.liferay.dynamic.data.mapping.lang)";\
		resource.bundle.base.name="content.Language";\
		service.ranking="1"
Web-ContextPath: /dynamic-data-lists-form-web
-dsannotations-options: inherit