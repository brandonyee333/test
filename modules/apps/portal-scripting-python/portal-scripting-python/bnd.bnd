Bundle-Name: Liferay Portal Scripting Python
Bundle-SymbolicName: com.liferay.portal.scripting.python
Bundle-Version: 2.0.13
Import-Package:\
	!com.github.luben.zstd,\
	\
	!com.informix.*,\
	\
	!com.jcraft.jzlib,\
	\
	!com.kenai.jnr.*,\
	\
	!com.ning.compress.*,\
	\
	!com.oracle.svm.core.annotate,\
	\
	!jnr.a64asm,\
	\
	!jnr.x86asm,\
	\
	!junit.framework.*,\
	\
	!lzma.sdk.*,\
	\
	!net.jpountz.*,\
	\
	!oracle.*,\
	\
	!org.antlr.stringtemplate.*,\
	\
	!org.apache.logging.log4j.*,\
	\
	!org.brotli.dec,\
	\
	!org.checkerframework.checker.nullness.compatqual,\
	\
	!org.conscrypt,\
	\
	!org.eclipse.jetty.*,\
	\
	!org.gnu.readline.*,\
	\
	!org.hamcrest,\
	\
	!org.jboss.marshalling,\
	\
	!org.junit.*,\
	\
	!org.python.*,\
	\
	!org.tukaani.xz,\
	\
	!reactor.blockhound.*,\
	\
	!sun.io.*,\
	\
	!sun.misc.*,\
	\
	!sun.security.*,\
	\
	*
-fixupmessages:\
	"The default package '.' is not permitted by the Import-Package ...";is:=ignore,\
	"The JAR is empty: ...";is:=ignore,\
	"While setting properties ...";is:=ignore,\
	"Classes found in the wrong directory: ...";is:=ignore