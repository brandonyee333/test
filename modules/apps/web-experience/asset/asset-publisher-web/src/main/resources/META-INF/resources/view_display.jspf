--%>

<%
if (StringUtil.startsWith(assetPublisherDisplayContext.getDisplayStyle(), PortletDisplayTemplateManager.DISPLAY_STYLE_PREFIX)) {
	assetPublisherDisplayContext.setDisplayStyle(AssetPublisherWebConfigurationValues.DISPLAY_STYLE_DEFAULT);
}

if (!ArrayUtil.contains(AssetPublisherWebConfigurationValues.DISPLAY_STYLES, assetPublisherDisplayContext.getDisplayStyle())) {
%>

	<%= HtmlUtil.escape(LanguageUtil.format(request, "x-is-not-a-display-type", assetPublisherDisplayContext.getDisplayStyle())) %>

<%
}
else {
	for (String curDisplayStyle : AssetPublisherWebConfigurationValues.DISPLAY_STYLES) {
		if (Objects.equals(assetPublisherDisplayContext.getDisplayStyle(), curDisplayStyle)) {
%>

			<liferay-util:include page='<%= "/display/" + TextFormatter.format(curDisplayStyle, TextFormatter.N) + ".jsp" %>' servletContext="<%= application %>" />

<%
			break;
		}
	}
}
%>