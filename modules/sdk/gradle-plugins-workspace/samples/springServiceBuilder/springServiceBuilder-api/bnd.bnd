Bundle-Name: springServiceBuilder-api
Bundle-SymbolicName: springservicebuilder.api
Bundle-Version: 1.0.0
Export-Package:\
	springservicebuilder.exception,\
	springservicebuilder.model,\
	springservicebuilder.service,\
	springservicebuilder.service.persistence
-check: EXPORTS
-includeresource: META-INF/service.xml=../springServiceBuilder-service/service.xml
