@default = "assertNotEditable"
definition {

	function assertNotEditable(locator1) {
		WaitForSPARefresh();

		selenium.waitForVisible(${locator1}, "true");

		selenium.waitForNotEditable(${locator1});

		selenium.assertNotEditable(${locator1});

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

}