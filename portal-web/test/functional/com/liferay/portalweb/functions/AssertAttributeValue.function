@default = "assertAttributeValue"
definition {

	function assertAttributeValue(locator1, value1, attribute1) {
		WaitForSPARefresh();

		selenium.waitForElementPresent(${locator1}, "false");

		selenium.waitForVisible(${locator1}, "false");

		selenium.assertAttributeValue(${attribute1}, ${locator1}, ${value1});

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

}