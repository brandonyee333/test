@default = "click"
@summary = "Click on '${locator1}'"
definition {

	function click(locator1) {
		WaitForSPARefresh();

		selenium.waitForVisible(${locator1}, "true");

		selenium.mouseOver(${locator1});

		selenium.click(${locator1});

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function clickAt(locator1, value1) {
		WaitForSPARefresh();

		selenium.waitForVisible(${locator1}, "true");

		selenium.mouseOver(${locator1});

		selenium.clickAt(${locator1}, ${value1});

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function clickAtNotVisible(locator1, value1) {
		WaitForSPARefresh();

		selenium.waitForElementPresent(${locator1}, "true");

		selenium.mouseOver(${locator1});

		selenium.clickAt(${locator1}, ${value1});

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function clickAtSidebarClickAtWaitForScript(locator1) {
		WaitForSPARefresh();

		selenium.pause(1000);

		selenium.waitForElementPresent(${locator1}, "true");

		selenium.mouseOver(${locator1});

		selenium.waitForElementPresent(${locator1}, "true");

		selenium.pause(1000);

		Click.clickAt();

		selenium.waitForElementPresent(${locator1}, "true");
	}

	function clickNoMouseOver(locator1) {
		WaitForSPARefresh();

		selenium.waitForVisible(${locator1}, "true");

		selenium.click(${locator1});

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function clickNoSPARefresh(locator1) {
		selenium.waitForVisible(${locator1}, "true");

		selenium.mouseOver(${locator1});

		selenium.click(${locator1});

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function clickNoWaitForVisible(locator1) {
		WaitForSPARefresh();

		selenium.mouseOver(${locator1});

		selenium.click(${locator1});

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function clickWaitForInlineCKEditorNoMouseOver(locator1) {
		WaitForSPARefresh();

		if (selenium.isElementPresent("//div[contains(@class,'cke_editable_inline')]")) {
			selenium.waitForElementPresent(${locator1}, "true");
		}

		selenium.waitForVisible(${locator1}, "true");

		selenium.click(${locator1});
	}

	function javaScriptClick(locator1) {
		WaitForSPARefresh();

		selenium.javaScriptClick(${locator1});

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function makeVisibleClickAt(locator1, value1) {
		WaitForSPARefresh();

		selenium.waitForElementPresent(${locator1}, "true");

		selenium.mouseOver(${locator1});

		selenium.pause(1000);

		selenium.makeVisible(${locator1});

		selenium.waitForVisible(${locator1}, "true");

		selenium.clickAt(${locator1}, ${value1});

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function mouseDownMouseUp(locator1) {
		WaitForSPARefresh();

		selenium.waitForElementPresent(${locator1}, "true");

		selenium.mouseDown(${locator1});

		selenium.mouseUp(${locator1});

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function mouseMoveLeftClick(locator1) {
		WaitForSPARefresh();

		selenium.waitForElementPresent(${locator1}, "true");

		selenium.mouseOver(${locator1});

		selenium.waitForVisible(${locator1}, "true");

		selenium.mouseMoveAt(${locator1}, "-100,0");

		selenium.click(${locator1});

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function mouseOverClick(locator1) {
		WaitForSPARefresh();

		selenium.waitForElementPresent(${locator1}, "true");

		selenium.mouseOver(${locator1});

		selenium.waitForVisible(${locator1}, "true");

		selenium.click(${locator1});

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function pauseClickAt(locator1) {
		WaitForSPARefresh();

		selenium.pause(1000);

		selenium.mouseOver(${locator1});

		Click.clickAt();

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function waitForMenuToggleJSClick(locator1) {
		WaitForSPARefresh();

		selenium.waitForElementPresent(${locator1}, "true");

		selenium.pause(3000);

		Click();

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

}