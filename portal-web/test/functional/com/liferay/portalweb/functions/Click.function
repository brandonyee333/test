@default = "click"
@summary = "Click on '${locator1}'"
definition {

	function click() {
		WaitForSPARefresh();

		selenium.waitForVisible(${locator1}, "true");

		selenium.mouseOver(${locator1});

		selenium.click(${locator1});

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function clickAt() {
		WaitForSPARefresh();

		selenium.waitForVisible(${locator1}, "true");

		selenium.mouseOver(${locator1});

		selenium.clickAt(${locator1}, ${value1});

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function clickAtNotVisible() {
		WaitForSPARefresh();

		selenium.waitForElementPresent(${locator1}, "true");

		selenium.mouseOver(${locator1});

		selenium.clickAt(${locator1}, ${value1});

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function clickAtSidebarClickAtWaitForScript() {
		WaitForSPARefresh();

		selenium.pause(1000);

		selenium.waitForElementPresent(${locator1}, "true");

		selenium.mouseOver(${locator1});

		selenium.waitForElementPresent(${locator1}, "true");

		selenium.pause(1000);

		Click.clickAt();

		selenium.waitForElementPresent(${locator1}, "true");
	}

	function clickNoMouseOver() {
		WaitForSPARefresh();

		selenium.waitForVisible(${locator1}, "true");

		selenium.click(${locator1});

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function clickNoSPARefresh() {
		selenium.waitForVisible(${locator1}, "true");

		selenium.mouseOver(${locator1});

		selenium.click(${locator1});

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function clickNoWaitForVisible() {
		WaitForSPARefresh();

		selenium.mouseOver(${locator1});

		selenium.click(${locator1});

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function clickWaitForInlineCKEditorNoMouseOver() {
		WaitForSPARefresh();

		if (selenium.isElementPresent("//div[contains(@class,'cke_editable_inline')]")) {
			selenium.waitForElementPresent(${locator1}, "true");
		}

		selenium.waitForVisible(${locator1}, "true");

		selenium.click(${locator1});
	}

	function javaScriptClick() {
		WaitForSPARefresh();

		selenium.javaScriptClick(${locator1});

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function makeVisibleClickAt() {
		WaitForSPARefresh();

		selenium.waitForElementPresent(${locator1}, "true");

		selenium.mouseOver(${locator1});

		selenium.pause(1000);

		selenium.makeVisible(${locator1});

		selenium.waitForVisible(${locator1}, "true");

		selenium.clickAt(${locator1}, ${value1});

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function mouseDownMouseUp() {
		WaitForSPARefresh();

		selenium.waitForElementPresent(${locator1}, "true");

		selenium.mouseDown(${locator1});

		selenium.mouseUp(${locator1});

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function mouseMoveLeftClick(locator1) {
		WaitForSPARefresh();

		selenium.waitForElementPresent(${locator1}, "true");

		selenium.mouseOver(${locator1});

		selenium.waitForVisible(${locator1}, "true");

		selenium.mouseMoveAt(${locator1}, "-100,0");

		selenium.click(${locator1});

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function mouseOverClick() {
		WaitForSPARefresh();

		selenium.waitForElementPresent(${locator1}, "true");

		selenium.mouseOver(${locator1});

		selenium.waitForVisible(${locator1}, "true");

		selenium.click(${locator1});

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function pauseClickAt() {
		WaitForSPARefresh();

		selenium.pause(1000);

		selenium.mouseOver(${locator1});

		Click.clickAt();

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function waitForMenuToggleJSClick() {
		WaitForSPARefresh();

		selenium.waitForElementPresent(${locator1}, "true");

		selenium.pause(3000);

		Click();

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

}