@default = "assertElementNotPresent"
@summary = "Assert that '${locator1}' is not available"
definition {

	function assertElementNotPresent() {
		WaitForSPARefresh();

		selenium.waitForElementNotPresent(${locator1}, ${value1});

		selenium.assertElementNotPresent(${locator1});

		selenium.assertJavaScriptErrors(${value1});

		selenium.assertLiferayErrors();
	}

}