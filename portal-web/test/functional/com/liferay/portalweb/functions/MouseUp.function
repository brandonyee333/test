@default = "mouseUp"
definition {

	function mouseUp() {
		WaitForSPARefresh();

		selenium.mouseUp(${locator1});

		selenium.assertJavaScriptErrors(${value1});

		selenium.assertLiferayErrors();
	}

	function mouseUpAt(locator1, value1) {
		WaitForSPARefresh();

		selenium.waitForVisible(${locator1}, ${value1});

		selenium.mouseUpAt(${locator1}, ${value1});

		selenium.assertJavaScriptErrors(${value1});

		selenium.assertLiferayErrors();
	}

}