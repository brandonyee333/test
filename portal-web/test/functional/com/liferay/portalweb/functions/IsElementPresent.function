@default = "isElementPresent"
definition {

	function isElementPresent() {
		WaitForSPARefresh();

		selenium.isElementPresent(${locator1});
	}

	function isElementPresentAfterWait() {
		WaitForSPARefresh();

		selenium.isElementPresentAfterWait(${locator1});
	}

	function isVisible() {
		WaitForSPARefresh();

		selenium.isVisible(${locator1});
	}

	function pauseIsElementPresent() {
		WaitForSPARefresh();

		selenium.pause(1000);

		selenium.isElementPresent(${locator1});
	}

}