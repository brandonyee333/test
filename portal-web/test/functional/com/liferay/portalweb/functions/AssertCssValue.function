@default = "assertCssValue"
definition {

	function assertCssValue(locator2, locator1, value1) {
		WaitForSPARefresh();

		selenium.waitForVisible(${locator1}, ${value1});

		selenium.assertCssValue(${locator1}, ${locator2}, ${value1});

		selenium.assertJavaScriptErrors(${value1});

		selenium.assertLiferayErrors();
	}

}