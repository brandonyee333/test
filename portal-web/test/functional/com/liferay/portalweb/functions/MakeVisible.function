@default = "makeVisible"
definition {

	@summary-ignore = "true"
	function makeVisible() {
		WaitForSPARefresh();

		selenium.waitForElementPresent(${locator1}, ${value1});

		selenium.mouseOver(${locator1});

		selenium.makeVisible(${locator1});

		selenium.assertJavaScriptErrors(${value1});

		selenium.assertLiferayErrors();
	}

}