@default = "assertEditable"
definition {

	function assertEditable(locator1) {
		WaitForSPARefresh();

		

		

		selenium.assertEditable(${locator1});

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function assertEditableNotVisible(locator1) {
		WaitForSPARefresh();

		

		

		selenium.assertEditable(${locator1});

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

}