@default = "assertEditable"
definition {

	function assertEditable() {
		WaitForSPARefresh();

		selenium.waitForVisible(${locator1}, ${value1});

		selenium.waitForEditable(${locator1});

		selenium.assertEditable(${locator1});

		selenium.assertJavaScriptErrors(${value1});

		selenium.assertLiferayErrors();
	}

}