@default = "assertClickNoError"
@summary = "Click on '${locator1}' that should have a value of '${value1}'"
definition {

	function assertClickNoError {
		WaitForSPARefresh();

		if (contains(${locator1}, "/input")) {
			AssertClickNoError.assertValueClick();
		}
		else {
			AssertClickNoError.assertTextClick();
		}
	}

	function assertPartialTextClickAt {
		WaitForSPARefresh();

		AssertTextEquals.assertPartialText();

		selenium.mouseOver();

		selenium.clickAt();
	}

	function assertTextClick {
		WaitForSPARefresh();

		selenium.waitForVisible();

		var value = GetterUtil.getString(${value1});

		var regex = RegexUtil.escapeRegexChars(${value});

		selenium.waitForTextMatches(${locator1}, "(?i)${regex}");

		selenium.assertTextMatches(${locator1}, "(?i)${regex}");

		selenium.mouseOver();

		selenium.click();
	}

	function assertValueClick {
		WaitForSPARefresh();

		selenium.waitForVisible();

		selenium.waitForValue();

		selenium.assertValue();

		selenium.mouseOver();

		selenium.click();
	}

}