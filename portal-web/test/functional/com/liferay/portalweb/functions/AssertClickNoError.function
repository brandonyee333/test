@default = "assertClickNoError"
@summary = "Click on '${locator1}' that should have a value of '${value1}'"
definition {

	function assertClickNoError(locator1) {
		WaitForSPARefresh();

		if (contains(${locator1}, "/input")) {
			AssertClickNoError.assertValueClick();
		}
		else {
			AssertClickNoError.assertTextClick();
		}
	}

	function assertPartialTextClickAt() {
		WaitForSPARefresh();

		AssertTextEquals.assertPartialText();

		selenium.mouseOver(${locator1});

		selenium.clickAt(${locator1}, ${value1});
	}

	function assertTextClick() {
		WaitForSPARefresh();

		selenium.waitForVisible(${locator1}, "true");

		selenium.waitForText(${locator1}, ${value1});

		selenium.assertText(${locator1}, ${value1});

		selenium.mouseOver(${locator1});

		selenium.click(${locator1});
	}

	function assertValueClick() {
		WaitForSPARefresh();

		selenium.waitForVisible(${locator1}, "true");

		selenium.waitForValue(${locator1}, ${value1});

		selenium.assertValue(${locator1}, ${value1});

		selenium.mouseOver(${locator1});

		selenium.click(${locator1});
	}

}