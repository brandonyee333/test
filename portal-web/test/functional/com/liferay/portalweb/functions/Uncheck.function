@default = "clickAt"
definition {

	function clickAt() {
		WaitForSPARefresh();

		selenium.waitForVisible(${locator1}, "true");

		selenium.mouseOver(${locator1});

		if (selenium.isChecked(${locator1})) {
			selenium.clickAt(${locator1}, ${value1});
		}

		AssertNotChecked();

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function uncheckHiddenToggleSwitch(locator1) {
		WaitForSPARefresh();

		selenium.waitForElementPresent(${locator1}, "true");

		selenium.mouseOver(${locator1});

		if (selenium.isChecked("xpath=(${locator1})/../../input")) {
			selenium.clickAt(${locator1}, ${value1});
		}

		AssertNotChecked.assertNotCheckedHiddenToggleSwitch();

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function uncheckToggleSwitch() {
		WaitForSPARefresh();

		selenium.waitForElementPresent(${locator1}, "true");

		selenium.mouseOver(${locator1});

		if (selenium.isChecked(${locator1})) {
			selenium.clickAt(${locator1}, ${value1});
		}

		AssertNotChecked.assertNotCheckedNotVisible();

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function uncheckToggleSwitchNoErrorNoAssert() {
		WaitForSPARefresh();

		selenium.waitForElementPresent(${locator1}, "true");

		selenium.mouseOver(${locator1});

		if (selenium.isChecked(${locator1})) {
			selenium.clickAt(${locator1}, ${value1});
		}
	}

}