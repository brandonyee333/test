@default = "keyPress"
definition {

	function keyDown() {
		WaitForSPARefresh();

		selenium.mouseOver(${locator1});

		selenium.keyDown(${locator1}, ${value1});

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function keyPress() {
		WaitForSPARefresh();

		selenium.mouseOver(${locator1});

		selenium.keyPress(${locator1}, ${value1});

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function keyPressNoError() {
		WaitForSPARefresh();

		selenium.mouseOver(${locator1});

		selenium.keyPress(${locator1}, ${value1});
	}

	function keyUp() {
		WaitForSPARefresh();

		selenium.mouseOver(${locator1});

		selenium.keyUp(${locator1}, ${value1});

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

}