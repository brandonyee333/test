@default = "clickAt"
definition {

	function checkAll() {
		WaitForSPARefresh();

		selenium.waitForVisible(${locator1}, ${value1});

		selenium.mouseOver(${locator1});

		if (selenium.isNotChecked(${locator1})) {
			selenium.clickAt(${locator1}, ${value1});
		}

		selenium.assertChecked("xpath=( //div[@class='checkbox']//input[@title='Select All'])[2]");

		selenium.assertJavaScriptErrors(${value1});

		selenium.assertLiferayErrors();
	}

	function checkHiddenToggleSwitch(locator1) {
		WaitForSPARefresh();

		selenium.waitForElementPresent(${locator1}, ${value1});

		selenium.mouseOver(${locator1});

		if (selenium.isNotChecked("xpath=(${locator1})/../../input")) {
			selenium.clickAt(${locator1}, ${value1});
		}

		AssertChecked.assertCheckedHiddenToggleSwitch();

		selenium.assertJavaScriptErrors(${value1});

		selenium.assertLiferayErrors();
	}

	function checkToggleSwitch() {
		WaitForSPARefresh();

		selenium.waitForElementPresent(${locator1}, ${value1});

		selenium.mouseOver(${locator1});

		if (selenium.isNotChecked(${locator1})) {
			selenium.clickAt(${locator1}, ${value1});
		}

		AssertChecked.assertCheckedNotVisible();

		selenium.assertJavaScriptErrors(${value1});

		selenium.assertLiferayErrors();
	}

	function clickAt() {
		WaitForSPARefresh();

		selenium.waitForVisible(${locator1}, ${value1});

		selenium.mouseOver(${locator1});

		if (selenium.isNotChecked(${locator1})) {
			selenium.clickAt(${locator1}, ${value1});
		}

		AssertChecked();

		selenium.assertJavaScriptErrors(${value1});

		selenium.assertLiferayErrors();
	}

	function toggleSwitch() {
		WaitForSPARefresh();

		selenium.waitForElementPresent(${locator1}, ${value1});

		selenium.mouseOver(${locator1});

		if (selenium.isNotChecked(${locator1})) {
			selenium.clickAt(${locator1}, ${value1});
		}

		AssertElementPresent();

		selenium.assertJavaScriptErrors(${value1});

		selenium.assertLiferayErrors();
	}

}