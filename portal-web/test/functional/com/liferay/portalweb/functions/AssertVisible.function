@default = "assertVisible"
definition {

	function assertVisible() {
		WaitForSPARefresh();

		selenium.waitForVisible(${locator1}, "true");

		selenium.assertVisible(${locator1});

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function assertVisibleNoSPAWait() {
		selenium.waitForVisible(${locator1}, "true");

		selenium.assertVisible(${locator1});

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

}