@default = "selectWindow"
definition {

	function selectPopUp() {
		WaitForSPARefresh();

		selenium.pause(5000);

		selenium.selectPopUp(${value1});

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function selectWindow() {
		WaitForSPARefresh();

		selenium.pause(5000);

		selenium.selectWindow(${value1});

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function selectWindowNoSPARefresh() {
		selenium.pause(5000);

		selenium.selectWindow(${value1});

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function selectWindowTopNoSPARefresh() {
		selenium.pause(5000);

		selenium.selectWindow("null");

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

}