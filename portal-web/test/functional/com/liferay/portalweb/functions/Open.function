@default = "open"
@summary = "Open browser to '${locator1}'"
definition {

	function open(value1) {
		selenium.selectWindow("null");

		selenium.selectFrame("relative=top");

		selenium.open(${value1});

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();

		WaitForSPARefresh();
	}

	function openInTheNewTab(value2, value1, value3) {
		WaitForSPARefresh();

		selenium.executeJavaScript(${value1}, ${value2}, ${value3});

		SelectWindow.selectPopUp(locator1 = "null");

		selenium.open(${value1});
	}

	function openNoError(value1) {
		WaitForSPARefresh();

		selenium.selectWindow("null");

		selenium.selectFrame("relative=top");

		selenium.open(${value1});
	}

}