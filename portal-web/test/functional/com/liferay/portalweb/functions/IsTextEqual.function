@default = "isTextEqual"
definition {

	function isText() {
		WaitForSPARefresh();

		selenium.waitForElementPresent(${locator1}, "false");

		selenium.waitForVisible(${locator1}, "false");

		selenium.isText(${locator1}, ${value1});
	}

	function isTextEqual(locator1) {
		WaitForSPARefresh();

		if (contains(${locator1}, "/input")) {
			IsTextEqual.isValue();
		}
		else {
			IsTextEqual.isText();
		}
	}

	function isValue() {
		WaitForSPARefresh();

		selenium.waitForElementPresent(${locator1}, "false");

		selenium.waitForVisible(${locator1}, "false");

		selenium.isValue(${locator1}, ${value1});
	}

}