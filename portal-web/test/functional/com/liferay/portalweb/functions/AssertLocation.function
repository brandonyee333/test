@default = "assertLocation"
definition {

	function assertLocation() {
		WaitForSPARefresh();

		selenium.assertLocation(${value1});

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function assertPartialLocation() {
		WaitForSPARefresh();

		selenium.assertPartialLocation(${value1});

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

}