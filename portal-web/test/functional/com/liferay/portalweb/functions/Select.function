@default = "select"
definition {

	function pauseSelect() {
		WaitForSPARefresh();

		selenium.pause(5000);

		Select.select();

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function select(locator1, value1) {
		WaitForSPARefresh();

		selenium.waitForVisible(${locator1}, "true");

		selenium.mouseOver(${locator1});

		selenium.select(${locator1}, ${value1});

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

}