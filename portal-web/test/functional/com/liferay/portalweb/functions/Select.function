@default = "select"
definition {

	function pauseSelect() {
		WaitForSPARefresh();

		selenium.pause(5000);

		Select.select();

		selenium.assertJavaScriptErrors(${value1});

		selenium.assertLiferayErrors();
	}

	function select() {
		WaitForSPARefresh();

		selenium.waitForVisible(${locator1}, ${value1});

		selenium.mouseOver(${locator1});

		selenium.select(${locator1}, ${value1});

		selenium.assertJavaScriptErrors(${value1});

		selenium.assertLiferayErrors();
	}

}