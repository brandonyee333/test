@default = "assertElementPresent"
@summary = "Assert that '${locator1}' is available"
definition {

	function assertElementPresent() {
		WaitForSPARefresh();

		selenium.waitForElementPresent(${locator1}, ${value1});

		selenium.assertElementPresent(${locator1});

		selenium.assertJavaScriptErrors(${value1});

		selenium.assertLiferayErrors();
	}

	function assertVisible() {
		WaitForSPARefresh();

		selenium.waitForVisible(${locator1}, ${value1});

		selenium.assertVisible(${locator1});

		selenium.assertJavaScriptErrors(${value1});

		selenium.assertLiferayErrors();
	}

	function pauseAssertVisible() {
		WaitForSPARefresh();

		selenium.pause(2000);

		AssertElementPresent.assertVisible(locator1 = ${locator1});

		selenium.assertJavaScriptErrors(${value1});

		selenium.assertLiferayErrors();
	}

}