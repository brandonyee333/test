@default = "uploadTempFile"
definition {

	function uploadTempFile() {
		WaitForSPARefresh();

		selenium.waitForVisible(${locator1}, ${value1});

		selenium.mouseOver(${locator1});

		selenium.uploadTempFile(${locator1}, ${value1});

		selenium.assertJavaScriptErrors(${value1});

		selenium.assertLiferayErrors();
	}

	function uploadTempFileHiddenNoMouseOver() {
		WaitForSPARefresh();

		selenium.uploadTempFile(${locator1}, ${value1});

		selenium.assertJavaScriptErrors(${value1});

		selenium.assertLiferayErrors();
	}

}