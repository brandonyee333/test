@default = "copy"
definition {

	function copy(locator1) {
		WaitForSPARefresh();

		if (contains(${locator1}, "/input")) {
			Copy.valueCopy();
		}
		else {
			Copy.textCopy();
		}
	}

	function textCopy() {
		WaitForSPARefresh();

		selenium.waitForVisible(${locator1}, "true");

		selenium.mouseOver(${locator1});

		selenium.copyText(${locator1});

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function valueCopy() {
		WaitForSPARefresh();

		selenium.waitForVisible(${locator1}, "true");

		selenium.mouseOver(${locator1});

		selenium.copyValue(${locator1});

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

}