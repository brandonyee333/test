@default = "copy"
definition {

	function copy {
		WaitForSPARefresh();

		if (contains(${locator1}, "/input")) {
			Copy.valueCopy();
		}
		else {
			Copy.textCopy();
		}
	}

	function textCopy {
		WaitForSPARefresh();

		selenium.waitForVisible();

		selenium.mouseOver();

		selenium.getText();

		selenium.assertJavaScriptErrors();

		selenium.assertLiferayErrors();
	}

	function valueCopy {
		WaitForSPARefresh();

		selenium.waitForVisible();

		selenium.mouseOver();

		selenium.getElementValue();

		selenium.assertJavaScriptErrors();

		selenium.assertLiferayErrors();
	}

}