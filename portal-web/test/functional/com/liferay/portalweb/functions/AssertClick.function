@default = "assertClick"
@summary = "Click on '${locator1}' that should have a value of '${value1}'"
definition {

	function assertClick(locator1) {
		WaitForSPARefresh();

		if (contains(${locator1}, "/input")) {
			AssertClick.assertValueClickAt();
		}
		else {
			AssertClick.assertTextClickAt();
		}
	}

	function assertPartialTextClickAt(locator1, value1) {
		WaitForSPARefresh();

		AssertTextEquals.assertPartialText();

		selenium.mouseOver(${locator1});

		selenium.clickAt(${locator1}, ${value1});

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function assertTextClickAt(locator1, value1) {
		WaitForSPARefresh();

		AssertTextEquals.assertText();

		selenium.mouseOver(${locator1});

		selenium.clickAt(${locator1}, ${value1});

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function assertTextClickAtWaitForLastScript(locator1) {
		WaitForSPARefresh();

		selenium.waitForVisible(${locator1}, "true");

		AssertClick.assertTextClickAt();

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();

		selenium.waitForElementPresent(${locator1}, "true");
	}

	function assertTextClickNoMouseOver(locator1) {
		WaitForSPARefresh();

		AssertTextEquals.assertText();

		selenium.click(${locator1});

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function assertValueClickAt(locator1, value1) {
		WaitForSPARefresh();

		AssertTextEquals.assertValue();

		selenium.mouseOver(${locator1});

		selenium.clickAt(${locator1}, ${value1});

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function pauseAssertTextClickAt() {
		WaitForSPARefresh();

		selenium.pause(1000);

		AssertClick.assertTextClickAt();

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function pauseMakeVisibleAssertTextEqualsClickAt(locator1, value1) {
		WaitForSPARefresh();

		selenium.pause(1000);

		selenium.makeVisible(${locator1});

		selenium.waitForVisible(${locator1}, "true");

		selenium.waitForText(${locator1}, ${value1});

		selenium.mouseDown(${locator1});

		selenium.pause(1000);

		selenium.mouseUp(${locator1});

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function waitForDMHomeAssertTextEqualsClick(locator1) {
		WaitForSPARefresh();

		selenium.waitForElementPresent(${locator1}, "true");

		selenium.pause(1500);

		AssertClick.assertTextClickAt();

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

}