@default = "paste"
definition {

	function ckEditorPaste() {
		WaitForSPARefresh();

		selenium.waitForVisible(${locator1}, "false");

		selenium.pause(1000);

		selenium.selectFrame(${locator1});

		selenium.waitForVisible(${locator1}, "false");

		selenium.mouseOver("//html/body");

		selenium.paste("//html/body");

		selenium.selectFrame("relative=parent");

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function paste() {
		WaitForSPARefresh();

		selenium.waitForVisible(${locator1}, "false");

		selenium.mouseOver(${locator1});

		selenium.paste(${locator1});

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

}