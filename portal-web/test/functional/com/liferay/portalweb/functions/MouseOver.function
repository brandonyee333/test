@default = "mouseOver"
@summary = "Mouse over '${locator1}'"
definition {

	function mouseOver() {
		WaitForSPARefresh();

		selenium.waitForVisible(${locator1}, "false");

		selenium.mouseOver(${locator1});

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function mouseOverClickNavigation() {
		WaitForSPARefresh();

		selenium.clickAt("//div[contains(@class,'portlet')]/span[contains(.,'Navigation Menu')]", "");

		selenium.waitForElementPresent(${locator1}, "false");

		MouseOver.mouseOver();

		selenium.pause(1000);

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function mouseOverInvisible() {
		WaitForSPARefresh();

		selenium.waitForElementPresent(${locator1}, "false");

		selenium.mouseOver(${locator1});

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function mouseOverNotVisible() {
		WaitForSPARefresh();

		selenium.waitForElementPresent(${locator1}, "false");

		selenium.mouseOver(${locator1});

		selenium.waitForVisible(${locator1}, "false");

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

}