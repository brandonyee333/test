@default = "mouseOver"
@summary = "Mouse over '${locator1}'"
definition {

	function mouseOver(locator1) {
		WaitForSPARefresh();

		selenium.waitForVisible(${locator1}, "true");

		selenium.mouseOver(${locator1});

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function mouseOverClickNavigation(locator1) {
		WaitForSPARefresh();

		selenium.clickAt("//div[contains(@class,'portlet')]/span[contains(.,'Navigation Menu')]", "");

		selenium.waitForElementPresent(${locator1}, "true");

		MouseOver.mouseOver();

		selenium.pause(1000);

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function mouseOverInvisible(locator1) {
		WaitForSPARefresh();

		selenium.waitForElementPresent(${locator1}, "true");

		selenium.mouseOver(${locator1});

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function mouseOverNotVisible(locator1) {
		WaitForSPARefresh();

		selenium.waitForElementPresent(${locator1}, "true");

		selenium.mouseOver(${locator1});

		selenium.waitForVisible(${locator1}, "true");

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

}