@default = "type"
@summary = "Type to '${locator1}' the value '${value1}'"
definition {

	function clickAtType() {
		WaitForSPARefresh();

		selenium.waitForVisible(${locator1}, "true");

		selenium.waitForEditable(${locator1});

		selenium.mouseOver(${locator1});

		selenium.clickAt(${locator1}, ${value1});

		selenium.pause(1000);

		selenium.type(${locator1}, ${value1});

		selenium.pause(1000);

		selenium.clickAt(${locator1}, ${value1});

		selenium.pause(1000);

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function sendKeys() {
		WaitForSPARefresh();

		selenium.waitForVisible(${locator1}, "true");

		selenium.waitForEditable(${locator1});

		selenium.mouseOver(${locator1});

		selenium.sendKeys(${locator1}, ${value1});

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function sendKeysAceEditor() {
		WaitForSPARefresh();

		selenium.waitForElementPresent(${locator1}, "true");

		selenium.waitForEditable(${locator1});

		selenium.mouseOver(${locator1});

		selenium.sendKeysAceEditor(${locator1}, ${value1});

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function sendKeysApplicationSearch() {
		WaitForSPARefresh();

		selenium.waitForElementPresent(${locator1}, "true");

		selenium.waitForEditable(${locator1});

		Type.sendKeys();

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function type() {
		WaitForSPARefresh();

		selenium.waitForVisible(${locator1}, "true");

		selenium.waitForEditable(${locator1});

		selenium.mouseOver(${locator1});

		selenium.type(${locator1}, ${value1});

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function typeAceEditor() {
		WaitForSPARefresh();

		selenium.waitForElementPresent(${locator1}, "true");

		selenium.waitForEditable(${locator1});

		selenium.mouseOver(${locator1});

		selenium.typeAceEditor(${locator1}, ${value1});

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function typeAceEditorNoMouseOver() {
		WaitForSPARefresh();

		selenium.waitForElementPresent(${locator1}, "true");

		selenium.waitForEditable(${locator1});

		selenium.typeAceEditor(${locator1}, ${value1});

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function typeClickAt() {
		WaitForSPARefresh();

		selenium.waitForVisible(${locator1}, "true");

		selenium.waitForEditable(${locator1});

		selenium.mouseOver(${locator1});

		selenium.type(${locator1}, ${value1});

		selenium.clickAt(${locator1}, ${value1});

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function typeCodeMirrorEditorNoError() {
		WaitForSPARefresh();

		selenium.waitForElementPresent(${locator1}, "true");

		selenium.mouseOver(${locator1});

		selenium.typeCodeMirrorEditor(${locator1}, ${value1});
	}

	function typeEditor() {
		WaitForSPARefresh();

		selenium.waitForVisible(${locator1}, "true");

		selenium.waitForEditable(${locator1});

		selenium.mouseOver(${locator1});

		selenium.typeEditor(${locator1}, ${value1});

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function typeEditorWaitForEditor() {
		WaitForSPARefresh();

		selenium.waitForVisible(${locator1}, "true");

		selenium.pause(1000);

		selenium.waitForEditable(${locator1});

		Type.typeEditor();

		selenium.pause(1000);

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function typeNotVisibleNoMouseOver() {
		WaitForSPARefresh();

		selenium.waitForEditable(${locator1});

		selenium.type(${locator1}, ${value1});

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function typePause() {
		WaitForSPARefresh();

		selenium.waitForVisible(${locator1}, "true");

		selenium.waitForEditable(${locator1});

		selenium.mouseOver(${locator1});

		selenium.type(${locator1}, ${value1});

		selenium.pause(1000);

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

}