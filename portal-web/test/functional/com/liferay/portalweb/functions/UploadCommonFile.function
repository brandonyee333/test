@default = "uploadCommonFile"
definition {

	function uploadCommonFile(locator1, value1) {
		WaitForSPARefresh();

		

		selenium.mouseOver(${locator1});

		selenium.uploadCommonFile(${locator1}, ${value1});

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function uploadCommonFileHidden(locator1, value1) {
		WaitForSPARefresh();

		selenium.mouseOver(${locator1});

		selenium.uploadCommonFile(${locator1}, ${value1});

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

	function uploadCommonFileHiddenNoMouseOver(locator1, value1) {
		WaitForSPARefresh();

		

		selenium.uploadCommonFile(${locator1}, ${value1});

		selenium.assertJavaScriptErrors("true");

		selenium.assertLiferayErrors();
	}

}