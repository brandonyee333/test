<html>
<head>
<title>Ratings</title>
</head>

<body>
<table border="1" cellpadding="1" cellspacing="1">
<thead>
<tr><td rowspan="1" colspan="3">Ratings</td></tr>
</thead>

<tbody>
<tr>
	<td>DISPLAY_VOTES</td>
	<td>//div[contains(@class,'ratings')]//a</td>
	<td></td>
</tr>
<tr>
	<td>THUMB</td>
	<td>//div[contains(@class,'ratings')]//a[contains(@class,'${key_ratingResult}')]</td>
	<td></td>
</tr>
<tr>
	<td>THUMBS_UP</td>
	<td>//div[contains(@class,'ratings')]//a[contains(@class,'thumbs-up')]</td>
	<td></td>
</tr>
<tr>
	<td>THUMB_UP_OFF</td>
	<td>//span[contains(@class,'thumb-up') and contains(@class,'rating-off')]</td>
	<td></td>
</tr>
<tr>
	<td>THUMBS_DOWN</td>
	<td>//div[contains(@class,'ratings')]//a[contains(@class,'thumbs-down')]</td>
	<td></td>
</tr>
<tr>
	<td>THUMB_DOWN_OFF</td>
	<td>//span[contains(@class,'thumb-down') and contains(@class,'rating-off')]</td>
	<td></td>
</tr>
<tr>
	<td>COMMENT_RATING_THUMB</td>
	<td>//div[(@class='lfr-discussion-body')]//div[contains(@class,'ratings')]//a[contains(@class,'${key_ratingResult}')]</td>
	<td></td>
</tr>
<tr>
	<td>REPLY_RATING_THUMB</td>
	<td>//h4[contains(@title,'RE: ${key_threadSubject}')]//following-sibling::div//button[contains(@title,'${key_ratingResult}') or contains(@data-title,'${key_ratingResult}')]</td>
	<td></td>
</tr>

<!--YOUR_RATING-->

<tr>
	<td>YOUR_RATING_LABEL</td>
	<td>xPath=(//div[@class='rating-label'])[1]</td>
	<td></td>
</tr>
<tr>
	<td>YOUR_RATING_STAR_1</td>
	<td>xPath=(//div[contains(@id,'_ratingStar')]//a[@class='rating-element icon-star'])[1]</td>
	<td></td>
</tr>
<tr>
	<td>YOUR_RATING_STAR_2</td>
	<td>xPath=(//div[contains(@id,'_ratingStar')]//a[@class='rating-element icon-star'])[2]</td>
	<td></td>
</tr>
<tr>
	<td>YOUR_RATING_STAR_3</td>
	<td>xPath=(//div[contains(@id,'_ratingStar')]//a[@class='rating-element icon-star'])[3]</td>
	<td></td>
</tr>
<tr>
	<td>YOUR_RATING_STAR_4</td>
	<td>xPath=(//div[contains(@id,'_ratingStar')]//a[@class='rating-element icon-star'])[4]</td>
	<td></td>
</tr>
<tr>
	<td>YOUR_RATING_STAR_5</td>
	<td>xPath=(//div[contains(@id,'_ratingStar')]//a[@class='rating-element icon-star'])[5]</td>
	<td></td>
</tr>
<tr>
	<td>YOUR_RATING_STAR_COUNT</td>
	<td>//div[contains(@class,'ratings-stars-dropdown')]//button[contains(.,'Rate this ${key_ratingStarCount} stars out of 5')]</td>
	<td></td>
</tr>
<tr>
	<td>YOUR_RATING_STAR_DELETE</td>
	<td>//div[contains(@class,'ratings-stars')]//button[@class='dropdown-item' and contains(.,'Delete')]</td>
	<td></td>
</tr>
<tr>
	<td>YOUR_RATING_STAR_DELETE_DISABLE</td>
	<td>//div[contains(@class,'ratings-stars')]//button[contains(@class,'dropdown-item disabled') and contains(.,'Delete')]</td>
	<td></td>
</tr>
<tr>
	<td>YOUR_RATING_STAR_EMPTY_1</td>
	<td>xPath=(//div[contains(@id,'_ratingStar')]//a[@class='rating-element icon-star-empty'])[1]</td>
	<td></td>
</tr>
<tr>
	<td>YOUR_RATING_STAR_EMPTY_2</td>
	<td>xPath=(//div[contains(@id,'_ratingStar')]//a[@class='rating-element icon-star-empty'])[2]</td>
	<td></td>
</tr>
<tr>
	<td>YOUR_RATING_STAR_EMPTY_3</td>
	<td>xPath=(//div[contains(@id,'_ratingStar')]//a[@class='rating-element icon-star-empty'])[3]</td>
	<td></td>
</tr>
<tr>
	<td>YOUR_RATING_STAR_EMPTY_4</td>
	<td>xPath=(//div[contains(@id,'_ratingStar')]//a[@class='rating-element icon-star-empty'])[4]</td>
	<td></td>
</tr>
<tr>
	<td>YOUR_RATING_STAR_EMPTY_5</td>
	<td>xPath=(//div[contains(@id,'_ratingStar')]//a[@class='rating-element icon-star-empty'])[5]</td>
	<td></td>
</tr>
<tr>
	<td>YOUR_RATING_STAR</td>
	<td>xPath=(//div[contains(@id,'_ratingStar')]//a[@class='rating-element icon-star'])[${key_ratingStarPosition}]</td>
	<td></td>
</tr>
<tr>
	<td>YOUR_RATING_STAR_EMPTY</td>
	<td>xPath=(//div[contains(@id,'_ratingStar')]//a[@class='rating-element icon-star-empty'])[${key_emptyStarPosition}]</td>
	<td></td>
</tr>
<tr>
	<td>YOUR_RATING_STAR_RESULT</td>
	<td>//div[contains(@class,'ratings-stars')]//button[contains(@title,'You have rated this ${key_ratingStarCount} stars out of 5') or contains(@data-title,'You have rated this ${key_ratingStarCount} stars out of 5')]</td>
	<td></td>
</tr>
<tr>
	<td>YOUR_RATING_STACKED_STAR_RESULT</td>
	<td>//div[contains(@class,'stacked-stars')]//label[contains(@class,'ratings-stars-star-full') and contains(@for,'star${key_ratingStarCount}')]</td>
	<td></td>
</tr>
<tr>
	<td></td>
	<td></td>
	<td></td>
</tr>

<!--AVERAGE-->

<tr>
	<td>AVERAGE_LABEL</td>
	<td>xPath=(//div[@class='rating-label'])[2]</td>
	<td></td>
</tr>
<tr>
	<td>AVERAGE_STAR_1</td>
	<td>xPath=(//div[contains(@id,'_ratingScore')]//span[@class='rating-element icon-star'])[1]</td>
	<td></td>
</tr>
<tr>
	<td>AVERAGE_STAR_2</td>
	<td>xPath=(//div[contains(@id,'_ratingScore')]//span[@class='rating-element icon-star'])[2]</td>
	<td></td>
</tr>
<tr>
	<td>AVERAGE_STAR_3</td>
	<td>xPath=(//div[contains(@id,'_ratingScore')]//span[@class='rating-element icon-star'])[3]</td>
	<td></td>
</tr>
<tr>
	<td>AVERAGE_STAR_4</td>
	<td>xPath=(//div[contains(@id,'_ratingScore')]//span[@class='rating-element icon-star'])[4]</td>
	<td></td>
</tr>
<tr>
	<td>AVERAGE_STAR_5</td>
	<td>xPath=(//div[contains(@id,'_ratingScore')]//span[@class='rating-element icon-star'])[5]</td>
	<td></td>
</tr>
<tr>
	<td>AVERAGE_STAR_EMPTY_1</td>
	<td>xPath=(//div[contains(@id,'_ratingScore')]//span[@class='rating-element icon-star-empty'])[1]</td>
	<td></td>
</tr>
<tr>
	<td>AVERAGE_STAR_EMPTY_2</td>
	<td>xPath=(//div[contains(@id,'_ratingScore')]//span[@class='rating-element icon-star-empty'])[2]</td>
	<td></td>
</tr>
<tr>
	<td>AVERAGE_STAR_EMPTY_3</td>
	<td>xPath=(//div[contains(@id,'_ratingScore')]//span[@class='rating-element icon-star-empty'])[3]</td>
	<td></td>
</tr>
<tr>
	<td>AVERAGE_STAR_EMPTY_4</td>
	<td>xPath=(//div[contains(@id,'_ratingScore')]//span[@class='rating-element icon-star-empty'])[4]</td>
	<td></td>
</tr>
<tr>
	<td>AVERAGE_STAR_EMPTY_5</td>
	<td>xPath=(//div[contains(@id,'_ratingScore')]//span[@class='rating-element icon-star-empty'])[5]</td>
	<td></td>
</tr>
<tr>
	<td>AVERAGE_STAR</td>
	<td>xPath=(//div[contains(@id,'_ratingScore')]//span[@class='rating-element icon-star'])[${key_averageRatingStar}]</td>
	<td></td>
</tr>
<tr>
	<td>AVERAGE_STAR_DISABLE</td>
	<td>xPath=(//div[contains(@id,'_ratingScore')]//span[(@class='rating-element icon-star-empty') and (@title='Ratings are disabled in Staging')])[${key_averageDisableStar}]</td>
	<td></td>
</tr>
<tr>
	<td>AVERAGE_STAR_EMPTY</td>
	<td>xPath=(//div[contains(@id,'_ratingScore')]//span[@class='rating-element icon-star-empty'])[${key_averageEmptyStar}]</td>
	<td></td>
</tr>
</tbody>
</table>
</body>
</html>