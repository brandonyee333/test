<html>
<head>
<title>Card</title>
</head>

<body>
<table border="1" cellpadding="1" cellspacing="1">
<thead>
<tr><td rowspan="1" colspan="3">Card</td></tr>
</thead>

<tbody>
<tr>
	<td>CARD_TITLE</td>
	<td>//*[contains(@class,'card-title')][.//*[normalize-space(text())='${key_card}']] | //*[contains(@class,'card-title')][normalize-space(text())='${key_card}']</td>
	<td></td>
</tr>
<tr>
	<td>GENERIC_LARGE_TEXT</td>
	<td>//div[contains(@class,'vertical-card')]//span[contains(@class,'lfr-card-title-text')]</td>
	<td></td>
</tr>
<tr>
	<td>SPECIFIC_CHECKBOX</td>
	<td>//div[contains(@class,'vertical-card') and contains(.,'${key_cardText}')]//input[@type='checkbox']</td>
	<td></td>
</tr>
<tr>
	<td>SPECIFIC_LARGE_TEXT</td>
	<td>//div[contains(@class,'vertical-card') and contains(.,'${key_cardText}')]//span[contains(@class,'lfr-card-title-text')]</td>
	<td></td>
</tr>
<tr>
	<td>SPECIFIC_SMALL_TEXT</td>
	<td>//div[contains(@class,'vertical-card') and contains(.,'${key_cardText}')]//span[contains(@class,'lfr-card-workflow-text')]</td>
	<td></td>
</tr>
<tr>
	<td>SPECIFIC_TEXT</td>
	<td>//div[contains(@class,'vertical-card') and contains(.,'${key_cardText}')]//span[contains(@class,'lfr-card-subtitle-text')]</td>
	<td></td>
</tr>
</tbody>
</table>
</body>
</html>