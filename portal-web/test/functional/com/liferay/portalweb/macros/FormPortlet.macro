definition {

	var validationErrorMessage = "This field is required.";

	@summary = "Default summary"
	macro clickSubmit() {
		AssertClick(
			locator1 = "Button#SUBMIT_1",
			value1 = "Submit");
	}

	@summary = "Default summary"
	macro nextPage(formPageCurrent = null, formPageNext = null) {
		AssertClick(
			locator1 = "Button#NEXT",
			value1 = "Next");

		var key_formPageName = ${formPageCurrent};

		AssertTextEquals(
			locator1 = "FormPortlet#FORM_PAGE_INACTIVE",
			value1 = ${formPageCurrent});

		var key_formPageName = ${formPageNext};

		AssertTextEquals(
			locator1 = "FormPortlet#FORM_PAGE_ACTIVE",
			value1 = ${formPageNext});
	}

	@summary = "Default summary"
	macro submit() {
		Click(locator1 = "FormPortlet#FORM_CONTENT");

		FormPortlet.clickSubmit();
	}

	@summary = "Default summary"
	macro submitLocalizedSuccessfully(buttonName = null) {
		AssertClick(
			locator1 = "Button#MAIN_CONTENT_SUBMIT",
			value1 = ${buttonName});

		Alert.viewSuccessMessage();
	}

	@summary = "Default summary"
	macro submitSuccessfully() {
		FormPortlet.submit();

		Alert.viewSuccessMessage();
	}

	@summary = "Default summary"
	macro submitWithError(errorMessage = null) {
		FormPortlet.submit();

		AssertTextEquals(
			locator1 = "Message#ERROR",
			value1 = ${errorMessage});
	}

	@summary = "Default summary"
	macro submitWithValidationError(validationErrorMessage = null) {
		FormPortlet.submit();

		AssertTextEquals(
			locator1 = "Message#ERROR_FORM_FIELD_REQUIRED",
			value1 = ${validationErrorMessage});
	}

	@summary = "Default summary"
	macro waitFormRenderer(text = null) {
		var key_text = ${text};

		WaitForElementPresent(locator1 = "Button#ANY_ENABLED");

		Pause(value1 = 2500);
	}

}