definition {

	@summary = "Default summary"
	macro addPollChoice(choiceField = null, pollsQuestionChoice = null) {
		var key_choiceField = ${choiceField};

		Type(
			locator1 = "Polls#CHOICE_FIELD",
			value1 = ${pollsQuestionChoice});
	}

	@summary = "Default summary"
	macro addPollCP(pollsQuestionChoiceB = null, pollsQuestion = null, pollsQuestionChoiceA = null, pollsQuestionTitle = null, permissionsViewRole = null, pollsQuestionChoiceE = null, pollsQuestionChoiceD = null, pollsQuestionChoiceC = null) {
		LexiconEntry.gotoAdd();

		PortletEntry.inputTitle(title = ${pollsQuestionTitle});

		PortletEntry.inputDescription(description = ${pollsQuestion});

		Type(
			locator1 = "TextInput#POLL_CHOICE_A",
			value1 = ${pollsQuestionChoiceA});

		Type(
			locator1 = "TextInput#POLL_CHOICE_B",
			value1 = ${pollsQuestionChoiceB});

		AssertChecked(
			locator1 = "Checkbox#NEVER_EXPIRE",
			value1 = "Never Expire");

		if (isSet(pollsQuestionChoiceC)) {
			AssertClick(
				locator1 = "Polls#ADD_CHOICE_BUTTON",
				value1 = "Add Choice");

			Type(
				locator1 = "Polls#CHOICE_C_FIELD",
				value1 = ${pollsQuestionChoiceC});
		}

		AssertChecked(
			locator1 = "Checkbox#NEVER_EXPIRE",
			value1 = "Never Expire");

		if (isSet(pollsQuestionChoiceD)) {
			AssertClick(
				locator1 = "Polls#ADD_CHOICE_BUTTON",
				value1 = "Add Choice");

			Type(
				locator1 = "Polls#CHOICE_D_FIELD",
				value1 = ${pollsQuestionChoiceD});
		}

		AssertChecked(
			locator1 = "Checkbox#NEVER_EXPIRE",
			value1 = "Never Expire");

		if (isSet(pollsQuestionChoiceE)) {
			AssertClick(
				locator1 = "Polls#ADD_CHOICE_BUTTON",
				value1 = "Add Choice");

			Type(
				locator1 = "Polls#CHOICE_E_FIELD",
				value1 = ${pollsQuestionChoiceE});
		}

		AssertChecked(
			locator1 = "Checkbox#NEVER_EXPIRE",
			value1 = "Never Expire");

		if (isSet(permissions)) {
			Panel.expandPanel(panelHeading = "Permissions");

			var key_permissionsViewRole = ${permissionsViewRole};

			Select(
				locator1 = "Select#PERMISSIONS_VIEW_ROLE",
				value1 = ${permissionsViewRole});
		}

		AssertClick(
			locator1 = "Button#SAVE",
			value1 = "Save");
	}

	@summary = "Default summary"
	macro addPollCPWithExpirationDate(pollsQuestionChoiceB = null, pollsQuestion = null, pollsQuestionChoiceA = null, pollsQuestionTitle = null, permissionsViewRole = null, pollsQuestionChoiceE = null, pollsQuestionChoiceD = null, expirationDate = null, pollsQuestionChoiceC = null) {
		LexiconEntry.gotoAdd();

		PortletEntry.inputTitle(title = ${pollsQuestionTitle});

		PortletEntry.inputDescription(description = ${pollsQuestion});

		Type(
			locator1 = "TextInput#POLL_CHOICE_A",
			value1 = ${pollsQuestionChoiceA});

		Type(
			locator1 = "TextInput#POLL_CHOICE_B",
			value1 = ${pollsQuestionChoiceB});

		AssertChecked(
			locator1 = "Checkbox#NEVER_EXPIRE",
			value1 = "Never Expire");

		Uncheck(
			locator1 = "Checkbox#NEVER_EXPIRE",
			value1 = "Never Expire");

		Type(
			locator1 = "TextInput#EXPIRATION_DATE",
			value1 = ${expirationDate});

		if (isSet(pollsQuestionChoiceC)) {
			AssertClick(
				locator1 = "Polls#ADD_CHOICE_BUTTON",
				value1 = "Add Choice");

			Type(
				locator1 = "Polls#CHOICE_C_FIELD",
				value1 = ${pollsQuestionChoiceC});
		}

		AssertNotChecked(
			locator1 = "Checkbox#NEVER_EXPIRE",
			value1 = "Never Expire");

		AssertTextEquals(
			locator1 = "TextInput#EXPIRATION_DATE",
			value1 = ${expirationDate});

		if (isSet(pollsQuestionChoiceD)) {
			AssertClick(
				locator1 = "Polls#ADD_CHOICE_BUTTON",
				value1 = "Add Choice");

			Type(
				locator1 = "Polls#CHOICE_D_FIELD",
				value1 = ${pollsQuestionChoiceD});
		}

		AssertNotChecked(
			locator1 = "Checkbox#NEVER_EXPIRE",
			value1 = "Never Expire");

		AssertTextEquals(
			locator1 = "TextInput#EXPIRATION_DATE",
			value1 = ${expirationDate});

		if (isSet(pollsQuestionChoiceE)) {
			AssertClick(
				locator1 = "Polls#ADD_CHOICE_BUTTON",
				value1 = "Add Choice");

			Type(
				locator1 = "Polls#CHOICE_E_FIELD",
				value1 = ${pollsQuestionChoiceE});
		}

		AssertNotChecked(
			locator1 = "Checkbox#NEVER_EXPIRE",
			value1 = "Never Expire");

		AssertTextEquals(
			locator1 = "TextInput#EXPIRATION_DATE",
			value1 = ${expirationDate});

		if (isSet(permissions)) {
			Panel.expandPanel(panelHeading = "Permissions");

			var key_permissionsViewRole = ${permissionsViewRole};

			Select(
				locator1 = "Select#PERMISSIONS_VIEW_ROLE",
				value1 = ${permissionsViewRole});
		}

		AssertClick(
			locator1 = "Button#SAVE",
			value1 = "Save");
	}

	@summary = "Default summary"
	macro addPollPG(pollsQuestionChoiceB = null, pollsQuestion = null, pollsQuestionChoiceA = null, pollsQuestionTitle = null) {
		AssertClick.assertPartialTextClickAt(
			locator1 = "Polls#ADD_NEW_POLL",
			value1 = "Add");

		IFrame.selectDialogFrame();

		LexiconEntry.gotoAdd();

		PortletEntry.inputTitle(title = ${pollsQuestionTitle});

		PortletEntry.inputDescription(description = ${pollsQuestion});

		Type(
			locator1 = "TextInput#POLL_CHOICE_A",
			value1 = ${pollsQuestionChoiceA});

		Type(
			locator1 = "TextInput#POLL_CHOICE_B",
			value1 = ${pollsQuestionChoiceB});

		Button.clickSave();

		SelectFrame(value1 = "relative=top");
	}

	@summary = "Default summary"
	macro selectPollPG(pollsQuestionTitle = null) {
		Click.makeVisibleClickAt(locator1 = "Polls#SELECT_QUESTION");

		IFrame.selectDialogFrame();

		Select(
			locator1 = "Polls#TITLE_DROPDOWN_SELECT",
			value1 = ${pollsQuestionTitle});

		PortletEntry.save();

		AssertSelectedLabel(
			locator1 = "Polls#TITLE_DROPDOWN_SELECT",
			value1 = ${pollsQuestionTitle});

		SelectFrame(value1 = "relative=top");
	}

	@summary = "Default summary"
	macro tearDownCP() {
		Navigator.openURL();

		ProductMenu.gotoPortlet(
			category = "Content",
			panel = "Site Administration",
			portlet = "Polls");

		while (IsElementPresent(locator1 = "Polls#POLLS_TABLE_ACTIONS_GENERIC")) {
			Click(locator1 = "Polls#POLLS_TABLE_ACTIONS_GENERIC");

			MenuItem.clickNoError(menuItem = "Delete");

			Confirm.waitForConfirmation(value1 = "Are you sure you want to delete this? It will be deleted immediately.");

			AssertTextEquals.assertPartialText(
				locator1 = "Message#SUCCESS",
				value1 = "Your request completed successfully.");
		}
	}

	@summary = "Default summary"
	macro viewEmptyChoiceErrorMessage() {
		AssertTextEquals(
			locator1 = "Message#ERROR",
			value1 = "Please enter valid choices.");
	}

	@summary = "Default summary"
	macro viewPollAsGuestPG(pollsQuestion = null, pollsQuestionChoiceList = null) {
		var key_pollsQuestion = ${pollsQuestion};

		AssertTextEquals.assertPartialText(
			locator1 = "Polls#POLL_QUESTION",
			value1 = "What is your favorite Liferay portlet?");

		for (var questionChoiceList : list ${pollsQuestionChoiceList}) {
			var key_pollsQuestionChoice = ${questionChoiceList};

			AssertElementNotPresent(locator1 = "Polls#POLL_QUESTION_CHOICE");
		}

		AssertElementNotPresent(locator1 = "Button#VOTE");

		AssertTextEquals(
			locator1 = "Message#INFO",
			value1 = "Please sign in to vote.");
	}

	@summary = "Default summary"
	macro viewPollChartArea(pollsQuestionTitle = null) {
		var key_pollsQuestionTitle = ${pollsQuestionTitle};

		Click(locator1 = "Polls#POLLS_TABLE_TITLE");

		Click(locator1 = "Polls#CHART_AREA");

		SelectWindow.selectPopUp(locator1 = "null");

		AssertElementPresent(locator1 = "Polls#CHART_IMAGE");

		Close.closeWindow(locator1 = "null");
	}

	@summary = "Default summary"
	macro viewPollPG(pollsQuestion = null, pollsQuestionChoiceList = null) {
		var key_pollsQuestion = ${pollsQuestion};

		AssertTextEquals.assertPartialText(
			locator1 = "Polls#POLL_QUESTION",
			value1 = ${pollsQuestion});

		for (var questionChoiceList : list ${pollsQuestionChoiceList}) {
			var key_pollsQuestionChoice = ${questionChoiceList};

			AssertTextPresent(
				locator1 = "Polls#POLL_QUESTION_CHOICE",
				value1 = ${questionChoiceList});
		}

		AssertTextEquals(
			locator1 = "Button#VOTE",
			value1 = "Vote");
	}

	@summary = "Default summary"
	macro viewVotedPollPG(pollsQuestionTotalVotes = null, pollsQuestionVotePercent = null, pollsQuestionChoice = null, pollsQuestionVoteCount = null) {
		var key_pollsQuestionChoice = ${pollsQuestionChoice};

		AssertTextEquals(
			locator1 = "Polls#VOTES_PERCENTAGE",
			value1 = ${pollsQuestionVotePercent});

		AssertTextEquals(
			locator1 = "Polls#VOTES_NUMBER",
			value1 = ${pollsQuestionVoteCount});

		var key_pollsQuestionTotalVotes = ${pollsQuestionTotalVotes};

		AssertTextEquals.assertPartialText(
			locator1 = "Polls#VOTES_TOTAL",
			value1 = "Total Votes: ${pollsQuestionTotalVotes}");
	}

	@summary = "Default summary"
	macro votePollPG(pollsQuestionChoice = null) {
		var key_pollsQuestionChoice = ${pollsQuestionChoice};

		Click(locator1 = "Polls#POLL_QUESTION_CHOICE");

		AssertClick(
			locator1 = "Button#VOTE",
			value1 = "Vote");

		AssertTextEquals.assertPartialText(
			locator1 = "Message#SUCCESS",
			value1 = "Thank you for your vote.");
	}

}