definition {

	@summary = "Default summary"
	macro deleteEntry(wikiPageTitle = null) {
		Click(locator1 = "Icon#DISPLAY_STYLE_LIST");

		var key_wikiPageTitle = ${wikiPageTitle};

		Click(locator1 = "WikiTable#ALL_PAGES_VERTICAL_ELLIPSIS");

		PortletEntry.clickMoveToRecycleBin();
	}

	@summary = "Default summary"
	macro restoreEntry(wikiPageTitle = null) {
		var key_wikiPageTitle = ${wikiPageTitle};

		Click(locator1 = "WikiTable#ALL_PAGES_VERTICAL_ELLIPSIS");

		MenuItem.click(menuItem = "Restore");
	}

	@summary = "Default summary"
	macro viewEntry(wikiPageTitle = null, draftStatus = null) {
		var key_wikiPageTitle = ${wikiPageTitle};

		AssertTextEquals(
			locator1 = "WikiTable#ALL_PAGES_WIKI_PAGE_TITLE",
			value1 = ${wikiPageTitle});

		AssertTextEquals(
			locator1 = "WikiTable#ALL_PAGES_STATUS",
			value1 = ${draftStatus});
	}

	@summary = "Default summary"
	macro viewNoEntry(wikiPageTitle = null) {
		var key_wikiPageTitle = ${wikiPageTitle};

		AssertElementNotPresent(locator1 = "WikiTable#ALL_PAGES_WIKI_PAGE_TITLE");
	}

}