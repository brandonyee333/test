definition {

	@summary = "Default summary"
	macro populateFieldCheckBox(wfFieldValue = null, wfFieldName = null) {
		var key_wfFieldName = ${wfFieldName};

		AssertTextEquals(
			locator1 = "WebForm#FORM_FIELDS_CHECKBOX_FIELD_HEADER",
			value1 = ${wfFieldName});

		AssertElementPresent(locator1 = "WebForm#FORM_FIELDS_CHECKBOX_FIELD");

		if (${wfFieldValue} == "true") {
			Check(locator1 = "WebForm#FORM_FIELDS_CHECKBOX_FIELD");
		}
		else if (${wfFieldValue} == "false") {
			Uncheck(locator1 = "WebForm#FORM_FIELDS_CHECKBOX_FIELD");
		}
	}

	@summary = "Default summary"
	macro populateFieldOptions(wfFieldValue = null, wfFieldName = null) {
		var key_wfFieldName = ${wfFieldName};

		AssertTextEquals(
			locator1 = "WebForm#FORM_FIELDS_FIELD_HEADER",
			value1 = ${wfFieldName});

		Select(
			locator1 = "WebForm#FORM_FIELDS_OPTIONS_FIELD",
			value1 = ${wfFieldValue});
	}

	@summary = "Default summary"
	macro populateFieldRadio(wfFieldValue = null, wfFieldName = null) {
		var key_wfFieldName = ${wfFieldName};

		AssertTextEquals(
			locator1 = "WebForm#FORM_FIELDS_FIELD_HEADER",
			value1 = ${wfFieldName});

		var key_wfRadioFieldOption = ${wfFieldValue};

		Click(locator1 = "WebForm#FORM_FIELDS_RADIO_FIELD_OPTION");
	}

	@summary = "Default summary"
	macro populateFieldText(wfFieldValue = null, wfFieldName = null) {
		var key_wfFieldName = ${wfFieldName};

		AssertTextEquals(
			locator1 = "WebForm#FORM_FIELDS_FIELD_HEADER",
			value1 = ${wfFieldName});

		Type(
			locator1 = "WebForm#FORM_FIELDS_TEXT_FIELD",
			value1 = ${wfFieldValue});
	}

	@summary = "Default summary"
	macro populateFieldTextBox(wfFieldValue = null, wfFieldName = null) {
		var key_wfFieldName = ${wfFieldName};

		AssertTextEquals(
			locator1 = "WebForm#FORM_FIELDS_FIELD_HEADER",
			value1 = ${wfFieldName});

		Type(
			locator1 = "WebForm#FORM_FIELDS_TEXT_BOX_FIELD",
			value1 = ${wfFieldValue});
	}

	@summary = "Default summary"
	macro sendBlankPG() {
		AssertClick(
			locator1 = "Button#SEND",
			value1 = "Send");

		AssertElementNotPresent(locator1 = "Message#SUCCESS");

		AssertTextEquals(
			locator1 = "WebForm#FORM_FIELDS_FIELD_MANDATORY_MESSAGE",
			value1 = "This field is mandatory.");
	}

	@summary = "Default summary"
	macro sendPG() {
		Click(locator1 = "WebForm#FORM_INFORMATION_TITLE");

		AssertClick(
			locator1 = "Button#SEND",
			value1 = "Send");

		AssertElementPresent(locator1 = "Message#SUCCESS");
	}

	@summary = "Default summary"
	macro viewFormFieldCheckBox(wfFieldName = null) {
		var key_wfFieldName = ${wfFieldName};

		AssertTextEquals(
			locator1 = "WebForm#FORM_FIELDS_CHECKBOX_FIELD_HEADER",
			value1 = ${wfFieldName});

		AssertElementPresent(locator1 = "WebForm#FORM_FIELDS_CHECKBOX_FIELD");
	}

	@summary = "Default summary"
	macro viewFormFieldOptions(wfFieldName = null) {
		var key_wfFieldName = ${wfFieldName};

		AssertTextEquals(
			locator1 = "WebForm#FORM_FIELDS_FIELD_HEADER",
			value1 = ${wfFieldName});

		AssertElementPresent(locator1 = "WebForm#FORM_FIELDS_OPTIONS_FIELD");
	}

	@summary = "Default summary"
	macro viewFormFieldParagraph(wfParagraphFieldText = null) {
		AssertTextEquals(
			locator1 = "WebForm#FORM_FIELDS_PARAGRAPH_FIELD",
			value1 = ${wfParagraphFieldText});
	}

	@summary = "Default summary"
	macro viewFormFieldRadio(optionsList = null, wfFieldName = null) {
		var key_wfFieldName = ${wfFieldName};

		AssertTextEquals(
			locator1 = "WebForm#FORM_FIELDS_FIELD_HEADER",
			value1 = ${wfFieldName});

		for (var wfRadioFieldOption : list ${optionsList}) {
			var key_wfRadioFieldOption = ${wfRadioFieldOption};

			AssertTextEquals(
				locator1 = "WebForm#FORM_FIELDS_RADIO_FIELD_OPTION_LABEL",
				value1 = ${wfRadioFieldOption});
		}
	}

	@summary = "Default summary"
	macro viewFormFieldText(wfFieldName = null) {
		var key_wfFieldName = ${wfFieldName};

		AssertTextEquals(
			locator1 = "WebForm#FORM_FIELDS_FIELD_HEADER",
			value1 = ${wfFieldName});

		AssertElementPresent(locator1 = "WebForm#FORM_FIELDS_TEXT_FIELD");
	}

	@summary = "Default summary"
	macro viewFormFieldTextBox(wfFieldName = null) {
		var key_wfFieldName = ${wfFieldName};

		AssertTextEquals(
			locator1 = "WebForm#FORM_FIELDS_FIELD_HEADER",
			value1 = ${wfFieldName});

		AssertElementPresent(locator1 = "WebForm#FORM_FIELDS_TEXT_BOX_FIELD");
	}

	@summary = "Default summary"
	macro viewPG(wfInformationDescription = null, wfInformationTitle = null) {
		AssertTextEquals(
			locator1 = "WebForm#FORM_INFORMATION_TITLE",
			value1 = ${wfInformationTitle});

		AssertTextEquals(
			locator1 = "WebForm#FORM_INFORMATION_DESCRIPTION",
			value1 = ${wfInformationDescription});
	}

}