definition {

	@summary = "Default summary"
	macro addContent(content = null) {
		SelectFrame(locator1 = "CKEditor#BODY_FIELD_IFRAME");

		KeyPress(
			locator1 = "CKEditor#BODY",
			value1 = ${content});

		SelectFrame(value1 = "relative=top");
	}

	@summary = "Default summary"
	macro assertEditorPresent() {
		AssertElementPresent(locator1 = "CKEditor#BODY_FIELD");
	}

	@summary = "Default summary"
	macro viewEntryContent(content = null) {
		AssertTextEquals(
			locator1 = "CKEditor#BODY",
			value1 = ${content});
	}

}