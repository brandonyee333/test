definition {

	@summary = "Default summary"
	macro dragAndDropPortletToPortletColumnPG(portletColumnNumberTo = null, columnNumberFrom = null, portletName = null) {
		var key_portletTitleName = ${portletName};

		MakeVisible(locator1 = "Home#PAGE_COLUMN_PORTLET_COLUMN_${columnNumberFrom}_PORTLET_HEADER");

		AssertTextEquals(
			locator1 = "Home#PAGE_COLUMN_PORTLET_COLUMN_${columnNumberFrom}_PORTLET_HEADER",
			value1 = ${portletName});

		DragAndDrop.dragAndDropPortletToObject(
			locator1 = "Home#PAGE_COLUMN_PORTLET_COLUMN_${columnNumberFrom}_PORTLET_HEADER",
			locator2 = "Home#PORTLET_COLUMN_${portletColumnNumberTo}",
			value1 = ${portletName});

		AssertTextEquals(
			locator1 = "Home#PORTLET_COLUMN_${portletColumnNumberTo}_NESTED_PORTLET_TITLE",
			value1 = ${portletName});
	}

	@summary = "Default summary"
	macro viewConfigurationDefaultLayoutTemplate(portletName = null) {
		Portlet.gotoPortletOptions(
			portletName = ${portletName},
			portletOption = "Configuration");

		IFrame.selectDialogFrame();

		AssertChecked(locator1 = "Portlet#LAYOUT_2_COLUMNS");

		SelectFrameTop(value1 = "relative=top");
	}

	@summary = "Default summary"
	macro viewPG(portletColumnNumberTo = null, portletName = null) {
		var key_portletTitleName = ${portletName};

		AssertTextEquals(
			locator1 = "Home#PORTLET_COLUMN_${portletColumnNumberTo}_NESTED_PORTLET_TITLE",
			value1 = ${portletName});
	}

}