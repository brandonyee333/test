definition {

	var dmDocumentTypeName = "Basic Document";

	@summary = "Default summary"
	macro gotoAddDocumentType(dmDocumentTypeName = null) {
		LexiconEntry.gotoAdd();

		var key_dmDocumentTypeName = ${dmDocumentTypeName};

		MenuItem.click(menuItem = ${dmDocumentTypeName});
	}

	@summary = "Default summary"
	macro gotoAddDocumentTypePG(dmDocumentTypeName = null) {
		Portlet.clickPortletPlusIconPG(portletName = "Documents and Media");

		var key_dmDocumentTypeName = ${dmDocumentTypeName};

		MenuItem.click(menuItem = ${dmDocumentTypeName});
	}

	@summary = "Default summary"
	macro gotoAddRepositoryCP() {
		AssertVisible(locator1 = "Button#PLUS");

		LexiconEntry.gotoAddMenuItem(menuItem = "Repository");
	}

	@summary = "Default summary"
	macro gotoAddRepositoryPG() {
		Portlet.clickPortletPlusIconPG(portletName = "Documents and Media");

		MenuItem.click(menuItem = "Repository");
	}

	@summary = "Default summary"
	macro gotoCheckedOutDocument(dmDocumentTitle = null, dmCheckedOutDocumentTitle = null) {
		var key_dmDocumentTitle = ${dmDocumentTitle};

		AssertClick(
			locator1 = "DocumentsAndMedia#DESCRIPTIVE_LIST_DOCUMENT_TITLE",
			value1 = ${dmCheckedOutDocumentTitle});
	}

	@summary = "Default summary"
	macro gotoDocumentCP(dmDocumentTitle = null) {
		var key_dmDocumentTitle = ${dmDocumentTitle};

		if (IsElementPresent(locator1 = "Icon#DISPLAY_STYLE_DESCRIPTIVE_ACTIVE")) {
			AssertClick(
				locator1 = "DocumentsAndMedia#DESCRIPTIVE_LIST_DOCUMENT_TITLE",
				value1 = ${dmDocumentTitle});
		}
		else {
			AssertClick(
				locator1 = "DocumentsAndMedia#ICON_DOCUMENT_TITLE_LINK",
				value1 = ${dmDocumentTitle});
		}
	}

	@summary = "Default summary"
	macro gotoDocumentDetails() {
		Click(locator1 = "Button#INFO");

		AssertClick(
			locator1 = "NavBar#DETAILS",
			value1 = "Details");
	}

	@summary = "Default summary"
	macro gotoDocumentPermissionsCP(dmDocumentTitle = null) {
		LexiconEntry.gotoEntryMenuItem(
			menuItem = "Permissions",
			rowEntry = ${dmDocumentTitle});

		IFrame.selectDialogFrame();
	}

	@summary = "Default summary"
	macro gotoDocumentPG(dmDocumentTitle = null) {
		var key_dmDocumentTitle = ${dmDocumentTitle};

		AssertClick(
			locator1 = "DocumentsAndMedia#DESCRIPTIVE_LIST_DOCUMENT_TITLE",
			value1 = ${dmDocumentTitle});
	}

	@summary = "Default summary"
	macro gotoDocumentVersion() {
		DMNavigator.gotoDocumentDetails();

		MenuItem.click(menuItem = "Versions");
	}

	@summary = "Default summary"
	macro gotoEditDocument(dmDocumentTitle = null) {
		var key_dmDocumentTitle = ${dmDocumentTitle};

		Click(locator1 = "DocumentsAndMedia#ICON_DOCUMENT_VERTICAL_ELLIPSIS");

		MenuItem.click(menuItem = "Edit");
	}

	@summary = "Default summary"
	macro gotoFolder(dmFolderName = null) {
		var key_dmFolderName = ${dmFolderName};

		AssertClick(
			locator1 = "DocumentsAndMedia#DESCRIPTIVE_LIST_FOLDER_TITLE",
			value1 = ${dmFolderName});

		AssertVisible(locator1 = "DocumentsAndMedia#BREADCRUMB_FOLDER_NAME");
	}

	@summary = "Default summary"
	macro gotoFolderPermissions(dmFolderName = null) {
		var key_dmFolderName = ${dmFolderName};

		Click(locator1 = "DocumentsAndMedia#DESCRIPTIVE_LIST_VERTICAL_ELLIPSIS");

		MenuItem.click(menuItem = "Permissions");

		IFrame.selectDialogFrame();
	}

	@summary = "Default summary"
	macro gotoHomeCP() {
		AssertClick(
			locator1 = "DocumentsAndMedia#BREADCRUMB_HOME",
			value1 = "HOME");
	}

	@summary = "Default summary"
	macro gotoRelatedAssetPG(dmDocumentTitle = null, assetTitle = null) {
		var key_dmDocumentTitle = ${dmDocumentTitle};

		AssertClick(
			locator1 = "DocumentsAndMedia#DESCRIPTIVE_LIST_DOCUMENT_TITLE",
			value1 = ${dmDocumentTitle});

		var key_assetTitle = ${key_assetTitle};

		AssertTextEquals(
			locator1 = "DocumentsAndMediaDocument#DOCUMENT_INFO_TITLE",
			value1 = ${dmDocumentTitle});

		AssertTextEquals(
			locator1 = "AssetRelatedAssets#HEADER",
			value1 = "Related Assets:");

		AssertTextEquals(
			locator1 = "DocumentsAndMediaDocument#DOCUMENT_INFO_RELATED_ASSETS_TITLE",
			value1 = ${assetTitle});

		AssertClick(
			locator1 = "DocumentsAndMediaDocument#DOCUMENT_INFO_RELATED_ASSETS_TITLE",
			value1 = ${assetTitle});
	}

	@summary = "Default summary"
	macro gotoRepository(dmRepositoryName = null) {
		var key_dmFolderName = ${dmRepositoryName};

		AssertClick(
			locator1 = "DocumentsAndMedia#DESCRIPTIVE_LIST_FOLDER_TITLE",
			value1 = ${dmRepositoryName});

		AssertVisible(locator1 = "DocumentsAndMedia#BREADCRUMB_FOLDER_NAME");
	}

	@summary = "Default summary"
	macro gotoURLDetail() {
		Click(locator1 = "Icon#INFO");

		Click(locator1 = "DocumentsAndMediaDocument#DETAILS_URL");
	}

	@summary = "Default summary"
	macro openDocumentsAndMediaAdmin(siteURLKey = null) {
		Navigator.openWithAppendToBaseURL(urlAppend = "group/${siteURLKey}/~/control_panel/manage?p_p_id=com_liferay_document_library_web_portlet_DLAdminPortlet");
	}

}