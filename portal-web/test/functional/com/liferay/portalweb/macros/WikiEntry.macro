definition {

	@summary = "Default summary"
	macro addMediaWikiDescription(wikiPageContent = null) {
		Type(
			locator1 = "TextArea#WEB_EDITOR",
			value1 = ${wikiPageContent});
	}

	@summary = "Default summary"
	macro addPageTitle(wikiPageTitle = null) {
		Type.typeEditor(
			locator1 = "AlloyEditor#TITLE_FIELD",
			value1 = ${wikiPageTitle});
	}

	@summary = "Default summary"
	macro cancel() {
		AssertClick(
			locator1 = "Button#CANCEL",
			value1 = "Cancel");
	}

	@summary = "Default summary"
	macro confirmHTML() {
		Confirm(value1 = "You may lose some formatting when switching from Creole to HTML. Do you want to continue?");
	}

	@summary = "Default summary"
	macro confirmMediaWiki() {
		Confirm(value1 = "You may lose some formatting when switching from Creole to MediaWiki. Do you want to continue?");
	}

	@summary = "Default summary"
	macro saveAsDraft() {
		AssertClick(
			locator1 = "Button#SAVE",
			value1 = "Save as Draft");

		Alert.viewSuccessMessage();
	}

	@summary = "Default summary"
	macro selectPageFormat(pageFormat = null) {
		if (IsNotVisible(locator1 = "Wiki#ADD_PAGE_FORMAT_DROPDOWN")) {
			Panel.expandPanel(panelHeading = "Configuration");

			SelectNoError(
				locator1 = "Wiki#ADD_PAGE_FORMAT_DROPDOWN",
				value1 = ${pageFormat});
		}
		else if (IsVisible(locator1 = "Wiki#ADD_PAGE_FORMAT_DROPDOWN")) {
			SelectNoError(
				locator1 = "Wiki#ADD_PAGE_FORMAT_DROPDOWN",
				value1 = ${pageFormat});
		}
	}

	@summary = "Default summary"
	macro viewPageContentBody(wikiPageContent = null) {
		AssertTextEquals(
			locator1 = "WikiEntry#BODY",
			value1 = ${wikiPageContent});
	}

	@summary = "Default summary"
	macro viewPageFormat(pageFormat = null) {
		if (IsNotVisible(locator1 = "Wiki#ADD_PAGE_FORMAT_DROPDOWN")) {
			Panel.expandPanel(panelHeading = "Configuration");
		}

		AssertSelectedLabel(
			locator1 = "Wiki#ADD_PAGE_FORMAT_DROPDOWN",
			value1 = ${pageFormat});
	}

}