definition {

	var key_panel = "user";

	@description = "Navigate to My Dashboard."
	@summary = "Default summary"
	macro gotoDashboard() {
		Navigator.openURL();

		if (IsElementNotPresent(locator1 = "ProductMenu#PANEL_EXPANDED")) {
			if (IsElementPresent(locator1 = "UserBar#USER_AVATAR_IMAGE")) {
				Click(locator1 = "UserBar#USER_AVATAR_IMAGE");

				Pause(locator1 = 5000);

				AssertClick(
					locator1 = "UserBar#USER_DASHBOARD",
					value1 = "My Dashboard");
			}
		}
		else {
			AssertClick(
				locator1 = "UserBar#USER_DASHBOARD",
				value1 = "My Dashboard");
		}
	}

	@description = "Navigate to Account via the User Bar."
	@summary = "Default summary"
	macro gotoMyAccount() {
		Navigator.openURL();

		if (IsElementNotPresent(locator1 = "ProductMenu#PANEL_EXPANDED")) {
			if (IsElementPresent(locator1 = "UserBar#USER_AVATAR_IMAGE")) {
				Click(locator1 = "UserBar#USER_AVATAR_IMAGE");

				ProductMenuHelper.expandCategory(category = "My Account");

				ProductMenuHelper.gotoPortlet(portlet = "Account Settings");
			}
		}
		else {
			ProductMenuHelper.expandCategory(category = "My Account");

			ProductMenuHelper.gotoPortlet(portlet = "Account Settings");
		}
	}

	@description = "Navigate to My Profile."
	@summary = "Default summary"
	macro gotoProfile() {
		Navigator.openURL();

		if (IsElementNotPresent(locator1 = "ProductMenu#PANEL_EXPANDED")) {
			if (IsElementPresent(locator1 = "UserBar#USER_AVATAR_IMAGE")) {
				Click(locator1 = "UserBar#USER_AVATAR_IMAGE");

				AssertClick(
					locator1 = "UserBar#USER_PROFILE",
					value1 = "My Profile");
			}
		}
		else {
			AssertClick(
				locator1 = "UserBar#USER_PROFILE",
				value1 = "My Profile");
		}
	}

	@summary = "Default summary"
	macro signOut() {
		if (IsElementPresent(locator1 = "UserBar#USER_AVATAR_IMAGE")) {
			if (IsElementNotPresent(locator1 = "ProductMenu#PANEL_EXPANDED")) {
				Click(locator1 = "UserBar#USER_AVATAR_IMAGE");
			}

			AssertVisible(locator1 = "ProductMenu#PANEL_EXPANDED");

			Click(locator1 = "UserBar#USER_SIGN_OUT");
		}
	}

	@summary = "Default summary"
	macro viewUserDefaultIcon() {
		AssertElementPresent(locator1 = "UserBar#USER_AVATAR_DEFAULT");
	}

}