definition {

	@summary = "Default summary"
	macro gotoEventToday(eventTitle = null) {
		var key_eventTitle = ${eventTitle};

		AssertClick(
			locator1 = "EventsListPortlet#TODAYS_EVENTS_EVENT",
			value1 = ${eventTitle});
	}

	@summary = "Default summary"
	macro gotoEventUpcoming(eventTitle = null) {
		var key_eventTitle = ${eventTitle};

		AssertClick(
			locator1 = "EventsListPortlet#UPCOMING_EVENTS_EVENT",
			value1 = ${eventTitle});
	}

	@summary = "Default summary"
	macro viewDefaultMessage() {
		AssertTextEquals(
			locator1 = "EventsListPortlet#PORTLET_NO_EVENTS",
			value1 = "There are no more events today.");
	}

	@summary = "Default summary"
	macro viewEventTime(eventTitle = null) {
		var key_eventTitle = ${eventTitle};

		AssertElementPresent(locator1 = "EventsListPortlet#TODAYS_EVENTS_EVENT_TIME");
	}

	@summary = "Default summary"
	macro viewHeader() {
		AssertTextEquals(
			locator1 = "EventsListPortlet#PORTLET_TITLE",
			value1 = "Events List");
	}

}