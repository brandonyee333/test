		AssetPublisherPortlet.addAsset(assetType = "Add Content (Select Scope and Type)");

		Select(
			locator1 = "Select#SCOPE",
			value1 = ${siteScope1});

		AssertSelectedLabel(
			locator1 = "Select#SCOPE",
