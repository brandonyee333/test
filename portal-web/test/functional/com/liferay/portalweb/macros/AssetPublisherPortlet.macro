			locator1 = "Select#SCOPE",
			value1 = ${siteScope2});

		AssertSelectedLabel(
			locator1 = "Select#SCOPE",
			value1 = ${siteScope2});

		Refresh();

		AssetPublisherPortlet.viewPG(
			assetContent = ${assetContent},
			assetTitle = ${assetTitle});

		Click(locator1 = "APAsset#ASSET_BACK_TO_ICON");
	}

