definition {

	@summary = "Default summary"
	macro addVideoId(videoId = null) {
		IFrame.selectDialogFrame();

		Type(
			locator1 = "TextInput#URL",
			value1 = ${videoId});
	}

	@summary = "Default summary"
	macro assertVideoTitle(videoTitle = null) {
		SelectFrame(locator1 = "YoutubePortlet#VIDEO_IFRAME");

		AssertTextEquals.assertPartialText(
			locator1 = "YoutubePortlet#VIDEO_TITLE",
			value1 = ${videoTitle});

		SelectFrameTop();
	}

	@summary = "Default summary"
	macro viewPortletConfiguration(videoId = null) {
		IFrame.selectDialogFrame();

		AssertTextEquals(
			locator1 = "TextInput#URL",
			value1 = ${videoId});
	}

}