definition {

	@summary = "Default summary"
	macro addServiceProviderConnection(nameIdentifierFormat = null, SPMetadataURL = null, Attributes = null, SPEntityID = null, SPNameID = null, nameIdentifierAttributeName = null) {
		AssertClick(
			locator1 = "CPSAMLAdminServiceProviderConnections#ADD_SERVICE_PROVIDER_BUTTON",
			value1 = "Add Service Provider");

		Type(
			locator1 = "CPSAMLAdmin#SAML_NAME_FIELD",
			value1 = ${SPNameID});

		Type(
			locator1 = "CPSAMLAdminAddServiceProvider#SERVICE_PROVIDER_ENTITY_ID_FIELD",
			value1 = ${SPEntityID});

		Check(locator1 = "CPSAMLAdminAddServiceProvider#SERVICE_PROVIDER_ENABLED_CHECKBOX");

		Type(
			locator1 = "CPSAMLAdmin#SAML_METADATA_URL_FIELD",
			value1 = ${SPMetadataURL});

		if (isSet(nameIdentifierAttributeName)) {
			Type(
				locator1 = "CPSAMLAdminAddServiceProvider#SERVICE_PROVIDER_NAME_IDENTIFIER_ATTRIBUTE_NAME_FIELD",
				value1 = ${nameIdentifierAttributeName});
		}

		if (isSet(nameIdentifierFormat)) {
			Select(
				locator1 = "CPSAMLAdmin#SAML_NAME_IDENTIFIER_FORMAT_SELECT",
				value1 = ${nameIdentifierFormat});
		}

		if (isSet(Attributes)) {
			Check(locator1 = "CPSAMLAdminIdentityProviderConnection#IDENTITY_PROVIDER_CONNECTION_ATTRIBUTE_ENABLE");

			Type(
				locator1 = "CPSAMLAdminIdentityProviderConnection#IDENTITY_PROVIDER_CONNECTION_ATTRIBUTE_TEXTAREA",
				value1 = ${Attributes});
		}

		PortletEntry.save();
	}

	@summary = "Default summary"
	macro configureIdentityProvider(authnRequestSignatureRequired = null, signMetadata = null) {
		if (${signMetadata} == "disable") {
			Uncheck(locator1 = "CPSAMLAdminIdentityProvider#IDENTITY_PROVIDER_SIGN_METADATA_CHECKBOX");
		}
		else {
			Check(locator1 = "CPSAMLAdminIdentityProvider#IDENTITY_PROVIDER_SIGN_METADATA_CHECKBOX");
		}

		if (${authnRequestSignatureRequired} == "disable") {
			Uncheck(locator1 = "CPSAMLAdminIdentityProvider#IDENTITY_PROVIDER_AUTHN_REQUEST_SIGNATURE_REQUIRED_CHECKBOX");
		}
		else {
			Check(locator1 = "CPSAMLAdminIdentityProvider#IDENTITY_PROVIDER_AUTHN_REQUEST_SIGNATURE_REQUIRED_CHECKBOX");
		}

		PortletEntry.save();
	}

	@summary = "Default summary"
	macro configureIdentityProviderConnection(nameIdentifierFormat = null, IdpEntityID = null, enableForceAuthn = null, IdpMetadataURL = null, IdpNameID = null) {
		Type(
			locator1 = "CPSAMLAdmin#SAML_NAME_FIELD",
			value1 = ${IdpNameID});

		Type(
			locator1 = "CPSAMLAdminIdentityProviderConnection#IDENTITY_PROVIDER_CONNECTION_ENTITY_ID_FIELD",
			value1 = ${IdpEntityID});

		Type(
			locator1 = "CPSAMLAdmin#SAML_METADATA_URL_FIELD",
			value1 = ${IdpMetadataURL});

		if (isSet(nameIdentifierFormat)) {
			Select(
				locator1 = "CPSAMLAdmin#SAML_NAME_IDENTIFIER_FORMAT_SELECT",
				value1 = ${nameIdentifierFormat});
		}
		else {
			Select(
				locator1 = "CPSAMLAdmin#SAML_NAME_IDENTIFIER_FORMAT_SELECT",
				value1 = "Email Address");
		}

		if (${enableForceAuthn} == "true") {
			Check(locator1 = "Checkbox#FORCE_AUTHN");
		}
		else {
			Uncheck(locator1 = "Checkbox#FORCE_AUTHN");
		}

		PortletEntry.save();
	}

}