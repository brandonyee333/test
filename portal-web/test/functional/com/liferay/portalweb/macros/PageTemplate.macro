definition {

	@summary = "Default summary"
	macro addCP(pageTemplateActive = null, pageTemplateName = null) {
		LexiconEntry.gotoAdd();

		PortletEntry.inputName(name = ${pageTemplateName});

		PortletEntry.inputDescriptionTextInput(description = "This is a page template description");

		if (${pageTemplateActive} == "No") {
			Click(locator1 = "ToggleSwitch#ACTIVE");
		}

		PortletEntry.save();

		var key_pageTemplateName = ${pageTemplateName};

		AssertTextEquals.assertPartialText(
			locator1 = "PageTemplates#PAGE_TEMPLATE_TABLE_NAME",
			value1 = ${pageTemplateName});

		AssertTextEquals(
			locator1 = "PageTemplates#PAGE_TEMPLATE_TABLE_ACTIVE",
			value1 = ${pageTemplateActive});
	}

	@summary = "Default summary"
	macro configurePageTemplateLayout(pageTemplateName = null, columnName = null) {
		Click(
			key_pageTemplateName = ${pageTemplateName},
			locator1 = "PageTemplates#PAGE_TEMPLATE_TABLE_NAME",
			value1 = ${pageTemplateName});

		Pause(value1 = 3000);

		SelectWindow.selectPopUp(value1 = "null");

		Click.pauseClickAt(locator1 = "ControlMenu#EDIT_COG");

		Page.editPageLayoutColumn(columnName = ${columnName});
	}

	@summary = "Default summary"
	macro deactivateAndActivate(pageTemplateName = null) {
		var key_pageTemplateName = ${pageTemplateName};

		AssertTextEquals.assertPartialText(
			locator1 = "PageTemplates#PAGE_TEMPLATE_TABLE_NAME",
			value1 = ${pageTemplateName});

		LexiconEntry.gotoEntryMenuItem(
			menuItem = "Edit",
			rowEntry = ${pageTemplateName});

		if (isSet(pageTemplateStatus)) {
			Click(locator1 = "ToggleSwitch#ACTIVE");
		}

		PortletEntry.save();
	}

	@summary = "Default summary"
	macro deleteCP(pageTemplateName = null) {
		LexiconEntry.gotoEntryMenuItemNoError(
			menuItem = "Delete",
			rowEntry = ${pageTemplateName});

		Confirm(value1 = "Are you sure you want to delete this? It will be deleted immediately.");

		Alert.viewSuccessMessage();
	}

	@summary = "Default summary"
	macro editCP(pageTemplateActive = null, pageTemplateName = null) {
		AssertTextEquals.assertPartialText(
			key_pageTemplateName = ${pageTemplateName},
			locator1 = "PageTemplates#PAGE_TEMPLATE_TABLE_NAME",
			value1 = ${pageTemplateName});

		LexiconEntry.gotoEntryMenuItem(
			menuItem = "Edit",
			rowEntry = ${pageTemplateName});

		PortletEntry.inputName(name = "${pageTemplateName} Edit");

		if (${pageTemplateActive} == "No") {
			Click(locator1 = "ToggleSwitch#ACTIVE");
		}

		Button.clickSave();

		var key_pageTemplateName = ${pageTemplateName};

		Alert.viewSuccessMessage();

		AssertTextEquals.assertPartialText(
			locator1 = "PageTemplates#PAGE_TEMPLATE_TABLE_NAME",
			value1 = "${pageTemplateName} Edit");

		AssertTextEquals(
			locator1 = "PageTemplates#PAGE_TEMPLATE_TABLE_ACTIVE",
			value1 = ${pageTemplateActive});
	}

	@summary = "Default summary"
	macro editDescription(pageTemplateName = null, pageTemplateDescription = null) {
		AssertTextEquals.assertPartialText(
			key_pageTemplateName = ${pageTemplateName},
			locator1 = "PageTemplates#PAGE_TEMPLATE_TABLE_NAME",
			value1 = ${pageTemplateName});

		AssertTextEquals.assertPartialText(
			key_pageTemplateDescription = ${pageTemplateDescription},
			locator1 = "PageTemplates#PAGE_TEMPLATE_TABLE_DESCRITPION",
			value1 = ${pageTemplateDescription});

		LexiconEntry.gotoEntryMenuItem(
			menuItem = "Edit",
			rowEntry = ${pageTemplateName});

		PortletEntry.inputDescriptionTextInput(description = "This is a page template description edit");

		PortletEntry.save();
	}

	@summary = "Default summary"
	macro gotoPageTemplateViaEdit(pageTemplateName = null) {
		var key_pageTemplateName = ${pageTemplateName};

		AssertTextEquals.assertPartialText(
			locator1 = "PageTemplates#PAGE_TEMPLATE_TABLE_NAME",
			value1 = ${pageTemplateName});

		AssertClick.assertPartialTextClickAt(
			locator1 = "PageTemplates#PAGE_TEMPLATE_TABLE_NAME",
			value1 = ${pageTemplateName});
	}

	@summary = "Default summary"
	macro tearDownCP() {
		ProductMenu.gotoPortlet(
			category = "Sites",
			panel = "Control Panel",
			portlet = "Page Templates");

		var key_rowEntry = "Page Template Name";

		while (IsElementPresent(locator1 = "Icon#ROW_VERTICAL_ELLIPSIS")) {
			LexiconEntry.gotoEntryMenuItemNoError(
				menuItem = "Delete",
				rowEntry = "Page Template Name");

			Confirm(value1 = "Are you sure you want to delete this? It will be deleted immediately.");

			Alert.viewSuccessMessage();
		}
	}

	@summary = "Default summary"
	macro viewCP(pageTemplateName = null) {
		AssertTextEquals.assertPartialText(
			key_pageTemplateName = ${pageTemplateName},
			locator1 = "PageTemplates#PAGE_TEMPLATE_TABLE_NAME",
			value1 = ${pageTemplateName});
	}

	@summary = "Default summary"
	macro viewDefaultCP(pageTemplateNameList = null) {
		for (var pageTemplateName : list ${pageTemplateNameList}) {
			var key_pageTemplateName = ${pageTemplateName};

			AssertTextEquals.assertPartialText(
				locator1 = "PageTemplates#PAGE_TEMPLATE_TABLE_NAME",
				value1 = ${pageTemplateName});
		}

		AssertElementNotPresent(locator1 = "PageTemplates#PAGE_TEMPLATE_TABLE_NAME_4");
	}

	@summary = "Default summary"
	macro viewDefaultLocalizedCP(pageTemplateDescriptionList = null, pageTemplateNameList = null) {
		for (var pageTemplateNameTranslation : list ${pageTemplateNameList}) {
			var key_pageTemplateName = ${pageTemplateNameTranslation};

			AssertTextEquals.assertPartialText(
				locator1 = "PageTemplates#PAGE_TEMPLATE_TABLE_NAME",
				value1 = ${pageTemplateNameTranslation});
		}

		for (var DescriptionTranslation : list ${pageTemplateDescriptionList}) {
			var key_pageTemplateDescription = ${DescriptionTranslation};

			AssertTextEquals.assertPartialText(
				locator1 = "PageTemplates#PAGE_TEMPLATE_TABLE_DESCRITPION",
				value1 = ${DescriptionTranslation});
		}
	}

	@summary = "Default summary"
	macro viewDefaultPortletPG(portletTitleList = null, pageTemplateName = null) {
		if (${pageTemplateName} == "Blog") {
			AssertElementPresent(locator1 = "Home#PORTLET_1");

			AssertElementPresent(locator1 = "Home#PORTLET_2");

			AssertElementPresent(locator1 = "Home#PORTLET_3");

			for (var portletName : list ${portletTitleList}) {
				var key_portletName = ${portletName};

				AssertTextEquals(
					locator1 = "Portlet#TITLE",
					value1 = ${portletName});
			}
		}
	}

	@summary = "Default summary"
	macro viewDescription(pageTemplateName = null, pageTemplateDescription = null) {
		var key_pageTemplateName = ${pageTemplateName};

		AssertTextEquals.assertPartialText(
			locator1 = "PageTemplates#PAGE_TEMPLATE_TABLE_NAME",
			value1 = ${pageTemplateName});

		var key_pageTemplateDescription = ${pageTemplateDescription};

		AssertTextEquals.assertPartialText(
			locator1 = "PageTemplates#PAGE_TEMPLATE_TABLE_DESCRITPION",
			value1 = ${pageTemplateDescription});
	}

	@summary = "Default summary"
	macro viewPG(siteName = null, pageTemplateName = null) {
		var key_pageTemplateName = ${pageTemplateName};

		AssertClick.assertPartialTextClickAt(
			locator1 = "PageTemplates#PAGE_TEMPLATE_TABLE_NAME",
			value1 = ${pageTemplateName});

		SelectWindow(value1 = "title=${pageTemplateName} - ${siteName}");

		AssertTextEquals(
			locator1 = "Home#SITE_NAME",
			value1 = ${pageTemplateName});

		AssertTextEquals(
			locator1 = "Home#PAGE_TEMPLATE",
			value1 = ${pageTemplateName});
	}

	@summary = "Default summary"
	macro viewStatus(pageTemplateName = null, pageTemplateStatus = null) {
		var key_pageTemplateName = ${pageTemplateName};

		AssertTextEquals.assertPartialText(
			locator1 = "PageTemplates#PAGE_TEMPLATE_TABLE_NAME",
			value1 = ${pageTemplateName});

		AssertTextEquals(
			locator1 = "PageTemplates#PAGE_TEMPLATE_TABLE_ACTIVE",
			value1 = ${pageTemplateStatus});
	}

}