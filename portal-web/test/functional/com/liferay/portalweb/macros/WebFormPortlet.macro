definition {

	@summary = "Default summary"
	macro addField(wfNewFieldName = null, wfPreviousFieldName = null, optionsList = null, wfFieldType = null, optional = null) {
		var key_wfPreviousFieldName = ${wfPreviousFieldName};

		Click(locator1 = "WebFormConfiguration#SETUP_FORM_FIELDS_ADD_ROW_BUTTON");

		WebFormPortlet.editField(
			optional = ${optional},
			optionsList = ${optionsList},
			wfFieldName = "New Item",
			wfFieldType = ${wfFieldType},
			wfNewFieldName = ${wfNewFieldName});
	}

	@summary = "Default summary"
	macro configureSetupFormFieldsPG(wfInformationDescription = null, wfInformationTitle = null, portletName = null) {
		Portlet.gotoPortletOptions(
			portletName = ${portletName},
			portletOption = "Configuration");

		SelectFrame(locator1 = "WebFormConfiguration#CONFIGURATION_IFRAME");

		if (isSet(wfInformationTitle)) {
			Type(
				locator1 = "TextInput#TITLE",
				value1 = ${wfInformationTitle});
		}

		if (isSet(wfInformationDescription)) {
			Type(
				locator1 = "TextArea#DESCRIPTION",
				value1 = ${wfInformationDescription});
		}
	}

	@summary = "Default summary"
	macro deleteEditableField(wfFieldName = null) {
		WebFormPortlet.viewEditableField(wfFieldName = ${wfFieldName});

		var key_wfFieldName = ${wfFieldName};

		DoubleClick(locator1 = "WebFormConfiguration#SETUP_FORM_FIELDS_DELETE_ROW_BUTTON");

		WebFormPortlet.viewEditableFieldNotVisibleCmd(wfFieldName = ${wfFieldName});
	}

	@summary = "Default summary"
	macro editField(wfNewFieldName = null, optionsList = null, wfFieldType = null, optional = null, wfFieldName = null) {
		var key_wfFieldName = ${wfFieldName};

		if (${wfFieldName} == "New Item") {
			Type(
				locator1 = "WebFormConfiguration#SETUP_FORM_FIELDS_NAME_FIELD_NEW",
				value1 = ${wfNewFieldName});
		}
		else {
			Type(
				locator1 = "WebFormConfiguration#SETUP_FORM_FIELDS_NAME_FIELD",
				value1 = ${wfNewFieldName});
		}

		Click(locator1 = "Button#BROWSE");

		if (isSet(wfFieldType)) {
			var key_wfNewFieldName = ${wfNewFieldName};

			Select(
				locator1 = "WebFormConfiguration#SETUP_FORM_FIELDS_TYPE_SELECT",
				value1 = ${wfFieldType});
		}

		if (((${wfFieldType} == "Options") || (${wfFieldType} == "Radio Buttons")) && isSet(optionsList)) {
			var key_wfNewFieldName = ${wfNewFieldName};

			Type(
				locator1 = "WebFormConfiguration#SETUP_FORM_FIELDS_OPTIONS_FIELD",
				value1 = ${optionsList});
		}

		if (${optional} == "true") {
			var key_wfNewFieldName = ${wfNewFieldName};

			Check(locator1 = "WebFormConfiguration#SETUP_FORM_FIELDS_OPTIONAL_CHECKBOX");
		}
	}

	@summary = "Default summary"
	macro editParagraphField(wfNewFieldName = null, wfParagraphFieldText = null) {
		var key_wfNewFieldName = ${wfNewFieldName};

		Type(
			locator1 = "WebFormConfiguration#SETUP_FORM_FIELDS_PARAGRAPH_FIELD",
			value1 = ${wfParagraphFieldText});
	}

	@summary = "Default summary"
	macro saveConfiguration() {
		AssertClick(
			locator1 = "Button#SAVE",
			value1 = "Save");

		Alert.viewSuccessMessage();

		SelectFrameTop(value1 = "relative=top");
	}

	@summary = "Default summary"
	macro viewEditableField(wfFieldName = null) {
		var key_wfFieldName = ${wfFieldName};

		AssertElementPresent(locator1 = "WebFormConfiguration#SETUP_FORM_FIELDS_NAME_FIELD");
	}

	@summary = "Default summary"
	macro viewEditableFieldNotPresent(wfFieldName = null) {
		var key_wfFieldName = ${wfFieldName};

		AssertElementNotPresent(locator1 = "WebFormConfiguration#SETUP_FORM_FIELDS_NAME_EDITABLE_FIELD");
	}

	@summary = "Default summary"
	macro viewEditableFieldNotVisibleCmd(wfFieldName = null) {
		var key_wfFieldName = ${wfFieldName};

		AssertNotVisible(locator1 = "WebFormConfiguration#SETUP_FORM_FIELDS_NAME_FIELD");
	}

	@summary = "Default summary"
	macro viewSubmittedField(optionsList = null, optional = null, wfFieldName = null) {
		var key_wfFieldName = ${wfFieldName};

		AssertTextEquals(
			locator1 = "WebFormConfiguration#SETUP_FORM_POPULATED_FIELDS_FIELD_TITLE",
			value1 = ${wfFieldName});

		AssertTextEquals(
			locator1 = "WebFormConfiguration#SETUP_FORM_POPULATED_FIELDS_FIELD_NAME",
			value1 = ${wfFieldName});

		if (${wfFieldType} == "Text Box") {
			var key_wfFieldType = "textarea";
			var wfFieldType = "textarea";

			AssertTextEquals(
				locator1 = "WebFormConfiguration#SETUP_FORM_POPULATED_FIELDS_FIELD_TYPE",
				value1 = ${wfFieldType});
		}
		else {
			var key_wfFieldType = ${wfFieldType};

			AssertTextEquals(
				locator1 = "WebFormConfiguration#SETUP_FORM_POPULATED_FIELDS_FIELD_TYPE",
				value1 = ${wfFieldType});
		}

		if (${optional} == "true") {
			AssertTextEquals(
				locator1 = "WebFormConfiguration#SETUP_FORM_POPULATED_FIELDS_FIELD_OPTIONAL",
				value1 = "Yes");
		}
		else {
			AssertTextEquals(
				locator1 = "WebFormConfiguration#SETUP_FORM_POPULATED_FIELDS_FIELD_OPTIONAL",
				value1 = "No");
		}

		if (isSet(optionsList)) {
			var key_optionsList = ${optionsList};

			AssertTextEquals(
				locator1 = "WebFormConfiguration#SETUP_FORM_POPULATED_FIELDS_FIELD_OPTIONS",
				value1 = ${optionsList});
		}
	}

}