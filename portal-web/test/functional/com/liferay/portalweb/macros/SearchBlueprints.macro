definition {

	macro addBlueprint {
		ApplicationsMenu.gotoPortlet(
			category = "Search Tuning",
			panel = "Applications",
			portlet = "Search Experiences");

		Click(locator1 = "Button#PLUS");

		PortletEntry.inputTitle(title = "${name}");

		if (isSet(description)) {
			PortletEntry.inputDescription(description = "${description}");
		}

		if (isSet(clauseOption)) {
			LexiconCard.clickCard(card = "Custom Clauses");
		}
		else {
			LexiconCard.clickCard(card = "Liferay Default Clauses");
		}

		Button.click(button = "Create");

		// Workaround for LPS-133591

		Refresh();
	}

	macro addElements {
		ApplicationsMenu.gotoPortlet(
			category = "Search Tuning",
			panel = "Applications",
			portlet = "Search Experiences");

		Navigator.gotoNavItem(navItem = "Elements");

		Click(locator1 = "Button#PLUS");

		PortletEntry.inputTitle(title = "${name}");

		Button.click(button = "Create");

		// Workaround for LPS-133591

		Refresh();

		SearchBlueprints.editElement(name = "${name}");

		Type.typeCodeMirrorEditorNoError(
			locator1 = "SearchTuning#BLUEPRINTS_ELEMENT_TEMPLATE_JSON",
			value1 = "${elementTemplateJSON}");

		Type.typeCodeMirrorEditorNoError(
			locator1 = "SearchTuning#BLUEPRINTS_ELEMENT_UI_CONFIGURATION_JSON",
			value1 = "${uiConfigurationJSON}");

		PortletEntry.save();
	}

	macro addQueryElements {
		AssertElementPresent(locator1 = "//div[contains(@class,'sidebar-header')]//span[contains(.,'Add Query Elements')]");

		Type.sendKeysApplicationSearch(
			locator1 = "SearchTuning#BLUEPRINTS_FRAGMENT_QUERY_SEARCH_BAR",
			value1 = "${fragment}");

		MouseOver(
			key_fragmentName = "${fragment}",
			locator1 = "SearchTuning#BLUEPRINTS_QUERY_FRAGMENT_NAME");

		Click.clickNoMouseOverNoWaitForVisible(
			key_fragmentName = "${fragment}",
			locator1 = "SearchTuning#BLUEPRINTS_ADD_QUERY_FRAGMENT");

		if (isSet(assetType)) {
			Click(locator1 = "SearchTuning#BLUEPRINTS_QUERY_BUILDER_ASSET_TYPE_DROPDOWN");

			Click(
				locator1 = "SearchTuning#BLUEPRINTS_QUERY_BUILDER_ASSET_TYPE_OPTION",
				sortOption = "${assetType}");
		}

		if (isSet(elasticsearchQuery)) {
			Type.typeCodeMirrorEditorNoError(
				locator1 = "SearchTuning#BLUEPRINTS_ELASTICSEACH_QUERY_JSON",
				value1 = "${elasticsearchQuery}");
		}

		if (isSet(numberBoost)) {
			Type(
				key_fieldLabel = "Boost",
				locator1 = "SearchTuning#BLUEPRINTS_QUERY_BUILDER_NUMBER_FIELD",
				value1 = "${numberBoost}");
		}

		if (isSet(tag1)) {
			Type(
				key_fieldLabel = "Tag 1",
				locator1 = "SearchTuning#BLUEPRINTS_QUERY_TEXT_FIELD",
				value1 = "${tag1}");
		}

		if (isSet(tag2)) {
			Type(
				key_fieldLabel = "Tag 2",
				locator1 = "SearchTuning#BLUEPRINTS_QUERY_TEXT_FIELD",
				value1 = "${tag2}");
		}

		PortletEntry.save();
	}

	macro deleteBlueprint {
		ApplicationsMenu.gotoPortlet(
			category = "Search Tuning",
			panel = "Applications",
			portlet = "Search Experiences");

		LexiconEntry.delete(rowEntry = "${name}");
	}

	macro editBlueprint {
		ApplicationsMenu.gotoPortlet(
			category = "Search Tuning",
			panel = "Applications",
			portlet = "Search Experiences");

		LexiconEntry.gotoEntryMenuItem(
			menuItem = "Edit",
			rowEntry = "${name}");
	}

	macro editElement {
		ApplicationsMenu.gotoPortlet(
			category = "Search Tuning",
			panel = "Applications",
			portlet = "Search Experiences");

		Navigator.gotoNavItem(navItem = "Elements");

		LexiconEntry.gotoEntryMenuItem(
			menuItem = "Edit",
			rowEntry = "${name}");
	}

	macro findBlueprintID {
		var blueprintsID = selenium.getAttribute("//h4[contains(.,'${name}')]/following-sibling::h5[2]/span[contains(@class,'id-text')]@textContent");

		var blueprintsID = StringUtil.extractDigits("${blueprintsID}");

		return "${blueprintsID}";
	}

	macro searchBlueprintsPreview {
		Type(
			locator1 = "SearchTuning#BLUEPRINTS_PREVIEW_SEARCH_BAR",
			value1 = "${searchTerm}");

		var browserType = PropsUtil.get("browser.type");

		if ("${browserType}" == "safari") {
			Click(locator1 = "Icon#BASIC_SEARCH");
		}
		else {
			KeyPress(
				locator1 = "SearchTuning#BLUEPRINTS_PREVIEW_SEARCH_BAR",
				value1 = "\RETURN");
		}

		WaitForLiferayEvent.initializeLiferayEventLog();
	}

	macro searchReactiveSearchWidget {
		AssertElementPresent(locator1 = "SearchTuning#BLUEPRINTS_SEARCH_BAR");

		Type(
			locator1 = "SearchTuning#BLUEPRINTS_SEARCH_BAR",
			value1 = "${searchTerm}");

		var browserType = PropsUtil.get("browser.type");

		if ("${browserType}" == "safari") {
			Click(locator1 = "Icon#BASIC_SEARCH");
		}
		else {
			KeyPress(
				locator1 = "SearchTuning#BLUEPRINTS_SEARCH_BAR",
				value1 = "\RETURN");
		}

		WaitForLiferayEvent.initializeLiferayEventLog();
	}

	macro selectBlueprintFromOptionsWidget {
		Portlet.gotoPortletOptions(
			portletName = "Blueprints Options",
			portletOption = "Configuration");

		SelectFrame(locator1 = "IFrame#CONFIGURATION");

		Button.clickSelect();

		SelectFrameTop();

		SelectFrame(
			key_title = "Select Blueprint",
			locator1 = "IFrame#MODAL_ANY");

		var key_blueprintName = "${name}";

		AssertClick(
			locator1 = "SearchTuning#BLUEPRINTS_TABLE_CHOOSE",
			value1 = "Choose");

		SelectFrameTop();

		SelectFrame(locator1 = "IFrame#CONFIGURATION");

		Button.clickSave();

		Alert.viewSuccessMessage();

		IFrame.closeFrame();
	}

	macro tearDownCP {
		Navigator.openURL();

		ApplicationsMenu.gotoPortlet(
			category = "Search Tuning",
			panel = "Applications",
			portlet = "Search Experiences");

		LexiconEntry.changeDisplayStyle(displayStyle = "list");

		if (IsElementNotPresent(locator1 = "Message#EMPTY_INFO")) {
			PortletEntry.selectAll();

			Click(locator1 = "ManagementBar#ELLIPSIS_ICON");

			MenuItem.clickNoError(menuItem = "Delete");

			AssertConfirm(value1 = "Are you sure you want to delete selected Blueprints?");

			VerifyElementPresent(locator1 = "Message#SUCCESS");
		}
	}

	macro viewBlueprintsSpecificOrder {
		var resultOrder = "0";

		for (var blueprintsTitle : list "${blueprintsList}") {
			var resultOrder = ${resultOrder} + 1;

			AssertTextEquals.assertPartialText(
				locator1 = "SearchTuning#BLUEPRINTS_ASSET_ENTRY_LIST_TITLE_SPECIFIC_ORDER",
				resultOrder = "${resultOrder}",
				value1 = "${blueprintsTitle}");
		}
	}

}