definition {

	@summary = "Default summary"
	macro gotoSiteTemplatesPage(siteName = null, pageName = null, siteTemplateName = null) {
		var key_siteTemplateName = ${siteTemplateName};

		AssertClick.assertPartialTextClickAt(
			locator1 = "SiteTemplates#SITE_TEMPLATE_TABLE_NAME",
			value1 = ${siteTemplateName});

		SelectWindow(value1 = "Home - ${siteTemplateName} - ${siteName}");

		Navigator._gotoPage(pageName = ${pageName});
	}

	@summary = "Default summary"
	macro gotoSiteTemplatesPageLowercase(siteName = null, pageName = null, siteTemplateName = null) {
		var key_siteTemplateName = ${siteTemplateName};

		AssertClick.assertPartialTextClickAt(
			locator1 = "SiteTemplates#SITE_TEMPLATE_TABLE_NAME",
			value1 = ${siteTemplateName});

		SelectWindow(value1 = "home - ${siteTemplateName} - ${siteName}");

		Navigator._gotoPage(pageName = ${pageName});
	}

	@summary = "Default summary"
	macro openSiteTemplatesAdmin(baseURL = null) {
		Navigator.openWithAppendToBaseURL(
			baseURL = ${baseURL},
			urlAppend = "group/control_panel/manage/-/site_templates/templates");
	}

}