definition {

	@summary = "Default summary"
	macro changeDisplayStyle(displayStyle = null) {
		Click(locator1 = "Icon#CURRENT_DISPLAY_STYLE");

		MenuItem.click(menuItem = StringUtil.upperCaseFirstLetter(${displayStyle}));
	}

	@summary = "Default summary"
	macro gotoAdd() {
		Click(locator1 = "Button#PLUS");
	}

	@summary = "Default summary"
	macro gotoAddMenuItem(menuItem = null) {
		LexiconEntry.gotoAdd();

		MenuItem.click(menuItem = ${menuItem});
	}

	@summary = "Default summary"
	macro gotoEllipsisMenuItem(menuItem = null) {
		Click.waitForMenuToggleJSClick(locator1 = "Icon#BODY_VERTICAL_ELLIPSIS");

		MenuItem.click(menuItem = ${menuItem});
	}

	@summary = "Default summary"
	macro gotoEllipsisMenuItemNoError(menuItem = null) {
		Click.waitForMenuToggleJSClick(locator1 = "Icon#BODY_VERTICAL_ELLIPSIS");

		MenuItem.clickNoError(menuItem = ${menuItem});
	}

	@summary = "Default summary"
	macro gotoEntry(rowEntry = null) {
		var key_rowEntry = ${rowEntry};

		AssertClick(
			locator1 = "ContentRow#ENTRY_CONTENT_ENTRY_NAME_LINK",
			value1 = ${rowEntry});
	}

	@summary = "Default summary"
	macro gotoEntryMenuItem(rowEntry = null, menuItem = null) {
		LexiconEntry.openEntryMenu(rowEntry = ${rowEntry});

		MenuItem.click(menuItem = ${menuItem});
	}

	@summary = "Default summary"
	macro gotoEntryMenuItemNoError(rowEntry = null, menuItem = null) {
		LexiconEntry.openEntryMenu(rowEntry = ${rowEntry});

		MenuItem.clickNoError(menuItem = ${menuItem});
	}

	@summary = "Default summary"
	macro gotoEntryMenuItemNoWait(rowEntry = null, menuItem = null) {
		Click(
			key_rowEntry = ${rowEntry},
			locator1 = "Icon#ROW_VERTICAL_ELLIPSIS");

		MenuItem.click(menuItem = ${menuItem});
	}

	@summary = "Default summary"
	macro gotoEntryMenuItemNoWaitNoError(rowEntry = null, menuItem = null) {
		Click(
			key_rowEntry = ${rowEntry},
			locator1 = "Icon#ROW_VERTICAL_ELLIPSIS");

		MenuItem.clickNoError(menuItem = ${menuItem});
	}

	@summary = "Default summary"
	macro gotoHeaderMenuItem(menuItem = null) {
		Click(locator1 = "Icon#HEADER_VERTICAL_ELLIPSIS");

		MenuItem.click(menuItem = ${menuItem});
	}

	@summary = "Default summary"
	macro gotoHeaderMenuItemNoError(menuItem = null) {
		Click(locator1 = "Icon#HEADER_VERTICAL_ELLIPSIS");

		MenuItem.clickNoError(menuItem = ${menuItem});
	}

	@summary = "Default summary"
	macro openEntryMenu(rowEntry = null) {
		Click.waitForMenuToggleJSClick(
			key_rowEntry = ${rowEntry},
			locator1 = "Icon#ROW_VERTICAL_ELLIPSIS");
	}

	@summary = "Default summary"
	macro viewEntryName(rowEntry = null) {
		AssertTextEquals(
			key_rowEntry = ${rowEntry},
			locator1 = "ContentRow#ENTRY_CONTENT_ENTRY_NAME",
			value1 = ${rowEntry});
	}

	@summary = "Default summary"
	macro viewEntryNamePartial(rowEntry = null) {
		AssertTextEquals.assertPartialText(
			key_rowEntry = ${rowEntry},
			locator1 = "ContentRow#ENTRY_CONTENT_ENTRY_NAME",
			value1 = ${rowEntry});
	}

	@summary = "Default summary"
	macro viewNoEntry(rowEntry = null) {
		AssertElementNotPresent(
			key_rowEntry = ${rowEntry},
			locator1 = "ContentRow#ENTRY_CONTENT_ENTRY_NAME");
	}

}