	@summary = "Default summary"
	macro editUserInformation(password = null, userFirstNameEdit = null, userLastNameEdit = null, userCustomFieldLabel = null, userCustomField = null, userEmailAddressEdit = null, userMiddleNameEdit = null, userScreenNameEdit = null) {
		AssertElementPresent.assertElementPresent(locator1 = "TextInput#FIRST_NAME");

		if (isSet(userFirstNameEdit)) {
			Type(
				locator1 = "TextInput#FIRST_NAME",
				value1 = ${userFirstNameEdit});
