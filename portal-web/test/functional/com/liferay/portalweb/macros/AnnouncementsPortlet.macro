definition {

	@summary = "Default summary"
	macro configureDisplayCountPG() {
		Portlet.gotoPortletOptions(
			portletName = "Announcements",
			portletOption = "Configuration");

		IFrame.selectDialogFrame();

		Select(
			locator1 = "Select#MAXIMUM_ITEMS_TO_DISPLAY",
			value1 = 5);

		PortletEntry.save();

		SelectFrameTop();
	}

	@summary = "Default summary"
	macro configurePaginationManageEntriesPG(itemsPerPage = null, distributionScope = null) {
		Select(
			locator1 = "AnnouncementsManageEntries#DISTRIBUTION_SCOPE_SELECT",
			value1 = ${distributionScope});

		Click(locator1 = "Button#ITEMS_PER_PAGE");

		MenuItem.click(menuItem = ${itemsPerPage});
	}

}