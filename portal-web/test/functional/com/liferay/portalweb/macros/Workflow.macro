		Workflow.viewCompletedTask(
			ddlDataDefinitionName = ${ddlDataDefinitionName},
			workflowAssetTitle = ${workflowAssetTitle},
			workflowAssetType = ${workflowAssetType},
			workflowTask = ${workflowTask});
	}

