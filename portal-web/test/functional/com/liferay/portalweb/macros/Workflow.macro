			value1 = ${workflowTask});

		AssertElementPresent(locator1 = "WorkflowSubmissions#LAST_ACTIVITY_DATE");

		AssertElementPresent(locator1 = "WorkflowSubmissions#END_DATE");

		AssertClick(
