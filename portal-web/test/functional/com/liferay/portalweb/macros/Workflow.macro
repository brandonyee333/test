	@summary = "Default summary"
	macro deactivateWorkflowDefinitionCmd() {
		MenuItem.clickNoError(menuItem = "Deactivate");

		Confirm(value1 = "Are you sure you want to deactivate this?");

		Alert.waitForSuccessMessageHide();
	}

