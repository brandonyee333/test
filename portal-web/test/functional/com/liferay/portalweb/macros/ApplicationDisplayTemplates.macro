definition {

	@summary = "Default summary"
	macro addADTWithFieldEntryCP(fieldName = null, portletName = null) {
		AssertVisible(locator1 = "Button#PLUS");

		LexiconEntry.gotoAdd();

		MenuItem.click(menuItem = "${portletName} Template");

		SiteAdmin.viewPortletTitle(portletTitle = "New ${portletName} Template");

		PortletEntry.inputName(name = "${portletName} Test ADT");

		Click(
			key_fieldName = ${fieldName},
			locator1 = "DDMEditTemplate#SCRIPT_FIELD");

		PortletEntry.save();

		Refresh();
	}

	@summary = "Default summary"
	macro addCP(adtType = null, adtFile = null) {
		var key_adtType = ${adtType};

		Portlet.viewEmptyMessage();

		LexiconEntry.gotoAdd();

		MenuItem.click(menuItem = "${adtType} Template");

		SiteAdmin.viewPortletTitle(portletTitle = "New ${adtType} Template");

		PortletEntry.inputName(name = "${adtType} Test ADT");

		UploadCommonFile(
			locator1 = "DDMEditTemplate#SCRIPT_FILE_FIELD",
			value1 = ${adtFile});

		PortletEntry.save();

		AssertTextEquals(
			locator1 = "ApplicationDisplayTemplates#ADT_TABLE_NAME_1",
			value1 = "${adtType} Test ADT");
	}

	@summary = "Default summary"
	macro addManualViaRSS(siteName = null) {
		IFrame.selectDialogFrame();

		Pause(value1 = 5000);

		if (IsElementPresent(locator1 = "Configuration#SETUP_DISPLAY_SETTINGS")) {
			AssertClick(
				locator1 = "Configuration#SETUP_DISPLAY_SETTINGS",
				value1 = "Display Settings");
		}

		AssertClick(
			locator1 = "ApplicationDisplayTemplatesConfiguration#MANAGE_DISPLAY_TEMPLATES_LINK",
			value1 = "Manage Display Templates for ${siteName}");

		var key_adtType = "RSS";

		SelectFrameTop(value1 = "relative=top");

		SelectFrame(locator1 = "ApplicationDisplayTemplates#ADT_IFRAME");

		LexiconEntry.gotoAdd();

		AssertVisible(locator1 = "ApplicationDisplayTemplates#RSS_FEEDS");

		AssertElementPresent(locator1 = "ApplicationDisplayTemplates#RSS_FEEDS");

		PortletEntry.inputName(name = "RSS Test ADT");

		Click(locator1 = "ApplicationDisplayTemplates#RSS_FEEDS");

		PortletEntry.save();
	}

	@summary = "Default summary"
	macro addPG(adtType = null, adtFile = null, siteName = null, portletName = null) {
		Portlet.gotoPortletOptions(
			portletName = ${portletName},
			portletOption = "Configuration");

		IFrame.selectConfigurationFrame();

		Pause(value1 = 5000);

		if (IsElementPresent(locator1 = "Configuration#SETUP_DISPLAY_SETTINGS")) {
			AssertClick(
				locator1 = "Configuration#SETUP_DISPLAY_SETTINGS",
				value1 = "Display Settings");
		}
		else if (IsElementPresent(locator1 = "Configuration#SETUP_DISPLAY_SETTINGS_PANEL")) {
			Panel.expandPanel(panelHeading = "Display Settings");
		}

		AssertClick(
			locator1 = "ApplicationDisplayTemplatesConfiguration#MANAGE_DISPLAY_TEMPLATES_LINK",
			value1 = "Manage Display Templates for ${siteName}");

		var key_adtType = ${adtType};

		SelectFrameTop();

		SelectFrame(locator1 = "ApplicationDisplayTemplates#ADT_IFRAME");

		LexiconEntry.gotoAdd();

		var key_adtType = ${adtType};

		AssertVisible(locator1 = "ApplicationDisplayTemplates#PORTLET_PREFERENCES");

		AssertElementPresent(locator1 = "ApplicationDisplayTemplates#PORTLET_PREFERENCES");

		PortletEntry.inputName(name = "${adtType} Test ADT");

		UploadCommonFile(
			locator1 = "DDMEditTemplate#SCRIPT_FILE_FIELD",
			value1 = ${adtFile});

		PortletEntry.save();

		AssertTextEquals(
			locator1 = "ApplicationDisplayTemplates#ADT_TABLE_NAME_1",
			value1 = "${adtType} Test ADT");

		SelectFrameTop(value1 = "relative=top");
	}

	@summary = "Default summary"
	macro addPGWithScript(adtType = null, siteName = null, script = null, portletName = null) {
		Portlet.gotoPortletOptions(
			portletName = ${portletName},
			portletOption = "Configuration");

		IFrame.selectConfigurationFrame();

		Pause(value1 = 5000);

		if (IsElementPresent(locator1 = "Configuration#SETUP_DISPLAY_SETTINGS")) {
			AssertClick(
				locator1 = "Configuration#SETUP_DISPLAY_SETTINGS",
				value1 = "Display Settings");
		}
		else if (IsElementPresent(locator1 = "Configuration#SETUP_DISPLAY_SETTINGS_PANEL")) {
			Panel.expandPanel(panelHeading = "Display Settings");
		}

		AssertClick(
			locator1 = "ApplicationDisplayTemplatesConfiguration#MANAGE_DISPLAY_TEMPLATES_LINK",
			value1 = "Manage Display Templates for ${siteName}");

		var key_adtType = ${adtType};

		SelectFrameTop();

		SelectFrame(locator1 = "ApplicationDisplayTemplates#ADT_IFRAME");

		LexiconEntry.gotoAdd();

		var key_adtType = ${adtType};

		AssertVisible(locator1 = "ApplicationDisplayTemplates#PORTLET_PREFERENCES");

		AssertElementPresent(locator1 = "ApplicationDisplayTemplates#PORTLET_PREFERENCES");

		PortletEntry.inputName(name = "${adtType} Test ADT");

		ApplicationDisplayTemplates.editADTScript(adtScript = ${script});

		AssertTextEquals(
			locator1 = "ApplicationDisplayTemplates#ADT_TABLE_NAME_1",
			value1 = "${adtType} Test ADT");

		SelectFrameTop(value1 = "relative=top");
	}

	@summary = "Default summary"
	macro addPortletADTWithFieldEntry(fieldName = null, portletName = null) {
		Portlet.gotoPortletOptions(
			portletName = ${portletName},
			portletOption = "Configuration");

		IFrame.selectConfigurationFrame();

		Pause(value1 = 3000);

		AssertClick.assertPartialTextClickAt(
			locator1 = "ApplicationDisplayTemplatesConfiguration#MANAGE_DISPLAY_TEMPLATES_LINK",
			value1 = "Manage Display Templates");

		SelectFrameTop();

		SelectFrame(locator1 = "ApplicationDisplayTemplates#ADT_IFRAME");

		LexiconEntry.gotoAdd();

		PortletEntry.inputName(name = "${portletName} Test ADT");

		Click(
			key_fieldName = ${fieldName},
			locator1 = "DDMEditTemplate#SCRIPT_FIELD");

		PortletEntry.save();

		SelectFrameTop(value1 = "relative=top");
	}

	@summary = "Default summary"
	macro editADTScript(adtScript = null) {
		Type.sendKeysAceEditor(
			locator1 = "TextArea#ACE_EDITOR",
			value1 = ${adtScript});

		PortletEntry.save();
	}

	@summary = "Default summary"
	macro gotoWidgetTemplatesEllipsisItem(item = null, widgetTemplateName = null) {
		Click.waitForMenuToggleJSClick(
			key_tableEntry = ${widgetTemplateName},
			locator1 = "LexiconTable#TABLE_ENTRY_ELLIPSIS_LINK");

		MenuItem.clickNoError(menuItem = ${item});
	}

	@summary = "Default summary"
	macro searchGlobalADT(templateName = null) {
		AssertElementPresent(locator1 = "Search#SEARCH_FIELD");

		AssertElementPresent(locator1 = "Icon#BASIC_SEARCH");

		Type(
			locator1 = "Search#SEARCH_FIELD",
			value1 = ${templateName});

		KeyPress(
			locator1 = "Search#SEARCH_FIELD",
			value1 = "\RETURN");

		AssertTextEquals(
			locator1 = "ApplicationDisplayTemplates#ADT_TABLE_NAME_1",
			value1 = ${templateName});
	}

	@summary = "Default summary"
	macro selectPortletADT(templateName = null, portletName = null) {
		Portlet.gotoPortletOptions(
			portletName = ${portletName},
			portletOption = "Configuration");

		IFrame.selectConfigurationFrame();

		var key_tab = "Display Settings";

		if (IsElementPresent(locator1 = "NavTab#TAB_LINK")) {
			Navigator.gotoNavTab(navTab = "Display Settings");
		}

		Select(
			locator1 = "Select#DISPLAY_TEMPLATE",
			value1 = ${templateName});

		PortletEntry.save();

		SelectFrameTop();
	}

}