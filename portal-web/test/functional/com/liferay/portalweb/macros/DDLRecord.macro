	@summary = "Default summary"
	macro populateFieldBoolean(ddlRecordFieldData = null, fieldName = null, fieldShowLabel = null, fieldFieldLabel = null) {
		DDLRecord.viewFieldLabel(
			fieldFieldLabel = ${fieldFieldLabel},
			fieldName = ${fieldName},
			fieldShowLabel = ${fieldShowLabel});

		var key_fieldName = ${fieldName};

		if (${ddlRecordFieldData} == "No") {
			if (${fieldShowLabel} == "No") {
				Uncheck(locator1 = "TextInput#DDM");
			}
			else {
				Uncheck(locator1 = "TextInput#DDM");
			}
		}
		else if (${ddlRecordFieldData} == "Yes") {
			if (${fieldShowLabel} == "No") {
				Check(locator1 = "TextInput#DDM");
			}
			else {
				Check(locator1 = "TextInput#DDM");
			}
		}
		else {
			fail("Invalid var recordFieldData. Must be (Yes|No).");
		}
	}

