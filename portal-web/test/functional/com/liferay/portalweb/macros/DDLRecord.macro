	@summary = "Default summary"
	macro populateFieldDocumentsAndMediaChooseFromDocumentLibrary(parentFieldName = null, fieldName = null, document = null, userRole = null) {
		var key_fieldName = ${fieldName};

		if (isSet(parentFieldName)) {
			var key_parentFieldName = ${parentFieldName};

			AssertClick(
				locator1 = "DDLEditRecord#DOCUMENTS_AND_MEDIA_CHILD_FIELD_CHOOSE_FROM_DOCUMENT_LIBRARY_BUTTON_",
				value1 = "Select");
		}
		else {
			AssertClick(
				locator1 = "Button#FIELD_SELECT",
				value1 = "Select");
		}

		SelectFrame(locator1 = "DocumentsAndMediaSelectDocument#SELECT_DOCUMENT_IFRAME");

		if (${userRole} == "Guest") {
			AssertTextEquals(
				locator1 = "Button#SIGN_IN",
				value1 = "Sign In");
		}
		else {
			UploadCommonFile.uploadCommonFileHiddenNoMouseOver(
				locator1 = "DocumentsAndMediaSelectDocument#SELECT_FILE_BUTTON",
				value1 = ${document});

			Pause(locator1 = 1000);

			SelectFrameTop(value1 = "relative=top");

			AssertClick(
				locator1 = "Button#ADD",
				value1 = "Add");
		}
	}

