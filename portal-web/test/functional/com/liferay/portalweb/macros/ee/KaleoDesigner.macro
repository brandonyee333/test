	@summary = "Default summary"
	macro viewSourceXMLLine(line = null, invalid = null, kdSourceXML = null) {
		KaleoDesigner.viewSourceXMLTab();

		ScrollWebElementIntoView(locator1 = "KaleoDesignerEditWorkflow#SOURCE_KALEO_XML_TAB");

		var key_line = ${line};

		if (${invalid} == "true") {
			AssertTextNotPresent(
				locator1 = "KaleoDesignerEditWorkflow#SOURCE_KALEO_XML_CONTENT_SPECIFIC_LINE_CONTENT",
				value1 = ${kdSourceXML});
		}
		else {
			AssertTextEquals.assertPartialText(
				locator1 = "KaleoDesignerEditWorkflow#SOURCE_KALEO_XML_CONTENT_SPECIFIC_LINE_CONTENT",
				value1 = ${kdSourceXML});
		}

		Pause(locator1 = 1000);

		AssertClick(
			locator1 = "KaleoDesignerEditWorkflow#VIEW_TAB",
			value1 = "View");

		Pause(locator1 = 1000);
	}

