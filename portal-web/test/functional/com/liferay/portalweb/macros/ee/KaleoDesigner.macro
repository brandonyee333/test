	@summary = "Default summary"
	macro editWorkflowDefinitionViaKDCP(workflowDefinitionTitle = null) {
		LexiconEntry.gotoEntryMenuItem(
			menuItem = "Edit",
			rowEntry = ${workflowDefinitionTitle});
