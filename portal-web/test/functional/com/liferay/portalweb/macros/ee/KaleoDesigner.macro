	@summary = "Default summary"
	macro editNodeName(nodeName = null) {
		DoubleClick(locator1 = "DDMEditStructure#SETTINGS_NAME");

		Type(
			locator1 = "TextInput#TEXT",
			value1 = ${nodeName});

		AssertClick(
			locator1 = "Button#SAVE",
