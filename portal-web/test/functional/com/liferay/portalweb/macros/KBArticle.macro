	macro gotoKBGrandchildArticleViaKBDisplayHierarchyNavigationPG(kbGrandchildArticleTitle = null, kbChildArticleTitle = null, kbArticleTitle = null) {
		var key_kbArticleTitle = ${kbArticleTitle};
