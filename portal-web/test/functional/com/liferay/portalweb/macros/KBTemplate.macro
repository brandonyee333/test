definition {

	@summary = "Default summary"
	macro addCP(kbTemplateTitle = null, kbTemplateContent = null) {
		LexiconEntry.gotoHeaderMenuItem(menuItem = "Templates");

		LexiconEntry.gotoAdd();

		AlloyEditor.addTitleAndContent(
			content = ${kbTemplateContent},
			title = ${kbTemplateTitle});

		PortletEntry.publish();
	}

	@summary = "Default summary"
	macro gotoCP(kbTemplateTitle = null) {
		LexiconEntry.gotoHeaderMenuItem(menuItem = "Templates");

		LexiconEntry.gotoEntryMenuItem(
			menuItem = "View",
			rowEntry = ${kbTemplateTitle});
	}

	@summary = "Default summary"
	macro tearDownCP() {
		Navigator.openURL();

		ProductMenu.gotoPortlet(
			category = "Content",
			panel = "Site Administration",
			portlet = "Knowledge Base");

		LexiconEntry.gotoHeaderMenuItem(menuItem = "Templates");

		if (IsElementPresent(locator1 = "ContentRow#ENTRY_CONTENT_ROW_1")) {
			Check.checkAll(locator1 = "Checkbox#SELECT_ALL");

			AssertClickNoError(
				locator1 = "Button#DELETE",
				value1 = "Delete");

			Confirm(value1 = "Are you sure you want to delete the selected templates?");

			Alert.viewSuccessMessage();
		}
	}

	@summary = "Default summary"
	macro viewCP(kbTemplateTitle = null, kbTemplateContent = null) {
		KBTemplate.gotoCP(kbTemplateTitle = ${kbTemplateTitle});

		AssertTextEquals(
			locator1 = "KnowledgeBaseTemplate#TEMPLATE_TITLE",
			value1 = ${kbTemplateTitle});

		AssertTextEquals.assertPartialText(
			locator1 = "KnowledgeBaseTemplate#TEMPLATE_CONTENT",
			value1 = ${kbTemplateContent});
	}

	@summary = "Default summary"
	macro viewCPViaAddTemplate(kbTemplateTitle = null, kbTemplateContent = null) {
		LexiconEntry.gotoAddMenuItem(menuItem = ${kbTemplateTitle});

		AssertTextEquals(
			locator1 = "AlloyEditor#TITLE_FIELD",
			value1 = ${kbTemplateTitle});

		AssertTextEquals(
			locator1 = "AlloyEditor#CONTENT_FIELD",
			value1 = ${kbTemplateContent});
	}

}