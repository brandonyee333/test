definition {

	var orgName = "Organization Name";

	@summary = "Default summary"
	macro addAdditionalEmailAddressesCP(orgAdditionalEmailAddress = null) {
		Organization.gotoIdentificationCP(panelHeading = "Additional Email Addresses");

		Type(
			locator1 = "UsersAndOrganizationsEditOrganization#ADDITIONAL_EMAIL_ADDRESSES_EMAIL_ADDRESS_FIELD",
			value1 = ${orgAdditionalEmailAddress});

		Click(locator1 = "UsersAndOrganizationsEditOrganization#ADDITIONAL_EMAIL_ADDRESSES_EMAIL_ADDRESS_FIELD");

		PortletEntry.save();

		Organization.gotoIdentificationCP(panelHeading = "Additional Email Addresses");

		AssertTextEquals(
			locator1 = "UsersAndOrganizationsEditOrganization#ADDITIONAL_EMAIL_ADDRESSES_EMAIL_ADDRESS_FIELD",
			value1 = ${orgAdditionalEmailAddress});
	}

	@summary = "Default summary"
	macro addAddressCP(orgAddressRegion = null, orgAddressStreet = null, orgAddressType = null, orgAddressPostal = null, orgAddressCountry = null, orgAddressCity = null) {
		Organization.gotoIdentificationCP();

		Type(
			locator1 = "UsersAndOrganizationsEditOrganization#ADDRESSES_STREET_FIELD_1",
			value1 = ${orgAddressStreet});

		Type(
			locator1 = "UsersAndOrganizationsEditOrganization#ADDRESSES_CITY_FIELD",
			value1 = ${orgAddressCity});

		Type(
			locator1 = "UsersAndOrganizationsEditOrganization#ADDRESSES_POSTAL_CODE_FIELD",
			value1 = ${orgAddressPostal});

		Select(
			locator1 = "UsersAndOrganizationsEditOrganization#ADDRESSES_COUNTRY_SELECT",
			value1 = ${orgAddressCountry});

		Select(
			locator1 = "UsersAndOrganizationsEditOrganization#ADDRESSES_REGION_SELECT",
			value1 = ${orgAddressRegion});

		Select(
			locator1 = "UsersAndOrganizationsEditOrganization#ADDRESSES_TYPE_SELECT",
			value1 = ${orgAddressType});

		Check(locator1 = "UsersAndOrganizationsEditOrganization#ADDRESSES_MAILING_CHECKBOX");

		Click(locator1 = "UsersAndOrganizationsEditOrganization#ADDRESSES_PRIMARY_RADIO");

		PortletEntry.save();
	}

	@summary = "Default summary"
	macro addCategorizationCP(orgName = null, tagName = null) {
		Organization.editOrganizationInformationCP(
			orgName = ${orgName},
			panelHeading = "Categorization");

		var key_tagName = ${tagName};

		Click(locator1 = "UsersAndOrganizationsEditOrganization#CATEGORIZATION_TAGS_FIELD");

		Type(
			locator1 = "UsersAndOrganizationsEditOrganization#CATEGORIZATION_TAGS_FIELD",
			value1 = ${tagName});

		AssertClick(
			locator1 = "Button#ADD_TAGS",
			value1 = "Add");

		AssertElementPresent(locator1 = "UsersAndOrganizationsEditOrganization#CATEGORIZATION_TAG");

		PortletEntry.save();

		Organization.gotoOrganizationInformationCP(panelHeading = "Categorization");

		AssertTextEquals(
			locator1 = "UsersAndOrganizationsEditOrganization#CATEGORIZATION_TAG",
			value1 = ${tagName});
	}

	@summary = "Default summary"
	macro addCommentCP(orgComment = null) {
		Organization.gotoMiscellaneousCP();

		Type(
			locator1 = "TextArea#COMMENTS",
			value1 = ${orgComment});

		PortletEntry.save();

		Organization.gotoMiscellaneousCP();

		AssertTextEquals(
			locator1 = "TextArea#COMMENTS",
			value1 = ${orgComment});
	}

	@summary = "Default summary"
	macro addCP(orgType = null, orgName = null, organizationName = null) {
		AssertClick(
			locator1 = "NavBar#ORGANIZATIONS",
			value1 = "Organizations");

		var key_navItem = "Organizations";

		AssertElementPresent(locator1 = "NavBar#ACTIVE_NAV_ITEM_LINK");

		LexiconEntry.gotoAdd();

		if (${orgType} == "Location") {
			MenuItem.click(menuItem = "Location");
		}
		else if (IsElementPresent(key_menuItem = "Organization", locator1 = "MenuItem#ANY_MENU_ITEM")) {
			MenuItem.click(menuItem = "Organization");
		}

		Type(
			locator1 = "TextInput#NAME",
			value1 = ${orgName});

		Button.clickSave();

		if (${organizationName} == "Duplicate") {
			Alert.viewRequestFailedToComplete();

			AssertTextEquals.assertPartialText(
				locator1 = "Message#ERROR_2",
				value1 = "The organization name is already taken.");
		}
		else {
			var key_orgType = ${orgType};

			Alert.viewSuccessMessage();

			AssertTextEquals(
				locator1 = "TextInput#NAME",
				value1 = ${orgName});

			AssertTextEquals.assertValue(
				locator1 = "UsersAndOrganizationsEditOrganization#DETAILS_TYPE",
				value1 = ${orgType});
		}
	}

	@summary = "Default summary"
	macro addMemberCP(orgName = null, userLastName = null, userScreenName = null, userMiddleName = null, userFirstName = null) {
		Organization.gotoActionsCmd(orgName = ${orgName});

		var key_orgName = ${orgName};

		MenuItem.click(menuItem = "Assign Users");

		Navigator.gotoNavTab(navTab = "Available");

		var key_userScreenName = ${userScreenName};

		if (IsElementNotPresent(locator1 = "UsersAndOrganizations#USER_TABLE_SCREEN_NAME")) {
			Type(
				locator1 = "TextInput#SITE_SEARCH_KEYWORDS",
				value1 = ${userScreenName});

			AssertClick(
				locator1 = "Button#SEARCH",
				value1 = "Search");
		}

		AssertTextEquals(
			locator1 = "UsersAndOrganizations#USER_TABLE_SCREEN_NAME",
			value1 = ${userScreenName});

		Check(locator1 = "UsersAndOrganizationsAssignUsers#USER_TABLE_CHECKBOX");

		AssertClick(
			locator1 = "Button#UPDATE_ASSOCIATIONS",
			value1 = "Update Associations");

		Alert.viewSuccessMessage();

		Navigator.gotoNavTab(navTab = "Current");

		AssertChecked(locator1 = "UsersAndOrganizationsAssignUsers#USER_TABLE_CHECKBOX");

		if (isSet(userMiddleName)) {
			AssertTextEquals(
				locator1 = "UsersAndOrganizations#USER_TABLE_USER_NAME",
				value1 = "${userFirstName} ${userMiddleName} ${userLastName}");
		}
		else {
			AssertTextEquals(
				locator1 = "UsersAndOrganizations#USER_TABLE_USER_NAME",
				value1 = "${userFirstName} ${userLastName}");
		}

		AssertTextEquals(
			locator1 = "UsersAndOrganizations#USER_TABLE_SCREEN_NAME",
			value1 = ${userScreenName});
	}

	@summary = "Default summary"
	macro addPhoneNumbersCP(orgPhoneNumber = null) {
		Organization.gotoIdentificationCP(panelHeading = "Phone Numbers");

		Type(
			locator1 = "UsersAndOrganizationsEditOrganization#PHONE_NUMBERS_NUMBER_FIELD",
