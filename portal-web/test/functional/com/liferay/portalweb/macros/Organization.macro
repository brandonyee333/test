		Organization.gotoIdentificationCP(panelHeading = "Phone Numbers");

		AssertTextEquals(
			locator1 = "UsersAndOrganizationsEditOrganization#PHONE_NUMBERS_NUMBER_FIELD",
			value1 = ${orgPhoneNumber});
	}

	@summary = "Default summary"
	macro addReminderQueriesCP(orgReminderQuery = null, orgReminderQueriesDefaultLanguage = null, orgLocalizedLanguage = null) {
		Organization.gotoMiscellaneousCP(panelHeading = "Reminder Queries");

		Type(
			locator1 = "UsersAndOrganizationsEditOrganization#REMINDER_QUERIES_DEFAULT_LANGUAGE_FIELD",
			value1 = ${orgReminderQueriesDefaultLanguage});

		Select(
			locator1 = "UsersAndOrganizationsEditOrganization#REMINDER_QUERIES_LOCALIZED_LANGUAGE_SELECT",
			value1 = ${orgLocalizedLanguage});

		Type(
			locator1 = "UsersAndOrganizationsEditOrganization#REMINDER_QUERIES_TEXT_FIELD",
			value1 = ${orgReminderQuery});

		PortletEntry.save();

		Organization.gotoMiscellaneousCP(panelHeading = "Reminder Queries");

		AssertTextEquals(
			locator1 = "UsersAndOrganizationsEditOrganization#REMINDER_QUERIES_DEFAULT_LANGUAGE_FIELD",
			value1 = ${orgReminderQueriesDefaultLanguage});

		Select(
			locator1 = "UsersAndOrganizationsEditOrganization#REMINDER_QUERIES_LOCALIZED_LANGUAGE_SELECT",
			value1 = ${orgLocalizedLanguage});

		AssertSelectedLabel(
			locator1 = "UsersAndOrganizationsEditOrganization#REMINDER_QUERIES_LOCALIZED_LANGUAGE_SELECT",
			value1 = ${orgLocalizedLanguage});
	}

	@summary = "Default summary"
	macro addServicesCP(orgServicesOpen = null, orgServicesClosed = null) {
		Organization.gotoIdentificationCP(panelHeading = "Services");

		Select(
			locator1 = "UsersAndOrganizationsEditOrganization#SERVICES_MONDAY_OPEN_SELECT",
			value1 = ${orgServicesOpen});

		Select(
			locator1 = "UsersAndOrganizationsEditOrganization#SERVICES_MONDAY_CLOSE_SELECT",
			value1 = ${orgServicesClosed});

		PortletEntry.save();

		Organization.gotoIdentificationCP(panelHeading = "Services");

		AssertSelectedLabel(
			locator1 = "UsersAndOrganizationsEditOrganization#SERVICES_MONDAY_OPEN_SELECT",
			value1 = ${orgServicesOpen});

		AssertSelectedLabel(
			locator1 = "UsersAndOrganizationsEditOrganization#SERVICES_MONDAY_CLOSE_SELECT",
			value1 = ${orgServicesClosed});
	}

	@summary = "Default summary"
	macro addSiteCP(checkEnablePropagationCheckbox = null, orgName = null, organizationSite = null) {
		Organization.gotoActionsCmd(orgName = ${orgName});

		var key_orgName = ${orgName};

		MenuItem.click(menuItem = "Edit");

		Pause(locator1 = 3000);

		Panel.expandPanel(panelHeading = "Organization Site");

		Check(locator1 = "UsersAndOrganizationsEditOrganization#ORGANIZATION_SITE_CREATE_SITE_CHECKBOX");

		if ((${organizationSite} == "Community Site") || (${organizationSite} == "Intranet Site")) {
			Select(
				locator1 = "UserGroupsEditUserGroup#PUBLIC_PAGES_SELECT",
				value1 = ${organizationSite});

			if (${checkEnablePropagationCheckbox} == "true") {
				AssertChecked(locator1 = "UserGroupsEditUserGroup#ENABLE_PROPAGATION_PUBLIC_PAGE_CHECKBOX");
			}
			else {
				Uncheck(locator1 = "UserGroupsEditUserGroup#ENABLE_PROPAGATION_PUBLIC_PAGE_CHECKBOX");
			}
		}

		PortletEntry.save();

		Panel.expandPanel(panelHeading = "Organization Site");

		if (IsElementPresent(locator1 = "UserGroupsEditUserGroup#PUBLIC_PAGES_SELECT")) {
			AssertChecked(locator1 = "UsersAndOrganizationsEditOrganization#ORGANIZATION_SITE_CREATE_SITE_CHECKBOX");
		}
	}

	@summary = "Default summary"
	macro addSiteCPWithPrivatePage(checkEnablePropagationCheckbox = null, orgName = null, organizationSite = null) {
		Organization.gotoActionsCmd(orgName = ${orgName});

		MenuItem.click(menuItem = "Edit");

		Pause(locator1 = 3000);

		Panel.expandPanel(panelHeading = "Organization Site");

		Check(locator1 = "UsersAndOrganizationsEditOrganization#ORGANIZATION_SITE_CREATE_SITE_CHECKBOX");

		if ((${organizationSite} == "Community Site") || (${organizationSite} == "Intranet Site")) {
			Select(
				locator1 = "UsersAndOrganizationsEditOrganization#ORGANIZATION_SITE_PRIVATE_PAGES_SELECT",
				value1 = ${organizationSite});

			if (${checkEnablePropagationCheckbox} == "true") {
				AssertChecked(locator1 = "UsersAndOrganizationsEditOrganization#ENABLE_PROPAGATION_PRIVATE_PAGE_CHECKBOX");
			}
			else {
				Uncheck(locator1 = "UsersAndOrganizationsEditOrganization#ENABLE_PROPAGATION_PRIVATE_PAGE_CHECKBOX");
			}
		}

		PortletEntry.save();

		Panel.expandPanel(panelHeading = "Organization Site");

		if (IsElementPresent(locator1 = "UsersAndOrganizationsEditOrganization#ORGANIZATION_SITE_PRIVATE_PAGES_SELECT")) {
			AssertChecked(locator1 = "UsersAndOrganizationsEditOrganization#ORGANIZATION_SITE_CREATE_SITE_CHECKBOX");
		}
	}

	@summary = "Default summary"
	macro addWebsitesCP(orgWebsite = null) {
		Organization.gotoIdentificationCP(panelHeading = "Websites");

		Type(
			locator1 = "UsersAndOrganizationsEditOrganization#WEBSITES_URL_FIELD",
			value1 = ${orgWebsite});

		Click(locator1 = "UsersAndOrganizationsEditOrganization#WEBSITES_PRIMARY_RADIO");

		PortletEntry.save();

		Organization.gotoIdentificationCP(panelHeading = "Websites");

		AssertTextEquals(
			locator1 = "UsersAndOrganizationsEditOrganization#WEBSITES_URL_FIELD",
			value1 = ${orgWebsite});
	}

	@summary = "Default summary"
	macro addWithLocalizedCountryCP(navItem = null, localizedOption = null, orgName = null, countryName = null, saveButton = null) {
		Navigator.gotoNavItem(navItem = ${navItem});

		LexiconEntry.gotoAdd();

		if (IsElementPresent(key_menuItem = ${localizedOption}, locator1 = "MenuItem#ANY_MENU_ITEM")) {
			MenuItem.click(menuItem = ${localizedOption});
		}

		Type(
			locator1 = "TextInput#NAME",
			value1 = ${orgName});

		Select(
			key_countryName = ${countryName},
			locator1 = "UsersAndOrganizations#ORGANIZATION_COUNTRY_NAME",
			value1 = ${countryName});

		AssertClick(
			key_saveButton = ${saveButton},
			locator1 = "Button#SAVE_LOCALIZED",
			value1 = ${saveButton});

		Alert.viewSuccessMessage();
	}

	@summary = "Default summary"
	macro assignOrgRoleCP(orgName = null, userLastName = null, userScreenName = null, roleName = null, userFirstName = null) {
		Organization.gotoActionsCmd(orgName = ${orgName});

		var key_orgName = ${orgName};

		Pause(locator1 = 5000);

		MenuItem.click(menuItem = "Assign Organization Roles");

		SelectFrame(locator1 = "IFrame#DIALOG");

		AssertTextEquals(
			locator1 = "//tr[contains(.,'${roleName}')]/td[1]/span/a",
			value1 = ${roleName});

		Click(locator1 = "//tr[contains(.,'${roleName}')]/td[1]/span/a");

		Navigator.gotoNavItem(navItem = "Available");

		Search.searchCP(searchTerm = ${userScreenName});

		var key_userScreenName = ${userScreenName};

		AssertTextEquals(
			locator1 = "UsersAndOrganizations#USER_TABLE_SCREEN_NAME",
			value1 = ${userScreenName});

		Check(locator1 = "UsersAndOrganizationsAssignUsers#USER_TABLE_CHECKBOX");

		AssertClick(
			locator1 = "Button#UPDATE_ASSOCIATIONS",
			value1 = "Update Associations");

		Alert.viewSuccessMessage();

		Navigator.gotoNavItem(navItem = "Current");

		AssertTextEquals(
			locator1 = "UsersAndOrganizations#USER_TABLE_USER_NAME",
			value1 = "${userFirstName} ${userLastName}");

		AssertTextEquals(
			locator1 = "UsersAndOrganizations#USER_TABLE_SCREEN_NAME",
			value1 = ${userScreenName});

		IFrame.selectTopFrame();

		Click(locator1 = "Icon#CLOSE");
	}

	@summary = "Default summary"
	macro deleteCP(orgName = null) {
		Organization.gotoActionsCmd(orgName = ${orgName});

		var key_orgName = ${orgName};

		MenuItem.clickNoError(menuItem = "Delete");

		Confirm(value1 = "Are you sure you want to delete this? It will be deleted immediately.");

		Alert.viewSuccessMessage();

		AssertTextNotPresent(value1 = ${orgName});
	}

	@summary = "Default summary"
	macro editOrganizationCreateSite(orgName = null) {
		Organization.editOrganizationInformationCP(
			orgName = ${orgName},
			panelHeading = "Organization Site");

		Check(locator1 = "UsersAndOrganizationsEditOrganization#ORGANIZATION_SITE_CREATE_SITE_CHECKBOX");

		PortletEntry.save();

		Organization.gotoOrganizationInformationCP(panelHeading = "Organization Site");

		AssertChecked(locator1 = "UsersAndOrganizationsEditOrganization#ORGANIZATION_SITE_CREATE_SITE_CHECKBOX");
	}

	@summary = "Default summary"
	macro editOrganizationInformationCP(orgName = null, panelHeading = null) {
		UsersAndOrganizationsNavigator.gotoOrganizations();

		Organization.gotoActionsCmd(orgName = ${orgName});

		var key_orgName = ${orgName};

		MenuItem.click(menuItem = "Edit");

		Organization.gotoOrganizationInformationCP(panelHeading = ${panelHeading});
	}

	@summary = "Default summary"
	macro editSiteCP(orgName = null, orgNameEdit = null) {
		Organization.gotoActionsCmd(orgName = ${orgName});

		var key_orgName = ${orgName};

		MenuItem.click(menuItem = "Edit");

		Navigator.gotoNavTab(navTab = "Organization Information");

		Type(
			locator1 = "TextInput#NAME",
			value1 = ${orgNameEdit});

		PortletEntry.save();

		AssertTextEquals(
			locator1 = "TextInput#NAME",
			value1 = ${orgNameEdit});
	}

	@summary = "Default summary"
	macro gotoActionsCmd(orgName = null) {
		Pause(locator1 = 1000);

		Type(
			locator1 = "NavBar#BASIC_SEARCH_FIELD",
			value1 = ${orgName});

		Click(locator1 = "Button#SUBMIT");

		AssertVisible(locator1 = "UsersAndOrganizations#ORGANIZATION_TABLE_NAME_GENERIC");

		var key_orgName = ${orgName};

		if (IsElementNotPresent(locator1 = "UsersAndOrganizations#ORGANIZATION_TABLE_NAME")) {
			Pagination.changePagination(itemsPerPage = 30);
		}

		AssertTextEquals(
			locator1 = "UsersAndOrganizations#ORGANIZATION_TABLE_NAME",
			value1 = ${orgName});

		LexiconEntry.openEntryMenu(rowEntry = ${orgName});
	}

	@summary = "Default summary"
	macro gotoCP(orgName = null, searchToken = null) {
		Type(
			locator1 = "TextInput#SEARCH",
			value1 = ${searchToken});

		Click(locator1 = "Button#SUBMIT");

		var key_orgName = ${orgName};

		AssertTextEquals(
			locator1 = "UsersAndOrganizations#ORGANIZATION_TABLE_NAME",
			value1 = ${orgName});

		AssertClick(
			locator1 = "UsersAndOrganizations#ORGANIZATION_TABLE_NAME",
			value1 = ${orgName});

		Breadcrumb.viewActiveEntry(breadcrumbName = ${orgName});
	}

	@summary = "Default summary"
	macro gotoIdentificationCP(panelHeading = null) {
		AssertClick(
			locator1 = "NavTab#IDENTIFICATION",
			value1 = "Identification");

		if (isSet(panelHeading)) {
			Panel.expandPanel(panelHeading = ${panelHeading});
		}
	}

	@summary = "Default summary"
	macro gotoMiscellaneousCP(panelHeading = null) {
		AssertClick(
			locator1 = "UsersAndOrganizations#MISCELLANEOUS",
			value1 = "Miscellaneous");

		if (isSet(panelHeading)) {
			Panel.expandPanel(panelHeading = ${panelHeading});
		}
	}

	@summary = "Default summary"
	macro gotoOrganizationInformationCP(panelHeading = null) {
		AssertClick(
			locator1 = "UsersAndOrganizations#ORGANIZATION_INFORMATION",
			value1 = "Organization Information");

		if (isSet(panelHeading)) {
			Panel.expandPanel(panelHeading = ${panelHeading});
		}
	}

	@summary = "Default summary"
	macro manageMembershipOptionsInSites(membershipType = null, orgName = null, selectMembershipType = null, allowManualMembershipManagement = null) {
		Organization.gotoActionsCmd(orgName = ${orgName});

		var key_orgName = ${orgName};

		MenuItem.click(menuItem = "Manage Site");

		if (${selectMembershipType} == "true") {
			AssertTextEquals(
				locator1 = "SitesEditSite#MEMBERSHIP_OPTIONS_MEMBERSHIP_TYPE_LABEL",
				value1 = "Membership Type");

			Select(
				locator1 = "SitesEditSite#MEMBERSHIP_OPTIONS_MEMBERSHIP_TYPE",
				value1 = ${membershipType});
		}

		if (${allowManualMembershipManagement} == "true") {
			Check.checkToggleSwitch(locator1 = "Checkbox#ALLOW_MANUAL_MEMBERSHIP_MANAGEMENT");
		}

		PortletEntry.save();
	}

	@summary = "Default summary"
	macro removeMemberCP(orgName = null, userScreenName = null) {
		Organization.gotoActionsCmd(orgName = ${orgName});

		var key_orgName = ${orgName};

		MenuItem.click(menuItem = "Assign Users");

		var key_userScreenName = ${userScreenName};

		AssertClick(
			locator1 = "UsersAndOrganizationsAssignUsers#CURRENT_TAB",
			value1 = "Current");

		AssertTextEquals(
			locator1 = "UsersAndOrganizations#USER_TABLE_SCREEN_NAME",
			value1 = ${userScreenName});

		Uncheck(locator1 = "UsersAndOrganizationsAssignUsers#USER_TABLE_CHECKBOX");

		AssertClick(
			locator1 = "Button#UPDATE_ASSOCIATIONS",
			value1 = "Update Associations");

		Alert.viewSuccessMessage();

		AssertTextEquals(
			locator1 = "Message#EMPTY_INFO",
			value1 = "No users were found.");
	}

	@summary = "Default summary"
	macro searchCP(searchTerm = null, orgName = null) {
		Type(
			locator1 = "TextInput#SEARCH",
			value1 = ${searchTerm});

		Click(locator1 = "Button#SUBMIT");

		var key_orgName = ${orgName};

		AssertTextEquals(
			locator1 = "UsersAndOrganizations#ORGANIZATION_TABLE_NAME",
			value1 = ${orgName});
	}

	@summary = "Default summary"
	macro selectParentOrganizationCP(orgName = null, parentOrgName = null) {
		var key_orgName = ${orgName};

		LexiconEntry.openEntryMenu(rowEntry = ${orgName});

		MenuItem.click(menuItem = "Edit");

		AssertClick(
			locator1 = "UsersAndOrganizationsEditOrganization#PARENT_ORGANIZATION_SELECT_BUTTON",
			value1 = "Select");

		SelectFrame(locator1 = "UsersAndOrganizationsSelectOrganization#SELECT_ORGANIZATION_IFRAME");

		AssertTextEquals(
			locator1 = "UsersAndOrganizationsEditUser#ORGANIZATIONS_TABLE_NAME",
			value1 = ${orgName});

		var key_orgName = ${parentOrgName};

		AssertClick(
			locator1 = "UsersAndOrganizationsSelectOrganization#ORGANIZATION_TABLE_CHOOSE_BUTTON",
			value1 = "Choose");

		SelectFrame(value1 = "relative=top");

		AssertTextEquals(
			locator1 = "UsersAndOrganizationsEditOrganization#PARENT_ORGANIZATION_TABLE_NAME",
			value1 = ${parentOrgName});

		PortletEntry.save();
	}

	@summary = "Default summary"
	macro tearDownCP(orgName = null) {
		ProductMenu.gotoPortlet(
			category = "Users",
			panel = "Control Panel",
			portlet = "Users and Organizations");

		while (IsElementPresent(locator1 = "UsersAndOrganizations#ORGANIZATION_TABLE_NAME_GENERIC", value1 = ${orgName})) {
			Click(locator1 = "UsersAndOrganizations#ORGANIZATION_TABLE_NAME_GENERIC");

			AssertClick(
				locator1 = "UsersAndOrganizationsOrganization#MENU_ASSIGN_USERS",
				value1 = "Assign Users");

			AssertClick(
				locator1 = "UsersAndOrganizationsAssignUsers#CURRENT_TAB",
				value1 = "Current");

			if ((IsElementPresent(locator1 = "Checkbox#SELECT_ALL")) && (IsVisible(locator1 = "Checkbox#SELECT_ALL"))) {
				Uncheck(locator1 = "Checkbox#SELECT_ALL");

				AssertClick(
					locator1 = "Button#UPDATE_ASSOCIATIONS",
					value1 = "Update Associations");

				AssertTextEquals(
					locator1 = "Message#INFO",
					value1 = "No users were found.");
			}

			AssertClick.assertPartialTextClickAt(
				locator1 = "Link#BACK",
				value1 = "Back");

			AssertClickNoError(
				locator1 = "UsersAndOrganizationsOrganization#MENU_DELETE",
				value1 = "Delete");

			Confirm(value1 = "Are you sure you want to delete this? It will be deleted immediately.");
		}
	}

	@summary = "Default summary"
	macro viewAssignMemberCP(userScreenName = null, userName = null) {
		var key_userScreenName = ${userScreenName};

		AssertTextEquals(
			locator1 = "UsersAndOrganizationsOrganization#USER_TABLE_NAME",
			value1 = ${userName});

		AssertTextEquals(
			locator1 = "UsersAndOrganizationsOrganization#USER_TABLE_SCREEN_NAME",
			value1 = ${userScreenName});
	}

	@summary = "Default summary"
	macro viewCP(orgType = null, orgName = null) {
		var key_orgName = ${orgName};

		AssertTextEquals(
			locator1 = "UsersAndOrganizations#ORGANIZATION_TABLE_NAME",
			value1 = ${orgName});

		AssertTextEquals(
			locator1 = "UsersAndOrganizations#ORGANIZATION_TABLE_TYPE",
			value1 = ${orgType});

		LexiconEntry.openEntryMenu(rowEntry = ${orgName});

		MenuItem.click(menuItem = "Edit");

		var key_orgType = ${orgType};

		AssertTextEquals(
			locator1 = "Portlet#HEADER",
			value1 = "Edit ${orgName}");

		AssertTextEquals(
			locator1 = "TextInput#NAME",
			value1 = ${orgName});

		AssertTextEquals.assertValue(
			locator1 = "UsersAndOrganizationsEditOrganization#DETAILS_TYPE",
			value1 = ${orgType});
	}

	@summary = "Default summary"
	macro viewLocalizedCountryCP(editLocalized = null, navItem = null, orgName = null, countryName = null) {
		AssertClick(
			key_navItem = ${navItem},
			locator1 = "NavBar#NAV_ITEM_LINK",
			value1 = ${navItem});

		LexiconEntry.openEntryMenu(rowEntry = ${orgName});

		MenuItem.click(menuItem = ${editLocalized});

		AssertTextEquals.assertPartialText(
			key_countryName = ${countryName},
			locator1 = "UsersAndOrganizations#ORGANIZATION_COUNTRY_NAME",
			value1 = ${countryName});
	}

	@summary = "Default summary"
	macro viewMembersNotFoundCP() {
		AssertTextEquals(
			locator1 = "Message#EMPTY_INFO",
			value1 = "This organization does not have any users.");
	}

	@summary = "Default summary"
	macro viewNoOrganizationsFoundCP() {
		AssertTextEquals(
			locator1 = "Message#EMPTY_INFO",
			value1 = "No organizations were found.");
	}

	@summary = "Default summary"
	macro viewParentOrganizationCP(parentOrgExist = null, orgName = null, subOrgName = null, parentOrgName = null) {
		Organization.gotoActionsCmd(orgName = ${orgName});

		var key_orgName = ${orgName};

		MenuItem.click(menuItem = "Edit");

		AssertClick(
			locator1 = "UsersAndOrganizationsEditOrganization#PARENT_ORGANIZATION_SELECT_BUTTON",
			value1 = "Select");

		SelectFrame(locator1 = "UsersAndOrganizationsSelectOrganization#SELECT_ORGANIZATION_IFRAME");

		if (${parentOrgExist} == "true") {
			var key_orgName = ${subOrgName};

			AssertTextEquals(
				locator1 = "UsersAndOrganizationsEditUser#ORGANIZATIONS_TABLE_NAME",
				value1 = ${subOrgName});

			AssertTextEquals(
				locator1 = "UsersAndOrganizationsSelectOrganization#ORGANIZATION_TABLE_PARENT_ORGANIZATION",
				value1 = ${parentOrgName});
		}
		else if (${parentOrgExist} == "false") {
			AssertTextEquals(
				locator1 = "UsersAndOrganizationsEditUser#ORGANIZATIONS_TABLE_NAME",
				value1 = ${orgName});

			AssertTextEquals(
				locator1 = "UsersAndOrganizationsSelectOrganization#ORGANIZATION_TABLE_PARENT_ORGANIZATION",
				value1 = "");
		}

		IFrame.closeFrame();
	}

	@summary = "Default summary"
	macro viewRemoveMemberCP(orgName = null, userFirstName = null) {
		Type(
			locator1 = "TextInput#SEARCH",
			value1 = ${orgName});

		Click(locator1 = "Icon#BASIC_SEARCH");

		var key_orgName = ${orgName};

		AssertTextEquals(
			locator1 = "UsersAndOrganizations#ORGANIZATION_TABLE_NAME",
			value1 = ${orgName});

		AssertClick(
			locator1 = "UsersAndOrganizations#ORGANIZATION_TABLE_NAME",
			value1 = ${orgName});

		AssertTextNotPresent(value1 = ${userFirstName});
	}

	@summary = "Default summary"
	macro viewSubOrganizationCP(orgType = null, orgName = null, suborgType = null, suborgName = null) {
		var key_orgName = ${orgName};

		AssertTextEquals(
			locator1 = "UsersAndOrganizations#ORGANIZATION_TABLE_TYPE",
			value1 = ${orgType});

		AssertClick(
			locator1 = "UsersAndOrganizations#ORGANIZATION_TABLE_NAME",
			value1 = ${orgName});

		var key_suborgName = ${suborgName};

		AssertTextEquals(
			locator1 = "UsersAndOrganizationsOrganization#SUBORGANIZATION_TABLE_NAME",
			value1 = ${suborgName});

		AssertTextEquals(
			locator1 = "UsersAndOrganizationsOrganization#SUBORGANIZATION_TABLE_TYPE",
			value1 = ${suborgType});

		AssertElementPresent(locator1 = "UsersAndOrganizationsOrganization#SUBORGANIZATION_TABLE_ACTIONS");
	}

}