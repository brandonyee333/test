definition {

	@summary = "Default summary"
	macro click(button = null) {
		Click.mouseDownMouseUp(
			key_text = ${button},
			locator1 = "Button#ANY");
	}

	@summary = "Default summary"
	macro clickAddRow() {
		Click(locator1 = "Button#ADD_ROW");
	}

	@summary = "Default summary"
	macro clickCancel() {
		Button.click(button = "Cancel");
	}

	@summary = "Default summary"
	macro clickComment() {
		Click(locator1 = "Button#COMMENT");
	}

	@summary = "Default summary"
	macro clickConfirm() {
		Button.click(button = "Confirm");
	}

	@summary = "Default summary"
	macro clickDone() {
		Button.click(button = "Done");
	}

	@summary = "Default summary"
	macro clickInstall() {
		Button.click(button = "Install");
	}

	@summary = "Default summary"
	macro clickNext() {
		Button.click(button = "Next");
	}

	@summary = "Default summary"
	macro clickNoError(button = null) {
		ClickNoError.mouseDownMouseUp(
			key_text = ${button},
			locator1 = "Button#ANY");
	}

	@summary = "Default summary"
	macro clickPublish() {
		ScrollWebElementIntoView(
			key_text = "Publish",
			locator1 = "Button#ANY");

		Button.click(button = "Publish");
	}

	@summary = "Default summary"
	macro clickSave() {
		Button.click(button = "Save");
	}

	@summary = "Default summary"
	macro clickSaveAsDraft() {
		Button.click(button = "Save as Draft");
	}

	@summary = "Default summary"
	macro clickSubmitButton() {
		Click(locator1 = "Button#SUBMIT");
	}

	@summary = "Default summary"
	macro clickSubmitForPublication() {
		Button.click(button = "Submit for Publication");
	}

	@summary = "Default summary"
	macro clickUpdate() {
		Button.click(button = "Update");
	}

	@summary = "Default summary"
	macro viewNotPresent(button = null) {
		AssertElementNotPresent(
			key_text = ${button},
			locator1 = "Button#ANY");
	}

	@summary = "Default summary"
	macro viewPresent(button = null) {
		AssertElementPresent(
			key_text = ${button},
			locator1 = "Button#ANY");
	}

}