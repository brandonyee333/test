definition {

	@summary = "Default summary"
	macro gotoAddPageViaPG() {
		Portlet.clickPortletPlusIconPG(portletName = "Wiki");

		MenuItem.click(menuItem = "Add Page");
	}

	@summary = "Default summary"
	macro gotoAllPagesCP() {
		Click(locator1 = "Dropdown#FILTER");

		var key_filterValue = "All Pages";

		AssertClick(
			locator1 = "Dropdown#FILTER_VALUES",
			value1 = "All Pages");
	}

	@summary = "Default summary"
	macro gotoAllPagesPG() {
		AssertClick(
			locator1 = "WikiTable#NAVIGATION_ALL_PAGES",
			value1 = "All Pages");

		var key_tabName = "All Pages";

		AssertElementPresent(locator1 = "WikiTable#NAVIGATION_ACTIVE_TAB");

		AssertElementPresent(locator1 = "Portlet#HEADER_TITLE");

		AssertTextEquals(
			locator1 = "Portlet#HEADER_TITLE",
			value1 = "All Pages");
	}

	@summary = "Default summary"
	macro gotoAllPagesPGViaWD() {
		AssertClick(
			locator1 = "WikiTable#NAVIGATION_ALL_PAGES",
			value1 = "All Pages");
	}

	@summary = "Default summary"
	macro gotoBodyLinkPG(wikiPageContent = null) {
		AssertClick(
			locator1 = "WikiEntry#BODY_LINK",
			value1 = ${wikiPageContent});
	}

	@summary = "Default summary"
	macro gotoChangeParent() {
		AssertClick(
			locator1 = "Wiki#PAGE_TABS_CHANGE_PARENT",
			value1 = "Change Parent");
	}

	@summary = "Default summary"
	macro gotoChildPageCP(wikiChildPageContent = null, wikiChildPageTitle = null) {
		AssertTextEquals.assertPartialText(
			locator1 = "Wiki#CHILD_PAGE_CONTENT",
			value1 = ${wikiChildPageContent});

		var key_wikiChildPageTitle = ${wikiChildPageTitle};

		AssertClick(
			locator1 = "Wiki#CHILD_PAGE_TITLE",
			value1 = ${wikiChildPageTitle});
	}

	@summary = "Default summary"
	macro gotoChildPagePG(wikiChildPageTitle = null) {
		var key_wikiChildPageTitle = ${wikiChildPageTitle};

		AssertTextEquals.assertPartialText(
			locator1 = "Wiki#CHILD_PAGE_HEADER",
			value1 = "Child Page");

		AssertClick(
			locator1 = "Wiki#CHILD_PAGE_TITLE",
			value1 = ${wikiChildPageTitle});
	}

	@summary = "Default summary"
	macro gotoCP(isOrphanPage = null, wikiPageTitle = null) {
		Click(locator1 = "Dropdown#FILTER");

		if (${isOrphanPage} == "true") {
			var key_filterValue = "Orphan Pages";

			AssertClick(
				locator1 = "Dropdown#FILTER_VALUES",
				value1 = "Orphan Pages");
		}
		else {
			var key_filterValue = "All Pages";

			AssertClick(
				locator1 = "Dropdown#FILTER_VALUES",
				value1 = "All Pages");
		}

		var key_wikiPageTitle = ${wikiPageTitle};

		AssertClick(
			locator1 = "Wiki#DESCRIPTIVE_VIEW_ENTRY_TITLE",
			value1 = ${wikiPageTitle});

		AssertElementNotPresent(locator1 = "Button#PLUS");

		AssertVisible(
			locator1 = "Portlet#HEADER",
			value1 = ${wikiPageTitle});
	}

	@summary = "Default summary"
	macro gotoDraftPagesPG() {
		AssertClick(
			locator1 = "WikiTable#NAVIGATION_DRAFT_PAGES",
			value1 = "Draft Pages");
	}

	@summary = "Default summary"
	macro gotoEntryCopyViaPGTable(wikiPageTitle = null) {
		var key_wikiPageTitle = ${wikiPageTitle};

		Click(locator1 = "WikiTable#ALL_PAGES_VERTICAL_ELLIPSIS");

		MenuItem.click(menuItem = "Copy");
	}

	@summary = "Default summary"
	macro gotoEntryEditViaPGTable(wikiPageTitle = null) {
		var key_wikiPageTitle = ${wikiPageTitle};

		Click(locator1 = "WikiTable#ALL_PAGES_VERTICAL_ELLIPSIS");

		MenuItem.click(menuItem = "Edit");
	}

	@summary = "Default summary"
	macro gotoEntryMoveViaTable(wikiPageTitle = null) {
		Click(locator1 = "Icon#DISPLAY_STYLE_LIST");

		var key_wikiPageTitle = ${wikiPageTitle};

		Click(locator1 = "WikiTable#ALL_PAGES_VERTICAL_ELLIPSIS");

		MenuItem.click(menuItem = "Move");
	}

	@summary = "Default summary"
	macro gotoEntryViaPGTable(wikiPageTitle = null) {
		var key_wikiPageTitle = ${wikiPageTitle};

		AssertClick(
			locator1 = "WikiTable#ALL_PAGES_WIKI_PAGE_TITLE",
			value1 = ${wikiPageTitle});
	}

	@summary = "Default summary"
	macro gotoFrontPageCP() {
		Click(locator1 = "Icon#DISPLAY_STYLE_DESCRIPTIVE");

		var key_wikiPageTitle = "FrontPage";

		AssertClick(
			locator1 = "Wiki#DESCRIPTIVE_VIEW_ENTRY_TITLE",
			value1 = "FrontPage");

		AssertVisible(
			locator1 = "Portlet#HEADER",
			value1 = "FrontPage");
	}

	@summary = "Default summary"
	macro gotoFrontPagePG() {
		AssertClick(
			locator1 = "WikiTable#NAVIGATION_FRONTPAGE",
			value1 = "FrontPage");
	}

	@summary = "Default summary"
	macro gotoNode(wikiNodeName = null) {
		var key_wikiNodeName = ${wikiNodeName};

		Click(locator1 = "Icon#DISPLAY_STYLE_LIST");

		AssertTextEquals(
			locator1 = "Wiki#NODE_TABLE_WIKI_NAME",
			value1 = ${wikiNodeName});

		AssertClick(
			locator1 = "Wiki#NODE_TABLE_WIKI_NAME",
			value1 = ${wikiNodeName});

		var key_filterValue = "All Pages";

		AssertElementPresent(locator1 = "Dropdown#FILTER_VALUES");
	}

	@summary = "Default summary"
	macro gotoPG(isOrphanPage = null, wikiPageTitle = null) {
		if (${isOrphanPage} == "true") {
			AssertClick(
				locator1 = "WikiTable#NAVIGATION_ORPHAN_PAGES",
				value1 = "Orphan Pages");
		}
		else {
			WikiNavigator.gotoAllPagesPG();
		}

		var key_wikiPageTitle = ${wikiPageTitle};

		AssertClick(
			locator1 = "WikiTable#ALL_PAGES_WIKI_PAGE_TITLE",
			value1 = ${wikiPageTitle});
	}

	@summary = "Default summary"
	macro gotoPGViaWD(wikiPageTitle = null) {
		AssertClick(
			locator1 = "WikiTable#NAVIGATION_ALL_PAGES",
			value1 = "All Pages");

		var key_wikiPageTitle = ${wikiPageTitle};

		AssertClick(
			locator1 = "WikiTable#ALL_PAGES_WIKI_PAGE_TITLE",
			value1 = ${wikiPageTitle});
	}

	@summary = "Default summary"
	macro openWikiAdmin(siteURLKey = null) {
		Navigator.openWithAppendToBaseURL(urlAppend = "group/${siteURLKey}/~/control_panel/manage?p_p_id=com_liferay_wiki_web_portlet_WikiAdminPortlet");
	}

}