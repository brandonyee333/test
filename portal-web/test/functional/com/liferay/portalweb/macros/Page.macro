			locator1 = "Button#ADD_PAGE_BTN",
			value1 = "Add Page");

		Alert.viewSuccessMessage();
	}

	@summary = "Default summary"
	macro selectMobileDeviceFamily(deviceFamilyName = null) {
		AssertClick(
			locator1 = "Button#SELECT_MOBILE_DEVICE_RULES",
