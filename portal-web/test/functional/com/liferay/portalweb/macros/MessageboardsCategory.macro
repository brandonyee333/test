definition {

	var assetType = "Message Boards Category";

	@summary = "Default summary"
	macro addCP(categoryName = null) {
		LexiconEntry.gotoAddMenuItem(menuItem = "Category");

		PortletEntry.inputName(name = ${categoryName});

		PortletEntry.save();
	}

	@summary = "Default summary"
	macro addPG(displayStyle = null, categoryName = null, categoryDescriptionEnabled = null, categoryDescription = null) {
		AssertClick(
			locator1 = "Button#ADD_CATEGORY",
			value1 = "Add Category");

		PortletEntry.inputName(name = ${categoryName});

		if (${categoryDescriptionEnabled} == "true") {
			PortletEntry.inputDescription(description = ${categoryDescription});
		}

		if (${displayStyle} == "Question") {
			Select(
				locator1 = "MessageBoardsEditCategory#DISPLAY_STYLE_SELECT",
				value1 = "Question");
		}
		else if ("${displayStyle" == "Default") {
			Select(
				locator1 = "MessageBoardsEditCategory#DISPLAY_STYLE_SELECT",
				value1 = "Default");
		}

		Click(locator1 = "Button#SAVE");

		Alert.viewSuccessMessage();
	}

	@summary = "Default summary"
	macro addSubcategoryCP(categoryName = null, subCategoryDescription = null, subCategoryName = null) {
		var key_categoryName = ${categoryName};
		var key_subCategoryName = ${subCategoryName};

		AssertClick(
			locator1 = "MessageBoards#CATEGORY_LIST_CATEGORY",
			value1 = ${categoryName});

		LexiconEntry.gotoAddMenuItem(menuItem = "Subcategory");

		PortletEntry.inputName(name = ${subCategoryName});

		PortletEntry.inputDescription(description = ${subCategoryDescription});

		PortletEntry.save();
	}

	@summary = "Default summary"
	macro addSubcategoryNullPG(subCategoryNullName = null, categoryName = null, subCategoryDescription = null) {
		var key_categoryName = ${categoryName};

		AssertClick(
			locator1 = "MessageBoards#CATEGORY_LIST_CATEGORY",
			value1 = ${categoryName});

		AssertClick(
			locator1 = "Button#ADD_SUBCATEGORY",
			value1 = "Add Subcategory");

		PortletEntry.inputName(name = ${subCategoryNullName});

		PortletEntry.inputDescription(description = ${subCategoryDescription});

		Button.clickSave();

		Alert.viewRequiredField();
	}

	@summary = "Default summary"
	macro addSubcategoryPG(categoryName = null, subCategoryDescription = null, subCategoryName = null) {
		var key_categoryName = ${categoryName};

		AssertClick(
			locator1 = "MessageBoards#CATEGORY_LIST_CATEGORY",
			value1 = ${categoryName});

		AssertClick(
			locator1 = "Button#ADD_SUBCATEGORY",
			value1 = "Add Subcategory");

		PortletEntry.inputName(name = ${subCategoryName});

		PortletEntry.inputDescription(description = ${subCategoryDescription});

		PortletEntry.save();
	}

	@summary = "Default summary"
	macro addSubcategoryToSubcategoryPG(subCategorySubCategoryName = null, categoryName = null, subCategoryDescription = null, subCategoryName = null) {
		var key_categoryName = ${categoryName};

		AssertClick(
			locator1 = "MessageBoards#CATEGORY_LIST_CATEGORY",
			value1 = ${categoryName});

		var key_subCategoryName = ${subCategoryName};

		AssertClick(
			locator1 = "MessageBoards#CATEGORY_LIST_SUBCATEGORY",
			value1 = ${subCategoryName});

		AssertClick(
			locator1 = "Button#ADD_SUBCATEGORY",
			value1 = "Add Subcategory");

		PortletEntry.inputName(name = ${subCategorySubCategoryName});

		PortletEntry.inputDescription(description = ${subCategoryDescription});

		PortletEntry.save();
	}

	@summary = "Default summary"
	macro deleteCP() {
		if (IsElementPresent(locator1 = "Checkbox#SELECT_ALL")) {
			Check.checkAll(locator1 = "Checkbox#SELECT_ALL");

			Click(locator1 = "Button#RECYCLE_BIN");

			AssertElementPresent(locator1 = "Message#SUCCESS");
		}
	}

	@summary = "Default summary"
	macro deletePG(categoryName = null) {
		var key_categoryName = ${categoryName};

		AssertTextEquals(
			locator1 = "MessageBoards#CATEGORY_LIST_CATEGORY",
			value1 = ${categoryName});

		LexiconEntry.openEntryMenu(rowEntry = ${categoryName});

		PortletEntry.clickMoveToRecycleBin();

		AssertElementPresent(locator1 = "Message#SUCCESS");

		AssertElementNotPresent(locator1 = "MessageBoards#CATEGORY_LIST_CATEGORY");
	}

	@summary = "Default summary"
	macro editPG(categoryNameEdit = null, categoryName = null) {
		var key_categoryName = ${categoryName};

		AssertTextEquals(
			locator1 = "MessageBoards#CATEGORY_LIST_CATEGORY",
			value1 = ${categoryName});

		LexiconEntry.openEntryMenu(rowEntry = ${categoryName});

		MenuItem.click(menuItem = "Edit");

		PortletEntry.inputName(name = ${categoryNameEdit});

		Click(locator1 = "Button#SAVE");

		Alert.viewSuccessMessage();

		AssertTextEquals(
			locator1 = "MessageBoards#CATEGORY_LIST_CATEGORY",
			value1 = ${categoryNameEdit});
	}

	@summary = "Default summary"
	macro gotoCP(categoryName = null) {
		var key_rowEntry = ${categoryName};

		AssertTextEquals(
			locator1 = "ContentRow#ENTRY_CONTENT_ENTRY_NAME_LINK",
			value1 = ${categoryName});

		LexiconEntry.gotoEntry(rowEntry = ${categoryName});

		AssertTextEquals(
			locator1 = "Portlet#HEADER",
			value1 = ${categoryName});
	}

	@summary = "Default summary"
	macro gotoPG(subCategoryEnabled = null, categoryName = null, categoryDescriptionEnabled = null, categoryDescription = null, subCategoryName = null) {
		if (${categoryDescriptionEnabled} == "true") {
			var key_categoryDescription = ${categoryDescription};
			var key_categoryName = ${categoryName};

			AssertClick(
				locator1 = "MessageBoards#CATEGORY_LIST_CATEGORY_DESCRIPTION",
				value1 = ${categoryDescription});
		}
		else {
			var key_categoryName = ${categoryName};

			AssertClick(
				locator1 = "MessageBoards#CATEGORY_LIST_CATEGORY",
				value1 = ${categoryName});
		}

		if (${subCategoryEnabled} == "true") {
			var key_categoryName = ${subCategoryName};

			Click(locator1 = "MessageBoards#CATEGORY_LIST_CATEGORY");
		}
	}

	@summary = "Default summary"
	macro subscribePG(categoryName = null) {
		var key_categoryName = ${categoryName};

		AssertTextEquals(
			locator1 = "MessageBoards#CATEGORY_LIST_CATEGORY",
			value1 = ${categoryName});

		LexiconEntry.openEntryMenu(rowEntry = ${categoryName});

		MenuItem.click(menuItem = "Subscribe");

		Alert.viewSuccessMessage();
	}

	@summary = "Default summary"
	macro tearDownCP() {
		Navigator.openURL();

		ProductMenu.gotoPortlet(
			category = "Content",
			panel = "Site Administration",
			portlet = "Message Boards");

		AssertElementPresent(locator1 = "Checkbox#SELECT_ALL");

		Check.checkAll(locator1 = "Checkbox#SELECT_ALL");

		Click(locator1 = "Icon#MOVE_TO_RECYCLE_BIN");

		AssertElementPresent(locator1 = "Message#SUCCESS");

		RecycleBin.emptyCP();
	}

	@summary = "Default summary"
	macro viewCategoryDefaultPG(subcategoriesNumber = null, threadsNumber = null, categoryName = null) {
		var key_categoryName = ${categoryName};

		AssertTextEquals(
			locator1 = "MessageBoards#CATEGORY_LIST_CATEGORY",
			value1 = ${categoryName});

		AssertElementNotPresent(locator1 = "MessageBoards#CATEGORY_TABLE_CATEGORY_SUBCATEGORY_GENERIC");

		var key_subcategoriesNumber = ${subcategoriesNumber};
		var key_threadsNumber = ${threadsNumber};

		AssertTextEquals.assertPartialText(
			locator1 = "MessageBoards#CATEGORY_LIST_SUBCATEGORIES",
			value1 = 0);

		AssertTextEquals.assertPartialText(
			locator1 = "MessageBoards#CATEGORY_LIST_THREADS",
			value1 = 0);

		AssertTextEquals.assertPartialText(
			locator1 = "MessageBoards#CATEGORY_LIST_POSTS",
			value1 = 0);

		Click(locator1 = "MessageBoards#CATEGORY_LIST_CATEGORY");

		AssertTextEquals(
			locator1 = "Portlet#HEADER_TITLE",
			value1 = ${categoryName});

		AssertElementNotPresent(locator1 = "MessageBoards#SUBCATEGORY_TABLE_PANEL");

		AssertElementNotPresent(locator1 = "MessageBoards#SUBCATEGORY_TABLE_CATEGORY_GENERIC");
	}

	@summary = "Default summary"
	macro viewCP(subcategoriesNumber = null, threadsNumber = null, categoryName = null) {
		var key_categoryName = ${categoryName};

		AssertElementPresent(locator1 = "MessageBoards#CATEGORY_LIST_CHECKBOX");

		AssertTextEquals(
			locator1 = "MessageBoards#CATEGORY_LIST_CATEGORY",
			value1 = ${categoryName});

		var key_subcategoriesNumber = ${subcategoriesNumber};

		AssertTextEquals.assertPartialText(
			locator1 = "MessageBoards#CATEGORY_LIST_SUBCATEGORIES",
			value1 = ${subcategoriesNumber});

		var key_threadsNumber = ${threadsNumber};

		AssertTextEquals.assertPartialText(
			locator1 = "MessageBoards#CATEGORY_LIST_THREADS",
			value1 = ${threadsNumber});

		AssertElementPresent(locator1 = "MessageBoards#CATEGORY_LIST_ACTIONS");

		AssertClick(
			locator1 = "MessageBoards#CATEGORY_LIST_CATEGORY",
			value1 = ${categoryName});

		AssertTextEquals(
			locator1 = "Portlet#HEADER",
			value1 = ${categoryName});
	}

	@summary = "Default summary"
	macro viewDefaultPG() {
		AssertElementNotPresent(locator1 = "MessageBoards#CATEGORY_TABLE_PANEL");

		AssertElementNotPresent(locator1 = "MessageBoards#CATEGORY_TABLE_CATEGORY_GENERIC");
	}

	@summary = "Default summary"
	macro viewMySubscriptionsPG() {
		AssertClick(
			locator1 = "MessageBoards#NAVIGATION_MY_SUBSCRIPTIONS",
			value1 = "My Subscriptions");

		var parentcategory1 = StringUtil.upperCase(${parentcategory1});

		AssertTextEquals(
			locator1 = "MessageBoardsMySubscriptions#CATEGORY_TABLE_CATEGORY_BREADCRUMB_1",
			value1 = ${parentcategory1});

		var parentcategory2 = StringUtil.upperCase(${parentcategory2});

		AssertTextEquals(
			locator1 = "MessageBoardsMySubscriptions#CATEGORY_TABLE_CATEGORY_BREADCRUMB_2",
			value1 = ${parentcategory2});

		var subscribedThread = StringUtil.upperCase(${subscribedThread});

		AssertTextEquals.assertPartialText(
			locator1 = "MessageBoardsMySubscriptions#CATEGORY_TABLE_CATEGORY_BREADCRUMB_3",
			value1 = ${subscribedThread});
	}

	@summary = "Default summary"
	macro viewNoPG(categoryName = null) {
		var key_categoryName = ${categoryName};

		AssertTextNotPresent(value1 = ${categoryName});

		AssertElementNotPresent(locator1 = "MessageBoards#CATEGORY_LIST_CATEGORY");

		AssertElementNotPresent(locator1 = "MessageBoards#CATEGORY_TABLE_CATEGORIES");

		AssertElementNotPresent(locator1 = "MessageBoards#CATEGORY_TABLE_THREADS");

		AssertElementNotPresent(locator1 = "MessageBoards#CATEGORY_TABLE_POSTS");

		AssertElementNotPresent(locator1 = "MessageBoards#CATEGORY_TABLE_ACTIONS");
	}

	@summary = "Default summary"
	macro viewPG(threadPostCount = null, threadsNumber = null, categoryName = null, categoryDescription = null) {
		var key_categoryName = ${categoryName};
		var key_threadsNumber = ${threadsNumber};

		AssertTextEquals(
			locator1 = "MessageBoards#CATEGORY_LIST_CATEGORY",
			value1 = ${categoryName});

		if (isSet(threadsNumber)) {
			var key_threadsNumber = ${threadsNumber};

			AssertTextEquals(
				locator1 = "MessageBoards#CATEGORY_LIST_THREADS",
				value1 = "${threadsNumber} Threads");
		}
		else if (${threadPostCount} == 1) {
			AssertTextEquals(
				locator1 = "MessageBoards#CATEGORY_LIST_THREADS",
				value1 = "1 Thread");
		}

		if ("categoryDescriptionEnabled" == "true") {
			var key_categoryDescription = ${categoryDescription};

			AssertTextEquals(
				locator1 = "MessageBoards#CATEGORY_LIST_CATEGORY_DESCRIPTION",
				value1 = ${categoryDescription});
		}
		else {
			AssertClick(
				locator1 = "MessageBoards#CATEGORY_LIST_CATEGORY",
				value1 = ${categoryName});
		}

		AssertTextEquals(
			locator1 = "Portlet#HEADER_TITLE",
			value1 = ${categoryName});
	}

	@summary = "Default summary"
	macro viewSubcategoryFromSubcategoryPG(categoryName = null, subCategoryDescription = null, subCategoryName = null) {
		var key_categoryName = ${categoryName};
		var key_subCategoryDescription = ${subCategoryDescription};
		var key_subCategoryName = ${subCategoryName};

		AssertTextEquals(
			locator1 = "Portlet#HEADER_TITLE",
			value1 = ${categoryName});

		AssertTextEquals(
			locator1 = "MessageBoards#CATEGORY_LIST_SUBCATEGORY",
			value1 = ${subCategoryName});

		AssertTextEquals(
			locator1 = "MessageBoards#CATEGORY_LIST_SUBCATEGORY_DESCRIPTION",
			value1 = ${subCategoryDescription});

		Click(locator1 = "MessageBoards#CATEGORY_LIST_SUBCATEGORY");

		AssertTextEquals(
			locator1 = "Portlet#HEADER_TITLE",
			value1 = ${subCategoryName});
	}

	@summary = "Default summary"
	macro viewSubcategoryPG(threadsNumber = null, categoryName = null, subCategoryDescription = null, subCategoryName = null) {
		var key_categoryName = ${categoryName};

		AssertClick(
			locator1 = "MessageBoards#CATEGORY_LIST_CATEGORY",
			value1 = ${categoryName});

		var key_categoryDescription = ${subCategoryDescription};
		var key_categoryName = ${subCategoryName};
		var key_threadsNumber = ${threadsNumber};

		AssertTextEquals(
			locator1 = "MessageBoards#CATEGORY_LIST_CATEGORY",
			value1 = ${subCategoryName});

		AssertTextEquals(
			locator1 = "MessageBoards#CATEGORY_LIST_CATEGORY_DESCRIPTION",
			value1 = ${subCategoryDescription});

		AssertTextEquals.assertPartialText(
			locator1 = "MessageBoards#CATEGORY_LIST_THREADS",
			value1 = ${threadsNumber});

		AssertTextEquals.assertPartialText(
			locator1 = "MessageBoards#CATEGORY_LIST_POSTS",
			value1 = ${threadsNumber});

		AssertElementPresent(locator1 = "MessageBoards#CATEGORY_LIST_ACTIONS");

		Click(locator1 = "MessageBoards#CATEGORY_LIST_CATEGORY");

		AssertTextEquals(
			locator1 = "Portlet#HEADER_TITLE",
			value1 = ${subCategoryName});
	}

}