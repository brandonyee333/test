definition {

	@summary = "Default summary"
	macro addPG(dmDocumentTitle = null, commentBody = null) {
		var key_dmDocumentTitle = ${dmDocumentTitle};

		AssertClick(
			locator1 = "DocumentsAndMedia#DESCRIPTIVE_LIST_DOCUMENT_TITLE",
			value1 = ${dmDocumentTitle});

		Type(
			locator1 = "Comments#COMMENT_FIELD",
			value1 = ${commentBody});

		Pause(locator1 = 3000);

		AssertClick(
			locator1 = "Button#REPLY",
			value1 = "Reply");

		Pause(locator1 = 3000);

		Alert.viewSuccessMessage();
	}

	@summary = "Default summary"
	macro viewPG(dmDocumentTitle = null, commentBody = null) {
		var key_dmDocumentTitle = ${dmDocumentTitle};

		AssertClick(
			locator1 = "DocumentsAndMedia#DESCRIPTIVE_LIST_DOCUMENT_TITLE",
			value1 = ${dmDocumentTitle});

		var key_entryComment = ${commentBody};

		AssertTextEquals.assertPartialText(
			locator1 = "Comments#COMMENT_BODY_SPECIFIC",
			value1 = ${commentBody});
	}

}