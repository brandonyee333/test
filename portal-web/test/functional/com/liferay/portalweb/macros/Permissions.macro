	@summary = "Default summary"
	macro setUpSiteRoleLoginUserPG(userEmailAddressVariation = null, syntaxCheckingEnabled = null, siteName = null, roleType = null, userLoginEmailAddress = null, pageName = null, portletName = null, sitePagePrivacy = null, userLastName = null, userScreenName = null, userMiddleName = null, userLoginFullName = null, userBirthday = null, roleTitle = null, sitePageType = null, userEmailAddress = null, newPassword = null, i = null, pageTemplateName = null, userFirstName = null, userScreenNameVariation = null, roleName = null, userGender = null, page = null, roleDescription = null) {
		ProductMenu.gotoPortlet(
			category = "Users",
			panel = "Control Panel",
			portlet = "Users and Organizations");

		User.addCP(
			userBirthday = ${userBirthday},
