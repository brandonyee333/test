		DMFolder.addPG(
			dmFolder = ${dmFolder},
			dmFolderDescription = ${dmFolderDescription},
			dmFolderName = ${dmFolderName},
			viewableBy = ${viewableBy});

		User.logoutAndLoginPG(
			userLoginEmailAddress = ${userLoginEmailAddress},
			userLoginFullName = ${userLoginFullName});
	}

	@summary = "Default summary"
	macro definePermissionCP(permissionDefinitionKey = null, permissionDefinitionValue = null, roleName = null, permissionNavigationValue = null, roleType = null) {
		ProductMenu.gotoPortlet(
			category = "Users",
			panel = "Control Panel",
			portlet = "Roles");

		Role.definePermissionCP(
			permissionDefinitionKey = ${permissionDefinitionKey},
			permissionDefinitionValue = ${permissionDefinitionValue},
			permissionNavigationValue = ${permissionNavigationValue},
			roleName = ${roleName},
			roleType = ${roleType});
	}

	@summary = "Default summary"
	macro definePermissionLoginUserCP(permissionDefinitionKey = null, permissionDefinitionValue = null, roleName = null, permissionNavigationValue = null, userLoginFullName = null, roleType = null, userLoginEmailAddress = null) {
