	@summary = "Default summary"
	macro viewNoTag(tagNameList = null) {
		if (isSet(tagNameList)) {
			for (var tagName : list ${tagNameList}) {
				var tagName = StringUtil.lowerCase(${tagName});

				AssertElementNotPresent(
					key_tagName = ${tagName},
					locator1 = "DocumentsAndMedia#TAG");
			}
		}
		else {
			var tagName = StringUtil.lowerCase(${tagName});

			AssertElementNotPresent(
				key_tagName = ${tagName},
				locator1 = "DocumentsAndMedia#TAG");
		}
	}

	@summary = "Default summary"
	macro viewOlderVersionPG(dmDocumentTitle = null, dmDocumentDescription = null, dmDocumentVersionNumber = null) {
