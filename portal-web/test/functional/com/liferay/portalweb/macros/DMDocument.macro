definition {

	var assetType = "Document";
	var dmDocumentTypeName = "Basic Document";

	@summary = "Default summary"
	macro addCategories(vocabularyName = null, categoryNameList = null) {
		Panel.expandPanel(panelHeading = "Categorization");

		AssetCategorization.addMultipleCategories(
			categoryNameList = ${categoryNameList},
			vocabularyName = ${vocabularyName});
	}

	@summary = "Default summary"
	macro addContractCP(dmContractTitle = null, contractType = null, dmContractLegalReviewer = null, dmContractSigningAuthority = null, dmContractDealName = null, dmContractFile = null, dmContractDescription = null, effectiveDate = null, expirationDate = null, status = null) {
		DMNavigator.gotoAddDocumentType(dmDocumentTypeName = "Contract");

		if (isSet(dmContractFile)) {
			UploadCommonFile(
				locator1 = "TextInput#FILE",
				value1 = ${dmContractFile});
		}

		PortletEntry.inputTitle(title = ${dmContractTitle});

		if (isSet(dmContractDescription)) {
			PortletEntry.inputDescription(description = ${dmContractDescription});
		}

		if (isSet(effectiveDate)) {
			Type.clickAtType(
				key_fieldLabel = "Effective Date",
				locator1 = "TextInput#GENERIC_TEXT_INPUT",
				value1 = ${effectiveDate});
		}

		if (isSet(expirationDate)) {
			Type.clickAtType(
				key_fieldLabel = "Expiration Date",
				locator1 = "TextInput#GENERIC_TEXT_INPUT",
				value1 = ${expirationDate});
		}

		if (isSet(contractType)) {
			Select(
				key_fieldLabel = "Contract Type",
				locator1 = "Select#GENERIC_SELECT_FIELD",
				value1 = ${contractType});
		}

		if (isSet(status)) {
			Select(
				key_fieldLabel = "Status",
				locator1 = "Select#GENERIC_SELECT_FIELD",
				value1 = ${status});
		}

		if (isSet(dmContractLegalReviewer)) {
			Type(
				key_fieldLabel = "Legal Reviewer",
				locator1 = "TextInput#GENERIC_TEXT_INPUT",
				value1 = ${dmContractLegalReviewer});
		}

		if (isSet(dmContractSigningAuthority)) {
			Type(
				key_fieldLabel = "Signing Authority",
				locator1 = "TextInput#GENERIC_TEXT_INPUT",
				value1 = ${dmContractSigningAuthority});
		}

		if (isSet(dmContractDealName)) {
			Type(
				key_fieldLabel = "Deal Name",
				locator1 = "TextInput#GENERIC_TEXT_INPUT",
				value1 = ${dmContractDealName});
		}

		AssertClick(
			locator1 = "Button#PUBLISH",
			value1 = "Publish");

		Alert.viewSuccessMessage();
	}

	@summary = "Default summary"
	macro addCP(dmDocumentFile = null, dmDocumentTypeName = null, dmDocumentDescription = null, documentsAndMediaField = null, customFieldText = null, tagNameList = null, vocabularyName = null, validationError = null, uploadTempFile = null, dmDocumentTitle = null, linkedPageName = null, linkFieldName = null, nullFile = null, categoryNameList = null) {
		DMNavigator.gotoAddDocumentType(dmDocumentTypeName = ${dmDocumentTypeName});

		if (${uploadTempFile} == "true") {
			UploadTempFile(
				locator1 = "TextInput#FILE",
				value1 = ${dmDocumentFile});
		}
		else if (${nullFile} == "true") {
			AssertElementPresent(locator1 = "TextInput#FILE");
		}
		else {
			if (isSet(dmDocumentFile)) {
				UploadCommonFile(
					locator1 = "TextInput#FILE",
					value1 = ${dmDocumentFile});
			}
		}

		if (isSet(customFieldText)) {
			Panel.expandPanel(panelHeading = "Custom Fields");

			Type(
				locator1 = "TextInput#CUSTOM_FIELD",
				value1 = ${customFieldText});
		}

		if (isSet(tagNameList)) {
			Panel.expandPanel(panelHeading = "Categorization");

			for (var tagName : list ${tagNameList}) {
				Click.clickAt(locator1 = "Button#ADD_TAGS");

				Type(
					locator1 = "AssetCategorization#TAGS_FIELD",
					value1 = ${tagName});
			}

			Click.clickAt(locator1 = "Button#ADD_TAGS");
		}

		if (isSet(vocabularyName)) {
			DMDocument.addCategories(
				categoryNameList = ${categoryNameList},
				vocabularyName = ${vocabularyName});
		}

		PortletEntry.inputTitle(title = ${dmDocumentTitle});

		if (isSet(dmDocumentDescription)) {
			PortletEntry.inputDescription(description = ${dmDocumentDescription});
		}

		if (isSet(documentsAndMediaField)) {
			var key_fieldName = "DocumentsandMedia";

			AssertClick(
				locator1 = "Button#FIELD_SELECT",
				value1 = "Select");

			SelectFrame(locator1 = "IFrame#DIALOG");

			AssertClick.assertPartialTextClickAt(
				key_dmDocumentTitle = ${documentsAndMediaField},
				locator1 = "WC#ICON_DOCUMENT_TITLE",
				value1 = ${documentsAndMediaField});

			SelectFrameTop(value1 = "relative=top");

			Click(locator1 = "Button#ADD");
		}

		if (isSet(linkedPageName)) {
			var key_pageName = ${linkedPageName};

			AssertClick(
				key_fieldName = ${linkFieldName},
				locator1 = "Button#FIELD_SELECT",
				value1 = "Select");

			while (IsElementNotPresent(locator1 = "WC#LINK_TO_PAGE_SELECT_PAGE_RADIO")) {
				ExecuteJavaScript(value1 = "$('.top-ended').scrollTop(1000)");
			}

			Click(locator1 = "WC#LINK_TO_PAGE_SELECT_PAGE_RADIO");

			ClickNoError(locator1 = "Button#SELECT");
		}

		if (isSet(validationError)) {
			Button.clickPublish();

			AssertTextEquals(
				locator1 = "Message#ERROR_ALERT",
				value1 = ${validationError});
		}
		else {
			PortletEntry.publish();
		}
	}

	@summary = "Default summary"
	macro addDMMarketingBannerCP(dmDocumentTitle = null, dmDocumentFile = null, businessGoal = null, campaignTheme = null, legalReview = null, dmDocumentDescription = null, bannerName = null, marketingSelect = null, bannerDescription = null) {
		var key_dmDocumentTitle = ${dmDocumentTitle};

		LexiconEntry.gotoAddMenuItem(menuItem = "Marketing Banner");

		UploadCommonFile(
			locator1 = "TextInput#FILE",
			value1 = ${dmDocumentFile});

		PortletEntry.inputTitle(title = ${dmDocumentTitle});

		PortletEntry.inputDescription(description = ${dmDocumentDescription});

		Select(
			locator1 = "DocumentsAndMediaEditMarketingBanner#MARKETING_SELECT",
			value1 = ${marketingSelect});

		Select(
			locator1 = "DocumentsAndMediaEditMarketingBanner#CAMPAIGN_THEME_SELECT",
			value1 = ${campaignTheme});

		Select(
			locator1 = "DocumentsAndMediaEditMarketingBanner#BUSINESS_GOAL_SELECT",
			value1 = ${businessGoal});

		Click(locator1 = "DocumentsAndMediaEditMarketingBanner#NEEDS_LEGAL_REVIEW_${legalReview}_RADIO");

		Type(
			locator1 = "DocumentsAndMediaEditMarketingBanner#BANNER_NAME_FIELD",
			value1 = ${bannerName});

		Type(
			locator1 = "DocumentsAndMediaEditMarketingBanner#BANNER_DESCRIPTION_FIELD",
			value1 = ${bannerDescription});

		PortletEntry.publish();
	}

	@summary = "Default summary"
	macro addDMShortcutCP(dmDocumentTitle = null, siteName = null, dmFolderName = null) {
		DMNavigator.gotoAddDocumentType(dmDocumentTypeName = "Shortcut");

		Click(locator1 = "DocumentsAndMediaAddShortcut#SELECT_SITE_BUTTON");

		IFrame.selectModalFrame();

		AssertClick(
			key_siteName = ${siteName},
			locator1 = "SitesSelectSite#CHOOSE_BUTTON",
			value1 = "Choose");

		SelectFrameTop(value1 = "relative=top");

		Click(locator1 = "DocumentsAndMediaAddShortcut#SELECT_DOCUMENT_BUTTON");

		IFrame.selectModalFrame();

		if (isSet(dmFolderName)) {
			AssertClick(
				key_dmFolderName = ${dmFolderName},
				locator1 = "DocumentsAndMediaAddShortcut#SELECT_FILE_FOLDER_NAME",
				value1 = ${dmFolderName});
		}

		AssertClick.assertPartialTextClickAt(
			key_dmDocumentTitle = ${dmDocumentTitle},
			locator1 = "DocumentsAndMediaAddShortcut#SELECT_FILE_DOCUMENT_TITLE",
			value1 = ${dmDocumentTitle});

		SelectFrameTop(value1 = "relative=top");

		PortletEntry.save();
	}

	@summary = "Default summary"
	macro addDMShortcutPG(dmDocumentTitle = null, siteName = null, dmFolderName = null) {
		DMNavigator.gotoAddDocumentTypePG(dmDocumentTypeName = "Shortcut");

		Click(locator1 = "DocumentsAndMediaAddShortcut#SELECT_SITE_BUTTON");

		IFrame.selectModalFrame();

		AssertClick(
			key_siteName = ${siteName},
			locator1 = "SitesSelectSite#CHOOSE_BUTTON",
			value1 = "Choose");

		SelectFrameTop(value1 = "relative=top");

		Click(locator1 = "DocumentsAndMediaAddShortcut#SELECT_DOCUMENT_BUTTON");

		IFrame.selectModalFrame();

		if (isSet(dmFolderName)) {
			AssertClick(
				key_dmFolderName = ${dmFolderName},
				locator1 = "DocumentsAndMediaAddShortcut#SELECT_FILE_FOLDER_NAME",
				value1 = ${dmFolderName});
		}

		AssertClick.assertPartialTextClickAt(
			key_dmDocumentTitle = ${dmDocumentTitle},
			locator1 = "DocumentsAndMediaAddShortcut#SELECT_FILE_DOCUMENT_TITLE",
			value1 = ${dmDocumentTitle});

		SelectFrameTop(value1 = "relative=top");

		Button.clickSave();
	}

	@summary = "Default summary"
	macro addDocumentTypeCmdCP(date = null, dmDocumentTitle = null, dmDocumentFile = null, textBox = null, numberField = null, dmDocumentTypeName = null, dmDocumentDescription = null, dateFieldName = null, booleanField = null, selectOption = null, textBoxFieldName = null, textField = null) {
		DMNavigator.gotoAddDocumentType(dmDocumentTypeName = ${dmDocumentTypeName});

		UploadCommonFile(
			locator1 = "TextInput#FILE",
			value1 = ${dmDocumentFile});

		PortletEntry.inputTitle(title = ${dmDocumentTitle});

		PortletEntry.inputDescription(description = ${dmDocumentDescription});

		if (isSet(date) && isSet(dateFieldName)) {
			Type(
				key_fieldName = ${dateFieldName},
				locator1 = "TextInput#DDM_FUZZY",
				value1 = ${date});
		}
		else if (isSet(date)) {
			Type(
				key_fieldName = "date",
				locator1 = "TextInput#DDM_FUZZY",
				value1 = ${date});
		}

		if (isSet(selectOption)) {
			Select(
				locator1 = "DocumentsAndMediaEditCustomDocumentType#SELECT_OPTIONS_SELECT",
				value1 = ${selectOption});
		}

		if (isSet(textBox) && isSet(textBoxFieldName)) {
			Type(
				key_fieldName = ${textBoxFieldName},
				locator1 = "DDMField#TEXT_BOX",
				value1 = ${textBox});
		}
		else if (isSet(textBox)) {
			Type(
				key_fieldName = "textBox",
				locator1 = "DDMField#TEXT_BOX",
				value1 = ${textBox});
		}

		if (isSet(textField)) {
			Type(
				key_fieldName = "Text",
				locator1 = "TextInput#DDM_FUZZY",
				value1 = ${textField});
		}

		if (isSet(numberField)) {
			Type(
				key_fieldName = "Number",
				locator1 = "TextInput#DDM_FUZZY",
				value1 = ${numberField});
		}

		if (isSet(booleanField)) {
			Check(
				key_fieldName = "Boolean",
				locator1 = "TextInput#DDM_FUZZY",
				value1 = ${booleanField});
		}
	}

	@summary = "Default summary"
	macro addDocumentTypeCP(date = null, dmDocumentTitle = null, dmDocumentFile = null, textBox = null, numberField = null, dateFieldName = null, dmDocumentDescription = null, dmDocumentTypeName = null, booleanField = null, selectOption = null, textBoxFieldName = null, textField = null) {
		DMDocument.addDocumentTypeCmdCP(
			booleanField = ${booleanField},
			date = ${date},
