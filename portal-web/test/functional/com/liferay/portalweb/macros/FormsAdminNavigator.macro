definition {

	var formName = "Created Form Name";

	@summary = "Default summary"
	macro gotoAddDataProvider() {
		IFrame.selectDialogFrame();

		Click(locator1 = "FormsAdmin#DATA_PROVIDER_PLUS_BUTTON");
	}

	@summary = "Default summary"
	macro gotoAddForm() {
		LexiconEntry.gotoAdd();
	}

	@summary = "Default summary"
	macro gotoDeleteField(fieldName = null) {
		var key_fieldName = ${fieldName};

		MouseOver(locator1 = "Form#FIELD_LABEL");

		Click(locator1 = "Form#FIELD_ELLIPSIS");

		Click(locator1 = "Form#FIELD_DELETE_BUTTON");
	}

	@summary = "Default summary"
	macro gotoEditField(fieldName = null) {
		var key_fieldName = ${fieldName};

		MouseOver(locator1 = "Form#FIELD_LABEL");

		Click(locator1 = "Form#FIELD_ELLIPSIS");

		Click(locator1 = "Form#FIELD_EDIT_BUTTON");
	}

	@summary = "Default summary"
	macro gotoEditFormByName(formName = null) {
		AssertClick(
			key_formName = ${formName},
			locator1 = "FormsAdmin#FORMS_TABLE_NAME",
			value1 = ${formName});
	}

	@summary = "Default summary"
	macro gotoPermissions(formName = null) {
		LexiconEntry.gotoEntryMenuItem(
			menuItem = "Permissions",
			rowEntry = ${formName});

		IFrame.selectDialogFrame();
	}

	@summary = "Default summary"
	macro gotoPreviewForm() {
		AssertClick(
			locator1 = "Message#INFO_LINK",
			value1 = "Click here to preview the form in a new window.");
	}

	@summary = "Default summary"
	macro gotoPublish() {
		AssertElementPresent(locator1 = "Form#NAME_FIELD");

		LexiconEntry.gotoHeaderMenuItem(menuItem = "Publish");
	}

	@summary = "Default summary"
	macro gotoPublishCopyURLLink() {
		Click(locator1 = "Form#PUBLISH_ICON");
	}

	@summary = "Default summary"
	macro gotoSettings() {
		AssertElementPresent(locator1 = "Form#NAME_FIELD");

		LexiconEntry.gotoHeaderMenuItem(menuItem = "Settings");
	}

	@summary = "Default summary"
	macro gotoView() {
		AssertElementPresent(locator1 = "Icon#BODY_VERTICAL_ELLIPSIS");

		LexiconEntry.gotoEllipsisMenuItem(menuItem = "View");
	}

	@summary = "Default summary"
	macro gotoViewEntries() {
		AssertElementPresent(locator1 = "Icon#BODY_VERTICAL_ELLIPSIS");

		LexiconEntry.gotoEllipsisMenuItem(menuItem = "View Entries");
	}

	@summary = "Default summary"
	macro openPublishURL() {
		var publishFormURL = selenium.getElementValue("Form#PUBLISH_FORM_PUBLIC_URL");

		Navigator.openSpecificURL(url = ${publishFormURL});
	}

}