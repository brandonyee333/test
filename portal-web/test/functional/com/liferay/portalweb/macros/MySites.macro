definition {

	@summary = "Default summary"
	macro gotoPagesPG(siteName = null, menuItem = null, pageName = null) {
		LexiconEntry.gotoEntryMenuItem(
			menuItem = ${menuItem},
			rowEntry = ${siteName});

		SelectWindow.selectPopUp(locator1 = "null");

		Navigator._gotoPage(pageName = ${pageName});

		Close.closeWindow(locator1 = "null");
	}

	@summary = "Default summary"
	macro viewMembershipRequested(siteName = null) {
		Click.waitForMenuToggleJSClick(
			key_rowEntry = ${siteName},
			locator1 = "Icon#ROW_VERTICAL_ELLIPSIS");

		MenuItem.viewPresent(menuItem = "Membership Requested");
	}

	@summary = "Default summary"
	macro viewNoOptions(navItem = null, siteName = null, menuItem = null) {
		if (isSet(navItem)) {
			Navigator.gotoNavItem(navItem = ${navItem});

			AssertElementNotPresent(
				key_rowEntry = ${siteName},
				locator1 = "Icon#ROW_VERTICAL_ELLIPSIS");
		}
		else {
			Click.waitForMenuToggleJSClick(
				key_rowEntry = ${siteName},
				locator1 = "Icon#ROW_VERTICAL_ELLIPSIS");

			MenuItem.viewNotPresent(menuItem = ${menuItem});
		}
	}

	@summary = "Default summary"
	macro viewTags(tagName = null) {
		AssertTextEquals(
			key_tagName = ${tagName},
			locator1 = "Tags#VIEW_TAGS_VIA_MY_SITES",
			value1 = ${tagName});
	}

}