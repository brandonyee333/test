definition {

	@summary = "Default summary"
	macro clickTagView(tagAssetCount = null, tagName = null) {
		var key_tagName = ${tagName};

		if (isSet(tagAssetCount)) {
			AssertTextEquals.assertPartialText(
				locator1 = "TagsNavigation#TAG_NAME",
				value1 = ${tagAssetCount});
		}

		AssertClick.assertPartialTextClickAt(
			locator1 = "TagsNavigation#TAG_NAME",
			value1 = ${tagName});
	}

	@summary = "Default summary"
	macro configureDisplayStylePG(displayTemplate = null) {
		Portlet.gotoPortletOptions(
			portletName = "Tags Navigation",
			portletOption = "Configuration");

		SelectFrame(locator1 = "TagsNavigationConfiguration#TAGS_NAVIGATION_IFRAME");

		if (isSet(displayTemplate)) {
			Select(
				locator1 = "Configuration#SETUP_DISPLAY_SETTINGS_DISPLAY_TEMPLATE_SELECT",
				value1 = ${displayTemplate});
		}

		PortletEntry.save();
	}

	@summary = "Default summary"
	macro configureFlaggableSettingsPG(showAssetCount = null, showUnusedTags = null) {
		Portlet.gotoPortletOptions(
			portletName = "Tags Navigation",
			portletOption = "Configuration");

		SelectFrame(locator1 = "TagsNavigationConfiguration#TAGS_NAVIGATION_IFRAME");

		if (${showUnusedTags} == "true") {
			Check.checkToggleSwitch(
				locator1 = "TagsNavigationConfiguration#SHOW_UNUSED_TAGS_CHECKBOX",
				value1 = "Show Unused Tags");
		}

		if (${showAssetCount} == "true") {
			Check.checkToggleSwitch(
				locator1 = "TagsNavigationConfiguration#SHOW_ASSET_COUNT_CHECKBOX",
				value1 = "Show Asset Count");
		}

		PortletEntry.save();
	}

	@summary = "Default summary"
	macro viewADTColorByPopularityPG(adtTagColor = null, tagName = null) {
		var key_adtTagColor = ${adtTagColor};
		var key_tagName = ${tagName};

		AssertTextEquals(
			locator1 = "TagsNavigation#ADT_COLOR_BY_POPULARITY_TAG",
			value1 = ${tagName});
	}

	@summary = "Default summary"
	macro viewDefaultPG(tagNameList = null) {
		for (var tagName : list ${tagNameList}) {
			var key_tagName = ${tagName};

			AssertTextEquals(
				locator1 = "TagsNavigation#TAG_NAME",
				value1 = ${tagName});
		}
	}

	@summary = "Default summary"
	macro viewTagCloud(tagPopularityLevel = null, tagName = null) {
		var key_tagPopularityLevel = ${tagPopularityLevel};

		AssertTextEquals(
			locator1 = "TagsNavigation#TAG_CLOUD_POPULARITY",
			value1 = ${tagName});
	}

	@summary = "Default summary"
	macro viewTagCloudConfiguration(displayTemplate = null, showAssetCount = null, showUnusedTags = null) {
		Portlet.gotoPortletOptions(
			portletName = "Tag Cloud",
			portletOption = "Configuration");

		SelectFrame(locator1 = "TagsNavigationConfiguration#TAG_CLOUD_IFRAME");

		if (isSet(displayTemplate)) {
			AssertSelectedLabel(
				locator1 = "Configuration#SETUP_DISPLAY_SETTINGS_DISPLAY_TEMPLATE_SELECT",
				value1 = ${displayTemplate});
		}

		if (${showUnusedTags} == "true") {
			AssertChecked(
				locator1 = "TagsNavigationConfiguration#SHOW_UNUSED_TAGS_CHECKBOX",
				value1 = "Show Unused Tags");
		}

		if (${showAssetCount} == "true") {
			AssertChecked(
				locator1 = "TagsNavigationConfiguration#SHOW_ASSET_COUNT_CHECKBOX",
				value1 = "Show Asset Count");
		}
	}

}