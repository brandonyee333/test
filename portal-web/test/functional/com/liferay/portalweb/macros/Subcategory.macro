definition {

	@summary = "Default summary"
	macro addCP(subcategoryName = null, vocabularyName = null, categoryName = null, subcategoryDescription = null) {
		var key_categoryName = ${categoryName};
		var key_vocabularyName = ${vocabularyName};

		AssertClick(
			locator1 = "Categories#VOCABULARY_ENTRY_LINK",
			value1 = ${vocabularyName});

		Pause(value1 = 1000);

		LexiconEntry.gotoEntryMenuItem(
			menuItem = "Add Subcategory",
			rowEntry = ${categoryName});

		PortletEntry.inputTitle(title = ${subcategoryName});

		if (isSet(subcategoryDescription)) {
			PortletEntry.inputDescription(description = ${subcategoryDescription});
		}

		PortletEntry.save();
	}

	@summary = "Default summary"
	macro addDuplicateCP(subcategoryName = null, vocabularyName = null, categoryName = null) {
		AssertClick(
			key_vocabularyName = ${vocabularyName},
			locator1 = "Categories#VOCABULARY_ENTRY_LINK",
			value1 = ${vocabularyName});

		LexiconEntry.gotoEntryMenuItem(
			menuItem = "Add Subcategory",
			rowEntry = ${categoryName});

		PortletEntry.inputTitle(title = ${subcategoryName});

		Button.clickSave();

		Alert.viewRequestFailedToComplete();

		AssertTextEquals.assertPartialText(
			locator1 = "Message#ERROR_2",
			value1 = "Please enter a unique name.");
	}

	@summary = "Default summary"
	macro addWithPropertyCP(subcategoryName = null, propertiesValueField = null, propertiesKeyField = null, vocabularyName = null, categoryName = null) {
		AssertClick(
			key_vocabularyName = ${vocabularyName},
			locator1 = "Categories#VOCABULARY_ENTRY_LINK",
			value1 = ${vocabularyName});

		LexiconEntry.gotoEntryMenuItem(
			menuItem = "Add Subcategory",
			rowEntry = ${categoryName});

		PortletEntry.inputTitle(title = ${subcategoryName});

		Panel.expandPanel(panelHeading = "Properties");

		Type(
			locator1 = "CategoriesEditCategory#PROPERTIES_KEY_FIELD_1",
			value1 = ${propertiesKeyField});

		Type(
			locator1 = "CategoriesEditCategory#PROPERTIES_VALUE_FIELD_1",
			value1 = ${propertiesValueField});

		PortletEntry.save();
	}

	@summary = "Default summary"
	macro deleteViaIconCP(subcategoryName = null, vocabularyName = null, categoryName = null) {
		var key_vocabularyName = ${vocabularyName};

		AssertClick(
			locator1 = "Categories#VOCABULARY_ENTRY_LINK",
			value1 = ${vocabularyName});

		var key_categoryName = ${categoryName};

		AssertClick(
			locator1 = "Categories#CATEGORY_ENTRY_LINK",
			value1 = ${categoryName});

		var key_subcategoryName = ${subcategoryName};

		Check(locator1 = "Categories#SUBCATEGORY_CHECKBOX");

		ClickNoError(locator1 = "Icon#DELETE");

		Confirm(value1 = "Are you sure you want to delete this? It will be deleted immediately.");

		Alert.viewSuccessMessage();

		AssertTextNotPresent(value1 = ${subcategoryName});
	}

	@summary = "Default summary"
	macro deleteViaMenuCP(subcategoryName = null, vocabularyName = null, categoryName = null) {
		AssertClick(
			key_vocabularyName = ${vocabularyName},
			locator1 = "Categories#VOCABULARY_ENTRY_LINK",
			value1 = ${vocabularyName});

		AssertClick(
			key_categoryName = ${categoryName},
			locator1 = "Categories#CATEGORY_ENTRY_LINK",
			value1 = ${categoryName});

		LexiconEntry.gotoEntryMenuItemNoError(
			menuItem = "Delete",
			rowEntry = ${subcategoryName});

		Confirm(value1 = "Are you sure you want to delete this? It will be deleted immediately.");

		Alert.viewSuccessMessage();

		AssertTextNotPresent(value1 = ${subcategoryName});
	}

	@summary = "Default summary"
	macro editCP(subcategoryNameEdit = null, subcategoryName = null, vocabularyName = null, categoryName = null) {
		AssertClick(
			key_vocabularyName = ${vocabularyName},
			locator1 = "Categories#VOCABULARY_ENTRY_LINK",
			value1 = ${vocabularyName});

		AssertClick(
			key_categoryName = ${categoryName},
			locator1 = "Categories#CATEGORY_ENTRY_LINK",
			value1 = ${categoryName});

		LexiconEntry.gotoEntryMenuItem(
			menuItem = "Edit",
			rowEntry = ${subcategoryName});

		PortletEntry.inputTitle(title = ${subcategoryNameEdit});

		PortletEntry.save();
	}

	@summary = "Default summary"
	macro moveCP(subcategoryName = null, categoryNameMove = null, vocabularyName = null, categoryName = null) {
		var key_categoryName = ${categoryName};
		var key_vocabularyName = ${vocabularyName};

		AssertClick(
			locator1 = "Categories#VOCABULARY_ENTRY_LINK",
			value1 = ${vocabularyName});

		AssertClick(
			locator1 = "Categories#CATEGORY_ENTRY_LINK",
			value1 = ${categoryName});

		LexiconEntry.gotoEntryMenuItem(
			menuItem = "Move",
			rowEntry = ${subcategoryName});

		Click(locator1 = "CategoriesEditSubcategory#CATEGORY_SELECT_BUTTON");

		var key_categoryName = ${categoryNameMove};

		Click(locator1 = "CategoriesEditSubcategory#MOVE_CATEGORIES_CATEGORY_CHECK_ICON");

		MouseOver(locator1 = "Icon#CLOSE");

		Click.clickAt(locator1 = "Icon#CLOSE");

		AssertClick(
			locator1 = "Button#MOVE",
			value1 = "Move");

		Alert.viewSuccessMessage();
	}

	@summary = "Default summary"
	macro searchCP(subcategoryName = null, subcategorySearchEntry = null, vocabularyName = null, categoryName = null) {
		var key_categoryName = ${categoryName};
		var key_vocabularyName = ${vocabularyName};

		AssertClick(
			locator1 = "Categories#VOCABULARY_ENTRY_LINK",
			value1 = ${vocabularyName});

		Click(locator1 = "Categories#CATEGORY_ENTRY_LINK");

		var key_subcategoryName = ${subcategoryName};

		Type(
			locator1 = "TextInput#SEARCH",
			value1 = ${subcategorySearchEntry});

		Click(locator1 = "Icon#BASIC_SEARCH");
	}

	@summary = "Default summary"
	macro viewCategoryPropertyCP(subcategoryName = null, propertiesValueField = null, propertiesKeyField = null, vocabularyName = null, categoryName = null) {
		AssertClick(
			key_vocabularyName = ${vocabularyName},
			locator1 = "Categories#VOCABULARY_ENTRY_LINK",
			value1 = ${vocabularyName});

		Click(
			key_categoryName = ${categoryName},
			locator1 = "Categories#CATEGORY_ENTRY_LINK");

		LexiconEntry.gotoEntryMenuItem(
			menuItem = "Edit",
			rowEntry = ${subcategoryName});

		Panel.expandPanel(panelHeading = "Properties");

		AssertTextEquals(
			locator1 = "CategoriesEditCategory#PROPERTIES_KEY_FIELD_1",
			value1 = ${propertiesKeyField});

		AssertTextEquals(
			locator1 = "CategoriesEditCategory#PROPERTIES_VALUE_FIELD_1",
			value1 = ${propertiesValueField});
	}

	@summary = "Default summary"
	macro viewCP(subcategoryName = null, vocabularyName = null, categoryName = null) {
		var key_categoryName = ${categoryName};
		var key_vocabularyName = ${vocabularyName};

		AssertClick(
			locator1 = "Categories#VOCABULARY_ENTRY_LINK",
			value1 = ${vocabularyName});

		AssertClick(
			locator1 = "Categories#CATEGORY_ENTRY_LINK",
			value1 = ${categoryName});

		var key_subcategoryName = ${subcategoryName};

		AssertTextEquals(
			locator1 = "Categories#SUBCATEGORY_ENTRY",
			value1 = ${subcategoryName});
	}

	@summary = "Default summary"
	macro viewSearchResultsCP(subcategoryName = null, nullResult = null, subcategoryDescriptionList = null, subCategoryNameList = null, subcategoryDescription = null) {
		if (isSet(subCategoryNameList)) {
			for (var subCategoryName : list ${subCategoryNameList}) {
				var key_subCategoryName = ${subCategoryName};

				AssertTextEquals(
					locator1 = "Categories#SUBCATEGORY_ENTRY",
					value1 = ${subcategoryName});
			}
		}

		if (isSet(subcategoryDescriptionList)) {
			for (var categoryDescription : list ${subcategoryDescriptionList}) {
				var key_subcategoryDescription = ${subcategoryDescription};

				AssertTextEquals(
					locator1 = "Categories#SUBCATEGORY_ENTRY_DESCRIPTION",
					value1 = ${subcategoryDescription});
			}
		}

		if (${nullResult} == "true") {
			AssertTextEquals(
				locator1 = "Message#EMPTY_INFO",
				value1 = "There are no categories.");
		}
	}

}