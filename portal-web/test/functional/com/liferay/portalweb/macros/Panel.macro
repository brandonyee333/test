definition {

	@summary = "Default summary"
	macro expandPanel(panelHeading = null) {
		var key_panelHeading = ${panelHeading};

		if ((IsElementPresent(locator1 = "Panel#PANEL_HEADING_COLLAPSED", value1 = ${panelHeading})) && (IsVisible(locator1 = "Panel#PANEL_HEADING_COLLAPSED", value1 = ${panelHeading}))) {
			AssertClick(
				locator1 = "Panel#PANEL_HEADING_COLLAPSED",
				value1 = ${panelHeading});
		}

		AssertElementPresent(locator1 = "Panel#PANEL_HEADING_EXPANDED");
	}

	@summary = "Default summary"
	macro expandSidebarApplicationsPanel() {
		if ((IsElementPresent(locator1 = "ControlMenuAddPanel#SIDEBAR_APPLICATIONS_PANEL_COLLAPSED")) && (IsVisible(locator1 = "ControlMenuAddPanel#SIDEBAR_APPLICATIONS_PANEL_COLLAPSED"))) {
			AssertClick(
				locator1 = "ControlMenuAddPanel#SIDEBAR_APPLICATIONS_PANEL_COLLAPSED",
				value1 = "Applications");

			AssertElementPresent(locator1 = "ControlMenuAddPanel#SIDEBAR_APPLICATIONS_PANEL_EXPANDED");
		}
	}

	@summary = "Default summary"
	macro expandSidebarContentPanel() {
		if ((IsElementPresent(locator1 = "ControlMenuAddPanel#SIDEBAR_CONTENT_PANEL_COLLAPSED")) && (IsVisible(locator1 = "ControlMenuAddPanel#SIDEBAR_CONTENT_PANEL_COLLAPSED"))) {
			AssertClick(
				locator1 = "ControlMenuAddPanel#SIDEBAR_CONTENT_PANEL_COLLAPSED",
				value1 = "Content");

			AssertElementPresent(locator1 = "ControlMenuAddPanel#SIDEBAR_CONTENT_PANEL_EXPANDED");
		}
	}

}