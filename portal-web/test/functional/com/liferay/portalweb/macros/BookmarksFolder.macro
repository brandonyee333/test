definition {

	var assetType = "Bookmarks Folder";

	@summary = "Default summary"
	macro addCP(folderDescription = null, folderName = null) {
		LexiconEntry.gotoAddMenuItem(menuItem = "Folder");

		PortletEntry.inputName(name = ${folderName});

		PortletEntry.inputDescription(description = ${folderDescription});

		PortletEntry.save();

		BookmarksFolder.viewFolder(
			folderDescription = ${folderDescription},
			folderName = ${folderName});
	}

	@summary = "Default summary"
	macro addNullCP() {
		LexiconEntry.gotoAddMenuItem(menuItem = "Folder");

		Button.clickSave();

		AssertTextEquals.assertPartialText(
			locator1 = "TextInput#REQUIRED_ALERT",
			value1 = "Name");

		AssertTextEquals.assertPartialText(
			locator1 = "TextInput#REQUIRED_ALERT",
			value1 = "Required");

		Alert.viewRequiredField();
	}

	@summary = "Default summary"
	macro addNullSubfolderCP(folderName = null) {
		var key_assetName = ${folderName};
		var key_folderName = ${folderName};

		AssertClick(
			locator1 = "Bookmarks#DESCRIPTIVE_ENTRY_TITLE",
			value1 = ${folderName});

		AssertTextEquals(
			locator1 = "Portlet#HEADER",
			value1 = ${folderName});

		LexiconEntry.gotoAddMenuItem(menuItem = "Subfolder");

		Button.clickSave();

		AssertTextEquals.assertPartialText(
			locator1 = "TextInput#REQUIRED_ALERT",
			value1 = "Name");

		AssertTextEquals.assertPartialText(
			locator1 = "TextInput#REQUIRED_ALERT",
			value1 = "Required");

		Alert.viewRequiredField();
	}

	@summary = "Default summary"
	macro addPG(folderDescription = null, folderName = null) {
		Portlet.clickPortletPlusIconPG(portletName = "Bookmarks");

		MenuItem.click(menuItem = "Folder");

		PortletEntry.inputName(name = ${folderName});

		PortletEntry.inputDescription(description = ${folderDescription});

		PortletEntry.save();

		BookmarksFolder.viewFolder(
			folderDescription = ${folderDescription},
			folderName = ${folderName});
	}

	@summary = "Default summary"
	macro addSubfolderCP(subfolderName = null, subfolderDescription = null, folderName = null) {
		var key_assetName = ${folderName};

		AssertClick(
			locator1 = "Bookmarks#DESCRIPTIVE_ENTRY_TITLE",
			value1 = ${folderName});

		AssertTextEquals(
			locator1 = "Portlet#HEADER",
			value1 = ${folderName});

		LexiconEntry.gotoAddMenuItem(menuItem = "Subfolder");

		var key_folderName = ${subfolderName};

		PortletEntry.inputName(name = ${subfolderName});

		PortletEntry.inputDescription(description = ${subfolderDescription});

		PortletEntry.save();

		BookmarksFolder.viewFolder(
			folderDescription = ${subfolderDescription},
			folderName = ${subfolderName});

		AssertTextEquals(
			locator1 = "Portlet#HEADER",
			value1 = ${folderName});
	}

	@summary = "Default summary"
	macro addSubfolderPG(folderDescription = null, folderName = null) {
		Portlet.clickPortletPlusIconPG(portletName = "Bookmarks");

		MenuItem.click(menuItem = "Subfolder");

		PortletEntry.inputName(name = ${folderName});

		PortletEntry.inputDescription(description = ${folderDescription});

		PortletEntry.save();

		BookmarksFolder.viewFolder(
			folderDescription = ${folderDescription},
			folderName = ${folderName});
	}

	@summary = "Default summary"
	macro deletePG(folderName = null) {
		AssertTextEquals(
			key_assetName = ${folderName},
			locator1 = "Bookmarks#DESCRIPTIVE_ENTRY_TITLE",
			value1 = ${folderName});

		LexiconEntry.gotoEntryMenuItem(
			menuItem = "Move to the Recycle Bin",
			rowEntry = ${folderName});

		AssertElementPresent(locator1 = "Message#SUCCESS");

		Navigator.openURL();

		ProductMenu.gotoPortlet(
			category = "Content",
			panel = "Site Administration",
			portlet = "Recycle Bin");

		RecycleBin.emptyCP();
	}

	@summary = "Default summary"
	macro editCP(folderNameEdit = null, folderName = null, folderDescriptionEdit = null) {
		LexiconEntry.gotoEntryMenuItem(
			menuItem = "Edit",
			rowEntry = ${folderName});

		PortletEntry.inputName(name = ${folderNameEdit});

		PortletEntry.inputDescription(description = ${folderDescriptionEdit});

		PortletEntry.save();

		BookmarksFolder.viewFolder(
			folderDescription = ${folderDescriptionEdit},
			folderName = ${folderNameEdit});
	}

	@summary = "Default summary"
	macro editPG(folderNameEdit = null, folderName = null, folderDescriptionEdit = null) {
		LexiconEntry.gotoEntryMenuItem(
			menuItem = "Edit",
			rowEntry = ${folderName});

		PortletEntry.inputName(name = ${folderNameEdit});

		PortletEntry.inputDescription(description = ${folderDescriptionEdit});

		PortletEntry.save();

		BookmarksFolder.viewFolder(
			folderDescription = ${folderDescriptionEdit},
			folderName = ${folderNameEdit});
	}

	@summary = "Default summary"
	macro editSubfolderCP(subfolderName = null, editSubfolderName = null, folderName = null, editSubfolderDescription = null) {
		AssertClick(
			key_assetName = ${folderName},
			locator1 = "Bookmarks#DESCRIPTIVE_ENTRY_TITLE",
			value1 = ${folderName});

		AssertTextEquals(
			locator1 = "Portlet#HEADER",
			value1 = ${folderName});

		LexiconEntry.gotoEntryMenuItem(
			menuItem = "Edit",
			rowEntry = ${subfolderName});

		PortletEntry.inputName(name = ${editSubfolderName});

		PortletEntry.inputDescription(description = ${editSubfolderDescription});

		PortletEntry.save();

		BookmarksFolder.viewFolder(
			folderDescription = ${editSubfolderDescription},
			folderName = ${editSubfolderName});
	}

	@summary = "Default summary"
	macro gotoPG(folderName = null) {
		var key_assetName = ${folderName};

		AssertClick.assertPartialTextClickAt(
			locator1 = "Bookmarks#DESCRIPTIVE_ENTRY_TITLE",
			value1 = ${folderName});

		Breadcrumb.viewActiveEntry(breadcrumbName = ${folderName});
	}

	@summary = "Default summary"
	macro gotoSubfolderPG(subfolderName = null, siteName = null, folderName = null, pageName = null) {
		Navigator.gotoSitePage(
			pageName = ${pageName},
			siteName = ${siteName});

		while (IsElementPresent.pauseIsElementPresent(locator1 = "Icon#BACK")) {
			Click(locator1 = "Icon#BACK");
		}

		var key_assetName = ${folderName};

		AssertClick.assertPartialTextClickAt(
			locator1 = "Bookmarks#DESCRIPTIVE_ENTRY_TITLE",
			value1 = ${folderName});

		var key_assetName = ${subfolderName};

		AssertClick.assertPartialTextClickAt(
			locator1 = "Bookmarks#DESCRIPTIVE_ENTRY_TITLE",
			value1 = ${subfolderName});

		Breadcrumb.viewActiveEntry(breadcrumbName = ${subfolderName});
	}

	@summary = "Default summary"
	macro mergeSubfolderToFolderCP(subfolderName = null, bookmarkName = null, folderName = null, bookmarkURL = null) {
		AssertClick(
			key_assetName = ${folderName},
			locator1 = "Bookmarks#DESCRIPTIVE_ENTRY_TITLE",
			value1 = ${folderName});

		AssertTextEquals(
			locator1 = "Portlet#HEADER",
			value1 = ${folderName});

		LexiconEntry.gotoEntryMenuItem(
			menuItem = "Edit",
			rowEntry = ${subfolderName});

		Click(locator1 = "Bookmarks#PARENT_FOLDER_PANEL");

		Check.checkToggleSwitch(locator1 = "Checkbox#MERGE_WITH_PARENT_FOLDER");

		Button.clickSave();

		Alert.viewSuccessMessage();

		Bookmark.viewBookmark(
			bookmarkName = ${bookmarkName},
			bookmarkURL = ${bookmarkURL});
	}

	@summary = "Default summary"
	macro moveSubfolderToRecycleBinPG(subfolderName = null) {
		LexiconEntry.gotoEntryMenuItem(
			menuItem = "Move to the Recycle Bin",
			rowEntry = ${subfolderName});

		AssertElementPresent(locator1 = "Message#SUCCESS");
	}

	@summary = "Default summary"
	macro moveToRecycleBinCP(folderName = null) {
		Navigator.openURL();

		ProductMenu.gotoPortlet(
			category = "Content",
			panel = "Site Administration",
			portlet = "Bookmarks");

		AssertTextEquals(
			key_assetName = ${folderName},
			locator1 = "Bookmarks#DESCRIPTIVE_ENTRY_TITLE",
			value1 = ${folderName});

		LexiconEntry.gotoEntryMenuItem(
			menuItem = "Move to the Recycle Bin",
			rowEntry = ${folderName});

		AssertElementPresent(locator1 = "Message#SUCCESS");
	}

	@summary = "Default summary"
	macro subscribePG(folderDescription = null) {
		var key_assetDescription = ${folderDescription};

		AssertTextEquals.assertPartialText(
			locator1 = "Bookmarks#DESCRIPTIVE_ENTRY_DESCRIPTION",
			value1 = ${folderDescription});

		Click.clickAt(locator1 = "Icon#INFO");

		Pause(locator1 = 1000);

		Click(locator1 = "Icon#SUBSCRIBE");

		Alert.viewSuccessMessage();
	}

	@summary = "Default summary"
	macro tearDownCP() {
		Navigator.openURL();

		ProductMenu.gotoPortlet(
			category = "Content",
			panel = "Site Administration",
			portlet = "Bookmarks");

		if (IsElementNotPresent(locator1 = "Message#EMPTY_INFO")) {
			Check.checkAll(locator1 = "Checkbox#SELECT_ALL");

			Click(locator1 = "Icon#MOVE_TO_RECYCLE_BIN");

			AssertElementPresent(locator1 = "Message#SUCCESS");

			AssertElementPresent(locator1 = "Message#EMPTY_INFO");
		}

		Navigator.openURL();

		ProductMenu.gotoPortlet(
			category = "Content",
			panel = "Site Administration",
			portlet = "Recycle Bin");

		RecycleBin.emptyCP();
	}

	@summary = "Default summary"
	macro viewFolder(folderDescription = null, folderName = null) {
		var key_assetName = ${folderName};

		AssertTextEquals(
			locator1 = "Bookmarks#DESCRIPTIVE_ENTRY_TITLE",
			value1 = ${folderName});

		var key_assetDescription = ${folderDescription};

		AssertTextEquals(
			locator1 = "Bookmarks#DESCRIPTIVE_ENTRY_DESCRIPTION",
			value1 = ${folderDescription});
	}

}