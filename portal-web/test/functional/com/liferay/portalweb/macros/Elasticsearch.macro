definition {

	macro getRemoteServerVersion {
		var curl = "http://localhost:9200";

		var serverInfo = JSONCurlUtil.get("${curl}");

		var serverVersion = RegexUtil.replace("${serverInfo}", "number\" : \"(\d+\.\d+\.\d+)", "1");

		echo("Version of the remote Elasticsearch server on port 9200: ${serverVersion}");

		return "${serverVersion}";
	}

	macro viewClusterStatus {
		AssertTextPresent(
			locator1 = "//pre",
			value1 = "${clusterStatus}");
	}

	@description = "Elasticsearch provides a Cluster Health API (http://localhost:9200/_cluster/health?pretty=true) to easily view the current status of the cluster."
	macro viewClusterStatusViaClusterHealthAPI {
		Navigator.openSpecificURL(url = "http://localhost:9200/_cluster/health?level=indices&pretty");

		AssertTextEquals.assertPartialText(
			locator1 = "//body",
			value1 = "&quot;cluster_name&quot; : &quot;LiferayElasticsearchCluster&quot;");

		AssertTextEquals.assertPartialText(
			locator1 = "//body",
			value1 = "&quot;number_of_nodes&quot; : ${numberOfNodes}");

		AssertTextEquals.assertPartialText(
			locator1 = "//body",
			value1 = "&quot;number_of_data_nodes&quot; : ${numberOfNodes}");
	}

	macro viewReplicaAddedInConsole {
		AssertConsoleTextPresent(value1 = "added.*reason: zen-disco-receive");
	}

	macro viewReplicaRemovedInConsole {
		AssertConsoleTextPresent(value1 = "removed.*reason: zen-disco-node_left");
	}

}