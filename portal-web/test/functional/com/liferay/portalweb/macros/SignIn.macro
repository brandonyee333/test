definition {

	var userEmailAddress = "test@liferay.com";
	var userPassword = "test";
	var userPasswordReminderAnswer = "test";

	@summary = "Default summary"
	macro _signIn(userPassword = null, userEmailAddress = null, rememberMe = null) {
		if (IsElementNotPresent(locator1 = "TextInput#EMAIL_ADDRESS")) {
			AssertClick(
				locator1 = "UserBar#USER_SIGN_IN",
				value1 = "Sign In");
		}

		Type(
			locator1 = "TextInput#EMAIL_ADDRESS",
			value1 = ${userEmailAddress});

		Type(
			locator1 = "TextInput#PASSWORD",
			value1 = ${userPassword});

		if (${rememberMe} == "true") {
			Check(locator1 = "Checkbox#REMEMBER_ME");
		}

		AssertClick(
			locator1 = "Button#SIGN_IN",
			value1 = "Sign In");

		AssertElementNotPresent(locator1 = "Button#SIGN_IN");
	}

	@summary = "Default summary"
	macro agreeToTermsOfUse() {
		AssertClick(
			locator1 = "Button#I_AGREE",
			value1 = "I Agree");

		AssertElementNotPresent(locator1 = "Button#I_AGREE");
	}

	@summary = "Default summary"
	macro setPasswordReminder(userPasswordReminderAnswer = null) {
		Type(
			locator1 = "TextInput#ANSWER",
			value1 = ${userPasswordReminderAnswer});

		Button.clickSave();
	}

	@summary = "Default summary"
	macro signIn(userPassword = null, userEmailAddress = null, rememberMe = null) {
		Navigator.openURL();

		SignIn._signIn(
			rememberMe = ${rememberMe},
			userEmailAddress = ${userEmailAddress},
			userPassword = ${userPassword});
	}

	@summary = "Default summary"
	macro signInPortalInstanceSetUp() {
		var defaultPortalURL = PropsUtil.get("default.portal.url");

		SignIn.signInSpecificURL(url = ${defaultPortalURL});

		if (IsElementPresent(locator1 = "Button#I_AGREE")) {
			SignIn.agreeToTermsOfUse();
		}

		if (IsElementPresent(locator1 = "Select#QUESTION")) {
			SignIn.setPasswordReminder();
		}

		ProductMenu.gotoPortlet(
			category = "Configuration",
			panel = "Control Panel",
			portlet = "Virtual Instances");

		while (IsElementPresent(key_rowNumber = 2, locator1 = "ContentRow#ENTRY_CONTENT_ROW_NUMBER_ELLIPSIS")) {
			Click.waitForMenuToggleJSClick(
				key_rowNumber = 2,
				locator1 = "ContentRow#ENTRY_CONTENT_ROW_NUMBER_ELLIPSIS");

			MenuItem.clickNoError(menuItem = "Delete");

			Confirm(value1 = "Are you sure you want to delete this? It will be deleted immediately.");

			Alert.waitForSuccessMessageHide();
		}

		var portalURL = PropsUtil.get("portal.url");

		var portalURL = StringUtil.replace(${portalURL}, "http://", "");

		var portalURL = StringUtil.replace(${portalURL}, ":8080", "");

		LexiconEntry.gotoAdd();

		Type(
			locator1 = "TextInput#WEB_ID",
			value1 = ${portalURL});

		Type(
			locator1 = "TextInput#VIRTUAL_HOST",
			value1 = ${portalURL});

		Type(
			locator1 = "TextInput#MAIL_DOMAIN",
			value1 = "liferay.com");

		Button.clickSave();

		while (IsElementPresent(locator1 = "//html[contains(@class,'lfr-spa-loading')]")) {
			Pause(value1 = 3000);
		}

		Alert.waitForSuccessMessageHide();

		var key_portalURL = ${portalURL};

		AssertTextEquals(
			locator1 = "VirtualInstances#VIRTUAL_INSTANCES_TABLE_WEB_ID",
			value1 = ${portalURL});

		AssertTextEquals(
			locator1 = "VirtualInstances#VIRTUAL_INSTANCES_TABLE_VIRTUAL_HOST",
			value1 = ${portalURL});

		Navigator.openURL();
	}

	@summary = "Default summary"
	macro signInSpecificURL(userPassword = null, userEmailAddress = null, rememberMe = null, url = null) {
		Navigator.openSpecificURL(url = ${url});

		SignIn._signIn(
			rememberMe = ${rememberMe},
			userEmailAddress = ${userEmailAddress},
			userPassword = ${userPassword});
	}

	@summary = "Default summary"
	macro signInTestSetup() {
		SignOut.signOut();

		SignIn.signIn();

		if (IsElementPresent(locator1 = "Button#I_AGREE")) {
			SignIn.agreeToTermsOfUse();
		}

		if (IsElementPresent(locator1 = "Select#QUESTION")) {
			SignIn.setPasswordReminder();
		}
	}

}