definition {

	@summary = "Default summary"
	macro clickMoveToRecycleBin() {
		MenuItem.click(menuItem = "Move to the Recycle Bin");
	}

	@summary = "Default summary"
	macro inputDescription(description = null) {
		Click(locator1 = "TextArea#DESCRIPTION");

		Type(
			locator1 = "TextArea#DESCRIPTION",
			value1 = ${description});
	}

	@summary = "Default summary"
	macro inputDescriptionTextInput(description = null) {
		Click(locator1 = "TextInput#DESCRIPTION");

		Type(
			locator1 = "TextInput#DESCRIPTION",
			value1 = ${description});
	}

	@summary = "Default summary"
	macro inputLocalizedName(localizedName = null, language = null) {
		Click(
			key_language = ${language},
			locator1 = "Language#SITE_NAME_TRANSLATION");

		PortletEntry.inputName(name = ${localizedName});
	}

	@summary = "Default summary"
	macro inputName(name = null) {
		Click(locator1 = "TextInput#NAME");

		Type(
			locator1 = "TextInput#NAME",
			value1 = ${name});

		if (IsElementPresent(locator1 = "TextInput#NAME_INVALID")) {
			Click(locator1 = "TextInput#NAME_MARGIN");
		}
	}

	@summary = "Default summary"
	macro inputSiteTemplateDescription(description = null) {
		Click(locator1 = "TextArea#SITE_TEMPLATE_DESCRIPTION");

		Type(
			locator1 = "TextArea#SITE_TEMPLATE_DESCRIPTION",
			value1 = ${description});
	}

	@summary = "Default summary"
	macro inputTitle(title = null) {
		Click(locator1 = "TextInput#TITLE");

		Type(
			locator1 = "TextInput#TITLE",
			value1 = ${title});

		if (IsElementPresent(locator1 = "TextInput#TITLE_INVALID")) {
			Click(locator1 = "TextInput#TITLE_MARGIN");
		}
	}

	@summary = "Default summary"
	macro publish() {
		Button.clickPublish();

		Alert.viewSuccessMessage();
	}

	@summary = "Default summary"
	macro publishAndWait() {
		Button.clickPublish();

		Pause(locator1 = 3000);

		Alert.viewSuccessMessage();
	}

	@summary = "Default summary"
	macro save() {
		Button.clickSave();

		Alert.viewSuccessMessage();
	}

	@summary = "Default summary"
	macro viewNoNavItemLink() {
		AssertElementNotPresent(locator1 = "NavBar#NAV_ITEM_LINK");
	}

}