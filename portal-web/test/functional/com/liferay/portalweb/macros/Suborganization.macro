definition {

	@summary = "Default summary"
	macro addCP(orgName = null, suborgName = null) {
		var key_orgName = ${orgName};

		LexiconEntry.gotoEllipsisMenuItem(menuItem = "Add Organization");

		Type(
			locator1 = "TextInput#NAME",
			value1 = ${suborgName});

		PortletEntry.save();

		AssertTextEquals(
			locator1 = "TextInput#NAME",
			value1 = ${suborgName});
	}

	@summary = "Default summary"
	macro gotoCP(suborgName = null, searchToken = null) {
		Type(
			locator1 = "TextInput#SEARCH",
			value1 = ${searchToken});

		Click(locator1 = "Button#SUBMIT");

		var key_suborgName = ${suborgName};

		AssertTextEquals(
			locator1 = "UsersAndOrganizationsOrganization#SUBORGANIZATION_TABLE_NAME",
			value1 = ${suborgName});

		AssertClick(
			locator1 = "UsersAndOrganizationsOrganization#SUBORGANIZATION_TABLE_NAME",
			value1 = ${suborgName});

		Breadcrumb.viewActiveEntry(breadcrumbName = ${suborgName});
	}

	@summary = "Default summary"
	macro tearDownCP() {
		Organization.tearDownCP(orgName = "Suborganization*");
	}

	@summary = "Default summary"
	macro viewCP(orgType = null, orgName = null, suborgType = null, suborgName = null) {
		Organization.viewSubOrganizationCP(
			orgName = ${orgName},
			orgType = ${orgType},
			suborgName = ${suborgName},
			suborgType = ${suborgType});

		var key_suborgName = ${suborgName};

		LexiconEntry.openEntryMenu(rowEntry = ${suborgName});

		MenuItem.click(menuItem = "Edit");

		var key_orgType = ${orgType};

		AssertTextEquals(
			locator1 = "Portlet#HEADER",
			value1 = "Edit ${suborgName}");

		AssertTextEquals(
			locator1 = "TextInput#NAME",
			value1 = ${suborgName});

		AssertTextEquals.assertValue(
			locator1 = "UsersAndOrganizationsEditOrganization#DETAILS_TYPE",
			value1 = ${orgType});

		AssertTextEquals(
			locator1 = "UsersAndOrganizationsEditOrganization#PARENT_ORGANIZATION_TABLE_NAME",
			value1 = ${orgName});

		AssertTextEquals(
			locator1 = "UsersAndOrganizationsEditOrganization#PARENT_ORGANIZATION_TABLE_TYPE",
			value1 = ${orgType});
	}

}