definition {

	var assetType = "Bookmarks Entry";

	@summary = "Default summary"
	macro addBookmarkViaAP(bookmarkFolderName = null, bookmarkDescription = null, bookmarkName = null, bookmarkURL = null) {
		AssetPublisherPortlet.addAsset(assetType = "Bookmarks Entry");

		if (isSet(bookmarkFolderName)) {
			AssertClick.pauseAssertTextClickAt(
				locator1 = "Button#SELECT",
				value1 = "Select");

			SelectFrameTop();

			SelectFrame(locator1 = "IFrame#SELECT_FOLDER");

			AssertClick(
				key_folderName = ${bookmarkFolderName},
				locator1 = "WC#FOLDER_TABLE_CHOOSE",
				value1 = "Choose");
		}

		SelectFrameTop();

		SelectFrame(locator1 = "IFrame#EDIT_ASSET");

		PortletEntry.inputName(name = ${bookmarkName});

		Type(
			locator1 = "TextInput#URL",
			value1 = ${bookmarkURL});

		PortletEntry.inputDescription(description = ${bookmarkDescription});

		AssertClick.pauseAssertTextClickAt(
			locator1 = "Button#SAVE",
			value1 = "Save");
	}

	@summary = "Default summary"
	macro addCP(bookmarkDescription = null, trailingSlash = null, bookmarkURL = null) {
		LexiconEntry.gotoAddMenuItem(menuItem = "Bookmark");

		if (isSet(bookmarkName)) {
			PortletEntry.inputName(name = ${bookmarkName});
		}
		else {
			var bookmarkName = ${bookmarkURL};
		}

		Type(
			locator1 = "TextInput#URL",
			value1 = ${bookmarkURL});

		if (isSet(bookmarkDescription)) {
			PortletEntry.inputDescription(description = ${bookmarkDescription});
		}

		PortletEntry.save();

		Bookmark.viewBookmark(
			bookmarkName = ${bookmarkName},
			bookmarkURL = ${bookmarkURL},
			trailingSlash = ${trailingSlash});
	}

	@summary = "Default summary"
	macro addIncorrectURLCP(bookmarkDescription = null, bookmarkURLInvalid = null, bookmarkName = null) {
		LexiconEntry.gotoAddMenuItem(menuItem = "Bookmark");

		PortletEntry.inputName(name = ${bookmarkName});

		Type(
			locator1 = "TextInput#URL",
			value1 = ${bookmarkURLInvalid});

		PortletEntry.inputDescription(description = ${bookmarkDescription});

		Button.clickSave();

		AssertTextEquals.assertPartialText(
			locator1 = "TextInput#URL_REQUIRED",
			value1 = "URL");

		AssertTextEquals.assertPartialText(
			locator1 = "TextInput#URL_REQUIRED",
			value1 = "Required");

		AssertTextEquals.assertPartialText(
			locator1 = "TextInput#URL_REQUIRED",
			value1 = "Please enter a valid URL.");
	}

	@summary = "Default summary"
	macro addInvalidURLPG(bookmarkDescription = null, bookmarkURLInvalid = null, bookmarkName = null) {
		Portlet.clickPortletPlusIconPG(portletName = "Bookmarks");

		MenuItem.click(menuItem = "Bookmark");

		PortletEntry.inputName(name = ${bookmarkName});

		Type(
			locator1 = "TextInput#URL",
			value1 = ${bookmarkURLInvalid});

		PortletEntry.inputDescription(description = ${bookmarkDescription});

		Button.clickSave();

		AssertTextEquals(
			locator1 = "TextInput#URL_REQUIRED",
			value1 = "URL Required Please enter a valid URL.");
	}

	@summary = "Default summary"
	macro addNullCP(bookmarkDescription = null, bookmarkName = null) {
		LexiconEntry.gotoAddMenuItem(menuItem = "Bookmark");

		if (isSet(bookmarkName)) {
			PortletEntry.inputName(name = ${bookmarkName});
		}

		if (isSet(bookmarkDescription)) {
			PortletEntry.inputDescription(description = ${bookmarkDescription});
		}

		Button.clickSave();

		AssertTextEquals.assertPartialText(
			locator1 = "TextInput#URL_REQUIRED",
			value1 = "URL");

		AssertTextEquals.assertPartialText(
			locator1 = "TextInput#URL_REQUIRED",
			value1 = "Required");

		AssertTextEquals.assertPartialText(
			locator1 = "TextInput#URL_REQUIRED",
			value1 = "This field is required.");
	}

	@summary = "Default summary"
	macro addPG(bookmarkDescription = null, bookmarkURL = null, bookmarkViewableBy = null) {
		Portlet.clickPortletPlusIconPG(portletName = "Bookmarks");

		MenuItem.click(menuItem = "Bookmark");

		if (isSet(bookmarkName)) {
			PortletEntry.inputName(name = ${bookmarkName});
		}
		else {
			var bookmarkName = ${bookmarkURL};
		}

		Type(
			locator1 = "TextInput#URL",
			value1 = ${bookmarkURL});

		if (isSet(bookmarkDescription)) {
			PortletEntry.inputDescription(description = ${bookmarkDescription});
		}

		if (isSet(bookmarkViewableBy)) {
			Panel.expandPanel(panelHeading = "Permissions");

			Select(
				locator1 = "AssetPermissions#VIEWABLE_AS_SELECT",
				value1 = ${bookmarkViewableBy});
		}

		PortletEntry.save();

		Bookmark.viewBookmark(
			bookmarkName = ${bookmarkName},
			bookmarkURL = ${bookmarkURL});
	}

	@summary = "Default summary"
	macro addRelatedAssetBookmarksEntryPG(bookmarkName = null, bookmarkURL = null) {
		SelectFrame(locator1 = "AssetRelatedAssets#SELECT_ASSET_IFRAME");

		LexiconEntry.gotoAdd();

		PortletEntry.inputName(name = ${bookmarkName});

		Type(
			locator1 = "TextInput#URL",
			value1 = ${bookmarkURL});

		Button.clickSave();

		SelectFrame(value1 = "relative=top");
	}

	@summary = "Default summary"
	macro addToSubfolderCP(bookmarkDescription = null, subfolderName = null, bookmarkName = null, folderName = null, bookmarkURL = null) {
		var key_assetName = ${folderName};

		AssertClick(
			locator1 = "Bookmarks#DESCRIPTIVE_ENTRY_TITLE",
			value1 = ${folderName});

		var key_assetName = ${subfolderName};

		AssertClick(
			locator1 = "Bookmarks#DESCRIPTIVE_ENTRY_TITLE",
			value1 = ${subfolderName});

		AssertTextEquals(
			locator1 = "Portlet#HEADER",
			value1 = ${subfolderName});

		LexiconEntry.gotoAddMenuItem(menuItem = "Bookmark");

		PortletEntry.inputName(name = ${bookmarkName});

		Type(
			locator1 = "TextInput#URL",
			value1 = ${bookmarkURL});

		PortletEntry.inputDescription(description = ${bookmarkDescription});

		PortletEntry.save();

		Bookmark.viewBookmark(
			bookmarkName = ${bookmarkName},
			bookmarkURL = ${bookmarkURL});
	}

	@summary = "Default summary"
	macro deletePG(bookmarkName = null) {
		AssertTextEquals(
			key_assetName = ${bookmarkName},
			locator1 = "Bookmarks#DESCRIPTIVE_ENTRY_TITLE",
			value1 = ${bookmarkName});

		LexiconEntry.gotoEntryMenuItem(
			menuItem = "Move to the Recycle Bin",
			rowEntry = ${bookmarkName});

		AssertElementPresent(locator1 = "Message#SUCCESS");

		Navigator.openURL();

		ProductMenu.gotoPortlet(
			category = "Content",
			panel = "Site Administration",
			portlet = "Recycle Bin");

		RecycleBin.emptyCP();
	}

	@summary = "Default summary"
	macro editCP(editBookmarkURL = null, editBookmarkName = null, editBookmarkDescription = null, bookmarkName = null) {
		LexiconEntry.gotoEntryMenuItem(
			menuItem = "Edit",
			rowEntry = ${bookmarkName});

		PortletEntry.inputName(name = ${editBookmarkName});

		Type(
			locator1 = "TextInput#URL",
			value1 = ${editBookmarkURL});

		if (isSet(bookmarkDescription)) {
			PortletEntry.inputDescription(description = ${editBookmarkDescription});
		}

		PortletEntry.save();

		Bookmark.viewBookmark(
			bookmarkName = ${editBookmarkName},
			bookmarkURL = ${editBookmarkURL});
	}

	@summary = "Default summary"
	macro editPG(bookmarkURLEdit = null, bookmarkNameEdit = null, bookmarkName = null) {
		LexiconEntry.gotoEntryMenuItem(
			menuItem = "Edit",
			rowEntry = ${bookmarkName});

		PortletEntry.inputName(name = ${bookmarkNameEdit});

		Type(
			locator1 = "TextInput#URL",
			value1 = ${bookmarkURLEdit});

		PortletEntry.save();

		Bookmark.viewBookmark(
			bookmarkName = ${bookmarkNameEdit},
			bookmarkURL = ${bookmarkURLEdit});
	}

	@summary = "Default summary"
	macro gotoPG(bookmarkName = null) {
		AssertTextEquals(
			key_assetName = ${bookmarkName},
			locator1 = "Bookmarks#DESCRIPTIVE_ENTRY_TITLE",
			value1 = ${bookmarkName});
	}

	@summary = "Default summary"
	macro moveToFolderPG(bookmarkName = null, folderName = null, folderName2 = null) {
		if (isSet(folderName)) {
			BookmarksFolder.gotoPG(folderName = ${folderName});
		}

		LexiconEntry.gotoEntryMenuItem(
			menuItem = "Move",
			rowEntry = ${bookmarkName});

		AssertClick(
			locator1 = "Button#SELECT",
			value1 = "Select");

		IFrame.selectDialogFrame();

		AssertClick(
			key_folderName = ${folderName2},
			locator1 = "WC#FOLDER_TABLE_CHOOSE",
			value1 = "Choose");

		SelectFrame(value1 = "relative=top");

		AssertClick(
			locator1 = "Button#MOVE",
			value1 = "Move");

		Alert.viewSuccessMessage();

		AssertTextEquals(
			locator1 = "Message#EMPTY_INFO",
			value1 = "There are no bookmarks in this folder.");
	}

	@summary = "Default summary"
	macro moveToHomeCP(subfolderName = null, bookmarkName = null, folderName = null) {
		AssertClick(
			key_assetName = ${folderName},
			locator1 = "Bookmarks#DESCRIPTIVE_ENTRY_TITLE",
			value1 = ${folderName});

		if (isSet(subfolderName)) {
			AssertClick(
				key_assetName = ${subfolderName},
				locator1 = "Bookmarks#DESCRIPTIVE_ENTRY_TITLE",
				value1 = ${subfolderName});

			AssertTextEquals(
				locator1 = "Portlet#HEADER",
				value1 = ${subfolderName});
		}

		LexiconEntry.gotoEntryMenuItem(
			menuItem = "Move",
			rowEntry = ${bookmarkName});

		AssertTextEquals(
			locator1 = "Portlet#HEADER",
			value1 = "Move Entries");

		AssertClick(
			locator1 = "Button#SELECT",
			value1 = "Select");

		IFrame.selectDialogFrame();

		AssertClick(
			locator1 = "Button#CHOOSE_THIS_FOLDER",
			value1 = "Choose This Folder");

		SelectFrame(value1 = "relative=top");

		AssertTextEquals(
			locator1 = "Portlet#HEADER",
			value1 = "Move Entries");

		AssertClick(
			locator1 = "Button#MOVE",
			value1 = "Move");

		Alert.viewSuccessMessage();

		AssertTextEquals(
			locator1 = "Message#EMPTY_INFO",
			value1 = "There are no bookmarks in this folder.");

		Navigator.openURL();

		ProductMenu.gotoPortlet(
			category = "Content",
			panel = "Site Administration",
			portlet = "Bookmarks");

		AssertTextEquals.assertPartialText(
			key_assetName = ${bookmarkName},
			locator1 = "Bookmarks#DESCRIPTIVE_ENTRY_TITLE",
			value1 = ${bookmarkName});
	}

	@summary = "Default summary"
	macro moveToRecycleBinCP(bookmarkName = null, bookmarkURL = null) {
		Navigator.openURL();

		ProductMenu.gotoPortlet(
			category = "Content",
			panel = "Site Administration",
			portlet = "Bookmarks");

		AssertTextEquals(
			key_assetName = ${bookmarkName},
			locator1 = "Bookmarks#DESCRIPTIVE_ENTRY_TITLE",
			value1 = ${bookmarkName});

		LexiconEntry.gotoEntryMenuItem(
			menuItem = "Move to the Recycle Bin",
			rowEntry = ${bookmarkName});

		AssertElementPresent(locator1 = "Message#SUCCESS");

		AssertTextNotPresent(
			key_bookmarkURL = ${bookmarkName},
			locator1 = "Bookmarks#BOOKMARKS_TABLE_URL",
			value1 = ${bookmarkURL});
	}

	@summary = "Default summary"
	macro moveToRecycleBinPG(bookmarkName = null) {
		LexiconEntry.gotoEntryMenuItem(
			menuItem = "Move to the Recycle Bin",
			rowEntry = ${bookmarkName});

		AssertElementPresent(locator1 = "Message#SUCCESS");
	}

	@summary = "Default summary"
	macro searchNullCP(bookmarkName = null, nullBookmarkName = null, bookmar2Name = null) {
		Search.searchCP(searchTerm = ${nullBookmarkName});

		var key_bookmarkName = ${nullBookmarkName};

		AssertTextNotPresent(
			locator1 = "Bookmarks#SEARCH_TABLE_ENTRY_NAME",
			value1 = ${bookmarkName});

		AssertTextNotPresent(
			locator1 = "Bookmarks#SEARCH_TABLE_ENTRY_NAME",
			value1 = ${bookmar2Name});
	}

	@summary = "Default summary"
	macro tearDownCP() {
		Navigator.openURL();

		ProductMenu.gotoPortlet(
			category = "Content",
			panel = "Site Administration",
			portlet = "Bookmarks");

		if (IsElementNotPresent(locator1 = "Message#EMPTY_INFO")) {
			Check.checkAll(locator1 = "Checkbox#SELECT_ALL");

			Click(locator1 = "Icon#MOVE_TO_RECYCLE_BIN");

			AssertElementPresent(locator1 = "Message#SUCCESS");

			AssertElementPresent(locator1 = "Message#EMPTY_INFO");
		}

		Navigator.openURL();

		ProductMenu.gotoPortlet(
			category = "Content",
			panel = "Site Administration",
			portlet = "Recycle Bin");

		RecycleBin.emptyCP();
	}

	@summary = "Default summary"
	macro viewBookmark(trailingSlash = null, bookmarkName = null, bookmarkURL = null) {
		AssertClickNoError(
			key_assetName = ${bookmarkName},
			locator1 = "Bookmarks#DESCRIPTIVE_ENTRY_TITLE",
			value1 = ${bookmarkName});

		if (${trailingSlash} == "false") {
			AssertLocation(value1 = ${bookmarkURL});
		}
		else {
			AssertLocation(value1 = "${bookmarkURL}/");
		}
	}

	@summary = "Default summary"
	macro viewBookmarkViaAP(bookmarkName = null) {
		AssertClick(
			key_assetTitle = ${bookmarkName},
			locator1 = "AP#ASSET_ABSTRACT_TITLE",
			value1 = ${bookmarkName});

		AssertTextEquals(
			locator1 = "APAsset#ASSET_TITLE_HEADER",
			value1 = ${bookmarkName});

		Click(locator1 = "AP#ASSET_ABSTRACT_BOOKMARK_DETAIL_LINK");

		SelectWindow(value1 = "title=Digital Experience Software Tailored to Your Needs | Liferay");

		AssertLocation.assertPartialLocation(value1 = "https://www.liferay.com");

		Close.closeWindow(locator1 = "title=Digital Experience Software Tailored to Your Needs | Liferay");
	}

	@summary = "Default summary"
	macro viewEntry(bookmarkName = null, bookmarkURL = null) {
		Click(locator1 = "Icon#DISPLAY_STYLE_LIST");

		AssertTextEquals(
			key_bookmarkName = ${bookmarkName},
			locator1 = "Bookmarks#BOOKMARKS_TABLE_NAME",
			value1 = ${bookmarkName});

		AssertTextEquals(
			key_bookmarkURL = ${bookmarkURL},
			locator1 = "Bookmarks#BOOKMARKS_TABLE_URL",
			value1 = ${bookmarkURL});
	}

	@summary = "Default summary"
	macro viewNoCategoryCP() {
		LexiconEntry.gotoAddMenuItem(menuItem = "Bookmark");

		Panel.expandPanel(panelHeading = "Categorization");

		AssertElementNotPresent(locator1 = "AssetCategorization#VOCABULARY");
	}

	@summary = "Default summary"
	macro viewNoPG(bookmarkName = null, bookmarkURL = null) {
		AssertTextNotPresent(value1 = ${bookmarkName});

		AssertTextNotPresent(value1 = ${bookmarkURL});
	}

}