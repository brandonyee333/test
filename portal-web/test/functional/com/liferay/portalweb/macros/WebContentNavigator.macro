definition {

	@summary = "Default summary"
	macro _openDescriptiveMenulistCP(webContentTitle = null, webContentTitleEscapeCharacter = null) {
		if (isSet(webContentTitleEscapeCharacter)) {
			var key_webContentTitle = ${webContentTitleEscapeCharacter};
		}
		else {
			var key_webContentTitle = ${webContentTitle};
		}

		Portlet.changeDisplayStyle(displayStyle = "Descriptive");

		AssertTextEquals.assertPartialText(
			locator1 = "WC#ENTRY_DESCRIPTIVE_TITLE",
			value1 = ${webContentTitle});

		Click(locator1 = "WC#ENTRY_DESCRIPTIVE_MENULIST_ICON");
	}

	@summary = "Default summary"
	macro gotoAddCP() {
		AssertVisible(locator1 = "Button#PLUS");

		Pause(locator1 = 3000);

		LexiconEntry.gotoAddMenuItem(menuItem = "Basic Web Content");

		AssertVisible(locator1 = "TextInput#TITLE");
	}

	@summary = "Default summary"
	macro gotoAddFeed() {
		LexiconEntry.gotoHeaderMenuItem(menuItem = "Feeds");

		LexiconEntry.gotoAdd();
	}

	@summary = "Default summary"
	macro gotoAddPGViaWCD() {
		Click.clickNoWaitForVisible(locator1 = "WCD#ADD_WEB_CONTENT");

		if (isSet(structureName)) {
			var structureName = ${structureName};
		}
		else {
			var structureName = "Basic Web Content";
		}

		var key_structureName = ${structureName};

		AssertVisible(
			locator1 = "WCD#ADD_STRUCTURED_WEB_CONTENT",
			value1 = ${structureName});

		AssertClick(
			locator1 = "WCD#ADD_STRUCTURED_WEB_CONTENT",
			value1 = ${structureName});

		SelectFrame(locator1 = "IFrame#MODAL_IFRAME");

		AssertVisible(locator1 = "TextInput#TITLE");
	}

	@summary = "Default summary"
	macro gotoAddWithStructureCP(structureName = null) {
		var key_structureName = ${structureName};

		LexiconEntry.gotoAdd();

		MenuItem.click(menuItem = ${structureName});
	}

	@summary = "Default summary"
	macro gotoArticleMenuPGViaWCD(webContentTitle = null) {
		MouseOver(locator1 = "WCD#WEB_CONTENT_CONTENT");

		MouseOver.mouseOverNotVisible(
			key_webContentTitle = ${webContentTitle},
			locator1 = "WCD#ARTICLE_ELLIPSIS_ICON");

		Click(
			key_webContentTitle = ${webContentTitle},
			locator1 = "WCD#ARTICLE_ELLIPSIS_ICON");
	}

	@summary = "Default summary"
	macro gotoEditCP(webContentTitle = null, webContentTitleEscapeCharacter = null) {
		WebContentNavigator._openDescriptiveMenulistCP(
			webContentTitle = ${webContentTitle},
			webContentTitleEscapeCharacter = ${webContentTitleEscapeCharacter});

		MenuItem.click(menuItem = "Edit");

		AssertElementPresent(locator1 = "Icon#BACK");
	}

	@summary = "Default summary"
	macro gotoEditFeed(feedName = null) {
		LexiconEntry.gotoHeaderMenuItem(menuItem = "Feeds");

		LexiconEntry.gotoEntryMenuItem(
			menuItem = "Edit",
			rowEntry = ${feedName});

		AssertElementPresent(locator1 = "Icon#BACK");
	}

	@summary = "Default summary"
	macro gotoEditPGViaWCD() {
		MouseOver(locator1 = "WC#BODY");

		Portlet.gotoPortletOptions(
			portletName = "Web Content Display",
			portletOption = "Edit Web Content");

		SelectFrame(locator1 = "IFrame#MODAL_IFRAME");

		AssertVisible(locator1 = "TextInput#TITLE");
	}

	@summary = "Default summary"
	macro gotoEditStructure(structureName = null) {
		var key_ddlDataDefinitionName = ${structureName};

		AssertClick(
			locator1 = "DDMSelectStructure#DDM_STRUCTURE_TABLE_NAME_LINK",
			value1 = ${structureName});

		SelectFrame(value1 = "relative=top");
	}

	@summary = "Default summary"
	macro gotoLocalizedEditPGViaWCD(localizedPortletOption = null) {
		MouseOver(locator1 = "WC#BODY");

		Portlet.gotoPortletOptions(portletOption = ${localizedPortletOption});
	}

	@summary = "Default summary"
	macro gotoManageFeeds() {
		LexiconEntry.gotoHeaderMenuItem(menuItem = "Feeds");

		SiteAdmin.viewPortletTitle(portletTitle = "Feeds");
	}

	@summary = "Default summary"
	macro gotoManageStructures() {
		LexiconEntry.gotoHeaderMenuItem(menuItem = "Structures");

		SiteAdmin.viewPortletTitle(portletTitle = "Structures");
	}

	@summary = "Default summary"
	macro gotoManageTemplates() {
		LexiconEntry.gotoHeaderMenuItem(menuItem = "Templates");

		SiteAdmin.viewPortletTitle(portletTitle = "Templates");
	}

	@summary = "Default summary"
	macro gotoManageTemplatesViaStructures(structureName = null) {
		LexiconEntry.gotoEntryMenuItem(
			menuItem = "Manage Templates",
			rowEntry = ${structureName});

		SiteAdmin.viewPortletTitle(portletTitle = "Templates for Structure: ${structureName}");
	}

	@summary = "Default summary"
	macro gotoPreviewEntryCP(webContentTitle = null, webContentTitleEscapeCharacter = null) {
		WebContentNavigator._openDescriptiveMenulistCP(
			webContentTitle = ${webContentTitle},
			webContentTitleEscapeCharacter = ${webContentTitleEscapeCharacter});

		MenuItem.click(menuItem = "Preview");
	}

	@summary = "Default summary"
	macro gotoPreviewViaHeaderCP(webContentTitle = null) {
		SiteAdmin.viewPortletTitle(portletTitle = ${webContentTitle});

		LexiconEntry.gotoHeaderMenuItem(menuItem = "Preview");
	}

	@summary = "Default summary"
	macro gotoViewStatus(webContentTitle = null, webContentStatus = null) {
		var key_webContentTitle = ${webContentTitle};

		Portlet.changeDisplayStyle(displayStyle = "Descriptive");

		AssertElementPresent.pauseAssertVisible(locator1 = "WC#ENTRY_DESCRIPTIVE_THUMBNAIL");

		AssertTextEquals(
			locator1 = "WC#ENTRY_DESCRIPTIVE_WORKFLOW_STATUS",
			value1 = ${webContentStatus});

		AssertClick(
			locator1 = "WC#ENTRY_DESCRIPTIVE_TITLE",
			value1 = ${webContentTitle});
	}

	@summary = "Default summary"
	macro gotoViewTemplate(templateName = null) {
		var key_ddlTemplateName = ${templateName};

		AssertClick(
			locator1 = "DDMSelectTemplate#TEMPLATE_TABLE_NAME_LINK",
			value1 = ${templateName});
	}

	@summary = "Default summary"
	macro openWebContentAdmin(baseURL = null, siteURLKey = null) {
		Navigator.openWithAppendToBaseURL(
			baseURL = ${baseURL},
			urlAppend = "group/${siteURLKey}/~/control_panel/manage?p_p_id=com_liferay_journal_web_portlet_JournalPortlet");
	}

}