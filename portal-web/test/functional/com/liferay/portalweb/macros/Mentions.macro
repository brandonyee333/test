definition {

	@summary = "Default summary"
	macro addMentionViaBlogsEntry(mentionsUserScreenName = null, entryTitle = null, entryContent = null) {
		var key_entryContent = ${entryContent};
		var key_mentionsUserScreenName = ${mentionsUserScreenName};

		BlogsNavigator.gotoAddEntry();

		AlloyEditor.addTitle(title = ${entryTitle});

		Type.sendKeys(
			locator1 = "AlloyEditor#CONTENT_FIELD",
			value1 = "${entryContent} @${mentionsUserScreenName}");

		Click.clickNoMouseOver(locator1 = "Mentions#MENTIONS_USER_DISPLAY_OPTION");

		PortletEntry.publish();
	}

	@summary = "Default summary"
	macro addMentionViaComments(entryComment = null, mentionsUserScreenName = null) {
		var key_entryComment = ${entryComment};
		var key_mentionsUserScreenName = ${mentionsUserScreenName};

		Type.sendKeys(
			locator1 = "Comments#COMMENT_FIELD",
			value1 = "${entryComment} @${mentionsUserScreenName}");

		Click.clickNoMouseOver(locator1 = "Mentions#MENTIONS_USER_DISPLAY_OPTION");

		AssertClick(
			locator1 = "Button#REPLY",
			value1 = "Reply");

		Alert.viewSuccessMessage();
	}

	@summary = "Default summary"
	macro addMentionViaMessageBoardsReply(threadSubject = null, mentionsUserScreenName = null, threadBody = null) {
		var key_mentionsUserScreenName = ${mentionsUserScreenName};
		var key_threadSubject = ${threadSubject};

		AssertClick(
			locator1 = "MessageBoards#THREAD_LIST_THREAD",
			value1 = ${threadSubject});

		AssertElementPresent(locator1 = "MessageBoardsThread#MESSAGE_REPLY_1");

		AssertClick(
			locator1 = "MessageBoardsThread#MESSAGE_REPLY_1",
			value1 = "Reply to Main Thread");

		SelectFrame(locator1 = "CKEditor#BODY_FIELD_IFRAME");

		Type.sendKeys(
			locator1 = "CKEditor#BODY",
			value1 = "${threadBody} @${mentionsUserScreenName}");

		SelectFrame.selectFrameTop();

		Click.clickNoMouseOver(locator1 = "Mentions#MENTIONS_USER_DISPLAY_OPTION");

		Click(locator1 = "Button#PUBLISH");

		Alert.viewSuccessMessage();
	}

	@summary = "Default summary"
	macro addMentionViaMessageBoardThread(editMBThread = null, threadSubject = null, mentionsUserScreenNameList = null, threadBody = null) {
		if (${editMBThread} == "True") {
			LexiconEntry.gotoEllipsisMenuItem(menuItem = "Edit");
		}
		else {
			LexiconEntry.gotoAddMenuItem(menuItem = "Thread");
		}

		var key_mentionsUserScreenName = ${mentionsUserScreenName};

		Click(locator1 = "TextInput#SUBJECT");

		Type(
			locator1 = "TextInput#SUBJECT",
			value1 = ${threadSubject});

		if (isSet(multipleMentions)) {
			for (var mentionsUserScreenName : list ${mentionsUserScreenNameList}) {
				SelectFrame(locator1 = "CKEditor#BODY_FIELD_IFRAME");

				Type.sendKeys(
					locator1 = "CKEditor#BODY",
					value1 = " @${mentionsUserScreenName}");

				SelectFrame.selectFrameTop();

				Click.clickNoMouseOver(
					key_mentionsUserScreenName = ${mentionsUserScreenName},
					locator1 = "Mentions#MENTIONS_USER_DISPLAY_OPTION");
			}
		}
		else {
			SelectFrame(locator1 = "CKEditor#BODY_FIELD_IFRAME");

			Type(
				locator1 = "CKEditor#BODY",
				value1 = "${threadBody} @${mentionsUserScreenName}");

			SelectFrame.selectFrameTop();

			Click.clickNoMouseOver(locator1 = "Mentions#MENTIONS_USER_DISPLAY_OPTION");
		}

		Click(locator1 = "Button#PUBLISH");

		Alert.viewSuccessMessage();
	}

	@summary = "Default summary"
	macro viewCommentMentionTagLink(mentionsUserScreenName = null, mentionsUserFullName = null) {
		var key_mentionsUserFullName = ${mentionsUserFullName};
		var key_mentionsUserScreenName = ${mentionsUserScreenName};
		var key_siteName = ${mentionsUserFullName};

		AssertClick(
			locator1 = "Mentions#MENTIONS_COMMENT_TAG_LINK",
			value1 = "@${mentionsUserScreenName}");

		AssertTextEquals(
			locator1 = "SitePages#SITE_NAME",
			value1 = ${mentionsUserFullName});
	}

	@summary = "Default summary"
	macro viewMentionTagLink(mentionsUserScreenName = null, mentionsUserFullName = null) {
		var key_mentionsUserScreenName = ${mentionsUserScreenName};
		var key_siteName = ${mentionsUserFullName};

		AssertClick(
			locator1 = "Mentions#MENTIONS_TAG_LINK",
			value1 = "@${mentionsUserScreenName}");

		AssertTextEquals(
			locator1 = "SitePages#SITE_NAME",
			value1 = ${mentionsUserFullName});
	}

}