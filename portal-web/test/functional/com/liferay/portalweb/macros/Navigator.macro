definition {

	@summary = "Default summary"
	macro _gotoPage(pageName = null) {
		var key_pageName = ${pageName};
		var count = 0;

		while ((${count} != 3) && (IsElementNotPresent(locator1 = "Home#PAGE_ACTIVE"))) {
			AssertClick(
				locator1 = "Home#PAGE",
				value1 = ${pageName});

			var count = ${count} + 1;
		}

		AssertVisible(locator1 = "Home#PAGE_ACTIVE");
	}

	@summary = "Default summary"
	macro _isLocalizedURL(locale = null) {
		var currentURL = Navigator.getCurrentURL();
		var portalURL = PropsUtil.get("portal.url");
		var isLocalizedURL = "false";

		if (contains(${currentURL}, "${portalURL}/${locale}")) {
			var isLocalizedURL = "true";
		}

		return ${isLocalizedURL};
	}

	@summary = "Default summary"
	macro closeSpecificWindow(closeWindowTitle = null, selectWindowTitle = null) {
		Navigator.selectSpecificWindow(windowTitle = ${closeWindowTitle});

		Close.closeAndSelectWindow(value1 = "title=${selectWindowTitle}");
	}

	@summary = "Default summary"
	macro closeWindow() {
		Close.closeWindow();
	}

	@summary = "Default summary"
	macro ensureLocaleURL(locale = null) {
		var isLocalizedURL = Navigator._isLocalizedURL(locale = ${locale});

		if (${isLocalizedURL} == "false") {
			var currentURL = Navigator.getCurrentURL();
			var portalURL = PropsUtil.get("portal.url");

			Navigator.openSpecificURL(url = StringUtil.replace(${currentURL}, ${portalURL}, "${portalURL}/${locale}"));
		}
	}

	@summary = "Default summary"
	macro getCurrentURL() {
		var currentURL = selenium.getLocation();

		return ${currentURL};
	}

	@summary = "Default summary"
	macro gotoBack() {
		Click(locator1 = "Icon#BACK");
	}

	@summary = "Default summary"
	macro gotoEditPageViaControlMenu(pageName = null) {
		Click(locator1 = "ControlMenu#EDIT_COG");

		AssertTextEquals(
			locator1 = "Portlet#HEADER",
			value1 = ${pageName});
	}

	@summary = "Default summary"
	macro gotoNavItem(navItem = null) {
		var key_navItem = ${navItem};

		AssertClick(
			locator1 = "NavBar#NAV_ITEM_LINK",
			value1 = ${navItem});

		AssertElementPresent(locator1 = "NavBar#ACTIVE_NAV_ITEM_LINK");
	}

	@summary = "Default summary"
	macro gotoNavNested(navNested = null) {
		var key_navNested = ${navNested};

		AssertClick.assertPartialTextClickAt(
			locator1 = "NavNested#NAV_NESTED_LINK",
			value1 = ${navNested});

		AssertElementPresent(locator1 = "NavNested#ACTIVE_NAV_NESTED_LINK");
	}

	@summary = "Default summary"
	macro gotoNavTab(navTab = null) {
		var key_tab = ${navTab};

		AssertClick(
			locator1 = "NavTab#TAB_LINK",
			value1 = ${navTab});

		AssertElementPresent(locator1 = "NavTab#ACTIVE_TAB_LINK");
	}

	@summary = "Default summary"
	macro gotoNavUnderline(navUnderline = null) {
		var key_navUnderline = ${navUnderline};

		AssertClick(
			locator1 = "NavUnderline#NAV_UNDERLINE_LINK",
			value1 = ${navUnderline});

		AssertElementPresent(locator1 = "NavUnderline#ACTIVE_NAV_UNDERLINE_LINK");
	}

	@summary = "Default summary"
	macro gotoPage(pageName = null) {
		Navigator.openURL();

		if (isSet(sitePagePrivacy)) {
			ProductMenu.gotoPrivatePages();
		}

		Pause(value1 = 3000);

		Navigator._gotoPage(pageName = ${pageName});
	}

	@summary = "Default summary"
	macro gotoPrivateSitePage(siteName = null, pageName = null) {
		Navigator.openPrivateSiteURL(siteName = ${siteName});

		Navigator._gotoPage(pageName = ${pageName});
	}

	@summary = "Default summary"
	macro gotoPrivateStagedSitePage(siteName = null, pageName = null) {
		Navigator.openPrivateStagedSiteURL(siteNameURL = ${siteName});

		ProductMenu.gotoPrivatePages();

		Navigator._gotoPage(pageName = ${pageName});
	}

	@summary = "Default summary"
	macro gotoSEOPanel() {
		Navigator.gotoNavTab(navTab = "SEO");

		Panel.expandPanel(panelHeading = "SEO");
	}

	@summary = "Default summary"
	macro gotoSitePage(baseURL = null, siteName = null, pageName = null) {
		Navigator.openSiteURL(
			baseURL = ${baseURL},
			siteName = ${siteName});

		Navigator._gotoPage(pageName = ${pageName});
	}

	@summary = "Default summary"
	macro gotoSpecificURLPage(pageName = null, url = null) {
		Navigator.openSpecificURL(url = ${url});

		Navigator._gotoPage(pageName = ${pageName});
	}

	@summary = "Default summary"
	macro gotoStagedSitePage(siteName = null, pageName = null) {
		Navigator.openStagingSiteURL(siteName = ${siteName});

		Navigator._gotoPage(pageName = ${pageName});
	}

	@summary = "Default summary"
	macro gotoStagedView() {
		ProductMenuHelper.openProductMenu();

		Click(locator1 = "Link#STAGING");
	}

	@summary = "Default summary"
	macro openNodePort(nodePort = null) {
		Open(value1 = "http://localhost:${nodePort}");
	}

	@summary = "Default summary"
	macro openPrivateSitePageURL(siteName = null, pageName = null) {
		var siteNameURL = StringUtil.replace(${siteName}, " ", "-");

		var siteNameURL = StringUtil.lowerCase(${siteNameURL});
		var pageNameURL = StringUtil.replace(${pageName}, " ", "-");

		var pageNameURL = StringUtil.lowerCase(${pageNameURL});

		Open(value1 = "/group/${siteNameURL}/${pageNameURL}");
	}

	@summary = "Default summary"
	macro openPrivateSiteURL(siteName = null) {
		var siteNameURL = StringUtil.replace(${siteName}, " ", "-");

		var siteNameURL = StringUtil.lowerCase(${siteNameURL});

		Open(value1 = "/group/${siteNameURL}");
	}

	@summary = "Default summary"
	macro openPrivateStagedSiteURL() {
		var siteNameURL = StringUtil.replace(${siteNameURL}, " ", "-");

		var siteNameURL = StringUtil.lowerCase(${siteNameURL});

		Open(value1 = "/group/${siteNameURL}-staging");
	}

	@summary = "Default summary"
	macro openPrivateURL() {
		Open(value1 = "/group/guest");
	}

	@summary = "Default summary"
	macro openSiteLanding(baseURL = null) {
		var siteNameURL = StringUtil.replace(${siteURLKey}, " ", "-");

		var siteURLKey = StringUtil.lowerCase(${siteNameURL});

		Navigator.openWithAppendToBaseURL(
			baseURL = ${baseURL},
			urlAppend = "group/${siteURLKey}/~/control_panel/manage?p_p_id=com_liferay_journal_web_portlet_JournalPortlet");
	}

	@summary = "Default summary"
	macro openSiteURL(siteName = null) {
		var siteNameURL = StringUtil.replace(${siteName}, " ", "-");

		var siteNameURL = StringUtil.lowerCase(${siteNameURL});
		var baseURL = ${baseURL};

		if (!(isSet(baseURL))) {
			var baseURL = PropsUtil.get("portal.url");
		}

		Open(value1 = "${baseURL}/web/${siteNameURL}");
	}

	@summary = "Default summary"
	macro openSpecificURL(url = null) {
		Open(value1 = ${url});
	}

	@summary = "Default summary"
	macro openStagingSiteURL(siteName = null) {
		var siteNameURL = StringUtil.replace(${siteName}, " ", "-");

		var siteNameURL = StringUtil.lowerCase(${siteNameURL});

		Open(value1 = "/web/${siteNameURL}-staging");
	}

	@summary = "Default summary"
	macro openURL() {
		Open(value1 = "/web/guest/home");
	}

	@summary = "Default summary"
	macro openWithAppendToBaseURL(urlAppend = null) {
		var baseURL = ${baseURL};

		if (!(isSet(baseURL))) {
			var baseURL = PropsUtil.get("portal.url");
		}

		Open(value1 = "${baseURL}/${urlAppend}");
	}

	@summary = "Default summary"
	macro selectSpecificWindow(windowTitle = null) {
		SelectWindow(value1 = "title=${windowTitle}");
	}

}