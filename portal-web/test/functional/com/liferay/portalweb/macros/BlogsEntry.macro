	@summary = "Default summary"
	macro viewWithTrackbackURLPG(entryTitle2 = null, entryContent2 = null, entryTitle = null, entryContent = null) {
		BlogsEntry.viewPG(
			entryContent = ${entryContent},
			entryTitle = ${entryTitle});

		var key_entryContent = ${entryContent};
		var key_entryTitle = ${entryTitle};

		if (IsTextEqual(locator1 = "Blogs#ENTRY_COMMENTS_COUNT", value1 = 2)) {
			AssertTextEquals(
				locator1 = "Blogs#ENTRY_COMMENTS_COUNT",
				value1 = 2);
		}
		else {
			AssertTextEquals(
				locator1 = "Blogs#ENTRY_COMMENTS_COUNT",
				value1 = 1);
		}

		AssertClick(
			locator1 = "BlogsEntry#TITLE_LINK",
			value1 = ${entryTitle});

		AssertTextEquals(
			locator1 = "BlogsEntry#TITLE",
			value1 = ${entryTitle});

		AssertTextEquals(
			locator1 = "BlogsEntry#CONTENT",
			value1 = ${entryContent});

		AssertTextEquals(
			locator1 = "Comments#ENTRY_COUNT_PANEL",
			value1 = "1 Comments");

		AssertTextEquals(
			locator1 = "Comments#COMMENT_BODY",
			value1 = "[...] ${entryContent2} [...] Read More");

		AssertClick(
			locator1 = "Link#READ_MORE",
			value1 = "Read More");

		var key_entryContent = ${entryContent2};
		var key_entryTitle = ${entryTitle2};

		AssertTextEquals(
			locator1 = "BlogsEntry#TITLE",
			value1 = ${entryTitle2});

		AssertTextEquals(
			locator1 = "BlogsEntry#CONTENT",
			value1 = ${entryContent2});
	}

