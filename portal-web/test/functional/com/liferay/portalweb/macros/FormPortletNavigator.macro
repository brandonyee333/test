definition {

	@summary = "Default summary"
	macro clickFormContent() {
		Click(locator1 = "FormPortlet#FORM_CONTENT");
	}

	@summary = "Default summary"
	macro gotoSelectForm() {
		AssertClick.pauseMakeVisibleAssertTextEqualsClickAt(
			locator1 = "FormPortlet#SELECT_FORM",
			value1 = "Select Form");

		IFrame.selectDialogFrame();
	}

}