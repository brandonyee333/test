definition {

	@summary = "Default summary"
	macro subscribeViaInfoPanelPG() {
		Click(locator1 = "Icon#INFO");

		Click(locator1 = "Icon#SUBSCRIBE");

		Alert.viewSuccessMessage();
	}

	@summary = "Default summary"
	macro unsubscribeViaMySubscriptions() {
		AssertClick(
			locator1 = "Link#UNSUBSCRIBE",
			value1 = "Unsubscribe");

		Alert.viewSuccessMessage();
	}

	@summary = "Default summary"
	macro viewDefaultPG() {
		AssertTextEquals.assertPartialText(
			locator1 = "Message#INFO",
			value1 = "No subscriptions were found.");
	}

	@summary = "Default summary"
	macro viewSubscription(assetName = null, assetTitle = null, assetType = null) {
		var key_assetName = ${assetName};
		var key_assetTitle = ${assetTitle};
		var key_assetType = ${assetType};

		AssertTextEquals(
			locator1 = "MySubscriptions#ASSET_NAME",
			value1 = ${assetName});

		AssertTextEquals(
			locator1 = "MySubscriptions#ASSET_TITLE",
			value1 = ${assetTitle});

		AssertTextEquals(
			locator1 = "MySubscriptions#ASSET_TYPE",
			value1 = ${assetType});
	}

	@summary = "Default summary"
	macro viewUnsubscribedViaInfoPanel() {
		Click(locator1 = "Icon#INFO");

		AssertVisible(locator1 = "Icon#STAR_UNSUBSCRIBED");
	}

}