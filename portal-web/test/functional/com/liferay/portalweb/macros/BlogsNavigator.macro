definition {

	@summary = "Default summary"
	macro gotoAddEntry() {
		if (IsElementPresent(locator1 = "Blogs#ADD_BLOGS_ENTRY")) {
			AssertClick(
				locator1 = "Blogs#ADD_BLOGS_ENTRY",
				value1 = "Add Blog Entry");
		}
		else {
			LexiconEntry.gotoAdd();
		}

		AssertVisible(locator1 = "BlogsEntry#ENTRY_COVER_IMAGE_SELECT_FILE");
	}

	@summary = "Default summary"
	macro gotoBlogsEntriesPermissionsCP() {
		LexiconEntry.gotoHeaderMenuItem(menuItem = "Entries Permissions");

		IFrame.selectDialogFrame();
	}

	@summary = "Default summary"
	macro gotoBlogsEntryPermissionsCP(entryTitle = null) {
		LexiconEntry.gotoEntryMenuItem(
			menuItem = "Permissions",
			rowEntry = ${entryTitle});

		IFrame.selectDialogFrame();
	}

	@summary = "Default summary"
	macro gotoBlogsEntryPermissionsPG() {
		LexiconEntry.gotoEllipsisMenuItem(menuItem = "Permissions");

		IFrame.selectDialogFrame();
	}

	@summary = "Default summary"
	macro gotoBrowseImage() {
		Click(locator1 = "Button#BROWSE_IMAGE");
	}

	@summary = "Default summary"
	macro gotoConfigurationScopePG() {
		Navigator.gotoNavItem(navItem = "Scope");
	}

	@summary = "Default summary"
	macro gotoConfigurationSetupPG() {
		Portlet.gotoPortletOptions(portletOption = "Configuration");

		IFrame.selectDialogFrame();
	}

	@summary = "Default summary"
	macro gotoEditCP(entryTitle = null) {
		Portlet.changeDisplayStyle(displayStyle = "Descriptive");

		var key_entryTitle = ${entryTitle};

		AssertTextEquals(
			locator1 = "Blogs#DESCRIPTIVE_VIEW_ENTRY_TITLE",
			value1 = ${entryTitle});

		Click(locator1 = "Blogs#DESCRIPTIVE_VIEW_ENTRY_OPTIONS_DROPDOWN");

		MenuItem.click(menuItem = "Edit");

		AssertElementPresent(locator1 = "Icon#BACK");

		AssertVisible(locator1 = "AlloyEditor#TITLE_FIELD");
	}

	@summary = "Default summary"
	macro gotoEditPG(entryTitle = null) {
		var key_entryTitle = ${entryTitle};

		AssertTextEquals(
			locator1 = "BlogsEntry#TITLE",
			value1 = ${entryTitle});

		LexiconEntry.gotoEllipsisMenuItem(menuItem = "Edit");

		AssertVisible(locator1 = "BlogsEntry#ENTRY_COVER_IMAGE_SELECT_FILE");
	}

	@summary = "Default summary"
	macro gotoEntryCP(entryStatus = null, entryTitle = null) {
		Portlet.changeDisplayStyle(displayStyle = "Descriptive");

		var key_entryTitle = ${entryTitle};

		if (isSet(entryStatus)) {
			AssertTextEquals(
				locator1 = "Blogs#DESCRIPTIVE_VIEW_ENTRY_STATUS",
				value1 = ${entryStatus});
		}

		AssertClick(
			locator1 = "Blogs#DESCRIPTIVE_VIEW_ENTRY_TITLE",
			value1 = ${entryTitle});
	}

	@summary = "Default summary"
	macro gotoEntryPG(entryTitle = null, entryContent = null) {
		var key_entryContent = ${entryContent};
		var key_entryTitle = ${entryTitle};

		AssertTextEquals(
			locator1 = "BlogsEntry#TITLE",
			value1 = ${entryTitle});

		AssertTextEquals(
			locator1 = "BlogsEntry#CONTENT",
			value1 = ${entryContent});

		AssertClick(
			locator1 = "BlogsEntry#TITLE_LINK",
			value1 = ${entryTitle});
	}

	@summary = "Default summary"
	macro gotoEntryWithAbstractPG(entryAbstractDescription = null, entryTitle = null) {
		var key_entryAbstractDescription = ${entryAbstractDescription};
		var key_entryTitle = ${entryTitle};

		AssertTextEquals(
			locator1 = "BlogsEntry#TITLE",
			value1 = ${entryTitle});

		AssertTextEquals.assertPartialText(
			locator1 = "BlogsEntry#CONTENT_ABSTRACT",
			value1 = ${entryAbstractDescription});

		AssertClick(
			locator1 = "BlogsEntry#TITLE_LINK",
			value1 = ${entryTitle});
	}

	@summary = "Default summary"
	macro gotoPG(blogEntryURL = null, entryTitle = null) {
		var key_entryTitle = ${entryTitle};

		if (isSet(blogEntryURL)) {
			AssertLocation(value1 = ${blogEntryURL});
		}
		else {
			Click(locator1 = "BlogsEntry#TITLE_LINK");
		}

		AssertTextEquals(
			locator1 = "BlogsEntry#TITLE",
			value1 = ${entryTitle});
	}

	@summary = "Default summary"
	macro gotoSelectFile() {
		AssertClick(
			locator1 = "BlogsEntry#ENTRY_COVER_IMAGE_SELECT_FILE",
			value1 = "Select File");
	}

	@summary = "Default summary"
	macro moveToRecycleBinCP(entryTitle = null) {
		Portlet.changeDisplayStyle(displayStyle = "Descriptive");

		var key_entryTitle = ${entryTitle};

		AssertTextEquals(
			locator1 = "Blogs#DESCRIPTIVE_VIEW_ENTRY_TITLE",
			value1 = ${entryTitle});

		Click(locator1 = "Blogs#DESCRIPTIVE_VIEW_ENTRY_OPTIONS_DROPDOWN");

		PortletEntry.clickMoveToRecycleBin();

		AssertElementPresent(locator1 = "Message#SUCCESS");
	}

	@summary = "Default summary"
	macro openBlogsAdmin(siteURLKey = null) {
		Navigator.openWithAppendToBaseURL(urlAppend = "group/${siteURLKey}/~/control_panel/manage?p_p_id=com_liferay_blogs_web_portlet_BlogsAdminPortlet");
	}

}