definition {

	@summary = "Default summary"
	macro addDraft(entrySubtitle = null, entryTitle = null, entryContent = null) {
		BlogsNavigator.gotoAddEntry();

		BlogsEntry.addEntryContent(
			entryContent = ${entryContent},
			entrySubtitle = ${entrySubtitle},
			entryTitle = ${entryTitle});

		BlogsEntry.saveAsDraft();
	}

	@summary = "Default summary"
	macro addDraftViaAutoSave(entrySubtitle = null, entryTitle = null, entryContent = null) {
		BlogsNavigator.gotoAddEntry();

		BlogsEntry.addEntryContent(
			entryContent = ${entryContent},
			entrySubtitle = ${entrySubtitle},
			entryTitle = ${entryTitle});

		BlogsEntry.autoSaveDraft();
	}

	@summary = "Default summary"
	macro addEntry(entrySubtitle = null, entryTitle = null, entryContent = null) {
		BlogsNavigator.gotoAddEntry();

		BlogsEntry.addEntryContent(
			entryContent = ${entryContent},
			entrySubtitle = ${entrySubtitle},
			entryTitle = ${entryTitle});

		PortletEntry.publish();
	}

	@summary = "Default summary"
	macro addEntryWithCategory(entrySubtitle = null, vocabularyName = null, entryTitle = null, categoryName = null, entryContent = null) {
		BlogsNavigator.gotoAddEntry();

		BlogsEntry.addEntryContent(
			entryContent = ${entryContent},
			entrySubtitle = ${entrySubtitle},
			entryTitle = ${entryTitle});

		Panel.expandPanel(panelHeading = "Categorization");

		AssetCategorization.addCategory(
			categoryName = ${categoryName},
			vocabularyName = ${vocabularyName});

		PortletEntry.publish();
	}

	@summary = "Default summary"
	macro addEntryWithCoverImageFromDMFolders(dmSubFolderName = null, entrySubtitle = null, imageFileName = null, dmFolderName = null, entryTitle = null, entryContent = null) {
		BlogsNavigator.gotoAddEntry();

		AlloyEditor.addTitle(title = ${entryTitle});

		BlogsEntry.addEntryContent(
			entryContent = ${entryContent},
			entrySubtitle = ${entrySubtitle},
			entryTitle = ${entryTitle});

		BlogsNavigator.gotoSelectFile();

		ItemSelector.selectDMImage(
			dmFolderName = ${dmFolderName},
			dmSubFolderName = ${dmSubFolderName},
			imageFileName = ${imageFileName});

		Pause(value1 = 1000);

		PortletEntry.publish();
	}

	@summary = "Default summary"
	macro addEntryWithHTML(entrySubtitle = null, entryTitle = null, entryContent = null) {
		BlogsNavigator.gotoAddEntry();

		AlloyEditor.addTitle(title = ${entryTitle});

		BlogsEntry.addSubtitle(entrySubtitle = ${entrySubtitle});

		AlloyEditor.addSourceContent(content = ${entryContent});

		PortletEntry.publish();
	}

	@summary = "Default summary"
	macro addEntryWithImageViaLinkBrowseFromDM(imageFileName = null, entryTitle = null, entryContent = null) {
		BlogsNavigator.gotoAddEntry();

		BlogsEntry.addEntryContent(
			entryContent = ${entryContent},
			entryTitle = ${entryTitle});

		ItemSelector.gotoItemSelectorViaAlloyEditor();

		ItemSelector.selectDMImage(imageFileName = ${imageFileName});

		Pause(value1 = 1000);

		PortletEntry.publish();
	}

	@summary = "Default summary"
	macro addEntryWithPermissions(viewableBy = null, entrySubtitle = null, entryTitle = null, entryContent = null) {
		BlogsNavigator.gotoAddEntry();

		BlogsEntry.addEntryContent(
			entryContent = ${entryContent},
			entrySubtitle = ${entrySubtitle},
			entryTitle = ${entryTitle});

		Panel.expandPanel(panelHeading = "Permissions");

		BlogsEntry.entryAddPermissions(viewableBy = ${viewableBy});

		PortletEntry.publish();
	}

	@summary = "Default summary"
	macro addEntryWithTag(entrySubtitle = null, tagName = null, entryTitle = null, entryContent = null) {
		BlogsNavigator.gotoAddEntry();

		BlogsEntry.addEntryContent(
			entryContent = ${entryContent},
			entrySubtitle = ${entrySubtitle},
			entryTitle = ${entryTitle});

		Panel.expandPanel(panelHeading = "Categorization");

		AssetCategorization.addTag(tagName = ${tagName});

		PortletEntry.publish();
	}

	@summary = "Default summary"
	macro addEntryWithTags(entrySubtitle = null, tagNameList = null, entryTitle = null, entryContent = null) {
		BlogsNavigator.gotoAddEntry();

		BlogsEntry.addEntryContent(
			entryContent = ${entryContent},
			entrySubtitle = ${entrySubtitle},
			entryTitle = ${entryTitle});

		Panel.expandPanel(panelHeading = "Categorization");

		for (var tagName : list ${tagNameList}) {
			AssetCategorization.addTag(tagName = ${tagName});
		}

		PortletEntry.publish();
	}

	@summary = "Default summary"
	macro addEntryWithUploadedCoverImage(navTab = null, uploadFileName = null, coverImageName = null, entrySubtitle = null, entryTitle = null, entryContent = null) {
		BlogsNavigator.gotoAddEntry();

		BlogsNavigator.gotoSelectFile();

		ItemSelector.uploadFile(
			navTab = ${navTab},
			uploadFileName = ${uploadFileName});

		Pause(value1 = 5000);

		AlloyEditor.addTitle(title = ${entryTitle});

		BlogsEntry.addEntryContent(
			entryContent = ${entryContent},
			entrySubtitle = ${entrySubtitle},
			entryTitle = ${entryTitle});

		AssertVisible(
			key_coverImageName = ${coverImageName},
			locator1 = "BlogsEntry#ENTRY_COVER_IMAGE_UNPUBLISHED");
	}

	@summary = "Default summary"
	macro addViaAP(entryTitle = null, entryContent = null) {
		AssetPublisherPortlet.addAsset(assetType = "Blogs Entry");

		AlloyEditor.addTitleAndContent(
			content = ${entryContent},
			title = ${entryTitle});

		AssertClick(
			locator1 = "Button#PUBLISH",
			value1 = "Publish");

		SelectFrameTop(value1 = "relative=top");

		Pause(value1 = 5000);

		var key_assetTitle = ${entryTitle};

		AssertTextEquals(
			locator1 = "AP#ASSET_ABSTRACT_TITLE",
			value1 = ${entryTitle});

		AssertTextEquals.assertPartialText(
			locator1 = "AP#ASSET_ABSTRACT_DESCRIPTION",
			value1 = ${entryContent});
	}

	@summary = "Default summary"
	macro addViaAPSelectScope(entryTitle = null, entryContent = null) {
		AssetPublisherPortlet.addAsset(assetType = "Add Content (Select Scope and Type)");

		Select(
			locator1 = "Select#TYPE",
			value1 = "Blogs Entry");

		AssertClick(
			locator1 = "Button#ADD",
			value1 = "Add");

		AlloyEditor.addTitleAndContent(
			content = ${entryContent},
			title = ${entryTitle});

		AssertClick(
			locator1 = "Button#PUBLISH",
			value1 = "Publish");

		SelectFrameTop(value1 = "relative=top");

		Pause(value1 = 5000);

		var key_assetTitle = ${entryTitle};

		AssertTextEquals(
			locator1 = "AP#ASSET_ABSTRACT_TITLE",
			value1 = ${entryTitle});

		AssertTextEquals.assertPartialText(
			locator1 = "AP#ASSET_ABSTRACT_DESCRIPTION",
			value1 = ${entryContent});
	}

	@summary = "Default summary"
	macro addWithCustomAbstract(entrySubtitle = null, entryAbstractDescription = null, entryTitle = null, entryContent = null) {
		BlogsNavigator.gotoAddEntry();

		BlogsEntry.addEntryContent(
			entryContent = ${entryContent},
			entrySubtitle = ${entrySubtitle},
			entryTitle = ${entryTitle});

		Panel.expandPanel(panelHeading = "Configuration");

		BlogsEntry.addCustomAbstract(entryAbstractDescription = ${entryAbstractDescription});

		PortletEntry.publish();
	}

	@summary = "Default summary"
	macro addWithCustomAbstractViaAP(entryAbstractDescription = null, entryTitle = null, entryContent = null) {
		AssetPublisherPortlet.addAsset(assetType = "Blogs Entry");

		BlogsEntry.addEntryContent(
			entryContent = ${entryContent},
			entryTitle = ${entryTitle});

		Panel.expandPanel(panelHeading = "Configuration");

		BlogsEntry.addCustomAbstract(entryAbstractDescription = ${entryAbstractDescription});

		AssertClick(
			locator1 = "Button#PUBLISH",
			value1 = "Publish");
	}

	@summary = "Default summary"
	macro addWithDefaultAbstract(entrySubtitle = null, entryTitle = null, entryContent = null) {
		BlogsNavigator.gotoAddEntry();

		BlogsEntry.addEntryContent(
			entryContent = ${entryContent},
			entrySubtitle = ${entrySubtitle},
			entryTitle = ${entryTitle});

		Panel.expandPanel(panelHeading = "Configuration");

		AssertChecked(
			locator1 = "Radio#FIRST_400_ABSTRACT",
			value1 = "Use the first 400 characters of the entry content.");

		PortletEntry.publish();
	}

	@summary = "Default summary"
	macro addWithInvalidContent(entrySubtitle = null, entryInvalidContent = null, entryTitle = null) {
		BlogsNavigator.gotoAddEntry();

		BlogsEntry.addEntryContent(
			entryContent = ${entryInvalidContent},
			entrySubtitle = ${entrySubtitle},
			entryTitle = ${entryTitle});

		BlogsEntry.publishWithInvalidContent();
	}

	@summary = "Default summary"
	macro addWithInvalidTitle(entrySubtitle = null, entryInvalidTitle = null, entryContent = null) {
		BlogsNavigator.gotoAddEntry();

		BlogsEntry.addEntryContent(
			entryContent = ${entryContent},
			entrySubtitle = ${entrySubtitle},
			entryTitle = ${entryInvalidTitle});

		BlogsEntry.publishWithInvalidTitle();
	}

	@summary = "Default summary"
	macro addWithInvalidTitleLength(entrySubtitle = null, entryInvalidTitleLength = null, entryContent = null) {
		BlogsNavigator.gotoAddEntry();

		BlogsEntry.addEntryContent(
			entryContent = ${entryContent},
			entrySubtitle = ${entrySubtitle},
			entryTitle = ${entryInvalidTitleLength});

		BlogsEntry.publishWithInvalidTitleLength();
	}

	@summary = "Default summary"
	macro addWithWorkflow(entrySubtitle = null, entryTitle = null, entryContent = null) {
		BlogsNavigator.gotoAddEntry();

		BlogsEntry.addEntryContent(
			entryContent = ${entryContent},
			entrySubtitle = ${entrySubtitle},
			entryTitle = ${entryTitle});

		BlogsEntry.publishWithWorkflow();
	}

	@summary = "Default summary"
	macro addWithWorkflowViaAP(entryTitle = null, entryContent = null) {
		AssetPublisherPortlet.addAsset(assetType = "Blogs Entry");

		AlloyEditor.addTitleAndContent(
			content = ${entryContent},
			title = ${entryTitle});

		AssertClick(
			locator1 = "Button#SUBMIT_FOR_PUBLICATION",
			value1 = "Submit for Publication");

		Pause(value1 = 5000);

		SelectFrame(value1 = "relative=top");
	}

	@summary = "Default summary"
	macro disableSocialBookmarkSites() {
		Navigator.gotoPage(pageName = "Blogs Page");

		Portlet.gotoPortletOptions(
			portletName = "Blogs",
			portletOption = "Configuration");

		IFrame.selectDialogFrame();

		BlogsConfiguration.uncheckSocialBookmarks();

		PortletEntry.save();

		IFrame.selectTopFrame();
	}

	@summary = "Default summary"
	macro editDraftPG(entrySubtitleEdit = null, entrySubtitle = null, entryContentEdit = null, entryTitleEdit = null, entryTitle = null, entryContent = null) {
		BlogsNavigator.gotoEditPG(entryTitle = ${entryTitle});

		BlogsEntry.editEntryContent(
			entryContent = ${entryContent},
			entryContentEdit = ${entryContentEdit},
			entrySubtitle = ${entrySubtitle},
			entrySubtitleEdit = ${entrySubtitleEdit},
			entryTitle = ${entryTitle},
			entryTitleEdit = ${entryTitleEdit});

		AssertClick(
			locator1 = "Button#SAVE_AS_DRAFT",
			value1 = "Save as Draft");

		Alert.viewSuccessMessage();
	}

	@summary = "Default summary"
	macro editEntryPG(entrySubtitleEdit = null, entrySubtitle = null, entryContentEdit = null, entryTitleEdit = null, entryTitle = null, entryContent = null) {
		BlogsNavigator.gotoEditPG(entryTitle = ${entryTitle});

		BlogsEntry.editEntryContent(
			entryContent = ${entryContent},
			entryContentEdit = ${entryContentEdit},
			entrySubtitle = ${entrySubtitle},
			entrySubtitleEdit = ${entrySubtitleEdit},
			entryTitle = ${entryTitle},
			entryTitleEdit = ${entryTitleEdit});

		PortletEntry.publish();
	}

	@summary = "Default summary"
	macro enableSocialBookmarkSites(socialBookmarkSites = null) {
		Navigator.gotoPage(pageName = "Blogs Page");

		Portlet.gotoPortletOptions(
			portletName = "Blogs",
			portletOption = "Configuration");

		IFrame.selectDialogFrame();

		BlogsConfiguration.checkSocialBookmarks();

		for (var socialBookmarkSite : list ${socialBookmarkSites}) {
			BlogsConfiguration.enableSocialBookmarkSites(
				socialBookmarkSite = ${socialBookmarkSite},
				socialBookmarkSites = ${socialBookmarkSite});
		}

		PortletEntry.save();

		IFrame.selectTopFrame();
	}

	@summary = "Default summary"
	macro publishDraftCP(entrySubtitle = null, entryTitle = null, entryContent = null) {
		BlogsNavigator.gotoEditCP(entryTitle = ${entryTitle});

		BlogsEntry.viewEntry(
			entryContent = ${entryContent},
			entrySubtitle = ${entrySubtitle},
			entryTitle = ${entryTitle});

		PortletEntry.publish();
	}

	@summary = "Default summary"
	macro subscribePG() {
		AssertClick(
			locator1 = "Blogs#SUBSCRIBE_LINK",
			value1 = "Subscribe");

		Alert.viewSuccessMessage();
	}

	@summary = "Default summary"
	macro tearDownConfigurationDisplaySettingsPG(pageName = null) {
		Navigator.gotoPage(pageName = ${pageName});

		BlogsNavigator.gotoConfigurationSetupPG();

		BlogsConfiguration.selectDisplayTemplate(displayTemplate = "Abstract");

		PortletEntry.save();

		IFrame.selectTopFrame();
	}

	@summary = "Default summary"
	macro tearDownConfigurationScopePG(pageName = null) {
		Navigator.gotoPage(pageName = ${pageName});

		BlogsNavigator.gotoConfigurationSetupPG();

		BlogsNavigator.gotoConfigurationScopePG();

		BlogsConfiguration.selectScopePG(scopeSelection = "Liferay");
	}

	@summary = "Default summary"
	macro tearDownCP() {
		Navigator.openURL();

		ProductMenu.gotoPortlet(
			category = "Content",
			panel = "Site Administration",
			portlet = "Blogs");

		if (IsElementPresent.isVisible(locator1 = "Blogs#ENTRY_TABLE_ALL_CHECKBOX")) {
			Click(locator1 = "Blogs#ENTRY_TABLE_ALL_CHECKBOX");

			AssertClick(
				locator1 = "Button#MOVE_TO_THE_RECYCLE_BIN",
				value1 = "Move to the Recycle Bin");

			AssertElementPresent(locator1 = "Message#SUCCESS");
		}

		Navigator.openURL();

		ProductMenu.gotoPortlet(
			category = "Content",
			panel = "Site Administration",
			portlet = "Recycle Bin");

		RecycleBin.emptyCP();
	}

	@summary = "Default summary"
	macro tearDownSubscribePG(pageName = null) {
		Navigator.gotoPage(pageName = ${pageName});

		AssertClick(
			locator1 = "Link#UNSUBSCRIBE",
			value1 = "Unsubscribe");

		Alert.viewSuccessMessage();
	}

	@summary = "Default summary"
	macro viewControlsPG() {
		AssertTextEquals(
			locator1 = "Blogs#ADD_BLOGS_ENTRY",
			value1 = "Add Blog Entry");

		AssertTextEquals(
			locator1 = "Link#SUBSCRIBE",
			value1 = "Subscribe");

		AssertTextEquals(
			locator1 = "Link#RSS",
			value1 = "RSS");
	}

	@summary = "Default summary"
	macro viewNoEntryCP() {
		AssertTextEquals(
			locator1 = "Message#EMPTY_INFO",
			value1 = "No entries were found.");
	}

}