definition {

	@summary = "Basic Smoke test for the JSON WS API macros"
	macro runSmoke {

		// Add role

		JSONRole.addOrganizationRole(roleName = "organization role");

		JSONRole.addRegularRole(roleName = "regular role");

		JSONRole.addSiteRole(roleName = "site role");

		JSONRole.addOrganizationRole(
			roleKey = "organization role 2",
			roleName = "organization role 2");

		JSONRole.addRegularRole(
			roleKey = "regular role 2",
			roleName = "regular role 2");

		JSONRole.addSiteRole(
			roleKey = "site role 2",
			roleName = "site role 2");

		// User

		JSONRole.assignRoleToUser(
			roleName = "site role",
			userEmailAddress = "test@liferay.com");
	}

}