definition {

	@summary = "Default summary"
	macro addFile(dmDocumentTitle = null, groupName = null, dmDocumentDescription = null, folderName = null) {
		var portalURL = JSONCompany.getPortalURL();
		var repositoryId = JSONGroupAPI._getSiteIdByGroupKey(groupName = ${groupName});

		if (isSet(folderName)) {
			Variables.assertDefined(parameterList = "${folderName},${groupName}");

			var folderId = JSONDocumentAPI._getFolderIdByFolderName(
				groupName = ${groupName},
				name = ${folderName});
		}
		else {
			var folderId = 0;
		}

		var curl = '''
			${portalURL}/api/jsonws/dlapp/add-file-entry \
				-u test@liferay.com:test \
				-d repositoryId=${repositoryId} \
				-d folderId=${folderId} \
				-d sourceFileName='' \
				-d mimeType='' \
				-d title=${dmDocumentTitle} \
				-d description=${dmDocumentDescription} \
				-d changeLog='' \
				-d file=@path_to_file
		''';

		echo("## Adding a 'File' with the following info using JSONWS:");

		echo("## * Title: ${dmDocumentTitle}");

		echo("## * Description: ${dmDocumentDescription}");

		var messageId = JSONCurlUtil.post(${curl});
	}

	@summary = "Default summary"
	macro addFileWithUploadedFile(sourceFileName = null, dmDocumentDescription = null, mimeType = null, workflowAction = null, dmDocumentTitle = null, groupName = null, assetCategoryIds = null, assetTagNames = null, folderName = null) {
		Variables.assertDefined(parameterList = "${groupName},${mimeType},${sourceFileName}");

		var portalURL = JSONCompany.getPortalURL();
		var repositoryId = JSONGroupAPI._getSiteIdByGroupKey(groupName = ${groupName});

		if (isSet(folderName)) {
			Variables.assertDefined(parameterList = ${folderName});

			var folderId = JSONDocumentAPI._getFolderIdByFolderName(
				groupName = ${groupName},
				name = ${folderName});
		}
		else {
			var folderId = 0;
		}

		var baseDir = PropsUtil.get("test.base.dir.name");
		var dependenciesDir = PropsUtil.get("test.dependencies.dir.name");

		var filePath = "${baseDir}${dependenciesDir}/${sourceFileName}";

		if (isSet(dmDocumentDescription)) {
			var description = ${dmDocumentDescription};
		}
		else {
			var description = "";
		}

		var serviceContext = JSONDocumentSetter.setServiceContext(
			assetCategoryIds = ${assetCategoryIds},
			assetTagNames = ${assetTagNames},
			serviceContext = ${serviceContext},
			workflowAction = ${workflowAction});

		var curl = '''
			${portalURL}/api/jsonws/dlapp/add-file-entry \
				-u test@liferay.com:test \
				-F repositoryId=${repositoryId} \
				-F folderId=${folderId} \
				-F sourceFileName=${sourceFileName} \
				-F mimeType=${mimeType} \
				-F title=${dmDocumentTitle} \
				-F description=${description} \
				-F changeLog='' \
				-F file=@${filePath} \
				-F serviceContext=${serviceContext}
		''';

		echo("## Adding a 'File' with the following info using JSONWS:");

		echo("## * Title: ${dmDocumentTitle}");

		echo("## * Description: ${description}");

		var messageId = JSONCurlUtil.post(${curl});
	}

	@summary = "Default summary"
	macro addFolder(groupName = null, dmFolderDescription = null, dmFolderName = null) {
		var portalURL = JSONCompany.getPortalURL();

		if (!(isSet(site))) {
			var site = "true";
		}

		var repositoryId = JSONGroupAPI._getGroupIdByName(
			groupName = ${groupName},
			site = ${site});

		if (!(isSet(parentFolderId))) {
			var parentFolderId = 0;
		}

		var curl = '''
			${portalURL}/api/jsonws/dlapp/add-folder \
				-u test@liferay.com:test \
				-d repositoryId=${repositoryId} \
				-d parentFolderId=${parentFolderId} \
				-d name=${dmFolderName} \
				-d description=${dmFolderDescription} \
		''';

		echo("## Adding a 'Folder' with the following info using JSONWS:");

		echo("## * Name: ${dmFolderName}");

		echo("## * Description: ${dmFolderDescription}");

		var messageId = JSONCurlUtil.post(${curl});
	}

	@summary = "Default summary"
	macro deleteFile(dmDocumentTitle = null, groupName = null) {
		var portalURL = JSONCompany.getPortalURL();

		if (!(isSet(site))) {
			var site = "true";
		}

		var groupId = JSONGroupAPI._getGroupIdByName(
			groupName = ${groupName},
			site = ${site});

		if (!(isSet(folderId))) {
			var folderId = 0;
		}

		var curl = '''
			${portalURL}/api/jsonws/dlfileentry/delete-file-entry \
				-u test@liferay.com:test \
				-d groupId=${groupId} \
				-d folderId=${folderId} \
				-d title=${dmDocumentTitle}
		''';

		com.liferay.poshi.runner.util.JSONCurlUtil.post(${curl});
	}

	@summary = "Default summary"
	macro getFileEntryId(dmDocumentTitle = null, groupName = null) {
		if (!(isSet(portalURL))) {
			var portalURL = JSONCompany.getPortalURL();
		}

		if (!(isSet(site))) {
			var site = "true";
		}

		var groupId = JSONGroupAPI._getGroupIdByName(
			groupName = ${groupName},
			portalURL = ${portalURL},
			site = ${site});

		if (!(isSet(folderId))) {
			var folderId = 0;
		}

		var curl = '''
			${portalURL}/api/jsonws/dlfileentry/get-file-entry \
				-u test@liferay.com:test \
				-d groupId=${groupId} \
				-d folderId=${folderId} \
				-d title=${dmDocumentTitle}
		''';

		var fileEntryId = JSONCurlUtil.post(${curl}, "$.[?(@['title'] == '${dmDocumentTitle}')]['fileEntryId']");

		return ${fileEntryId};

		echo("## * File Entry ID: ${fileEntryId}");
	}

	@summary = "Default summary"
	macro getFileEntryUUID(dmDocumentTitle = null, groupName = null) {
		if (!(isSet(portalURL))) {
			var portalURL = JSONCompany.getPortalURL();
		}

		if (!(isSet(site))) {
			var site = "true";
		}

		var groupId = JSONGroupAPI._getGroupIdByName(
			groupName = ${groupName},
			portalURL = ${portalURL},
			site = ${site});

		if (!(isSet(folderId))) {
			var folderId = 0;
		}

		var curl = '''
			${portalURL}/api/jsonws/dlfileentry/get-file-entry \
				-u test@liferay.com:test \
				-d groupId=${groupId} \
				-d folderId=${folderId} \
				-d title=${dmDocumentTitle}
		''';

		var fileEntryUuid = JSONCurlUtil.post(${curl}, "$.[?(@['title'] == '${dmDocumentTitle}')]['uuid']");

		return ${fileEntryUuid};
	}

}