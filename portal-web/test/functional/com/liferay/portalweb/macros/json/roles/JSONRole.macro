definition {

	@summary = "Default summary"
	macro addOrganizationRole(roleName = null, roleKey = null, roleDescription = null) {
		Variables.assertDefined(parameterList = ${roleName});

		var descriptionMap = JSONRoleSetter.setDescriptionMap(description = ${roleDescription});
		var name = JSONRoleSetter.setName(name = ${roleName});
		var titleMap = JSONRoleSetter.setTitleMap(title = ${roleKey});
		var type = JSONRoleSetter.setType(roleType = "organization");

		JSONRoleAPI._addRole(
			descriptionMap = ${descriptionMap},
			name = ${name},
			titleMap = ${titleMap},
			type = ${type});
	}

	@summary = "Default summary"
	macro addRegularRole(roleName = null, roleKey = null, roleDescription = null) {
		Variables.assertDefined(parameterList = ${roleName});

		var descriptionMap = JSONRoleSetter.setDescriptionMap(description = ${roleDescription});
		var name = JSONRoleSetter.setName(name = ${roleName});
		var titleMap = JSONRoleSetter.setTitleMap(title = ${roleKey});
		var type = JSONRoleSetter.setType(roleType = "regular");

		JSONRoleAPI._addRole(
			descriptionMap = ${descriptionMap},
			name = ${name},
			titleMap = ${titleMap},
			type = ${type});
	}

	@summary = "Default summary"
	macro addSiteRole(roleName = null, roleKey = null, roleDescription = null) {
		Variables.assertDefined(parameterList = ${roleName});

		var descriptionMap = JSONRoleSetter.setDescriptionMap(description = ${roleDescription});
		var name = JSONRoleSetter.setName(name = ${roleName});
		var titleMap = JSONRoleSetter.setTitleMap(title = ${roleKey});
		var type = JSONRoleSetter.setType(roleType = "site");

		JSONRoleAPI._addRole(
			descriptionMap = ${descriptionMap},
			name = ${name},
			titleMap = ${titleMap},
			type = ${type});
	}

	@summary = "Default summary"
	macro assignRoleToUser(roleName = null, userEmailAddress = null) {
		Variables.assertDefined(parameterList = "${roleName},${userEmailAddress}");

		var roleId = JSONRoleSetter.setRoleId(name = ${roleName});
		var userId = JSONRoleSetter.setUserId(userEmailAddress = ${userEmailAddress});

		JSONRoleAPI._assignRoleToUser(
			roleId = ${roleId},
			userId = ${userId});
	}

	@summary = "Default summary"
	macro assignSiteRoleToUser(groupName = null, roleTitle = null, userEmailAddress = null) {
		Variables.assertDefined(parameterList = "${groupName},${roleTitle},${userEmailAddress}");

		var groupId = JSONUserSetter.setGroupId(groupName = ${groupName});
		var roleId = JSONRoleSetter.setRoleId(name = ${roleTitle});
		var userId = JSONRoleSetter.setUserId(userEmailAddress = ${userEmailAddress});

		JSONRoleAPI._assignSiteRoleToUser(
			groupId = ${groupId},
			roleId = ${roleId},
			userId = ${userId});
	}

}