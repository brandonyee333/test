definition {

	@summary = "Default summary"
	macro _addCategory(vocabularyId = null, groupId = null, parentCategoryId = null, descriptionMap = null, titleMap = null) {
		Variables.assertDefined(parameterList = "${groupId},${parentCategoryId},${titleMap},${descriptionMap},${vocabularyId}");

		var portalURL = JSONCompany.getPortalURL();

		var curl = '''
			${portalURL}/api/jsonws/assetcategory/add-category \
				-u test@liferay.com:test \
				-d groupId=${groupId} \
				-d parentCategoryId=${parentCategoryId} \
				-d titleMap=${titleMap} \
				-d descriptionMap=${descriptionMap} \
				-d vocabularyId=${vocabularyId} \
				-d categoryProperties=
		''';

		var categoryId = JSONCurlUtil.post(${curl}, "$.categoryId");

		var categoryId = StringUtil.replace(${categoryId}, "[\"", "");

		var categoryId = StringUtil.replace(${categoryId}, "\"]", "");

		return ${categoryId};
	}

	@summary = "Default summary"
	macro _addVocabulary(groupId = null, descriptionMap = null, titleMap = null) {
		Variables.assertDefined(parameterList = "${groupId},${titleMap},${descriptionMap}");

		var portalURL = JSONCompany.getPortalURL();

		var curl = '''
			${portalURL}/api/jsonws/assetvocabulary/add-vocabulary \
				-u test@liferay.com:test \
				-d groupId=${groupId} \
				-d title= \
				-d titleMap=${titleMap} \
				-d descriptionMap=${descriptionMap} \
				-d Settings=
		''';

		com.liferay.poshi.runner.util.JSONCurlUtil.post(${curl});
	}

	@summary = "Default summary"
	macro _getCategoryIdByName(vocabularyId = null, groupId = null, categoryName = null) {
		Variables.assertDefined(parameterList = "${groupId},${categoryName},${vocabularyId}");

		var portalURL = JSONCompany.getPortalURL();

		var curl = '''
			${portalURL}/api/jsonws/assetcategory/get-vocabulary-categories \
				-u test@liferay.com:test \
				-d groupId=${groupId} \
				-d name=${categoryName} \
				-d vocabularyId=${vocabularyId} \
				-d <CURL_DATA[start=-1]CURL_DATA> \
				-d <CURL_DATA[end=-1]CURL_DATA> \
				-d -obc=
		''';

		var categoryId = JSONCurlUtil.post(${curl}, "$.[?(@['titleCurrentValue'] == '${categoryName}')]['categoryId']");

		var categoryId = StringUtil.replace(${categoryId}, "[\"", "");

		var categoryId = StringUtil.replace(${categoryId}, "\"]", "");

		if (${categoryId} == "") {
			fail("FAIL. Cannot find category.");
		}

		return ${categoryId};
	}

	@summary = "Default summary"
	macro _getVocabularyIdByName(groupId = null, vocabularyName = null) {
		Variables.assertDefined(parameterList = "${groupId},${vocabularyName}");

		var portalURL = JSONCompany.getPortalURL();

		var curl = '''
			${portalURL}/api/jsonws/assetvocabulary/get-group-vocabularies \
				-u test@liferay.com:test \
				-d groupId=${groupId}
		''';

		var vocabularyId = JSONCurlUtil.post(${curl}, "$.[?(@['titleCurrentValue'] == '${vocabularyName}')]['vocabularyId']");

		var vocabularyId = StringUtil.replace(${vocabularyId}, "[\"", "");

		var vocabularyId = StringUtil.replace(${vocabularyId}, "\"]", "");

		if (${vocabularyId} == "") {
			fail("FAIL. Cannot find vocabulary.");
		}

		return ${vocabularyId};
	}

	@summary = "Default summary"
	macro _updateCategory(vocabularyId = null, parentCategoryId = null, descriptionMap = null, titleMap = null, categoryId = null) {
		Variables.assertDefined(parameterList = "${categoryId},${parentCategoryId},${titleMap},${descriptionMap},${vocabularyId}");

		var portalURL = JSONCompany.getPortalURL();

		var curl = '''
			${portalURL}/api/jsonws/assetcategory/update-category \
				-u test@liferay.com:test \
				-d categoryId=${categoryId} \
				-d parentCategoryId=${parentCategoryId} \
				-d titleMap=${titleMap} \
				-d descriptionMap=${descriptionMap} \
				-d vocabularyId=${vocabularyId} \
				-d categoryProperties=
		''';

		com.liferay.poshi.runner.util.JSONCurlUtil.post(${curl});
	}

}