	@summary = "Default summary"
	macro removeMemberCP(userLastName = null, userScreenName = null, userMiddleName = null, userFirstName = null) {
		var key_cardText = ${userScreenName};

		Type(
			locator1 = "TextInput#SEARCH",
			value1 = ${userScreenName});

		Click(locator1 = "Icon#BASIC_SEARCH");

		if (isSet(userMiddleName)) {
			AssertTextEquals.assertPartialText(
				locator1 = "Card#SPECIFIC_LARGE_TEXT",
				value1 = "${userFirstName} ${userMiddleName} ${userLastName}");
		}
		else {
			AssertTextEquals.assertPartialText(
				locator1 = "Card#SPECIFIC_LARGE_TEXT",
				value1 = "${userFirstName} ${userLastName}");
		}

		AssertTextEquals(
			locator1 = "Card#SPECIFIC_TEXT",
			value1 = ${userScreenName});

		LexiconEntry.gotoEntryMenuItemNoError(
			menuItem = "Remove Membership",
			rowEntry = ${userScreenName});

		Confirm.waitForConfirmation(value1 = "Are you sure you want to delete this? It will be deleted immediately.");

		Alert.viewSuccessMessage();
	}

	@summary = "Default summary"
	macro removeSiteRolesSiteOwnerUserGroupsCP(userGroupName = null) {
		var key_userGroupName = ${userGroupName};

		Navigator.gotoNavItem(navItem = "User Groups");

		Type(
			locator1 = "NavBar#BASIC_SEARCH_FIELD",
			value1 = ${userGroupName});

		Click(locator1 = "Button#SUBMIT");

		Click(locator1 = "Icon#DISPLAY_STYLE_LIST");

		AssertTextEquals(
			locator1 = "UserGroups#USER_GROUP_TABLE_NAME",
			value1 = ${userGroupName});

		LexiconEntry.openEntryMenu(rowEntry = ${userGroupName});

		MenuItem.click(menuItem = "Assign Site Roles");

		IFrame.selectDialogFrame();

		Uncheck(locator1 = "Checkbox#SITE_OWNER");

		SelectFrameTop();

		AssertClick(
			locator1 = "Button#DONE",
			value1 = "Done");

		Alert.viewSuccessMessage();
	}

