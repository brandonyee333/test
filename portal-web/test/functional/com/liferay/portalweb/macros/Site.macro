	@summary = "Default summary"
	macro inactivateCP(siteName = null) {
		AssertTextEquals(
			locator1 = "TextInput#NAME",
			value1 = ${siteName});

		AssertTextEquals(
			locator1 = "SitesEditSite#ACTIVE_LABEL",
			value1 = "Active");

		Uncheck.uncheckToggleSwitch(locator1 = "Checkbox#ACTIVE");

		PortletEntry.save();
	}

	@summary = "Default summary"
	macro joinViaMySitesPG(membershipType = null, siteName = null) {
		var key_siteName = ${siteName};

		AssertTextEquals(
			locator1 = "Message#EMPTY_INFO",
			value1 = "No sites were found.");

		Navigator.gotoNavItem(navItem = "Available Sites");

		Pause(locator1 = 3000);

		if (${membershipType} == "Private") {
			AssertElementNotPresent(
				key_itemName = ${siteName},
				locator1 = "ListGroupItem#ITEM_NAME");
		}
		else if (${membershipType} == "Restricted") {
			AssertTextEquals(
				key_itemName = ${siteName},
				locator1 = "ListGroupItem#ITEM_NAME",
				value1 = ${siteName});

			AssertTextEquals(
				key_itemName = ${siteName},
				locator1 = "ListGroupItem#ITEM_SUB_INFO",
				value1 = "Members: 1");

			LexiconEntry.gotoEntryMenuItemNoError(
				menuItem = "Request Membership",
				rowEntry = ${siteName});

			Type(
				locator1 = "TextArea#COMMENTS",
				value1 = "Please allow me to join the Restricted Site.");

			Button.clickSave();

			AssertTextEquals.assertPartialText(
				locator1 = "Message#SUCCESS_1",
				value1 = "Your request was sent. You will receive a reply by email.");

			Alert.viewSuccessMessage();

			MySites.viewMembershipRequested(siteName = ${siteName});
		}
		else {
			AssertTextEquals(
				key_itemName = ${siteName},
				locator1 = "ListGroupItem#ITEM_NAME",
				value1 = ${siteName});

			AssertTextEquals(
				key_itemName = ${siteName},
				locator1 = "ListGroupItem#ITEM_SUB_INFO",
				value1 = "Members: 1");

			LexiconEntry.gotoEntryMenuItemNoError(
				menuItem = "Join",
				rowEntry = ${siteName});

			Alert.viewSuccessMessage();

			AssertTextEquals(
				key_itemName = ${siteName},
				locator1 = "ListGroupItem#ITEM_NAME",
				value1 = ${siteName});

			AssertTextEquals(
				key_itemName = ${siteName},
				locator1 = "ListGroupItem#ITEM_SUB_INFO",
				value1 = "Members: 2");

			Click.waitForMenuToggleJSClick(
				key_rowEntry = ${siteName},
				locator1 = "Icon#ROW_VERTICAL_ELLIPSIS");

			AssertVisible(
				key_menuItem = "Leave",
				locator1 = "MenuItem#ANY_MENU_ITEM",
				value1 = "Leave");
		}
	}

	@summary = "Default summary"
	macro leaveViaMySitesPG(siteName = null) {
		AssertTextEquals(
			key_itemName = ${siteName},
			locator1 = "ListGroupItem#ITEM_NAME",
			value1 = ${siteName});

		AssertTextEquals(
			key_itemName = ${siteName},
			locator1 = "ListGroupItem#ITEM_SUB_INFO",
			value1 = "Members: 2");

		Navigator.gotoNavItem(navItem = "Available Sites");

		AssertTextEquals(
			key_itemName = ${siteName},
			locator1 = "ListGroupItem#ITEM_NAME",
			value1 = ${siteName});

		AssertTextEquals(
			key_itemName = ${siteName},
			locator1 = "ListGroupItem#ITEM_SUB_INFO",
			value1 = "Members: 2");

		LexiconEntry.gotoEntryMenuItem(
			menuItem = "Leave",
			rowEntry = ${siteName});

		Alert.viewSuccessMessage();

		AssertTextEquals(
			key_itemName = ${siteName},
			locator1 = "ListGroupItem#ITEM_NAME",
			value1 = ${siteName});

		AssertTextEquals(
			key_itemName = ${siteName},
			locator1 = "ListGroupItem#ITEM_SUB_INFO",
			value1 = "Members: 1");

		Click.waitForMenuToggleJSClick(
			key_rowEntry = ${siteName},
			locator1 = "Icon#ROW_VERTICAL_ELLIPSIS");

		AssertVisible(
			key_menuItem = "Join",
			locator1 = "MenuItem#ANY_MENU_ITEM",
			value1 = "Join");
	}

	@summary = "Default summary"
	macro limitMembership(siteLimitMembership = null) {
		if (${siteLimitMembership} == "Yes") {
			Check.checkToggleSwitch(locator1 = "SitesEditSite#PARENT_SITE_LIMIT_MEMBERSHIP_CHECKBOX");
		}
		else if (${siteLimitMembership} == "No") {
			Uncheck.uncheckToggleSwitch(locator1 = "SitesEditSite#PARENT_SITE_LIMIT_MEMBERSHIP_CHECKBOX");
		}

		PortletEntry.save();
	}

	@summary = "Default summary"
	macro manageMembershipOptions(membershipType = null, selectMembershipType = null, allowManualMembershipManagement = null) {
		ProductMenu.gotoPortlet(
			category = "Configuration",
			panel = "Site Administration",
			portlet = "Site Settings");

		if (${selectMembershipType} == "true") {
			AssertTextEquals(
				locator1 = "SitesEditSite#MEMBERSHIP_OPTIONS_MEMBERSHIP_TYPE_LABEL",
				value1 = "Membership Type");

			Select(
				locator1 = "SitesEditSite#MEMBERSHIP_OPTIONS_MEMBERSHIP_TYPE",
				value1 = ${membershipType});
		}

		if (${allowManualMembershipManagement} == "true") {
			Check.checkToggleSwitch(locator1 = "Checkbox#ALLOW_MANUAL_MEMBERSHIP_MANAGEMENT");
		}
		else if (${allowManualMembershipManagement} == "false") {
			Uncheck.uncheckToggleSwitch(locator1 = "Checkbox#ALLOW_MANUAL_MEMBERSHIP_MANAGEMENT");
		}

		PortletEntry.save();
	}

