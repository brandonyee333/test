	@summary = "Default summary"
	macro searchMemberCP(userLastNameSearchValue = null, userScreenNameSearchValue = null, userEmailAddressSearchValue = null, userLastName = null, userScreenName = null, userFirstNameSearchValue = null, userFirstName = null) {
		if (isSet(userScreenNameSearchValue)) {
			Type(
				locator1 = "TextInput#SEARCH",
				value1 = ${userScreenNameSearchValue});
		}
		else if (isSet(userFirstNameSearchValue)) {
			Type(
				locator1 = "TextInput#SEARCH",
				value1 = ${userFirstNameSearchValue});
		}
		else if (isSet(userLastNameSearchValue)) {
			Type(
				locator1 = "TextInput#SEARCH",
				value1 = ${userLastNameSearchValue});
		}
		else {
			Type(
				locator1 = "TextInput#SEARCH",
				value1 = ${userEmailAddressSearchValue});
		}

		Click(locator1 = "Icon#BASIC_SEARCH");

		Site.viewMemberCP(
			userFirstName = ${userFirstName},
			userLastName = ${userLastName},
			userScreenName = ${userScreenName});
	}

	@summary = "Default summary"
	macro searchMembershipCP(emptyResults = null, searchValue = null) {
		Type(
			locator1 = "TextInput#SEARCH",
			value1 = ${searchValue});

		Click(locator1 = "Icon#BASIC_SEARCH");

		if (${emptyResults} == "true") {
			AssertElementPresent(locator1 = "Message#EMPTY_INFO");
		}
		else {
			AssertElementPresent(locator1 = "Card#GENERIC_LARGE_TEXT");

			var cardText = StringUtil.unquote(${searchValue});

			AssertTextEquals(
				key_cardText = ${cardText},
				locator1 = "Card#SPECIFIC_LARGE_TEXT",
				value1 = ${cardText});
		}
	}

	@summary = "Default summary"
	macro selectPageType(checkPropagation = null, siteTemplate = null, selectPrivatePages = null, selectPublicPages = null) {
		Panel.expandPanel(panelHeading = "Pages");

		if (${selectPublicPages} == "true") {
			Select(
				locator1 = "SitesEditSite#PAGES_PUBLIC_PAGES_SITE_TEMPLATE_SELECT",
				value1 = ${siteTemplate});
		}
		else if (${selectPrivatePages} == "true") {
			Select(
				locator1 = "SitesEditSite#PAGES_PRIVATE_PAGES_SITE_TEMPLATE_SELECT",
				value1 = ${siteTemplate});

			if (${checkPropagation} == "true") {
				Panel.expandPanel(panelHeading = "Pages");

				Check.checkToggleSwitch(locator1 = "Checkbox#PRIVATE_PAGES_ENABLE_PROPAGATION");
			}
		}

		PortletEntry.save();
	}

	@summary = "Default summary"
	macro selectParentSite(parentSiteName = null, chooseButtonAvailable = null) {
		AssertClick(
			locator1 = "SitesEditSite#PARENT_SITE_SELECT",
			value1 = "Select");

		var key_parentSiteName = ${parentSiteName};

		SelectFrame(locator1 = "SitesSelectSite#SELECT_SITE_IFRAME");

		Type(
			locator1 = "NavBar#BASIC_SEARCH_FIELD",
			value1 = ${parentSiteName});

		Click(locator1 = "Icon#BASIC_SEARCH");

		if (${chooseButtonAvailable} == "false") {
			AssertTextNotPresent(
				locator1 = "SitesSelectSite#SITES_TABLE_NAME",
				value1 = ${parentSiteName});

			AssertTextEquals(
				locator1 = "Message#EMPTY_INFO",
				value1 = "No sites were found.");
		}

		Close(locator1 = "null");

		SelectFrame(value1 = "relative=top");
	}

	@summary = "Default summary"
	macro tearDownCP() {
		ProductMenu.gotoPortlet(
			category = "Sites",
			panel = "Control Panel",
			portlet = "Sites");

		Type(
			locator1 = "NavBar#BASIC_SEARCH_FIELD",
			value1 = "Name");

		Click(locator1 = "Icon#BASIC_SEARCH");

		if (IsElementNotPresent(locator1 = "Message#EMPTY_INFO")) {
			Check.checkAll(locator1 = "Checkbox#SELECT_ALL");

			ClickNoError(locator1 = "Icon#DELETE");

			Confirm(value1 = "Are you sure you want to delete this? It will be deleted immediately.");

			Alert.viewSuccessMessage();
		}
	}

	@summary = "Default summary"
	macro viewCannotAdd(siteNameInvalid = null, siteName = null) {
		LexiconEntry.gotoAddMenuItem(menuItem = "Blank Site");

		PortletEntry.inputName(name = ${siteName});

		Click(locator1 = "Button#SAVE");

		if (${siteNameInvalid} == "Duplicate") {
			Alert.viewRequestFailedToComplete();

			AssertTextEquals.assertPartialText(
				locator1 = "Message#ERROR_2",
				value1 = "Please enter a unique name.");
		}
		else if (${siteNameInvalid} == "Null") {
			Alert.viewErrorMessage(errorMessage = "Your request failed to complete.");

			Alert.viewSecondErrorMessage(errorMessage = "The Site Name cannot be blank, numeric or a reserved word such as null. The Site Name cannot contain the following invalid characters: *.");

			AssertTextEquals(
				locator1 = "Message#REQUIRED_INFO",
				value1 = "This field is required.");
		}
		else {
			Alert.viewRequestFailedToComplete();

			AssertTextEquals.assertPartialText(
				locator1 = "Message#ERROR_2",
				value1 = "The Site Name cannot be blank, numeric or a reserved word such as null.");

			AssertTextEquals.assertPartialText(
				locator1 = "Message#ERROR_2",
				value1 = "The Site Name cannot contain the following invalid characters: *.");
		}
	}

	@summary = "Default summary"
	macro viewChildCP(siteName = null, childSiteName = null) {
		Site.viewCP(siteName = ${siteName});

		LexiconEntry.gotoEntryMenuItem(
			menuItem = "View Child Sites",
			rowEntry = ${siteName});

		Breadcrumb.viewActiveEntry(breadcrumbName = ${siteName});

		Site.viewCP(siteName = ${childSiteName});
	}

	@summary = "Default summary"
	macro viewCP(siteMember = null, siteName = null, siteType = null) {
		var key_siteName = ${siteName};

		AssertElementPresent(locator1 = "Sites#SITE_TABLE_CHECKBOX");

		AssertTextEquals.assertPartialText(
			locator1 = "Sites#SITE_TABLE_NAME",
			value1 = ${siteName});

		AssertTextEquals(
			locator1 = "Sites#SITE_TABLE_TYPE",
			value1 = ${siteType});

		if (${siteMember} == "User") {
			AssertTextEquals(
				locator1 = "Sites#SITE_TABLE_MEMBERS_USERS",
				value1 = "1 ${siteMember}");
		}

		AssertTextEquals(
			locator1 = "Sites#SITE_TABLE_ACTIVE",
			value1 = "Yes");

		AssertElementPresent(locator1 = "Sites#SITE_TABLE_ACTIONS");
	}

	@summary = "Default summary"
	macro viewCurrentLanguagesCP(displaySettings = null, currentSiteLanguages = null, availableSiteLanguages = null) {
		var key_displaySettings = ${displaySettings};

		if (IsNotVisible(locator1 = "SiteSettingsDisplaySettings#DEFINE_DEFAULT_AND_AVAILABLE_SITE_LANGUAGES_RADIO")) {
			Navigator.gotoNavTab(navTab = "Languages");
		}

		Check(
			locator1 = "SiteSettingsDisplaySettings#DEFINE_DEFAULT_AND_AVAILABLE_SITE_LANGUAGES_RADIO",
			value1 = "Display Settings");

		for (var currentSiteLanguage : list ${currentSiteLanguages}) {
			var currentSiteLanguage = ${currentSiteLanguage};

			AssertTextEquals.assertPartialText(
				locator1 = "LanguageConfiguration#LANGUAGES_CURRENT",
				value1 = ${currentSiteLanguage});
		}

		for (var availableSiteLanguage : list ${availableSiteLanguages}) {
			var availableSiteLanguage = ${availableSiteLanguage};

			AssertTextEquals.assertPartialText(
				locator1 = "LanguageConfiguration#LANGUAGES_AVAILABLE",
				value1 = ${availableSiteLanguage});
		}

		if (isSet(defaultSiteLanguage)) {
			var defaultSiteLanguage = ${defaultSiteLanguage};

			Select(
				locator1 = "LanguageConfiguration#DEFAULT_LANGUAGE_SELECT",
				value1 = ${defaultSiteLanguage});
		}
	}

