	@summary = "Default summary"
	macro assignUserAsMemberCP(userLastName = null, userScreenName = null, userMiddleName = null, userFirstName = null) {
		var key_cardText = ${userScreenName};

		LexiconEntry.gotoAdd();

		AssertVisible(locator1 = "Button#DONE");

		IFrame.selectDialogFrame();

		if (isSet(userMiddleName)) {
			AssertTextEquals(
				locator1 = "Card#SPECIFIC_LARGE_TEXT",
				value1 = "${userFirstName} ${userMiddleName} ${userLastName}");
		}
		else if (IsElementNotPresent(locator1 = "Card#SPECIFIC_LARGE_TEXT")) {
			var searchTerm = ${userFirstName};

			Search.searchCP(searchTerm = ${searchTerm});

			AssertTextEquals(
				locator1 = "Card#SPECIFIC_LARGE_TEXT",
				value1 = "${userFirstName} ${userLastName}");
		}
		else {
			AssertTextEquals(
				locator1 = "Card#SPECIFIC_LARGE_TEXT",
				value1 = "${userFirstName} ${userLastName}");
		}

		AssertTextEquals(
			locator1 = "Card#SPECIFIC_TEXT",
			value1 = ${userScreenName});

		Check(locator1 = "Card#SPECIFIC_CHECKBOX");

		SelectFrameTop();

		Button.clickDone();

		Alert.viewSuccessMessage();
	}

