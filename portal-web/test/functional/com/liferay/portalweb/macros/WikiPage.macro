	@summary = "Default summary"
	macro editFrontPagePG(wikiPageContentEdit = null) {
		AssertClick(
			locator1 = "Link#EDIT",
			value1 = "Edit");

		Pause(locator1 = 3000);

		AlloyEditor.addContent(content = ${wikiPageContentEdit});

		AssertClick(
			locator1 = "Button#PUBLISH",
