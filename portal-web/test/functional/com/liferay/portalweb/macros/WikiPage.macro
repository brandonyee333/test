		var key_wikiChildPageTitle = ${wikiChildPageTitle};

		AlloyEditor.addTitleAndContent(
			content = ${wikiChildPageContent},
			title = ${wikiChildPageTitle});

		Click(locator1 = "Button#PUBLISH");

