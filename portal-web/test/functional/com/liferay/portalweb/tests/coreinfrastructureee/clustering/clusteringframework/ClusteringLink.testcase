@component-name = "portal-performance-and-fault-tolerance-ee"
definition {

	property portal.release = "true";
	property portal.upstream = "true";
	property testray.main.component.name = "Clustering";

	setUp {
		TestCase.setUpPortalInstance();

		User.firstLoginPG();
	}

	tearDown {
		var testLiferayVirtualInstance = PropsUtil.get("test.liferay.virtual.instance");

		if (${testLiferayVirtualInstance} == "true") {
			PortalInstances.tearDownCP();
		}
		else {
			Page.tearDownPG();

			BlogsEntry.tearDownCP();
		}
	}

	@priority = 5
	test ClusteringLinkPortalProperties {
		property custom.properties = "cluster.link.enabled=false";
		property test.liferay.virtual.instance = "false";

		AssertConsoleTextNotPresent(value1 = "channelName: liferay-channel-control");

		Portlet.shutdownServer();

		AntCommand(
			locator1 = "build-test.xml",
			value1 = "portal-ext-properties-update -Dupdate.properties=\"cluster.link.enabled=true\" -Dupdate.properties.original=\"cluster.link.enabled=false\"");

		Portlet.startServer(deleteLiferayHome = "false");

		Portlet.assertServerStartup();

		AssertConsoleTextPresent(value1 = "channelName: liferay-channel-control");

		AssertConsoleTextPresent(value1 = "channelName: liferay-channel-transport-0");

		Portlet.shutdownServer();

		AntCommand(
			locator1 = "build-test.xml",
			value1 = "portal-ext-properties-update -Dadd.new.properties=true -Dupdate.properties=\"cluster.link.channel.name.control=test-control-channel\"");

		AntCommand(
			locator1 = "build-test.xml",
			value1 = "portal-ext-properties-update -Dadd.new.properties=true -Dupdate.properties=\"cluster.link.channel.name.transport.0=test-transport-channel\"");

		Portlet.startServer(deleteLiferayHome = "false");

		Portlet.assertServerStartup();

		AssertConsoleTextPresent(value1 = "channelName: test-control-channel");

		AssertConsoleTextPresent(value1 = "channelName: test-transport-channel");

		Portlet.shutdownServer();

		AntCommand(
			locator1 = "build-test.xml",
			value1 = "portal-ext-properties-update -Dadd.new.properties=true -Dupdate.properties=\"cluster.link.channel.properties.control=tcp.xml\"");

		Portlet.startServer(deleteLiferayHome = "false");

		Portlet.assertServerStartup();

		AssertConsoleTextPresent(value1 = "Create a new JGroups channel");

		AssertConsoleTextPresent(value1 = "properties: TCP");

		Portlet.shutdownServer();

		AntCommand(
			locator1 = "build-test.xml",
			value1 = "portal-ext-properties-update -Dupdate.properties=\"cluster.link.channel.properties.transport.0=tcp.xml\" -Dupdate.properties.original=\"cluster.link.channel.properties.control=tcp.xml\"");

		Portlet.startServer(deleteLiferayHome = "false");

		Portlet.assertServerStartup();

		AssertConsoleTextPresent(value1 = "Create a new JGroups channel");

		AssertConsoleTextPresent(value1 = "properties: TCP");

		AssertConsoleTextPresent(value1 = "Autodetecting JGroups outgoing IP address and interface for www.google.com:80");

		var ipAddress = Clustering.getClusterNodeOutgoingIPAddress(nodePort = 8080);

		Portlet.shutdownServer();

		AntCommand(
			locator1 = "build-test.xml",
			value1 = "portal-ext-properties-update -Dupdate.properties=\"cluster.link.autodetect.address=\" -Dupdate.properties.original=\"cluster.link.channel.properties.transport.0=tcp.xml\"");

		Portlet.startServer(deleteLiferayHome = "true");

		Portlet.assertServerStartup();

		AssertConsoleTextPresent(value1 = "bind_addr=127.0.0.1");

		AssertConsoleTextNotPresent(value1 = "Autodetecting JGroups outgoing IP address and interface for www.google.com:80");

		Portlet.shutdownServer();

		AntCommand(
			locator1 = "build-test.xml",
			value1 = "portal-ext-properties-update -Dadd.cluster.link.properties=true -Dadd.new.properties=true -Dcluster.node.ip.address=${ipAddress}");

		Portlet.startServer(deleteLiferayHome = "false");

		Portlet.assertServerStartup();

		AssertConsoleTextPresent(value1 = "bind_addr=${ipAddress}");
	}

}