@component-name = "portal-clustering"
definition {
	property app.server.bundles.size = "1";
	property cluster.enabled = "true";
	property portal.release = "true";
	property portal.upstream = "true";
	property remote.elasticsearch.enabled = "true";
	property testray.main.component.name = "Clustering";

	setUp {
		TestCase.setUpPortalInstance();

		User.firstLoginPG();
	}

	tearDown {
		var testPortalInstance = PropsUtil.get("test.portal.instance");

		if ("${testPortalInstance}" == "true") {
			PortalInstances.tearDownCP();
		}
		else {
			Page.tearDownCP();

			BlogsEntry.tearDownCP();
		}
	}

	@priority = "3"
	test ScheduleJobOnClusterNode1 {
		property custom.properties = "cluster.link.enabled=true";
		property test.name.skip.portal.instance = "ClusteringScheduleJob#ScheduleJobOnClusterNode1";

		Clustering.viewClusterStatusInConsole();

		Clustering.enableDebugging(
			nodePort = "8080"
		);

		Clustering.enableDebugging(
			nodePort = "9080"
		);

		Clustering.deployJarOnSpecificServer(
			liferayDependencyJars = "com.liferay.cluster.test.module.jar",
			nodePort = "8080"
		);

		Clustering.viewTextPresentOnSpecificNode(
			exceptionText = "Memory clustered job from modules is triggered at 1502232826800",
			nodePort = "8080"
		);

		Clustering.shutdownSpecificServer(nodePort = "8080");

		Clustering.runGroovyScript(
			nodePort = "9080",
			scriptFile = "groovy-script-master-slave.groovy"
		);

		Clustering.viewTextPresentOnSpecificNode(
			expectedText = "This node is master node",
			nodePort = "9080"
		);

		Clustering.viewTextNotPresentOnSpecificNode(
			exceptionText = "Memory clustered job from modules is triggered at 1502232826800",
			nodePort = "9080"
		);

		Clustering.deployJarOnSpecificServer(
			liferayDependencyJars = "com.liferay.cluster.test.module.jar",
			nodePort = "9080"
		);

		Clustering.viewTextPresentOnSpecificNode(
			expectedText = "Scheduler job com.liferay.cluster.test.module.internel.SchedulerTestMessageListener.com.liferay.cluster.test.module.internel.SchedulerTestMessageListener already exists",
			nodePort = "9080"
		);

		Clustering.viewTextPresentOnSpecificNode(
			expectedText = "Memory clustered job from modules is triggered at 1502232826800",
			nodePort = "9080"
		);
	}

	@priority = "3"
	test ScheduleJobOnAllClusterNode {
		property custom.properties = "cluster.link.enabled=true";
		property test.name.skip.portal.instance = "ClusteringScheduleJob#ScheduleJobOnAllClusterNode";

		Clustering.viewClusterStatusInConsole();

		Clustering.enableDebugging(
			nodePort = "8080"
		);

		Clustering.enableDebugging(
			nodePort = "9080"
		);

		Clustering.runGroovyScript(
			nodePort = "8080",
			scriptFile = "groovy-script-master-slave.groovy"
		);

		Clustering.viewTextPresentOnSpecificNode(
			expectedText = "This node is master node",
			nodePort = "8080"
		);

		Clustering.runGroovyScript(
			nodePort = "9080",
			scriptFile = "groovy-script-master-slave.groovy"
		);

		Clustering.viewTextPresentOnSpecificNode(
			expectedText = "This node is slave node",
			nodePort = "9080"
		);

		Clustering.deployJarOnSpecificServer(
			liferayDependencyJars = "com.liferay.cluster.test.module.jar",
			nodePort = "9080"
		);

		Clustering.viewTextNotPresentOnSpecificNode(
			exceptionText = "Memory clustered job from modules is triggered at 1502232826800",
			nodePort = "8080"
		);

		Clustering.viewTextNotPresentOnSpecificNode(
			exceptionText = "Memory clustered job from modules is triggered at 1502232826800",
			nodePort = "9080"
		);

		Clustering.deployJarOnSpecificServer(
			liferayDependencyJars = "com.liferay.cluster.test.module.jar",
			nodePort = "8080"
		);

		Clustering.viewTextPresentOnSpecificNode(
			expectedText = "Memory clustered job from modules is triggered at 1502232826800",
			nodePort = "8080"
		);

		Clustering.shutdownSpecificServer(nodePort = "8080");

		Clustering.runGroovyScript(
			nodePort = "9080",
			scriptFile = "groovy-script-master-slave.groovy"
		);

		Clustering.viewTextPresentOnSpecificNode(
			expectedText = "This node is master node",
			nodePort = "9080"
		);

		Clustering.viewTextPresentOnSpecificNode(
			exceptionText = "Memory clustered job from modules is triggered at 1502232826800",
			nodePort = "9080"
		);
	}
}