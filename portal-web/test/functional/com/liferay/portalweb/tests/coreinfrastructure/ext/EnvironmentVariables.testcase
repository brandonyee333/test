@component-name = "portal-util-misc"
definition {

	property portal.release = "true";
	property portal.upstream = "true";
	property testray.main.component.name = "Ext";

	setUp {
		TestCase.setUpPortalInstance();

		User.firstLoginPG();
	}

	tearDown {
		var testPortalInstance = PropsUtil.get("test.portal.instance");

		if ("${testPortalInstance}" == "true") {
			PortalInstances.tearDownCP();
		}
	}

	@priority = "4"
	test ConfigurePortalExtPropertyViaJVM {
		property test.environment.variables = "LIFERAY_PROPS_BY_COMPANY_20097=feature.flag.COMMERCE-8087=true${line.separator}CATALINA_OPTS=\"$CATALINA_OPTS -Dcompany-id-properties=true\"";

		ImportExport.openImportExportAdmin();

		ImportExport.gotoImport();
	}

	@priority = "4"
	test ConfigurePortalExtPropertyViaSystemExt {
		property custom.system.properties = "company-id-properties=true";
		property test.environment.variables = "LIFERAY_PROPS_BY_COMPANY_20097=feature.flag.COMMERCE-8087=true";

		ImportExport.openImportExportAdmin();

		ImportExport.gotoImport();
	}

}