@component-name = "portal-scheduler"
definition {

	property ci.retries.disabled = "true";
	property portal.release = "true";
	property portal.upstream = "true";
	property testray.main.component.name = "Scheduler";

	setUp {
		TestCase.setUpPortalInstance();

		User.firstLoginPG();
	}

	tearDown {
		var testPortalInstance = PropsUtil.get("test.portal.instance");

		if (${testPortalInstance} == "true") {
			PortalInstances.tearDownCP();
		}
	}

	@priority = 3
	test CanStartPortalWithSchedulerDisabled {
		property custom.properties = "scheduler.enabled=false";
		property test.assert.warning.exceptions = "true";

		Navigator.openURL();

		ProductMenu.gotoPortlet(
			category = "Content & Data",
			portlet = "Web Content");
	}

	@description = "This is a use case for LPS-167717. Verify triggering one scheduled job does not trigger all jobs."
	@priority = 4
	test TriggeringOneJobDoesNotTriggerAllJobs {
		property test.assert.warning.exceptions = "true";

		task ("Given several job triggers") {
			FileInstall.deployFileOnServer(jarFile = "test-scheduler-job.war");

			WaitForConsoleTextPresent(value1 = "STARTED test-scheduler-job");
		}

		task ("When the user triggers one of the jobs") {
			JobScheduler.openJobSchedulerAdmin();

			Navigator.gotoNavTab(navTab = "Scheduled Jobs");

			Pagination.changePagination(itemsPerPage = 60);

			Click(
				key_name = "Test1",
				locator1 = "JobScheduler#RUN_NOW_BUTTON");
		}

		task ("Then only that job is triggered") {
			WaitForConsoleTextPresent(value1 = "Trigger 1");

			AssertConsoleTextNotPresent(value1 = "Trigger 2");
		}
	}

}