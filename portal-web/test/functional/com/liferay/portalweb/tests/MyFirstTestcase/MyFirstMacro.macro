definition {

	macro login {
		Open(locator1 = "http://localhost:8080");

		AssertClick(
			locator1 = "JCLogin#USER_LOGIN_PAGE_FIELD",
			value1 = "Sign In");

		Type(
			locator1 = "JCLogin#EMAIL_ADDRESS_FIELD",
			value1 = "${userEmailAddress}");

		Type(
			locator1 = "JCLogin#PASSWORD_FIELD",
			value1 = "{$userPassWord}");

		var buttonName = "Sign In";
		AssertClick(
			locator1 = "JCLogin#USER_LOGIN_PORTLET_BUTTON_FIELD",
			value1 = "${buttonName}");

		var buttonName = "I Agree";
		AssertClick(
			locator1 = "JCTermsOfUse#TERMS_AGREE_FIELD",
			value1 = "${buttonName}");

		Type(
			locator1 = "JCPasswordReminder#PASSWORD_REMINDER_FIELD",
			value1 = "test");

		var buttonName = "Save";
		AssertClick(
			locator1 = "JCPasswordReminder#PASSWORD_REMINDER_SAVE_FIELD",
			value1 = "${buttonName}");
	}

	macro viewLogin {
		AssertElementPresent(locator1 = "JCWelcome#USER_ICON");
	}
}