@component-name = "portal-lima"
definition {

	property testray.main.component.name = "Blogs";

	setUp {
		TestCase.setUpPortalInstance();

		User.firstLoginPG();

		Navigator.openURL();
	}

	tearDown {
		var testPortalInstance = PropsUtil.get("test.portal.instance");

		if (${testPortalInstance} == "true") {
			PortalInstances.tearDownCP();
		}
	}

	@description = "Can Create a Blog"
	@priority = 5
	test CanCreateBlog {
		task ("Given Go to Blogs Part") {
			BlogsNavigator.openBlogsAdmin(siteURLKey = "guest");
		}

		task ("Then created new Blog") {
			MyTestFile.CreateBlogs(
				entryContent = "This is Blog Content",
				entryTitle = "This is Title");
		}
	}

	@description = "Can Delete a Blog"
	@priority = 5
	test CanDeleteBlog {
		task ("Given Go to Blogs Part") {
			BlogsNavigator.openBlogsAdmin(siteURLKey = "guest");
		}

		task ("When created new Blog") {
			MyTestFile.CreateBlogs(
				entryContent = "This is Blog Content",
				entryTitle = "This is Title");
		}

		task ("Then delete the Blog contain this title") {
			MyTestFile.DeleteBlog(rowEntry = "This is Title");
		}
	}

	@description = "Can Edit a Blog"
	@priority = 5
	test CanEditBlog {
		task ("Given Go to Blogs Part") {
			BlogsNavigator.openBlogsAdmin(siteURLKey = "guest");
		}

		task ("Given created new Blog") {
			MyTestFile.CreateBlogs(
				entryContent = "This is Blog Content",
				entryTitle = "This is Title");
		}

		task ("Then Edit the Blog") {
			MyTestFile.EditBlogs(
				entryTitle = "This is Title",
				entryTitleEdit = "This Title is Edited");
		}
	}

	@description = "Can Search Blogs"
	@priority = 5
	test CanSearchBlogs {
		task ("Given Go to Blogs Part") {
			BlogsNavigator.openBlogsAdmin(siteURLKey = "guest");
		}

		task ("When created new Blog") {
			MyTestFile.CreateBlogs(
				entryContent = "This is Blog Content",
				entryTitle = "This is Title");
		}

		task ("Then to the search barre and type the title") {
			BlogsEntry.searchCP(
				entryContent = "Blogs Content",
				entrySearchTerm = "This is ",
				entryTitle = "This is Title");
		}
	}

}