@component-name = "portal-util-misc"
definition {

	property osgi.app.includes = "password-generator";
	property portal.release = "true";
	property portal.upstream = "true";
	property testray.main.component.name = "Util";

	setUp {
		TestCase.setUpPortalInstance();

		User.firstLoginPG();

		Page.add(pageName = "Password Generator Page");

		Navigator.gotoPage(pageName = "Password Generator Page");

		Portlet.addPG(portletName = "Password Generator");
	}

	tearDown {
		var testLiferayVirtualInstance = PropsUtil.get("test.liferay.virtual.instance");

		if (${testLiferayVirtualInstance} == "true") {
			PortalInstances.tearDownCP();
		}
	}

	@priority = 2
	test GeneratePassword {
		Navigator.gotoPage(pageName = "Password Generator Page");

		PasswordGenerator.generatePasswordWithAllOptions(passwordLength = 6);
	}

}