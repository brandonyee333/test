@component-name = "portal-analytics-cloud"
definition {

	property portal.release = "false";
	property portal.upstream = "true";
	property property.group = "analytics.cloud.profile";
	property testray.main.component.name = "Analytics Cloud";

	setUp {
		Navigator.openURL(baseURL = "https://osbasahdxpserver73-ac-stagingdxps.lfr.cloud/");
	}

	tearDown {
		ACUtils.closeAllSessionsAndWait();
	}

	@description = "Test Summary: Browse portal pages as Benny Browser"
	@priority = "5"
	test SallyShopperTest {
		ACUtils.navigateToSitePageWithUser(
			emailList = "sally.shopper@liferay.com",
			pageName = "Home",
			siteName = "Brother Ocean Co.");

		Navigator.gotoSitePage(pageName = "Order");
		ACPersonas.buyBoard();
		ACPersonas.buySwimwear();
		ACPersonas.buyGear();

	}
} 