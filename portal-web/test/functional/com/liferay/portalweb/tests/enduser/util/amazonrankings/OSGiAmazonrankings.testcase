@component-name = "portal-util-misc"
definition {

	property osgi.app.includes = "amazon-rankings";
	property portal.release = "true";
	property portal.upstream = "true";
	property testray.main.component.name = "Util";

	setUp {
		TestCase.setUpPortalInstance();

		User.firstLoginPG();

		Page.add(pageName = "Amazon Rankings Page");

		Navigator.gotoPage(pageName = "Amazon Rankings Page");

		Portlet.addPG(portletName = "Amazon Rankings");
	}

	tearDown {
		var testLiferayVirtualInstance = PropsUtil.get("test.liferay.virtual.instance");

		if (${testLiferayVirtualInstance} == "true") {
			PortalInstances.tearDownCP();
		}
	}

	@priority = 2
	test ViewAmazonRankingsPortlet {
		Navigator.gotoPage(pageName = "Amazon Rankings Page");

		Portlet.viewPG(
			portletBody = "Please contact the administrator to configure an Amazon license.",
			portletName = "Amazon Rankings");
	}

}