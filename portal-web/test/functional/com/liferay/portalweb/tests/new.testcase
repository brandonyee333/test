@component-name = "portal-smoke"
definition {

	property portal.upstream = "true";
	property portal.release = "true";
	property testray.main.component.name = "Smoke";

	var userEmailAddress = "test@liferay.com";
	var userPassword = "test";
	var userPasswordReminderAnswer = "test";

	@description = "Sign in to Liferay Portal as '${userEmailAddress}' using the password '${userPassword}'"
	@priority = 3
	test SignIn {
		AssertClick(
			locator1 = "UserBar#USER_SIGN_IN",
			value1 = "Sign In");

		Type(
			locator1 = "TextInput#EMAIL_ADDRESS",
			value1 = ${userEmailAddress});

		Type(
			locator1 = "TextInput#PASSWORD",
			value1 = ${userPassword});

		Click(locator1 = "Button#SIGN_IN");

		AssertElementPresent(locator1 = "UserBar#USER_AVATAR_ICON");

		// WebContentNavigator.openWebContentAdmin(siteURLKey = "guest");
		
		// WebContent.addArticleCP(
        //     webContentContent = "WC Content",
        //     webContentTitle = "Apple");

		JSONWebcontent.addWebContent(
			content = "WC WebContent Content",
			groupName = "Guest",
			title = "Web Content Title 1");
}
}