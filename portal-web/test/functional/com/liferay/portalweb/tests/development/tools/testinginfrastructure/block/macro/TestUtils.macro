definition {

	@summary = "Default summary"
	macro assertEquals(actual = null, expected = null) {
		echo(${expected});

		echo(${actual});

		if (${expected} == ${actual}) {
			echo("PASSED");
		}
		else {
			TestUtils.fail(message = "FAILED: expected '${expected}', actual was '${actual}'");
		}
	}

	@summary = "Default summary"
	macro assertNotEquals(actual = null, expected = null) {
		echo(${expected});

		echo(${actual});

		if (${expected} != ${actual}) {
			echo("PASSED");
		}
		else {
			TestUtils.fail(message = "FAILED: '${expected}' equals '${actual}'");
		}
	}

	@summary = "Default summary"
	macro fail() {
		if (!(isSet(message))) {
			var message = "FAIL";
		}

		echo(${message});

		fail(${message});
	}

	@summary = "Default summary"
	macro hardRefresh() {
		var mac = OSDetector.isApple();

		if (${mac} == "true") {
			RobotType.robotTypeShortcut(locator1 = "Shift + Command + r");
		}
		else {
			RobotType.robotTypeShortcut(locator1 = "Ctrl + Shift + r");
		}

		WaitForPageLoad();
	}

	@summary = "Default summary"
	macro isGreaterThan(actual = null, expected = null) {
		echo(${expected});

		echo(${actual});

		var result = MathUtil.isGreaterThan(${actual}, ${expected});

		if (${result} == "true") {
			echo("PASSED");
		}
		else {
			TestUtils.fail(message = "FAILED: actual '${actual}' is less than or equals to expected '${expected}'");
		}
	}

	@summary = "Default summary"
	macro pass() {
		if (!(isSet(message))) {
			var message = "PASS";
		}

		echo(${message});
	}

	@summary = "Default summary"
	macro typeIntoField() {
		Navigator.openURL();

		Page.add(pageName = "Test Page Name");
	}

}