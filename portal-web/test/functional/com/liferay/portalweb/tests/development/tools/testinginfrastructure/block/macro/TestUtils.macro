definition {

	macro assertEquals {
		echo("${expected}");

		echo("${actual}");

		if ("${expected}" == "${actual}") {
			echo("PASSED");
		}
		else {
			TestUtils.fail(message = "FAILED: expected '${expected}', actual was '${actual}'");
		}
	}

	macro assertNotEquals {
		echo("${expected}");

		echo("${actual}");

		if ("${expected}" != "${actual}") {
			echo("PASSED");
		}
		else {
			TestUtils.fail(message = "FAILED: '${expected}' equals '${actual}'");
		}
	}

	macro fail {
		if (!(isSet(message))) {
			var message = "FAIL";
		}

		echo("${message}");

		fail("${message}");
	}

	macro pass {
		if (!(isSet(message))) {
			var message = "PASS";
		}

		echo("${message}");
	}

	macro typeIntoField {
		Navigator.openURL();

		Page.add(pageName = "Test Page Name");
	}

}