<html>
<head>
<title>LRLogin</title>
</head>
<body>
<table cellpadding="1" cellspacing="1" border="1">
<thead>
<tr><td rowspan="1" colspan="3">GoogleDoc</td></tr>
</thead>
<tbody>
<tr>
	<td>LOGIN_IN_BUTTON</td>
	<td>//span[@class='taglib-icon-label']</td>
	<td></td>
</tr>

<tr>
	<td>EMAIL_ADDRESS_FIELD</td>
	<td>//input[@id='_com_liferay_login_web_portlet_LoginPortlet_login']</td>
	<td></td>
</tr>

<tr>
	<td>PASSWORD_FIELD</td>
	<td>//input[@id='_com_liferay_login_web_portlet_LoginPortlet_password']</td>
	<td></td>
</tr>

<tr>
	<td>SIGN_IN_BUTTON</td>
	<td>//button[@class='btn btn-primary btn-default']</td>
	<td></td>
</tr>
</tbody>
</table>
</body>
</html>