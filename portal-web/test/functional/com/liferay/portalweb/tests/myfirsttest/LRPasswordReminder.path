<html>
<head>
<title>LRPasswordReminder</title>
</head>
<body>
<table cellpadding="1" cellspacing="1" border="1">
<thead>
<tr><td rowspan="1" colspan="3">LRPasswordReminder</td></tr>
</thead>
<tbody>
<tr>
	<td>CLICK_PASSWORD_REMINDER_BUTTON</td>
	<td>//button[@id='reminderQueryQuestion']</td>
	<td></td>
</tr>

<tr>
	<td>SELECT_PASSWORD_REMINDER_OPTION</td>
	<td>//option[@value='what-is-your-library-card-number']</td>
	<td></td>
</tr>

<tr>
	<td>PASSWORD_REMINDER_FIELD</td>
	<td>//input[@id='reminderQueryAnswer']</td>
	<td></td>
</tr>

<tr>
	<td>SAVE_PASSWORD_REMINDER_BUTTON</td>
	<td>//button[@type='submit']</td>
	<td></td>
</tr>
</tbody>
</table>
</body>
</html>