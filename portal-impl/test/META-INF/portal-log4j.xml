<?xml version="1.0"?>

<Configuration>
	<Appenders>
		<Console name="CONSOLE" target="SYSTEM_OUT">
			<PatternLayout pattern="%d{ABSOLUTE} %-5p [%t][%c{1}:%L] %m%n" />
		</Console>
	</Appenders>

	<Loggers>
		<Logger level="INFO" name="com.liferay.portal.spring.hibernate.DialectDetector" />

		<Root level="ERROR">
			<AppenderRef ref="CONSOLE" />
		</Root>
	</Loggers>
</Configuration>